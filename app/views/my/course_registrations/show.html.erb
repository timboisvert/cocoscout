<% content_for :title, @course_offering.title %>

<%
  src = @course_offering.og_image_source.to_s
  og_image_url = case src
  when "group_photo"
    @course_offering.group_photo.attached? ? url_for(@course_offering.group_photo) : nil
  when "instructor_headshot"
    @course_offering.instructor_headshot.attached? ? url_for(@course_offering.instructor_headshot) : nil
  when "none"
    nil
  else
    person_id = src.to_i
    if person_id > 0
      coi = @course_offering.course_offering_instructors.includes(:person).find { |c| c.person_id == person_id }
      if coi&.headshot&.attached?
        url_for(coi.headshot)
      elsif coi&.person&.headshot&.attached?
        url_for(coi.person.headshot)
      end
    elsif @course_offering.group_photo.attached?
      url_for(@course_offering.group_photo)
    elsif @course_offering.instructor_headshot.attached?
      url_for(@course_offering.instructor_headshot)
    end
  end

  og_description = strip_tags(@course_offering.description.to_s).squish.truncate(200)
%>

<% content_for :head do %>
  <meta property="og:type" content="website">
  <meta property="og:title" content="<%= @course_offering.title %>">
  <meta property="og:description" content="<%= og_description %>">
  <% if og_image_url %><meta property="og:image" content="<%= og_image_url %>"><% end %>
  <meta property="og:url" content="<%= my_course_show_url(code: @course_offering.short_code) %>">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= @course_offering.title %>">
  <meta name="twitter:description" content="<%= og_description %>">
  <% if og_image_url %><meta name="twitter:image" content="<%= og_image_url %>"><% end %>
<% end %>

<%
  # Get location from first session that has one
  if @all_sessions.any?
    course_location = @all_sessions.detect { |s| s.location.present? }&.location
  end
%>

<div class="min-h-screen bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">

    <!-- Full-Width Header -->
    <div class="mb-8 sm:mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-3 coustard-regular"><%= @course_offering.title %></h1>
      <% if @course_offering.subtitle.present? %>
        <p class="text-lg text-slate-600"><%= @course_offering.subtitle %></p>
      <% end %>
    </div>

    <%= render partial: "shared/notice", locals: { notice: notice, alert: flash[:alert] } %>

    <!-- Two Column Layout: Info & Form -->
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-12">

      <!-- Left Column: Course Info -->
      <div class="space-y-8">
        <%# Description %>
        <% if @course_offering.description.present? %>
          <div data-controller="text-expand" data-text-expand-max-height-value="288">
            <div class="relative">
              <div data-text-expand-target="content" class="prose prose-slate max-w-none text-slate-700 overflow-hidden" style="max-height: 288px;">
                <%= @course_offering.description %>
              </div>
              <div data-text-expand-target="fade" class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-white to-transparent pointer-events-none"></div>
            </div>
            <button type="button" data-action="text-expand#toggle" data-text-expand-target="toggleBtn" class="text-sm text-pink-600 hover:text-pink-700 font-medium mt-2 cursor-pointer">
              Read more
            </button>
          </div>
        <% end %>

        <%# Instruction Text %>
        <% if @course_offering.instruction_text.present? %>
          <div class="bg-gradient-to-br from-slate-50 to-white border border-slate-200 rounded-lg p-6 sm:p-8 shadow-sm">
            <div class="prose prose-slate max-w-none text-slate-700">
              <%= @course_offering.instruction_text %>
            </div>
          </div>
        <% end %>

        <%# Schedule %>
        <% if @all_sessions.any? %>
          <div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">Schedule</h3>
          <div class="bg-white border border-slate-200 rounded-lg shadow-sm divide-y divide-slate-100">
            <% @all_sessions.each do |show| %>
              <div class="flex items-center gap-3 px-4 py-3">
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium text-slate-900">
                    <%= show.date_and_time.strftime("%a, %b %-d") %>
                    <% if show.secondary_name.present? %>
                      <span class="text-slate-400 font-normal">— <%= show.secondary_name %></span>
                    <% end %>
                  </p>
                  <p class="text-xs text-slate-500">
                    <% if show.duration_minutes.present? %>
                      <% end_time = show.date_and_time + show.duration_minutes.minutes %>
                      <% if show.date_and_time.strftime("%p") == end_time.strftime("%p") %>
                        <%= show.date_and_time.strftime("%-I:%M") %> – <%= end_time.strftime("%-I:%M %p") %>
                      <% else %>
                        <%= show.date_and_time.strftime("%-I:%M %p") %> – <%= end_time.strftime("%-I:%M %p") %>
                      <% end %>
                    <% else %>
                      <%= show.date_and_time.strftime("%-I:%M %p") %>
                    <% end %>
                  </p>
                </div>
              </div>
            <% end %>
          </div>
          </div>
        <% end %>

        <%# Instructors %>
        <% cois = @course_offering.course_offering_instructors.includes(:person) %>
        <% instructors = cois.map(&:person) %>
        <% coi_by_person = cois.index_by(&:person_id) %>
        <% show_individual = @course_offering.show_individual_photos? || @course_offering.show_individual_bios? %>
        <% show_group_photo = @course_offering.show_group_photo? && @course_offering.group_photo.attached? && instructors.size > 1 %>
        <% show_preface = @course_offering.show_group_bio? && @course_offering.instructor_preface.present? && instructors.size > 1 %>
        <% if (instructors.any? || @course_offering.instructor_name.present?) && (show_individual || show_group_photo || show_preface) %>
          <div>
          <h3 class="text-base font-semibold text-slate-900 mb-2"><%= instructors.size == 1 ? 'Instructor' : 'Instructors' %></h3>
          <% if instructors.any? %>
            <% if show_group_photo %>
              <div class="mb-3">
                <%= image_tag @course_offering.group_photo.variant(resize_to_limit: [800, 800]), alt: "Instructors", class: "w-full rounded-lg" %>
              </div>
            <% end %>
            <% if show_preface %>
              <div class="text-sm text-slate-600 prose prose-sm prose-slate max-w-none mb-3"><%= @course_offering.instructor_preface %></div>
            <% end %>
            <% if show_individual %>
            <div class="space-y-3">
              <% instructors.each do |instructor| %>
                <% coi = coi_by_person[instructor.id] %>
                <% has_override = coi&.headshot&.attached? %>
                <% has_profile = !has_override && instructor.safe_headshot_variant(:tile).present? %>
                <% has_image = has_override || has_profile %>
                <% show_photo = @course_offering.show_individual_photos? && has_image && !coi&.hide_photo? %>
                <% show_bio = @course_offering.show_individual_bios? && coi&.bio.present? %>
                <div class="bg-white border border-slate-200 rounded-lg p-5 shadow-sm">
                  <div class="flex items-start gap-5">
                    <% if show_photo %>
                      <% if has_override %>
                        <%= image_tag coi.headshot.variant(resize_to_limit: [200, 400]), alt: instructor.name, class: "w-[120px] rounded-lg flex-shrink-0" %>
                      <% elsif has_profile %>
                        <%= image_tag instructor.safe_headshot_variant(:tile), alt: instructor.name, class: "w-[120px] rounded-lg flex-shrink-0" %>
                      <% end %>
                    <% end %>
                    <div class="flex-1 min-w-0">
                      <p class="font-semibold text-slate-900 text-lg"><%= instructor.name %></p>
                      <% if show_bio %>
                        <div data-controller="text-expand" data-text-expand-max-height-value="120">
                          <div class="relative">
                            <div data-text-expand-target="content" class="prose prose-sm prose-slate max-w-none text-slate-600 mt-1 overflow-hidden" style="max-height: 120px;">
                              <%= coi.bio %>
                            </div>
                            <div data-text-expand-target="fade" class="absolute bottom-0 left-0 right-0 h-10 bg-gradient-to-t from-white to-transparent pointer-events-none"></div>
                          </div>
                          <button type="button" data-action="text-expand#toggle" data-text-expand-target="toggleBtn" class="text-xs text-pink-600 hover:text-pink-700 font-medium mt-1 cursor-pointer">
                            Show more
                          </button>
                        </div>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
            <% end %>
          <% else %>
            <div class="bg-white border border-slate-200 rounded-lg p-5 shadow-sm">
              <div class="flex items-center gap-4">
                <div class="w-[120px] h-[120px] rounded-lg bg-slate-100 flex items-center justify-center text-slate-500 font-bold text-2xl flex-shrink-0">
                  <%= @course_offering.instructor_name.to_s.split(" ").map { |n| n[0] }.join("").first(2).upcase %>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="font-semibold text-slate-900 text-lg"><%= @course_offering.instructor_name %></p>
                </div>
              </div>
              <% if @course_offering.instructor_bio.present? %>
                <div class="mt-3 pt-3 border-t border-slate-100" data-controller="text-expand" data-text-expand-max-height-value="96">
                  <div class="relative">
                    <div data-text-expand-target="content" class="prose prose-sm prose-slate max-w-none text-slate-600 overflow-hidden" style="max-height: 96px;">
                      <%= @course_offering.instructor_bio %>
                    </div>
                    <div data-text-expand-target="fade" class="absolute bottom-0 left-0 right-0 h-12 bg-gradient-to-t from-white to-transparent pointer-events-none"></div>
                  </div>
                  <button type="button" data-action="text-expand#toggle" data-text-expand-target="toggleBtn" class="text-xs text-pink-600 hover:text-pink-700 font-medium mt-1 cursor-pointer">
                    Show more
                  </button>
                </div>
              <% end %>
            </div>
          <% end %>
          </div>
        <% end %>

        <%# Location Box with Map (matches sign-up form) %>
        <% if course_location.present? %>
          <% loc = course_location %>
          <% address = [loc.address1, loc.address2, loc.city, loc.state, loc.postal_code].compact.reject(&:blank?).join(', ') %>
          <div class="bg-white border border-slate-200 rounded-lg shadow-sm overflow-hidden">
            <div class="p-4 space-y-4">
              <div>
                <div class="font-semibold text-gray-900"><%= loc.name %></div>
                <div class="text-sm text-gray-600 mt-1">
                  <% if loc.address1.present? %>
                    <%= loc.address1 %><br>
                  <% end %>
                  <% if loc.address2.present? %>
                    <%= loc.address2 %><br>
                  <% end %>
                  <% if loc.city.present? || loc.state.present? || loc.postal_code.present? %>
                    <%= loc.city %><% if loc.city.present? && loc.state.present? %>,<% end %> <%= loc.state %> <%= loc.postal_code %>
                  <% end %>
                </div>
              </div>

              <% if address.present? %>
                <div class="w-full h-[200px]">
                  <iframe
                    width="100%"
                    height="100%"
                    style="border:0; border-radius: 0.5rem;"
                    loading="lazy"
                    allowfullscreen
                    referrerpolicy="no-referrer-when-downgrade"
                    src="https://www.google.com/maps?q=<%= URI.encode_www_form_component(address) %>&output=embed">
                  </iframe>
                </div>

                <div class="grid grid-cols-2 gap-2">
                  <a href="http://maps.apple.com/?address=<%= URI.encode_www_form_component(address) %>" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-1 px-3 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-md hover:bg-gray-200 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                    </svg>
                    Open in Maps
                  </a>
                  <a href="https://www.google.com/maps/search/?api=1&query=<%= URI.encode_www_form_component(address) %>" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-1 px-3 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-md hover:bg-gray-200 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                    </svg>
                    Google Maps
                  </a>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Right Column: Form -->
      <div>
        <div class="lg:sticky lg:top-8 space-y-4">

          <% if @existing_registration&.confirmed? %>
            <!-- Confirmed Registration -->
            <div class="bg-white border border-slate-200 rounded-lg shadow-sm">
              <div class="p-5 text-center">
                <div class="flex items-center justify-center mb-3">
                  <div class="h-12 w-12 rounded-full bg-green-100 flex items-center justify-center">
                    <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                    </svg>
                  </div>
                </div>
                <h3 class="text-lg font-bold text-slate-900 mb-1">You're Registered!</h3>
                <p class="text-sm text-slate-600 mb-4">
                  Payment confirmed. You're all set!
                </p>
                <div class="bg-green-50 border border-green-200 rounded-lg p-3 mb-4">
                  <p class="text-sm text-green-800">
                    <strong><%= @existing_registration.formatted_amount %></strong> paid on
                    <%= @existing_registration.paid_at&.strftime("%B %-d, %Y") %>
                  </p>
                </div>
                <%= link_to my_dashboard_path do %>
                  <%= render "shared/button", text: "Go to Dashboard", variant: "secondary", size: "medium" %>
                <% end %>
              </div>
            </div>

          <% else %>

            <!-- Profile Section -->
            <div class="bg-white border border-slate-200 rounded-lg shadow-sm">
              <div class="p-5">
                <label class="block text-sm font-medium text-gray-700 mb-3">Registering as:</label>
                <div class="flex items-center gap-3 px-4 py-3 bg-white border border-gray-300 rounded-lg">
                  <% if @person.headshot&.attached? %>
                    <%= image_tag @person.headshot.variant(resize_to_fill: [48, 48]), class: "w-12 h-12 rounded object-cover flex-shrink-0" %>
                  <% else %>
                    <div class="w-12 h-12 rounded bg-gray-200 flex items-center justify-center flex-shrink-0">
                      <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path>
                      </svg>
                    </div>
                  <% end %>
                  <div class="flex-1 text-left min-w-0">
                    <div class="font-medium text-gray-900 truncate"><%= @person.name %></div>
                    <div class="text-sm text-gray-500 truncate">@<%= @person.public_key %></div>
                  </div>
                </div>
                <div class="mt-0 text-left">
                  <%= link_to profile_path, target: "_blank", class: "text-xs text-pink-500 hover:text-pink-600 underline" do %>
                    Edit Profile
                  <% end %>
                </div>
              </div>
            </div>

            <!-- Price -->
            <div class="flex items-center justify-between py-3">
              <span class="text-sm font-medium text-slate-600">Course Fee</span>
              <div class="text-right">
                <% if @course_offering.early_bird_active? %>
                  <div class="flex items-baseline justify-end gap-2">
                    <span class="text-sm text-slate-400 line-through"><%= @course_offering.formatted_price %></span>
                    <span class="text-xl font-bold text-pink-600"><%= @course_offering.formatted_early_bird_price %></span>
                    <span class="text-xs text-slate-400">+ tax</span>
                  </div>
                  <p class="text-xs text-slate-500">Early bird price · ends <%= @course_offering.early_bird_deadline.strftime("%B %-d") %></p>
                <% else %>
                  <span class="text-xl font-bold text-pink-600"><%= @course_offering.formatted_price %></span>
                  <span class="text-xs text-slate-400">+ tax</span>
                <% end %>
              </div>
            </div>

            <!-- Register Button -->
            <% if @course_offering.accepting_registrations? %>
              <%= form_with url: my_course_checkout_path(code: @course_offering.short_code), method: :post, data: { turbo: false } do %>
                <%= render "shared/button",
                    text: "Securely Pay & Register",
                    variant: "primary",
                    size: "jumbo",
                    type: :submit,
                    classes: "w-full" %>
              <% end %>
              <p class="text-xs text-slate-500 text-center mt-2 flex items-center justify-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
                Secure payment via Stripe
              </p>
            <% else %>
              <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 text-center">
                <p class="text-sm text-slate-600"><%= @course_offering.registration_closed_reason %></p>
              </div>
            <% end %>

          <% end %>
        </div>
      </div>

    </div>

    <!-- Footer -->
    <div class="mt-12 pt-6 border-t border-slate-200">
      <div class="flex items-center justify-center gap-2">
        <%= render "shared/cocoscout_logo", size: :tiny %>
        <span class="text-base font-semibold coustard-regular text-pink-500">CocoScout</span>
      </div>
    </div>
  </div>
</div>
