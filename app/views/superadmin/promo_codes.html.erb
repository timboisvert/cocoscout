<% content_for :title, "Promo Codes - Superadmin" %>

<div class="w-full px-5 pt-5">
  <%= render partial: "shared/notice", locals: { notice: notice, alert: alert } %>

  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      ["Superadmin", superadmin_path]
    ],
    text: "Promo Codes",
    links: [
      { text: "New Promo Code", path: promo_code_new_path }
    ]
  } %>

  <div class="mt-4">
    <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
      <%= render "shared/card_header", title: "All Promo Codes" do %>
        <p class="text-sm text-gray-500 mt-1"><%= @promo_codes.count %> total codes</p>
      <% end %>

      <% if @promo_codes.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Code</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Recipient</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Coverage</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Uses</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Expires</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
                <th class="px-4 py-3"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <% @promo_codes.each do |pc| %>
                <tr class="<%= 'opacity-50' unless pc.active? %>">
                  <td class="px-4 py-3 text-sm font-mono font-bold text-gray-900"><%= pc.code %></td>
                  <td class="px-4 py-3 text-sm text-gray-700"><%= pc.recipient_name.presence || "—" %></td>
                  <td class="px-4 py-3 text-sm text-gray-500">
                    <% if pc.coverage_type == "full" %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">All fees</span>
                    <% else %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">CocoScout fee only</span>
                    <% end %>
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-700">
                    <%= pc.uses_count %> / <%= pc.max_uses || "∞" %>
                  </td>
                  <td class="px-4 py-3 text-sm">
                    <% if !pc.active? %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">Inactive</span>
                    <% elsif pc.expired? %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Expired</span>
                    <% elsif pc.maxed_out? %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-800">Maxed Out</span>
                    <% else %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Active</span>
                    <% end %>
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-500">
                    <%= pc.expires_at&.strftime("%b %-d, %Y") || "Never" %>
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-500">
                    <%= pc.created_at.strftime("%b %-d, %Y") %>
                  </td>
                  <td class="px-4 py-3 text-right text-sm">
                    <% if pc.active? %>
                      <%= button_to "Deactivate", promo_code_deactivate_path(pc), method: :patch,
                          class: "text-red-600 hover:text-red-800 text-xs font-medium cursor-pointer",
                          data: { turbo_confirm: "Deactivate promo code #{pc.code}?" } %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="p-8 text-center text-gray-500">
          <p class="text-sm">No promo codes yet.</p>
          <%= link_to promo_code_new_path do %>
            <%= render "shared/button", text: "Create First Promo Code", variant: "primary", size: "small" %>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Redemptions section %>
    <% redemptions = FeatureCreditRedemption.includes(:feature_credit, :organization, :redeemable).order(created_at: :desc).limit(20) %>
    <% if redemptions.any? %>
      <div class="mt-6 bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
        <%= render "shared/card_header", title: "Recent Redemptions" do %>
          <p class="text-sm text-gray-500 mt-1">Last 20 promo code redemptions</p>
        <% end %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Code</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Organization</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Applied To</th>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <% redemptions.each do |r| %>
                <tr>
                  <td class="px-4 py-3 text-sm font-mono font-bold text-gray-900"><%= r.feature_credit.code %></td>
                  <td class="px-4 py-3 text-sm text-gray-700"><%= r.organization&.name || "—" %></td>
                  <td class="px-4 py-3 text-sm text-gray-700">
                    <% if r.redeemable.is_a?(CourseOffering) %>
                      <%= r.redeemable.title %>
                    <% else %>
                      <%= r.redeemable_type %> #<%= r.redeemable_id %>
                    <% end %>
                  </td>
                  <td class="px-4 py-3 text-sm text-gray-500"><%= r.created_at.strftime("%b %-d, %Y %l:%M %p") %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>
  </div>
</div>
