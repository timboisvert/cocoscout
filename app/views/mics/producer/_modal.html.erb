<%#
  Native HTML <dialog> modal. Locals: id, title. Block content = body.
%>
<%# Native <dialog>. `m-auto + fixed inset-0` is what re-enables browser
    centering after Tailwind's preflight strips margins. Width caps at
    36rem and at 92vw on small screens. %>
<dialog id="<%= id %>"
        data-controller="mics-modal"
        data-action="click->mics-modal#backdropClose"
        class="fixed inset-0 m-auto w-[min(36rem,92vw)] max-h-[85vh] p-0 rounded shadow-2xl backdrop:bg-gray-900/50 overflow-hidden">
  <div class="flex flex-col max-h-[85vh]">
    <div class="flex items-center justify-between gap-3 px-5 sm:px-6 py-3 border-b border-gray-100 bg-pink-500 text-white shrink-0">
      <h3 class="coustard-regular text-lg sm:text-xl"><%= title %></h3>
      <button type="button" data-action="click->mics-modal#close"
              class="cursor-pointer px-2 py-1 text-white hover:bg-pink-600 active:bg-pink-700 text-sm leading-none">
        ✕
      </button>
    </div>
    <div class="px-5 sm:px-6 py-5 overflow-y-auto">
      <%= yield %>
    </div>
  </div>
</dialog>
