<%
  mics_seo title: "Submit a mic — Find a Mic",
            description: "Add a new open mic. Anyone with an account can list a mic anywhere in the U.S."
%>
<%= render "mics/header" %>

<main class="w-full bg-white">
  <section class="bg-pink-500 text-white border-b border-pink-600">
    <div class="w-full px-4 sm:px-8 py-5 sm:py-7">
      <h1 class="coustard-regular text-3xl sm:text-4xl">Submit a mic</h1>
      <p class="mt-1 text-sm sm:text-base text-pink-100 max-w-3xl">
        Any city, any night. Submissions land in a moderation queue and go live within a day.
      </p>
    </div>
  </section>

  <% if flash[:alert] %>
    <div class="w-full px-4 sm:px-8 py-3 bg-red-50 border-b border-red-200 text-red-700 text-sm">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <div class="w-full px-4 sm:px-8 py-6 bg-pink-50">
    <div class="w-full max-w-5xl">
      <%= form_with url: mics_create_submission_path, method: :post, class: "space-y-6" do %>

        <%# Venue — find-or-add. As the user types the name, we hit
            /mics/venues/lookup and surface up to 8 fuzzy matches. If
            they pick one, the rest of the form auto-fills from the
            existing venue and a hidden `venue_id` carries the reused
            ID through submission so we don't write a dup row. %>
        <section class="bg-white border border-pink-100 rounded"
                 data-controller="venue-finder"
                 data-venue-finder-url-value="<%= mics_venues_lookup_path %>">
          <header class="px-5 sm:px-6 py-3 border-b border-pink-100 bg-pink-50">
            <h2 class="text-xs uppercase tracking-wider text-pink-700 font-bold">Venue</h2>
            <p class="text-xs text-gray-500 mt-1">
              We'll check for an existing venue as you type — pick one if you spot it, so we don't dupe.
            </p>
          </header>
          <div class="px-5 sm:px-6 py-5">
            <%= hidden_field_tag "venue_id", nil, data: { venue_finder_target: "venueIdInput" } %>

            <%# Venue name input drives the lookup. %>
            <div class="mb-4">
              <label class="block text-xs uppercase tracking-wider text-gray-600 font-bold mb-1">Venue name <span class="text-pink-500">*</span></label>
              <input type="text" name="venue[name]" required
                     placeholder="e.g. Cole's Bar"
                     data-venue-finder-target="nameInput"
                     data-action="input->venue-finder#search"
                     class="w-full px-3 py-2.5 border border-gray-300 rounded bg-white text-gray-900 placeholder:text-gray-400 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm">
            </div>

            <%# Match cards land here. %>
            <div data-venue-finder-target="results" class="mb-4"></div>

            <%# Banner shown after a pick — "Using existing venue: X · use a different one". %>
            <div data-venue-finder-target="selectedBanner"
                 class="hidden mb-4 flex items-baseline justify-between gap-3 px-3 py-2 bg-emerald-50 border border-emerald-200 rounded">
              <div class="text-xs text-emerald-800">
                Using existing venue: <strong data-venue-finder-target="selectedName"></strong>. We'll attach this mic to it.
              </div>
              <a href="#" data-action="click->venue-finder#resetSelection" class="text-xs text-emerald-700 hover:text-emerald-900 font-bold underline">Use a different one</a>
            </div>

            <%# Address fields — hidden once a venue is picked so the
                user doesn't accidentally edit shared address data. %>
            <div data-venue-finder-target="addressFields">
              <%= render "mics/form_field", name: "venue[address1]", label: "Address" %>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-4">
                <%= render "mics/form_field", name: "venue[neighborhood]", label: "Neighborhood" %>
                <%= render "mics/form_field", name: "venue[postal_code]",  label: "ZIP" %>
                <%= render "mics/form_field", name: "venue[city]",  label: "City", required: true %>
                <div class="mb-4">
                  <%= render "shared/us_state_select",
                        name: "venue[state]", required: true, label: "State" %>
                </div>
              </div>
            </div>
          </div>
        </section>

        <%# Basic info %>
        <section class="bg-white border border-pink-100 rounded">
          <header class="px-5 sm:px-6 py-3 border-b border-pink-100 bg-pink-50">
            <h2 class="text-xs uppercase tracking-wider text-pink-700 font-bold">Basic info</h2>
          </header>
          <div class="px-5 sm:px-6 py-5">
            <%= render "mics/form_field", name: "mic[name]", label: "Mic name", required: true %>
            <%= render "mics/form_field", name: "mic[format]", label: "Format", type: "select",
                  options: Mic.formats.keys.map { |k| [ mics_format_label(k), k ] } %>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-4">
              <%= render "mics/form_field", name: "mic[spot_length_minutes]", label: "Spot length",
                    placeholder: "e.g. 5, 3-5 minutes, 5ish" %>
              <%= render "mics/form_field", name: "mic[signup_cap]", label: "Maximum # of performers",
                    placeholder: "e.g. 10, 10ish, 10-15" %>
            </div>
            <%= render "mics/form_field", name: "mic[blurb]", label: "Blurb", type: "textarea", rows: 4,
                  placeholder: "Anything performers should know — the vibe, who hosts, drink minimum, etc." %>
          </div>
        </section>

        <%# Schedule %>
        <section class="bg-white border border-pink-100 rounded">
          <header class="px-5 sm:px-6 py-3 border-b border-pink-100 bg-pink-50">
            <h2 class="text-xs uppercase tracking-wider text-pink-700 font-bold">Schedule</h2>
          </header>
          <div class="px-5 sm:px-6 py-5" data-controller="mics-schedule-form">
            <input type="hidden" name="mic[recurrence_pattern]" value="weekly" data-mics-schedule-form-target="hiddenPattern">

            <%= render "mics/form_field", name: "ui_primary_pattern", label: "How often?", type: "select",
                  value: "weekly",
                  options: [
                    [ "Weekly",                                    "weekly" ],
                    [ "Every other week",                          "biweekly" ],
                    [ "Multiple times per month (e.g. 1st & 3rd Monday)", "monthly_nth_weekdays" ],
                    [ "Monthly",                                   "monthly" ],
                    [ "Custom dates (one-offs / pop-ups)",         "custom_dates" ]
                  ],
                  data: { "mics-schedule-form-target": "primary",
                          action: "change->mics-schedule-form#refresh" } %>

            <div data-mics-schedule-form-target="anchorBlock" class="hidden">
              <%= render "mics/form_field", name: "mic[recurrence_anchor_date]", label: "Starting on", type: "date",
                    help: "Pick any known mic date so we know which alternating weeks." %>
            </div>

            <div data-mics-schedule-form-target="monthlyKindBlock" class="hidden">
              <%= render "mics/form_field", name: "ui_monthly_kind", label: "Monthly on…", type: "select",
                    value: "monthly_nth_weekday",
                    options: [
                      [ "A specific weekday (e.g. 2nd Tuesday)",       "monthly_nth_weekday" ],
                      [ "A specific day of the month (e.g. the 15th)", "monthly_day_of_month" ]
                    ],
                    data: { "mics-schedule-form-target": "monthlyKind",
                            action: "change->mics-schedule-form#refresh" } %>
            </div>

            <div data-mics-schedule-form-target="nthBlock" class="hidden">
              <%= render "mics/form_field", name: "mic[recurrence_nth_week]", label: "Which one?", type: "select",
                    value: 1,
                    options: [ [ "1st", 1 ], [ "2nd", 2 ], [ "3rd", 3 ], [ "4th", 4 ], [ "5th", 5 ], [ "Last", -1 ] ] %>
            </div>

            <div data-mics-schedule-form-target="nthMultiBlock" class="hidden mb-4">
              <label class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-2">Which weeks?</label>
              <input type="hidden" name="mic[recurrence_nth_weeks][]" value="">
              <div class="flex flex-wrap gap-2">
                <% [ [ 1, "1st" ], [ 2, "2nd" ], [ 3, "3rd" ], [ 4, "4th" ], [ 5, "5th" ], [ -1, "Last" ] ].each do |val, label| %>
                  <label class="inline-flex items-center gap-1.5 px-3 py-1.5 border bg-white border-gray-300 text-gray-700 hover:bg-pink-50 rounded">
                    <input type="checkbox" name="mic[recurrence_nth_weeks][]" value="<%= val %>" class="h-4 w-4 accent-pink-500">
                    <span class="text-sm"><%= label %></span>
                  </label>
                <% end %>
              </div>
              <p class="mt-1 text-xs text-gray-500">Pick every week the mic runs. e.g. for "first and third Monday," check 1st and 3rd.</p>
            </div>

            <div data-mics-schedule-form-target="domBlock" class="hidden">
              <%= render "mics/form_field", name: "mic[recurrence_day_of_month]", label: "Day of month (1–31)",
                    help: "If a month doesn't have that day (e.g. Feb 30), it's skipped." %>
            </div>

            <div data-mics-schedule-form-target="dowBlock">
              <%= render "mics/form_field", name: "mic[day_of_week]", label: "Which day of the week?", type: "select",
                    options: (0..6).map { |i| [ mics_day_name(i), i ] } %>
            </div>

            <div data-mics-schedule-form-target="customDatesBlock" class="hidden mb-4">
              <label class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-2">Dates this mic happens</label>
              <div data-controller="mics-custom-dates"
                   data-mics-custom-dates-initial-value="[]">
                <input type="hidden" name="mic[custom_dates_json]"
                       data-mics-custom-dates-target="store" value="[]">
                <div class="flex flex-wrap gap-2 items-end mb-3">
                  <input type="date" data-mics-custom-dates-target="datePicker"
                         class="px-3 py-2 text-sm border border-gray-300 focus:border-pink-500 outline-none rounded">
                  <input type="time" data-mics-custom-dates-target="timePicker"
                         class="px-3 py-2 text-sm border border-gray-300 focus:border-pink-500 outline-none rounded">
                  <button type="button" data-action="click->mics-custom-dates#add"
                          class="cursor-pointer px-3 py-2 text-sm bg-pink-500 hover:bg-pink-600 text-white font-bold rounded">
                    + Add date
                  </button>
                </div>
                <div data-mics-custom-dates-target="list" class="flex flex-wrap"></div>
                <p data-mics-custom-dates-target="empty" class="text-xs text-gray-500 italic">No dates yet — add one above.</p>
              </div>
              <p class="mt-2 text-xs text-gray-500">Use this for pop-ups or any mic that doesn't repeat on a fixed cadence. Each date gets its own start time.</p>
            </div>

            <div data-mics-schedule-form-target="startTimeBlock">
              <%= render "mics/form_field", name: "mic[starts_local_time]", label: "Start time", type: "time" %>
            </div>
          </div>
        </section>

        <%# Sign-up info %>
        <section class="bg-white border border-pink-100 rounded">
          <header class="px-5 sm:px-6 py-3 border-b border-pink-100 bg-pink-50">
            <h2 class="text-xs uppercase tracking-wider text-pink-700 font-bold">Sign-up info</h2>
          </header>
          <div class="px-5 sm:px-6 py-5" data-controller="mics-signup-form">
            <%= render "mics/form_field", name: "mic[signup_method]", label: "Sign-up type", type: "select",
                  value: "in_person",
                  options: Mic.signup_methods.keys.map { |k| [ mics_signup_method_label(k), k ] },
                  data: { "mics-signup-form-target": "channel", action: "change->mics-signup-form#refresh" } %>

            <div data-mics-signup-form-target="urlBlock" class="hidden">
              <%= render "mics/form_field", name: "mic[signup_url]", label: "How to sign up online",
                    placeholder: "https://… or e.g. \"Through Lia Berman's FB Google Sheet post\"",
                    help: "A URL becomes a \"Sign up\" button; free text gets shown as instructions instead." %>
            </div>

            <%= render "mics/form_field", name: "mic[signup_opens_at_text]", label: "When sign-up opens",
                  placeholder: "e.g. 7:30 PM, or 2 weeks beforehand",
                  help: "Whatever describes it best — a time of day (\"7:30 PM\"), a lead time (\"2 weeks before\"), or however you'd say it." %>

            <label class="flex items-center gap-2 mb-4 text-sm text-gray-800">
              <input type="hidden" name="mic[bucket_draw]" value="0">
              <input type="checkbox" name="mic[bucket_draw]" value="1"
                     class="h-4 w-4 text-pink-600 border-gray-300 rounded focus:ring-pink-500 accent-pink-500">
              <span>Bucket draw / random draw</span>
            </label>

            <%= render "mics/form_field", name: "mic[signup_notes]", label: "Sign-up notes (optional)", type: "textarea", rows: 3,
                  placeholder: "House rules, bump-in offers, drink minimums, anything that doesn't fit above.",
                  help: "Shown publicly under sign-up info." %>
          </div>
        </section>

        <%# Accessibility & age %>
        <section class="bg-white border border-pink-100 rounded">
          <header class="px-5 sm:px-6 py-3 border-b border-pink-100 bg-pink-50">
            <h2 class="text-xs uppercase tracking-wider text-pink-700 font-bold">Accessibility & age</h2>
          </header>
          <div class="px-5 sm:px-6 py-5">
            <fieldset class="mb-4">
              <legend class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-2">Wheelchair accessibility</legend>
              <input type="hidden" name="mic[accessibility][wheelchair_level]" value="">
              <% [
                [ "fully",   "♿ Fully wheelchair accessible",
                  "Can get into the building, onto the stage, and into the restrooms." ],
                [ "partial", "♿ Partially wheelchair accessible",
                  "Can get into the building, but not necessarily onto the stage or into the restrooms." ],
                [ "",        "Not wheelchair accessible / unknown",
                  "The mic won't show up when performers filter for wheelchair access." ]
              ].each do |val, label, desc| %>
                <label class="flex items-start gap-2 text-sm text-gray-800 py-1.5">
                  <input type="radio" name="mic[accessibility][wheelchair_level]" value="<%= val %>"
                         <%= "checked" if val == "" %>
                         class="mt-0.5 h-4 w-4 text-pink-600 border-gray-300 focus:ring-pink-500 accent-pink-500">
                  <span class="flex-1">
                    <span class="font-bold"><%= label %></span>
                    <span class="block text-xs text-gray-500 leading-snug"><%= desc %></span>
                  </span>
                </label>
              <% end %>
            </fieldset>

            <%= render "mics/form_field", name: "mic[age_choice]", label: "Age requirement", type: "select",
                  value: "unknown",
                  options: [ [ "Unknown", "unknown" ], [ "All ages", "all_ages" ], [ "21+", "21" ] ] %>
          </div>
        </section>

        <%# Socials — optional at create time but here so you don't have to come back. %>
        <section class="bg-white border border-pink-100 rounded">
          <header class="px-5 sm:px-6 py-3 border-b border-pink-100 bg-pink-50">
            <h2 class="text-xs uppercase tracking-wider text-pink-700 font-bold">Socials (optional)</h2>
            <p class="text-xs text-gray-500 mt-1">Add as many as you like — each becomes a button on the public mic page.</p>
          </header>
          <div class="px-5 sm:px-6 py-5 space-y-3">
            <% 3.times do |i| %>
              <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 items-end">
                <label class="block text-sm">
                  <span class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-1">Type</span>
                  <select name="mic_links[<%= i %>][link_type]"
                          class="w-full px-3 py-2 text-sm border border-gray-300 focus:border-pink-500 outline-none bg-white">
                    <option value="">— pick one —</option>
                    <option value="instagram">Instagram</option>
                    <option value="x_twitter">X / Twitter</option>
                    <option value="tiktok">TikTok</option>
                    <option value="website">Website</option>
                  </select>
                </label>
                <label class="block text-sm sm:col-span-2">
                  <span class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-1">URL</span>
                  <input type="url" name="mic_links[<%= i %>][url]" placeholder="https://…"
                         class="w-full px-3 py-2 text-sm border border-gray-300 focus:border-pink-500 outline-none">
                </label>
              </div>
            <% end %>
          </div>
        </section>

        <div class="flex items-center justify-between gap-3 pt-2">
          <a href="<%= mics_home_path %>" class="text-sm text-gray-500 hover:text-gray-700 underline">Cancel</a>
          <%= render "shared/button", text: "Submit for review", variant: "primary", size: "medium", type: :submit %>
        </div>
      <% end %>
    </div>
  </div>
</main>

<%= render "mics/site_footer" %>
