<%#
  A consistent label + input wrapper. Locals: name (string), label (string),
  type ("text"|"email"|"url"|"time"|"date"|"textarea"|"select"), required (bool),
  value (any), placeholder (string), help (string), options (array of [label, value]).

  Inputs are pink-focused, rounded (matching shared/button), generous size.
%>
<%
  type = local_assigns[:type] || "text"
  required = local_assigns[:required] || false
  value = local_assigns[:value]
  placeholder = local_assigns[:placeholder]
  options = local_assigns[:options]
  data_attrs = local_assigns[:data] || {}
  field_id = "field_#{name.to_s.parameterize}_#{rand(99999)}"
  field_classes = "w-full px-3 py-2.5 border border-gray-300 rounded bg-white text-gray-900 placeholder:text-gray-400 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm"
%>
<div class="mb-4">
  <label for="<%= field_id %>" class="block text-xs uppercase tracking-wider text-gray-600 font-bold mb-1">
    <%= label %><% if required %> <span class="text-pink-500">*</span><% end %>
  </label>
  <% case type %>
  <% when "textarea" %>
    <%= text_area_tag(name, value,
          id: field_id, rows: (local_assigns[:rows] || 4),
          required: required, placeholder: placeholder,
          class: field_classes, data: data_attrs) %>
  <% when "select" %>
    <%= select_tag(name,
          options_for_select((options || []), value),
          id: field_id, class: field_classes, data: data_attrs) %>
  <% else %>
    <%= tag.input(id: field_id, type: type, name: name, value: value,
          placeholder: placeholder, maxlength: local_assigns[:maxlength],
          required: required, class: field_classes, data: data_attrs) %>
  <% end %>
  <% if local_assigns[:help].present? %>
    <p class="mt-1 text-xs text-gray-500"><%= help %></p>
  <% end %>
</div>
