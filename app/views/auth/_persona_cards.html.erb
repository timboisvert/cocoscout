<%#
  Three persona cards used on both the signin and signup pages.
  The cards explain who CocoScout is for — same account, three
  distinct surfaces.

  Compact icon + headline + one-line description. Designed to fit
  inside a sticky left-column panel without dominating the page.
%>
<div class="space-y-4">
  <%# Performers — line-icon people group (audience/cast) %>
  <div class="flex items-start gap-3">
    <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-pink-100 flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-pink-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 0 0-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 0 1 5.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 0 1 9.288 0M15 7a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2 2 0 1 1-4 0 2 2 0 0 1 4 0ZM7 10a2 2 0 1 1-4 0 2 2 0 0 1 4 0Z"/>
      </svg>
    </div>
    <div class="min-w-0">
      <h3 class="text-sm font-semibold text-slate-900">Performers</h3>
      <p class="text-sm text-slate-600">Audition for shows, find open mics, and manage your availability.</p>
    </div>
  </div>

  <%# Producers — clipboard-check (run a show, run sign-ups) %>
  <div class="flex items-start gap-3">
    <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-pink-100 flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-pink-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2M9 5a2 2 0 0 0 2 2h2a2 2 0 0 0 2-2M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2"/>
      </svg>
    </div>
    <div class="min-w-0">
      <h3 class="text-sm font-semibold text-slate-900">Producers</h3>
      <p class="text-sm text-slate-600">Run productions, cast roles, coordinate sign-ups, and handle payouts.</p>
    </div>
  </div>

  <%# Mic regulars — outlined star (favorites + interest) %>
  <div class="flex items-start gap-3">
    <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-pink-100 flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-pink-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z"/>
      </svg>
    </div>
    <div class="min-w-0">
      <h3 class="text-sm font-semibold text-slate-900">Open mic regulars</h3>
      <p class="text-sm text-slate-600">Favorite mics, get sign-up alerts, and run a mic of your own.</p>
    </div>
  </div>
</div>
