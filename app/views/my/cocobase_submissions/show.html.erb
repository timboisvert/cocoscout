<% content_for :title, "Cocobase - #{@show.event_type.titleize}" %>

<%
  entity = @submission.submittable
  headshot_variant = entity.safe_headshot_variant(:thumb)
  is_submitted = @submission.submitted?
  is_closed = @cocobase.closed?
  is_past_deadline = @cocobase.past_deadline?
  read_only = is_submitted || is_closed
%>

<div class="w-full mb-10">
  <%= render partial: "shared/notice", locals: { notice: notice } %>
  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      ["Open Requests", my_requests_path]
    ],
    text: "Cocobase",
    links: []
  } %>

  <div class="max-w-2xl mx-auto space-y-6">
    <!-- Header Card -->
    <div class="bg-white border border-gray-200 rounded-lg shadow-sm p-6">
      <div class="flex items-center gap-4 mb-4">
        <% if headshot_variant %>
          <%= image_tag headshot_variant, alt: entity.name, class: "w-12 h-12 rounded-lg object-cover" %>
        <% else %>
          <div class="w-12 h-12 rounded-lg bg-gray-200 flex items-center justify-center text-gray-600 font-bold text-sm">
            <%= entity.initials %>
          </div>
        <% end %>
        <div>
          <h2 class="text-lg font-semibold text-gray-900"><%= entity.name %></h2>
          <p class="text-sm text-gray-500"><%= @production.name %></p>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4 text-sm">
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Show</p>
          <p class="text-gray-900"><%= @show.event_type.titleize %> &middot; <%= @show.date_and_time.strftime("%b %-d, %Y %l:%M %p") %></p>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Deadline</p>
          <p class="<%= is_past_deadline ? 'text-red-600 font-medium' : 'text-gray-900' %>">
            <% if @cocobase.deadline.present? %>
              <%= @cocobase.deadline.strftime("%b %-d, %Y %l:%M %p") %>
              <% if is_past_deadline %>
                <span class="text-xs">(past)</span>
              <% end %>
            <% else %>
              No deadline
            <% end %>
          </p>
        </div>
      </div>

      <% if is_submitted %>
        <div class="mt-4 p-3 bg-green-50 border border-green-200 rounded-lg">
          <p class="text-sm text-green-800 font-medium">Submitted
            <% if @submission.submitted_at.present? %>
              on <%= @submission.submitted_at.strftime("%b %-d, %Y at %l:%M %p") %>
            <% end %>
          </p>
        </div>
      <% elsif is_closed %>
        <div class="mt-4 p-3 bg-gray-50 border border-gray-200 rounded-lg">
          <p class="text-sm text-gray-600">This Cocobase is now closed and no longer accepting submissions.</p>
        </div>
      <% end %>
    </div>

    <!-- Form -->
    <% if @fields.any? %>
      <%= form_with url: my_update_cocobase_submission_path(@submission), method: :patch, multipart: true, class: "space-y-4" do |f| %>
        <% @fields.each do |field| %>
          <% answer = @answers_by_field[field.id] %>
          <div class="bg-white border border-gray-200 rounded-lg shadow-sm p-5">
            <div class="flex items-center gap-2 mb-1">
              <label class="text-sm font-medium text-gray-900"><%= field.label %></label>
              <% if field.required? %>
                <span class="text-pink-500 text-xs font-medium">Required</span>
              <% end %>
            </div>
            <% if field.description.present? %>
              <p class="text-xs text-gray-500 mb-3"><%= field.description %></p>
            <% end %>

            <% case field.field_type %>
            <% when "text" %>
              <% if read_only %>
                <p class="text-sm text-gray-900"><%= answer&.value %></p>
              <% else %>
                <input type="text" name="answers[<%= field.id %>][value]" value="<%= answer&.value %>"
                  <% if field.required? %>required<% end %>
                  class="w-full rounded-lg border-gray-300 text-sm focus:ring-pink-500 focus:border-pink-500"
                  placeholder="Enter your response...">
              <% end %>

            <% when "textarea" %>
              <% if read_only %>
                <p class="text-sm text-gray-900 whitespace-pre-wrap"><%= answer&.value %></p>
              <% else %>
                <textarea name="answers[<%= field.id %>][value]" rows="4"
                  <% if field.required? %>required<% end %>
                  class="w-full rounded-lg border-gray-300 text-sm focus:ring-pink-500 focus:border-pink-500"
                  placeholder="Enter your response..."><%= answer&.value %></textarea>
              <% end %>

            <% when "url" %>
              <% if read_only %>
                <% if answer&.value.present? %>
                  <a href="<%= answer.value %>" target="_blank" rel="noopener noreferrer"
                    class="text-sm text-pink-600 hover:text-pink-700 underline break-all"><%= answer.value %></a>
                  <% if answer.youtube_url? %>
                    <div class="mt-2 rounded-lg overflow-hidden border border-gray-200">
                      <iframe width="100%" height="200" src="https://www.youtube.com/embed/<%= answer.youtube_embed_id %>"
                        frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen class="rounded-lg"></iframe>
                    </div>
                  <% elsif answer.spotify_url? %>
                    <div class="mt-2 rounded-lg overflow-hidden border border-gray-200">
                      <iframe src="https://open.spotify.com/embed/<%= answer.spotify_embed_uri %>" width="100%" height="152"
                        frameborder="0" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                        loading="lazy" class="rounded-lg"></iframe>
                    </div>
                  <% end %>
                <% else %>
                  <p class="text-sm text-gray-400 italic">Not provided</p>
                <% end %>
              <% else %>
                <div data-controller="url-preview">
                  <input type="url" name="answers[<%= field.id %>][value]" value="<%= answer&.value %>"
                    <% if field.required? %>required<% end %>
                    data-url-preview-target="input"
                    data-action="input->url-preview#change"
                    class="w-full rounded-lg border-gray-300 text-sm focus:ring-pink-500 focus:border-pink-500"
                    placeholder="https://">
                  <div data-url-preview-target="preview" class="hidden"></div>
                </div>
              <% end %>

            <% when "file_upload" %>
              <% if answer&.file&.attached? %>
                <div class="mb-2">
                  <% if answer.file.content_type&.start_with?("image/") %>
                    <%= image_tag answer.file, class: "w-32 h-32 object-cover rounded-lg" %>
                  <% else %>
                    <a href="<%= url_for(answer.file) %>" target="_blank" rel="noopener noreferrer"
                      class="inline-flex items-center gap-1 text-sm text-pink-600 hover:text-pink-700">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                      </svg>
                      <%= answer.file.filename %>
                    </a>
                  <% end %>
                </div>
              <% end %>
              <% unless read_only %>
                <input type="file" name="answers[<%= field.id %>][file]"
                  class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-pink-50 file:text-pink-700 hover:file:bg-pink-100">
              <% end %>

            <% when "yesno" %>
              <% if read_only %>
                <% if answer&.value == "yes" %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Yes</span>
                <% elsif answer&.value == "no" %>
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700">No</span>
                <% else %>
                  <p class="text-sm text-gray-400 italic">Not answered</p>
                <% end %>
              <% else %>
                <div class="flex items-center gap-4">
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="answers[<%= field.id %>][value]" value="yes"
                      <%= 'checked' if answer&.value == 'yes' %>
                      class="h-4 w-4 text-pink-600 border-gray-300 focus:ring-pink-500 accent-pink-500">
                    <span class="text-sm text-gray-700">Yes</span>
                  </label>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="radio" name="answers[<%= field.id %>][value]" value="no"
                      <%= 'checked' if answer&.value == 'no' %>
                      class="h-4 w-4 text-pink-600 border-gray-300 focus:ring-pink-500 accent-pink-500">
                    <span class="text-sm text-gray-700">No</span>
                  </label>
                </div>
              <% end %>
            <% end %>
          </div>
        <% end %>

        <% unless read_only %>
          <div class="flex items-center gap-3 justify-end">
            <%= render "shared/button", text: "Save Draft", variant: "secondary", size: "medium", type: :submit %>
            <button type="submit" name="commit" value="Submit"
              class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg shadow-sm text-white bg-pink-600 hover:bg-pink-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500">
              Submit
            </button>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <div class="bg-white border border-gray-200 rounded-lg shadow-sm p-8 text-center text-gray-500">
        <p class="text-sm">No fields have been set up for this Cocobase yet.</p>
      </div>
    <% end %>
  </div>
</div>
