<% content_for :title, "Shows & Events" %>

<%
  shows_actions = [
    { icon: "calendar", text: "Calendar", description: "View all events on a calendar", path: manage_shows_calendar_path },
    { icon: "clipboard-list", text: "Schedule Event", description: "Create a new show or event", path: manage_shows_new_wizard_path }
  ]

  shows_description = <<~HTML
    <p>
      Manage all your shows and events across all productions. View upcoming performances, track
      past events, and see cast assignments at a glance.
    </p>
  HTML
%>

<div class="w-full" data-turbo-cache="false">
  <%= render partial: "shared/notice", locals: { notice: notice } %>

  <%= render "shared/module_header",
    title: "Shows & Events",
    description: shows_description,
    actions: shows_actions
  %>

  <div class="border-t border-gray-200 pt-4 mt-2">
    <%= render "shared/filters/filter_bar", wrapper_data_controller: "filter-select", filter_groups: [
    {
      label: "View",
      filters: [
        { text: "Upcoming", path: manage_shows_path(filter: "upcoming", view_mode: @view_mode, range: @range, event_type: @event_type_filter.join(","), production: @production_filter), active: @filter == "upcoming" },
        { text: "Past", path: manage_shows_path(filter: "past", event_type: @event_type_filter.join(","), production: @production_filter), active: @filter == "past" }
      ]
    },
    @filter == "upcoming" ? { separator: true } : nil,
    @filter == "upcoming" ? {
      label: "Browse",
      filters: [
        { text: "By Month", path: manage_shows_path(filter: "upcoming", view_mode: "by_month", event_type: @event_type_filter.join(","), production: @production_filter), active: @view_mode == "by_month" },
        { text: "All", path: manage_shows_path(filter: "upcoming", view_mode: "all", range: @range, event_type: @event_type_filter.join(","), production: @production_filter), active: @view_mode == "all" }
      ]
    } : nil,
    (@filter == "upcoming" && @view_mode == "all") ? { separator: true } : nil,
    (@filter == "upcoming" && @view_mode == "all") ? {
      label: "Range",
      filters: [
        { text: "3 Months", path: manage_shows_path(filter: "upcoming", view_mode: "all", range: "3_months", event_type: @event_type_filter.join(","), production: @production_filter), active: @range == "3_months" },
        { text: "6 Months", path: manage_shows_path(filter: "upcoming", view_mode: "all", range: "6_months", event_type: @event_type_filter.join(","), production: @production_filter), active: @range == "6_months" },
        { text: "All Time", path: manage_shows_path(filter: "upcoming", view_mode: "all", range: "all_time", event_type: @event_type_filter.join(","), production: @production_filter), active: @range == "all_time" }
      ]
    } : nil,
    { separator: true },
    {
      partial: "shared/filters/dropdown_filter",
      locals: {
        label: "Production",
        name: "production",
        options: [{ value: "", text: "All Productions" }] + @productions.map { |p| { value: p.id.to_s, text: p.name } },
        selected: @production_filter.to_s,
        data_attributes: {
          action: "change->filter-select#update",
          filter_select_param_value: "production",
          filter_select_event_type_value: @event_type_filter.join(","),
          filter_select_filter_value: @filter,
          filter_select_view_mode_value: @view_mode,
          filter_select_range_value: @range
        }
      }
    },
    { separator: true },
    {
      partial: "shared/filters/event_type_multiselect_filter",
      locals: {
        path_helper: ->(event_type:, entity:, filter: nil) { manage_shows_path(event_type: event_type, filter: filter || @filter, view_mode: @view_mode, range: @range, production: @production_filter) },
        event_type_filter: @event_type_filter,
        entity_filter: [],
        filter: @filter
      }
    }
  ].compact %>

  <% if @shows_capped %>
    <div class="text-sm text-amber-700 bg-amber-50 border border-amber-200 rounded-lg px-4 py-2 mb-3">Showing the first 500 upcoming shows. Switch to By Month or narrow the range to see specific dates.</div>
  <% end %>

  <% if @shows.any? %>
    <div class="space-y-1" data-controller="linked-highlight">
      <% @shows.each do |show| %>
        <%
          is_third_party = show.production.type_third_party?

          if is_third_party
            # For third-party: show rental info
            cast_summary = nil
          elsif show.casting_enabled?
            # For in-house with casting enabled: show cast summary with roles and sign-ups
            assignments = @assignments_by_show[show.id] || []
            roles = @roles_by_show[show.id] || []
            cant_make_it = @cant_make_it_by_show[show.id] || {}
            sign_up_regs = @sign_up_registrations_by_show[show.id] || []
            assignments_by_role = assignments.group_by(&:role_id)
            cast_summary = {
              roles: roles,
              assignments_by_role: assignments_by_role,
              cant_make_it_by_assignment: cant_make_it,
              sign_up_registrations: sign_up_regs
            }
          else
            # Casting disabled: still show sign-ups but no roles
            sign_up_regs = @sign_up_registrations_by_show[show.id] || []
            if sign_up_regs.any?
              cast_summary = {
                roles: [],
                assignments_by_role: {},
                cant_make_it_by_assignment: {},
                sign_up_registrations: sign_up_regs
              }
            else
              cast_summary = nil
            end
          end

          # Determine right panel type
          right_panel_type = if is_third_party
            :rental_services
          elsif show.casting_enabled? || cast_summary.present?
            :cast_summary
          else
            nil
          end
        %>
        <%= render partial: "shared/show_row", locals: {
          show: show,
          link_path: manage_show_path(show.production, show),
          show_canceled: true,
          show_recurring: true,
          show_linked: true,
          show_location: true,
          show_production: true,
          right_panel: right_panel_type,
          cast_summary: cast_summary
        } %>
      <% end %>
    </div>
  <% elsif @view_mode == "by_month" %>
    <div class="text-sm text-gray-500">
      No shows or events in <%= @current_month.strftime("%B %Y") %>.
    </div>
  <% else %>
    <div class="text-sm text-gray-500">No shows or events found.</div>
  <% end %>

  <% if @view_mode == "by_month" %>
    <!-- Month Navigation -->
    <div class="flex items-center justify-between mt-6">
      <div>
        <% if @can_go_prev %>
          <%= render "shared/button",
              text: @prev_month.strftime("%B %Y"),
              path: manage_shows_path(month: @prev_month.strftime("%Y-%m-01"), filter: @filter, view_mode: "by_month", event_type: @event_type_filter.join(","), production: @production_filter),
              variant: "secondary",
              size: "small",
              icon: "chevron-left",
              data: { turbo_prefetch: false } %>
        <% end %>
      </div>
      <div>
        <% if @can_go_next %>
          <%= render "shared/button",
              text: @next_month.strftime("%B %Y"),
              path: manage_shows_path(month: @next_month.strftime("%Y-%m-01"), filter: @filter, view_mode: "by_month", event_type: @event_type_filter.join(","), production: @production_filter),
              variant: "secondary",
              size: "small",
              icon: "chevron-right",
              data: { turbo_prefetch: false } %>
        <% end %>
      </div>
    </div>
  <% end %>
  </div>
</div>

<%# Turbo frame for recurring series modal %>
<%= turbo_frame_tag "recurring_series_modal" %>