<%# A single Mic row in a city listing. Dense, full-bleed, link-to-detail. %>
<%
  next_occ = (defined?(next_occurrence) && next_occurrence) || mic.next_occurrences(limit: 1).first
  starts_at = next_occ && next_occ[:starts_at]
  status = next_occ && next_occ[:mic_status]
  status_label =
    case status
    when "cancelled"   then [ "Cancelled",      "bg-red-50 text-red-700 border-red-200" ]
    when "online_only" then [ "Online tonight", "bg-amber-50 text-amber-700 border-amber-200" ]
    when "extra_spots" then [ "Extra spots",    "bg-emerald-50 text-emerald-700 border-emerald-200" ]
    else nil
    end
%>
<%= link_to mics_detail_path(mic.slug),
      class: "block px-4 sm:px-8 py-3 hover:bg-pink-50 transition-colors" do %>
  <div class="flex items-baseline gap-3 sm:gap-4">
    <div class="text-sm tabular-nums w-24 sm:w-28 flex-shrink-0 text-gray-600">
      <% if starts_at %>
        <span class="font-bold text-gray-900"><%= mics_day_short(starts_at.wday) %></span>
        <span><%= starts_at.strftime("%-l:%M%p").downcase %></span>
      <% else %>
        —
      <% end %>
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 flex-wrap">
        <span class="coustard-regular text-base sm:text-lg text-gray-900 truncate"><%= mic.name %></span>
        <% if mic.paused? %>
          <span class="inline-flex items-center text-[10px] uppercase tracking-wider px-1.5 py-0.5 bg-amber-500 text-white font-bold rounded">
            ⏸ Paused<% if mic.canceled_until.present? && mic.canceled_until >= Date.current %> · back <%= mic.canceled_until.strftime("%b %-d") %><% end %>
          </span>
        <% end %>
        <% if mic.powered_by_cocoscout? %>
          <span class="inline-flex items-center text-[10px] uppercase tracking-wider px-1.5 py-0.5 bg-pink-500 text-white font-bold rounded">
            CocoScout
          </span>
        <% end %>
        <% if status_label %>
          <span class="inline-flex items-center text-[10px] uppercase tracking-wider px-1.5 py-0.5 border rounded <%= status_label[1] %>">
            <%= status_label[0] %>
          </span>
        <% end %>
      </div>
      <div class="text-xs text-gray-500 truncate mt-0.5">
        <%= mic.venue.name %> · <%= mic.venue.neighborhood_city %><% if mic.venue.accessibility["wheelchair"] %> · ♿<% end %>
      </div>
    </div>
    <div class="text-[11px] uppercase tracking-wider text-gray-500 font-bold hidden sm:block shrink-0">
      <%= mics_format_label(mic.format) %>
    </div>
  </div>
<% end %>
