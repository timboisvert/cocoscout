<%
  mics_seo title: "Challenge claim on #{@mic.name} — Find a Mic",
            description: "File a challenge to an existing owner claim."
%>

<%= render "mics/form_shell", title: "Challenge claim on #{@mic.name}",
      description: "The current lead owner has 72 hours to respond. A moderator will decide if no response is filed." do %>
  <%= form_with url: mics_create_challenge_path(@mic.slug), method: :post do %>
    <%= render "mics/form_field", name: "mic_challenge[reason]", label: "Reason for challenge", type: "textarea", rows: 4, required: true %>
    <%= render "mics/form_field", name: "mic_challenge[evidence][url]", label: "Evidence URL", type: "url",
          placeholder: "https://..." %>
    <%= render "mics/form_field", name: "mic_challenge[evidence][note]", label: "Additional context", type: "textarea", rows: 3 %>

    <div class="flex items-center justify-between gap-3 pt-2 border-t border-gray-100">
      <a href="<%= mics_detail_path(@mic.slug) %>" class="text-sm text-gray-500 hover:text-gray-700 underline">Cancel</a>
      <%= render "shared/button", text: "File challenge", variant: "primary", size: "medium", type: :submit %>
    </div>
  <% end %>
<% end %>
