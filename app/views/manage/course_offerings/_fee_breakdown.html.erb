<%# Fee breakdown display - used by both wizard pricing and edit pricing tab %>
<%# Wrap this inside a data-controller="fee-calculator" element %>
<% promo_code = local_assigns[:promo_code] %>
<% promo_field = local_assigns[:promo_field_name] || "promo_code" %>
<% has_promo = promo_code.present? %>

<%# Single unified breakdown %>
<div data-fee-calculator-target="breakdownPlaceholder" class="bg-gray-50 border border-gray-200 rounded-lg p-4">
  <p class="text-sm text-gray-400 italic text-center">Enter a price above to calculate fees</p>
</div>

<div data-fee-calculator-target="breakdown" class="hidden bg-gray-50 border border-gray-200 rounded-lg p-4">
  <div class="space-y-2">
    <div class="flex justify-between text-sm">
      <span class="text-gray-600">Registration price</span>
      <span class="font-medium text-gray-900" data-fee-calculator-target="registrationPrice">$0.00</span>
    </div>
    <div class="text-sm" data-fee-calculator-target="feeRow">
      <div class="flex justify-between">
        <a href="#" data-action="click->fee-calculator#toggleFeeDetails" class="flex items-center gap-1 hover:text-pink-500 transition">
          <span data-fee-calculator-target="feeLabel">CocoScout fee (5%)</span>
          <svg data-fee-calculator-target="feeChevron" class="w-3.5 h-3.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </a>
        <span class="font-medium" data-fee-calculator-target="cocoscoutFee">$0.00</span>
      </div>
      <%# Expandable fee details %>
      <div data-fee-calculator-target="feeDetails" class="hidden mt-2 ml-2 pl-3 border-l-2 border-gray-200 space-y-1">
        <div class="flex justify-between text-xs text-gray-500">
          <span data-fee-calculator-target="stripeFeeLabel">Stripe card processing (2.9% + 30¢)</span>
          <span data-fee-calculator-target="stripeFee">$0.00</span>
        </div>
        <div class="flex justify-between text-xs text-gray-500">
          <span>CocoScout platform fee</span>
          <span data-fee-calculator-target="platformFee">$0.00</span>
        </div>
        <p class="text-xs text-gray-400 pt-1">Stripe fees are the standard rate for online card payments. CocoScout covers these out of the 5% fee — net revenue will always be exactly 95%.</p>
      </div>
    </div>
    <div class="border-t border-gray-300 pt-2 flex justify-between text-sm font-semibold">
      <span class="text-gray-900">Net revenue per registration</span>
      <span class="text-pink-600" data-fee-calculator-target="producerNet">$0.00</span>
    </div>
    <div class="flex justify-between text-sm font-semibold hidden" data-early-bird-net-row>
      <span class="text-gray-900">Net revenue per early bird</span>
      <span class="text-pink-600" data-fee-calculator-target="earlyBirdNet">$0.00</span>
    </div>
  </div>
</div>

<%# Promo code: subtle link + applied badge %>
<div class="mt-3 flex items-center gap-3">
  <a href="#" data-fee-calculator-target="promoLink"
     data-action="click->fee-calculator#openPromoModal"
     class="text-xs text-gray-400 hover:text-pink-500 transition <%= 'hidden' if has_promo %>">I have a promo code</a>

  <div data-fee-calculator-target="promoAppliedBadge" class="<%= 'hidden' unless has_promo %>">
    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
      <span data-promo-code-text><%= promo_code %></span>
      <a href="#" data-action="click->fee-calculator#removePromo" class="ml-1 text-green-600 hover:text-green-900">&times;</a>
    </span>
  </div>
</div>

<%= hidden_field_tag promo_field, promo_code || "", data: { fee_calculator_target: "promoHidden" } %>
<%= hidden_field_tag "promo_coverage_type", (local_assigns[:promo_coverage_type] || "none"), data: { fee_calculator_target: "promoCoverageHidden" } %>

<%# Promo code modal %>
<div data-fee-calculator-target="promoModal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
  <div class="fixed inset-0 bg-black/40" data-action="click->fee-calculator#closePromoModal"></div>
  <div class="relative bg-white rounded-xl shadow-xl p-6 w-full max-w-sm mx-4">
    <h3 class="text-base font-semibold text-gray-900 mb-1">Enter Promo Code</h3>
    <p class="text-xs text-gray-500 mb-4">If you have a promo code, enter it below to waive the CocoScout fee.</p>
    <input type="text"
           data-fee-calculator-target="promoInput"
           data-action="input->fee-calculator#clearPromoError keydown->fee-calculator#promoKeydown"
           placeholder="e.g. WELCOME2025"
           value="<%= promo_code || '' %>"
           class="block w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition text-sm font-mono uppercase">
    <div data-fee-calculator-target="promoStatus" class="mt-2 min-h-[20px]"></div>
    <div class="mt-4 flex items-center justify-end gap-3">
      <%= render "shared/button", text: "Cancel", variant: "ghost-cancel", size: "small", type: :button, data: { action: "fee-calculator#closePromoModal" } %>
      <%= render "shared/button", text: "Apply", variant: "primary", size: "medium", type: :button, data: { action: "fee-calculator#applyPromo" } %>
    </div>
  </div>
</div>
