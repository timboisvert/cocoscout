<%
  contract = @contract
  contractor = @contractor
  show_financials = @show_financials
  contractor_line_item = @contractor_line_item
  has_financials = show_financials&.has_data?

  contractor_share_pct = contract.contractor_share_percentage
  our_share_pct = contract.revenue_share_percentage

  if has_financials
    total_revenue = show_financials.total_revenue
    contractor_amount = (total_revenue * contractor_share_pct / 100.0).round(2)
    our_amount = (total_revenue * our_share_pct / 100.0).round(2)
    contractor_collected = show_financials.contractor_collected.to_f
    contractor_net_owed = (contractor_amount - contractor_collected).round(2)
  end

  is_paid = contractor_line_item&.paid?
%>

<!-- Revenue Share Summary -->
<div class="bg-white rounded-lg border border-gray-200 p-5">
  <div class="flex items-center justify-between mb-4">
    <h3 class="font-semibold text-gray-900">Revenue Share Contract</h3>
    <span class="inline-flex items-center rounded-md px-2.5 py-1 text-xs font-medium bg-purple-100 text-purple-700">
      <%= our_share_pct %>/<%= contractor_share_pct %> Split
    </span>
  </div>

  <div class="text-sm text-gray-600 mb-4">
    <span class="font-medium"><%= contract.contractor_name %></span>
    <span class="text-gray-400 mx-1">•</span>
    Contract: <%= contract.contractor_share_percentage %>% contractor / <%= contract.revenue_share_percentage %>% ours
  </div>

  <% if has_financials %>
    <!-- Revenue Breakdown -->
    <div class="bg-gray-50 rounded-lg p-4 space-y-3">
      <div class="flex items-center justify-between">
        <span class="text-sm text-gray-600">Total Revenue</span>
        <span class="font-semibold text-gray-900"><%= number_to_currency(total_revenue) %></span>
      </div>
      <div class="border-t border-gray-200 pt-3 space-y-2">
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600">Our Share (<%= our_share_pct %>%)</span>
          <span class="font-medium text-gray-900"><%= number_to_currency(our_amount) %></span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-gray-600">Contractor Share (<%= contractor_share_pct %>%)</span>
          <span class="font-medium text-gray-900"><%= number_to_currency(contractor_amount) %></span>
        </div>
        <% if contractor_collected > 0 %>
          <div class="flex items-center justify-between">
            <span class="text-sm text-amber-700">Contractor already collected</span>
            <span class="font-medium text-amber-700">− <%= number_to_currency(contractor_collected) %></span>
          </div>
          <div class="flex items-center justify-between border-t border-gray-200 pt-2">
            <span class="text-sm text-pink-700 font-medium">Net Owed to Contractor</span>
            <span class="font-semibold text-pink-700 text-lg"><%= number_to_currency(contractor_net_owed) %></span>
          </div>
        <% else %>
          <div class="flex items-center justify-between border-t border-gray-200 pt-2">
            <span class="text-sm text-pink-700 font-medium">Contractor Payout</span>
            <span class="font-semibold text-pink-700 text-lg"><%= number_to_currency(contractor_amount) %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="bg-pink-50 border border-pink-200 rounded-lg p-4">
      <div class="flex gap-3">
        <svg class="w-5 h-5 text-pink-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <div>
          <p class="text-sm text-pink-800 font-medium">Financial data needed</p>
          <p class="text-sm text-pink-700 mt-1">Enter ticket sales and revenue data to calculate the contractor payout.</p>
          <div class="mt-3">
            <%= link_to manage_money_show_financials_path(@show) do %>
              <%= render "shared/button", text: "Enter Financial Data", variant: "primary", size: "small" %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<% if has_financials && contractor_line_item %>
  <!-- Contractor Payout Card -->
  <div class="bg-white rounded-lg border border-gray-200 p-5">
    <div class="flex items-center justify-between mb-4">
      <h3 class="font-semibold text-gray-900">Contractor Payout</h3>
      <% if is_paid %>
        <span class="inline-flex items-center rounded-md px-2.5 py-1 text-xs font-medium bg-green-100 text-green-700">
          <%= contractor_line_item.payment_method_label || "Paid" %>
        </span>
      <% else %>
        <span class="inline-flex items-center rounded-md px-2.5 py-1 text-xs font-medium bg-pink-100 text-pink-700">
          Awaiting Payout
        </span>
      <% end %>
    </div>

    <!-- Contractor Info -->
    <div class="flex items-center gap-4 p-4 bg-gray-50 rounded-lg">
      <div class="w-14 h-14 rounded-lg bg-pink-100 flex items-center justify-center text-pink-600 font-bold text-lg">
        <%= contractor&.initials || contract.contractor_name[0..1].upcase %>
      </div>
      <div class="flex-1">
        <div class="text-lg font-semibold text-gray-900"><%= contract.contractor_name %></div>
        <div class="text-xs flex items-center gap-2 flex-wrap mt-1">
          <% if contractor&.venmo_configured? %>
            <span class="inline-flex items-center gap-1 text-blue-600">
              <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19.5 3c.9 1.5 1.3 3.1 1.3 5.1 0 5.6-4.8 12.9-8.7 18H4.8L2.2 3.8l6.3-.6 1.5 12c1.4-2.3 3.1-5.9 3.1-8.4 0-1.9-.3-3.2-.9-4.3L19.5 3z"/>
              </svg>
              <span><%= contractor.formatted_venmo_identifier %></span>
            </span>
          <% end %>
          <% if contractor&.zelle_configured? %>
            <span class="inline-flex items-center gap-1 text-purple-600">
              <svg class="w-3 h-3" viewBox="0 0 50 50" fill="currentColor">
                <path d="M25 50c13.807 0 25-11.193 25-25S38.807 0 25 0 0 11.193 0 25s11.193 25 25 25z"/>
              </svg>
              <span><%= contractor.zelle_identifier %></span>
            </span>
          <% end %>
          <% unless contractor&.any_payment_method_configured? %>
            <span class="text-gray-400">(no payment method)</span>
          <% end %>
        </div>
      </div>
      <div class="text-right">
        <div class="text-2xl font-bold <%= is_paid ? 'text-green-700' : 'text-gray-900' %>">
          <%= number_to_currency(contractor_net_owed) %>
        </div>
        <div class="text-xs text-gray-500">
          <%= contractor_share_pct %>% of revenue
          <% if contractor_collected > 0 %>
            <span class="text-amber-600">− <%= number_to_currency(contractor_collected) %> held</span>
          <% end %>
        </div>
      </div>
    </div>

    <% if is_paid %>
      <!-- Paid State -->
      <div class="bg-green-50 rounded-lg p-4 mt-4">
        <div class="flex items-center gap-2 text-green-700">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/>
          </svg>
          <span class="font-medium">Paid</span>
          <% if contractor_line_item.paid_at %>
            <span class="text-sm text-green-600">on <%= contractor_line_item.paid_at.strftime('%B %-d, %Y') %></span>
          <% end %>
        </div>
        <% if contractor_line_item.payment_method.present? %>
          <div class="text-sm text-green-600 mt-1 ml-7">via <%= contractor_line_item.payment_method_label %></div>
        <% end %>
      </div>
    <% elsif !contractor&.any_payment_method_configured? && contractor %>
      <!-- No Payment Method - show form to add -->
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mt-4">
        <div class="flex gap-3">
          <svg class="w-5 h-5 text-amber-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
          </svg>
          <div class="flex-1">
            <p class="text-sm text-amber-800 font-medium">Add payment info to pay this contractor</p>
            <p class="text-sm text-amber-700 mt-1">Enter a Venmo handle or Zelle email/phone number to enable payment actions.</p>
          </div>
        </div>
      </div>

      <%= form_with url: manage_contractor_payment_info_money_show_payout_path(@show, contractor.id), method: :patch, local: true, class: "bg-white rounded-lg border border-gray-200 p-5 mt-4" do |f| %>
        <h3 class="font-semibold text-gray-900 mb-4">Contractor Payment Info</h3>
        <div class="space-y-4">
          <div>
            <label class="text-sm font-medium text-gray-700 block mb-1">Venmo Handle</label>
            <input type="text" name="venmo_handle" placeholder="@username" value="<%= contractor.formatted_venmo_identifier %>"
                   class="w-full text-sm px-3 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-1 focus:ring-pink-300 focus:border-pink-300" />
          </div>
          <div>
            <label class="text-sm font-medium text-gray-700 block mb-1">Zelle Email or Phone</label>
            <input type="text" name="zelle_email" placeholder="email@example.com or phone number" value="<%= contractor.zelle_identifier %>"
                   class="w-full text-sm px-3 py-2 border border-gray-200 rounded-lg focus:outline-none focus:ring-1 focus:ring-pink-300 focus:border-pink-300" />
          </div>
          <div>
            <%= render "shared/button", text: "Save Payment Info", variant: "primary", size: "medium", type: :submit %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
