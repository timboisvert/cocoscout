<% content_for :title, "New document" %>

<div class="w-full mb-10">
  <%= render partial: "shared/notice", locals: { notice: notice, alert: alert } %>
  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      [ "Documents", manage_org_documents_path ]
    ],
    text: "New document",
    links: []
  } %>

  <div class="max-w-xl bg-white border border-gray-200 rounded-lg shadow-sm p-6">
    <% if @document.errors.any? %>
      <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        <%= @document.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <%= form_with url: manage_org_documents_path, method: :post do |f| %>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Production</label>
          <select name="production_id"
                  class="block w-full text-sm rounded-lg border border-gray-300 px-3 py-2.5 focus:ring-pink-500 focus:border-pink-500">
            <% @managed_productions.each do |production| %>
              <option value="<%= production.id %>" <%= "selected" if @production_id == production.id %>><%= production.name %></option>
            <% end %>
          </select>
          <p class="text-xs text-gray-500 mt-1">Documents live inside a production. You can change sharing afterward.</p>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
          <%= text_field_tag "production_document[title]", @document.title, required: true,
                placeholder: "e.g. Performer Handbook",
                class: "block w-full text-sm rounded-lg border border-gray-300 px-3 py-2.5 focus:ring-pink-500 focus:border-pink-500" %>
        </div>
      </div>

      <div class="flex items-center justify-end gap-3 mt-6">
        <%= link_to "Cancel", manage_org_documents_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
        <%= render "shared/button", text: "Create document", variant: "primary", size: "medium", type: :submit %>
      </div>
    <% end %>
  </div>
</div>
