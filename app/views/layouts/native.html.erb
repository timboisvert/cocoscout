<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "CocoScout" %></title>
    <%# viewport-fit=cover exposes safe area insets for iPhone notch + home indicator %>
    <meta name="viewport" content="width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=5">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "actiontext", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= Sentry.get_trace_propagation_meta.html_safe %>
  </head>

  <body class="inter-regular text-slate-700 bg-[#f9f9f7]"
        data-turbo-native="true"
        <% if Current.user.present? %>
          data-controller="user-notifications"
          data-user-notifications-user-id-value="<%= Current.user.id %>"
        <% end %>>

    <main class="px-4 pt-4 pb-8 overflow-x-hidden" data-controller="bridge--form">
      <div id="flash-messages"></div>
      <%= yield %>
    </main>

    <%# Global modal turbo frames %>
    <%= turbo_frame_tag "contact_modal" %>
    <%= yield :modals %>
  </body>
</html>
