<% content_for :title, @document.title %>

<div class="w-full" data-controller="document-toc">
  <%= render partial: "shared/notice", locals: { notice: notice, alert: alert } %>
  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      [@production.name, edit_manage_production_path(@production)],
      [ "Documents", manage_production_documents_path(@production) ]
    ],
    text: @document.title,
    links: [
      { text: "Sharing", icon: "share", variant: "secondary", type: :button,
        data: { controller: "modal", action: "click->modal#open", "modal-id": "sharing-modal-#{@document.id}" } },
      { text: "Edit", icon: "pencil", variant: "secondary", path: edit_manage_production_document_path(@production, @document) },
      { text: "Delete", icon: "trash", variant: "secondary", path: manage_production_document_path(@production, @document),
        method: :delete, data: { turbo_confirm: "Delete \"#{@document.title}\"? This can't be undone." } }
    ]
  } %>

  <%# Reader view — a pinned contents rail on the left; the document scrolls. %>
  <div class="lg:flex lg:gap-8 lg:h-[calc(100vh-10rem)]">
    <aside class="hidden lg:block lg:w-60 flex-shrink-0 overflow-y-auto py-2" data-document-toc-target="wrapper">
      <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Contents</div>
      <nav data-document-toc-target="toc" class="space-y-0.5 text-sm border-l border-gray-200 pl-3"></nav>
    </aside>

    <article class="flex-1 min-w-0 lg:overflow-y-auto bg-white border border-gray-200 rounded-lg shadow-sm px-6 sm:px-12 py-8 sm:py-10 min-h-[70vh] lg:min-h-0">
      <%# Mobile contents — collapsible (the sidebar rail is desktop-only). %>
      <details class="lg:hidden mb-5 border border-gray-200 rounded-lg bg-gray-50/60" data-controller="details-menu" data-document-toc-target="wrapper">
        <summary class="list-none cursor-pointer px-3 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wide flex items-center justify-between">
          <span>Contents</span>
          <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
        </summary>
        <nav data-document-toc-target="toc" class="px-3 pb-2 space-y-0.5 text-sm"></nav>
      </details>

      <h1 class="text-2xl sm:text-4xl coustard-regular text-gray-900 <%= @document.productions.size > 1 ? "mb-2" : "mb-6" %>"><%= @document.title %></h1>
      <% if @document.productions.size > 1 %>
        <div class="mb-6 inline-flex items-center gap-2 text-xs text-gray-500">
          <span class="text-[10px] uppercase tracking-wider px-1.5 py-0.5 rounded bg-indigo-50 text-indigo-700 font-bold">Shared</span>
          <span>Applies to <%= @document.applies_to_summary %></span>
        </div>
      <% end %>
      <div class="document-render max-w-3xl" data-document-toc-target="content">
        <%= @document.body %>
      </div>
    </article>
  </div>

  <% if current_user_can_manage?(@production) %>
    <%= render "sharing_modal", document: @document, production: @production,
          talent_pool_options: @talent_pool_options, candidate_people: @candidate_people %>
  <% end %>
</div>
