<% content_for :title, "Amend Contract - Details" %>

<div class="w-full mb-10">
  <%= render partial: "shared/notice", locals: { notice: notice, alert: alert } %>

  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      ["Money", manage_money_index_path],
      ["Contracts", manage_contracts_path],
      [@contract.contractor_name, manage_contract_path(@contract)]
    ],
    text: "Amend Contract",
    links: []
  } %>

  <div class="max-w-4xl mx-auto mt-6">
    <p class="text-gray-600 mb-6">Update the production name, ticket tiers and prices, discounts, and who provides the tech.</p>

    <%= render "manage/contracts/amend_steps", current: 4 %>

    <%= form_with url: save_amend_ticketing_tech_manage_contract_path(@contract), method: :post, local: true do %>
      <div class="bg-white border border-gray-200 rounded-lg p-5 mb-6">
        <h3 class="text-base font-semibold text-gray-900 mb-4">Production Name</h3>
        <label class="block text-xs font-medium text-gray-700 mb-1">Name shown on the contract and the show</label>
        <input type="text" name="production_name" value="<%= @production_name %>"
               placeholder="e.g. Music &amp; Improv Show"
               class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-pink-500 focus:border-pink-500">
        <p class="text-xs text-gray-500 mt-2">Renaming here updates the linked production in CocoScout too.</p>
      </div>

      <div class="bg-white border border-gray-200 rounded-lg p-5 mb-6">
        <h3 class="text-base font-semibold text-gray-900 mb-4">Ticketing</h3>
        <%= render "manage/contracts/ticketing_fields", ticketing: @ticketing %>
      </div>

      <div class="bg-white border border-gray-200 rounded-lg p-5 mb-6">
        <h3 class="text-base font-semibold text-gray-900 mb-4">Tech</h3>
        <%= render "manage/contracts/tech_fields", tech: @tech %>
      </div>

      <div class="flex justify-between items-center pt-4 border-t border-gray-200">
        <%= render "shared/button", text: "Back: Payments", variant: "secondary", size: "medium", icon: "arrow-left", path: amend_payments_manage_contract_path(@contract) %>
        <%= render "shared/button", text: "Next: Review", variant: "primary", size: "medium", type: :submit %>
      </div>
    <% end %>
  </div>
</div>
