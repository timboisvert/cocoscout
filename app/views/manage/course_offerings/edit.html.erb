<% content_for :title, "Edit #{@course_offering.title}" %>

<div class="w-full pb-24" data-controller="tabs instructor-search"
     data-tabs-initial-tab-value="<%= params[:tab].to_i %>"
     data-instructor-search-search-url-value="<%= manage_course_offering_search_instructor_path(@course_offering) %>"
     data-instructor-search-invite-url-value="<%= manage_course_offering_invite_instructor_path(@course_offering) %>">

  <%= render partial: "shared/notice", locals: { notice: notice, alert: alert } %>

  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      ["Courses", manage_course_offerings_path],
      [@course_offering.title, manage_course_offering_path(@course_offering)]
    ],
    text: "Edit",
    links: []
  } %>

  <%# Tab Navigation %>
  <nav class="flex space-x-2 border-b border-gray-200 mb-6 overflow-x-auto">
    <button type="button" data-tabs-target="tab" data-index="0" data-action="tabs#select" class="px-4 py-2 text-sm font-medium border-b-2 cursor-pointer whitespace-nowrap">Basics</button>
    <button type="button" data-tabs-target="tab" data-index="1" data-action="tabs#select" class="px-4 py-2 text-sm font-medium border-b-2 cursor-pointer whitespace-nowrap">Instructor</button>
    <button type="button" data-tabs-target="tab" data-index="2" data-action="tabs#select" class="px-4 py-2 text-sm font-medium border-b-2 cursor-pointer whitespace-nowrap">Pricing</button>
    <button type="button" data-tabs-target="tab" data-index="3" data-action="tabs#select" class="px-4 py-2 text-sm font-medium border-b-2 cursor-pointer whitespace-nowrap">Details</button>
    <button type="button" data-tabs-target="tab" data-index="4" data-action="tabs#select" class="px-4 py-2 text-sm font-medium border-b-2 cursor-pointer whitespace-nowrap">Sessions</button>
  </nav>

  <%# ==================== TAB 0: BASICS ==================== %>
  <div data-tabs-target="panel">
    <%= form_with model: @course_offering, url: manage_course_offering_path(@course_offering), method: :patch, local: true, class: "space-y-6" do |form| %>
      <%= hidden_field_tag :tab, "0" %>

      <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
        <%= render "shared/card_header", title: "Course Title & Description" %>
        <div class="p-5 space-y-5">
          <div>
            <label for="course_offering_title" class="block text-sm font-medium text-gray-900 mb-1.5">
              Course Title <span class="text-pink-500">*</span>
            </label>
            <%= form.text_field :title, required: true,
                placeholder: "e.g., Intro to Improv - Spring 2025",
                class: "block w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition" %>
          </div>

          <div>
            <label for="course_offering_subtitle" class="block text-sm font-medium text-gray-900 mb-1.5">
              Subtitle
            </label>
            <%= form.text_field :subtitle,
                placeholder: "e.g., A 6-week course for beginners",
                class: "block w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition" %>
          </div>

          <div>
            <label for="course_offering_description" class="block text-sm font-medium text-gray-900 mb-1.5">
              Description
            </label>
            <p class="text-xs text-gray-500 mb-2">Describe what students will learn — this is shown on the public registration page.</p>
            <%= form.rich_text_area :description, class: "w-full min-h-[150px]" %>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <%= render "shared/button", text: "Save Basics", variant: "primary", size: "medium", type: :submit %>
      </div>
    <% end %>
  </div>

  <%# ==================== TAB 1: INSTRUCTOR ==================== %>
  <div data-tabs-target="panel" class="hidden">
    <div class="space-y-6">
      <%# Current Instructor Display %>
      <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
        <%= render "shared/card_header", title: "Instructor" %>
        <div class="p-5">

          <%# Selected instructor section %>
          <div data-instructor-search-target="selectedSection"
               class="<%= 'hidden' unless @instructor_person %>">
            <label class="block text-sm font-medium text-gray-900 mb-1.5">Current Instructor</label>
            <div class="flex items-center gap-4 p-4 border border-pink-200 bg-pink-50 rounded-lg">
              <div data-instructor-search-target="selectedHeadshot">
                <% if @instructor_person %>
                  <% headshot_variant = @instructor_person.safe_headshot_variant(:tile) %>
                  <% if headshot_variant %>
                    <%= image_tag headshot_variant, alt: @instructor_person.name, class: "w-12 h-12 rounded-lg object-cover flex-shrink-0" %>
                  <% else %>
                    <div class="w-12 h-12 rounded-lg bg-pink-100 flex items-center justify-center text-pink-700 font-bold text-sm flex-shrink-0">
                      <%= @instructor_person.initials %>
                    </div>
                  <% end %>
                <% end %>
              </div>
              <div class="flex-grow min-w-0">
                <div class="font-medium text-gray-900" data-instructor-search-target="selectedName">
                  <%= @instructor_person&.name %>
                </div>
                <div class="text-sm text-gray-500" data-instructor-search-target="selectedEmail">
                  <%= @instructor_person&.email %>
                </div>
              </div>
              <button type="button"
                      data-action="instructor-search#changePerson"
                      class="px-3 py-1.5 text-gray-600 bg-white rounded-md text-xs font-medium shadow-sm hover:bg-gray-50 transition-all border border-gray-300 cursor-pointer flex-shrink-0">
                Change
              </button>
            </div>
          </div>

          <%# Search section %>
          <div data-instructor-search-target="searchSection"
               class="<%= 'hidden' if @instructor_person %>">
            <label for="instructor_search" class="block text-sm font-medium text-gray-900 mb-1.5">
              Search for Instructor
            </label>
            <input type="text" id="instructor_search"
                   data-instructor-search-target="searchInput"
                   data-action="input->instructor-search#search"
                   placeholder="Search by name or email..."
                   autocomplete="off"
                   class="block w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition">

            <div data-instructor-search-target="searchResults" class="mt-3 max-h-80 overflow-y-auto"></div>
          </div>
        </div>
      </div>

      <%# Instructor Bio + Headshot + Save %>
      <%= form_with url: manage_course_offering_update_instructor_path(@course_offering), method: :post, local: true, multipart: true, class: "space-y-6", id: "instructor-form" do |form| %>
        <input type="hidden" name="instructor_person_id"
               value="<%= @course_offering.instructor_person_id %>"
               data-instructor-search-target="personIdField">

        <%# Add to Production Team toggle %>
        <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden"
             data-instructor-search-target="teamToggleSection"
             style="<%= 'display:none' unless @instructor_person %>">
          <%= render "shared/card_header", title: "Production Team" %>
          <div class="p-5">
            <div class="flex items-center justify-between">
              <div>
                <span class="text-sm font-medium text-gray-900">Add to production team</span>
                <p class="text-xs text-gray-500 mt-0.5">Make the instructor a manager of this course's production with notifications enabled.</p>
              </div>
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="hidden" name="instructor_on_team" value="0">
                <input type="checkbox" name="instructor_on_team" value="1"
                       <%= 'checked' if @course_offering.instructor_on_team? %>
                       class="sr-only peer">
                <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-pink-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-pink-500"></div>
              </label>
            </div>
          </div>
        </div>

        <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
          <%= render "shared/card_header", title: "Instructor Photo" %>
          <div class="p-5">
            <p class="text-xs text-gray-500 mb-2">Upload a photo for the instructor shown on the registration page. If not set, their profile photo will be used.</p>
            <% if @course_offering.instructor_headshot.attached? %>
              <div class="mb-3 flex items-center gap-3">
                <%= image_tag @course_offering.instructor_headshot.variant(resize_to_fill: [128, 128]), alt: "Instructor photo", class: "w-16 h-16 rounded-lg object-cover" %>
                <span class="text-xs text-gray-500">Current photo</span>
              </div>
            <% end %>
            <input type="file" name="instructor_headshot" accept="image/*"
                   class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-pink-50 file:text-pink-700 hover:file:bg-pink-100 cursor-pointer">
          </div>
        </div>

        <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
          <%= render "shared/card_header", title: "Instructor Bio" %>
          <div class="p-5">
            <p class="text-xs text-gray-500 mb-2">A brief bio shown on the registration page. Optional.</p>
            <%= rich_text_area_tag :instructor_bio, @course_offering.instructor_bio, class: "w-full min-h-[120px]" %>
          </div>
        </div>

        <div class="flex items-center gap-3">
          <%= render "shared/button", text: "Save Instructor", variant: "primary", size: "medium", type: :submit %>
        </div>
      <% end %>
    </div>
  </div>

  <%# ==================== TAB 2: PRICING ==================== %>
  <div data-tabs-target="panel" class="hidden">
    <%= form_with model: @course_offering, url: manage_course_offering_path(@course_offering), method: :patch, local: true, class: "space-y-6" do |form| %>
      <%= hidden_field_tag :tab, "2" %>

      <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
        <%= render "shared/card_header", title: "Registration Fee" %>
        <div class="p-5 space-y-5">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="course_offering_price_dollars" class="block text-sm font-medium text-gray-900 mb-1.5">
                Price <span class="text-pink-500">*</span>
              </label>
              <div class="relative mt-2">
                <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500 pointer-events-none">$</span>
                <%= number_field_tag "course_offering[price_dollars]",
                    @course_offering.price_cents.present? ? format("%.2f", @course_offering.price_cents / 100.0) : nil,
                    min: 0, step: 0.01,
                    placeholder: "150.00",
                    class: "block w-full pl-7 px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition" %>
              </div>
            </div>
            <div>
              <label for="course_offering_currency" class="block text-sm font-medium text-gray-900 mb-1.5">
                Currency
              </label>
              <div class="mt-5">
                <%= form.select :currency, [["USD", "usd"], ["CAD", "cad"], ["GBP", "gbp"], ["EUR", "eur"]], {},
                    class: "block w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition" %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
        <%= render "shared/card_header", title: "Early Bird Pricing" %>
        <div class="p-5 space-y-5">
          <div class="flex items-center justify-between mb-3">
            <span class="text-sm font-medium text-gray-900">Offer early bird pricing</span>
            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" id="enable_early_bird"
                     <%= 'checked' if @course_offering.early_bird_price_cents.present? %>
                     class="sr-only peer"
                     onchange="
                       var fields = document.getElementById('early-bird-fields');
                       fields.classList.toggle('hidden', !this.checked);
                       if (!this.checked) {
                         fields.querySelectorAll('input').forEach(function(i) { i.value = ''; });
                       }
                     ">
              <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-pink-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-pink-500"></div>
            </label>
          </div>
          <div id="early-bird-fields" class="<%= 'hidden' unless @course_offering.early_bird_price_cents.present? %>">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label for="course_offering_early_bird_price_dollars" class="block text-sm font-medium text-gray-700 mb-1.5">
                  Early Bird Price
                </label>
                <div class="relative mt-2">
                  <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500 pointer-events-none">$</span>
                  <%= number_field_tag "course_offering[early_bird_price_dollars]",
                      @course_offering.early_bird_price_cents.present? ? format("%.2f", @course_offering.early_bird_price_cents / 100.0) : nil,
                      min: 0, step: 0.01,
                      placeholder: "120.00",
                      class: "block w-full pl-7 px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition" %>
                </div>
              </div>
              <div>
                <label for="course_offering_early_bird_deadline" class="block text-sm font-medium text-gray-700 mb-1.5">
                  Early Bird Deadline
                </label>
                <%= form.datetime_local_field :early_bird_deadline,
                    class: "block w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition" %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <%= render "shared/button", text: "Save Pricing", variant: "primary", size: "medium", type: :submit %>
      </div>
    <% end %>
  </div>

  <%# ==================== TAB 3: DETAILS ==================== %>
  <div data-tabs-target="panel" class="hidden">
    <%= form_with model: @course_offering, url: manage_course_offering_path(@course_offering), method: :patch, local: true, class: "space-y-6" do |form| %>
      <%= hidden_field_tag :tab, "3" %>

      <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
        <%= render "shared/card_header", title: "Capacity" %>
        <div class="p-5">
          <label for="course_offering_capacity" class="block text-sm font-medium text-gray-900 mb-1.5">
            Max Registrations
          </label>
          <p class="text-xs text-gray-500 mb-2">Leave blank for unlimited spots.</p>
          <%= form.number_field :capacity, min: 1,
              placeholder: "20",
              class: "block w-48 px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition" %>
        </div>
      </div>

      <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
        <%= render "shared/card_header", title: "Registration Window" %>
        <div class="p-5">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="course_offering_opens_at" class="block text-sm font-medium text-gray-700 mb-1.5">
                Opens At
              </label>
              <p class="text-xs text-gray-500 mb-2">When registration becomes available. Status must also be "Open".</p>
              <%= form.datetime_local_field :opens_at,
                  class: "block w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition" %>
            </div>
            <div>
              <label for="course_offering_closes_at" class="block text-sm font-medium text-gray-700 mb-1.5">
                Closes At
              </label>
              <p class="text-xs text-gray-500 mb-2">Auto-close registration date.</p>
              <%= form.datetime_local_field :closes_at,
                  class: "block w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition" %>
            </div>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <%= render "shared/button", text: "Save Details", variant: "primary", size: "medium", type: :submit %>
      </div>
    <% end %>
  </div>

  <%# ==================== TAB 4: SESSIONS ==================== %>
  <div data-tabs-target="panel" class="hidden">
    <div class="space-y-6">
      <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
        <%= render "shared/card_header", title: "Class Sessions" %>
        <div class="p-5">
          <p class="text-sm text-gray-600 mb-4">
            Sessions are managed as events on this course's production.
            You can edit dates, times, locations, and other details from the shows page.
          </p>

          <% if @sessions.any? %>
            <div class="space-y-2">
              <% @sessions.each do |show| %>
                <div class="flex items-center gap-3 py-2 px-3 border border-gray-100 rounded-lg hover:bg-gray-50">
                  <div class="flex-shrink-0 w-10 h-10 bg-pink-50 border border-pink-100 rounded-md flex flex-col items-center justify-center">
                    <span class="text-[10px] font-medium text-pink-600 uppercase leading-none"><%= show.date_and_time.strftime("%b") %></span>
                    <span class="text-sm font-bold text-pink-700 leading-tight"><%= show.date_and_time.strftime("%-d") %></span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-900">
                      <%= show.date_and_time.strftime("%A, %B %-d, %Y") %>
                    </p>
                    <p class="text-xs text-gray-500">
                      <%= show.date_and_time.strftime("%-I:%M %p") %>
                      <% if show.duration_minutes.present? %>
                        &middot; <%= show.duration_minutes %> min
                      <% end %>
                      <% if show.location.present? %>
                        &middot; <%= show.location.name %>
                      <% end %>
                    </p>
                  </div>
                  <% if show.secondary_name.present? %>
                    <span class="text-xs text-gray-400"><%= show.secondary_name %></span>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-400 italic">No sessions scheduled yet.</p>
          <% end %>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <%= link_to manage_production_shows_path(@course_offering.production) do %>
          <%= render "shared/button", text: "Manage Sessions", variant: "secondary", size: "medium" %>
        <% end %>
      </div>
    </div>
  </div>

</div>
