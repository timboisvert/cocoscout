<% content_for :title, "Plan your Audition Sessions" %>

<div class="w-full" data-controller="location-modal audition-session-modal" data-production-id="<%= @production.id %>" data-audition-cycle-id="<%= @audition_cycle.id %>">
  <%= render partial: "shared/notice", locals: { notice: notice } %>
  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      ["Sign-ups", manage_signups_path],
      [@production.name, manage_signups_production_path(@production)],
      ["Auditions", manage_signups_auditions_path(@production)]
    ],
    text: "Sessions",
    links: []
  } %>

  <%= render partial: "manage/auditions/cycle_status_panel" %>
  <%= render partial: "manage/auditions/topical_nav", locals: { current_topic: :sessions } %>

  <div class="w-full">
    <!-- Scheduled sessions -->
    <div class="space-y-2" id="audition_sessions_list">
      <% if @audition_sessions.any? %>
        <% @audition_sessions.each do |session| %>
          <%
            session_auditions = session.auditions
            scheduled_count = session_auditions.size
            run_path = manage_signups_auditions_cycle_session_path(@production, @audition_cycle, session)
            schedule_path = manage_schedule_auditions_signups_auditions_cycle_path(@production, @audition_cycle)
          %>
          <%= link_to run_path, class: "block bg-white border border-gray-200 rounded-lg hover:border-pink-400 transition-colors no-underline cursor-pointer [&_*]:cursor-pointer" do %>
            <div class="flex flex-col md:flex-row md:items-stretch">
              <%# Left Panel: Session details %>
              <div class="md:w-1/2 px-4 py-3 flex items-center gap-4">
                <%# Date Box %>
                <div class="flex-shrink-0 w-14 text-center">
                  <div class="text-xs font-semibold text-pink-600 uppercase"><%= session.start_at.strftime("%b") %></div>
                  <div class="text-2xl font-bold text-gray-900"><%= session.start_at.strftime("%-d") %></div>
                  <div class="text-xs text-gray-500"><%= session.start_at.strftime("%a") %></div>
                </div>
                <%# Session Details %>
                <div class="flex-1 min-w-0">
                  <div class="font-medium text-gray-900">
                    <%= session.start_at.strftime("%l:%M %p").strip %>
                  </div>
                  <div class="text-sm text-gray-600 truncate">
                    <% if session.location.present? %>
                      <%= session.location.name %>
                    <% else %>
                      No location
                    <% end %>
                  </div>
                </div>
              </div>

              <%# Right Panel: Scheduled auditionees %>
              <div class="md:w-1/2 px-4 py-3 md:border-l border-t md:border-t-0 border-gray-200 flex items-center gap-1 flex-wrap min-w-0">
                <% if scheduled_count.zero? %>
                  <span class="text-sm text-gray-400 italic">Empty</span>
                <% else %>
                  <% session_auditions.each do |audition| %>
                    <%
                      auditionable = audition.auditionable
                      next unless auditionable
                      headshot = auditionable.respond_to?(:safe_headshot_variant) ? auditionable.safe_headshot_variant(:thumb) : nil
                      request_path = audition.audition_request_id ? manage_signups_auditions_cycle_request_path(@production, @audition_cycle, audition.audition_request_id) : nil
                      click_handler = request_path ? "event.stopPropagation(); event.preventDefault(); window.location.href='#{request_path}'" : nil
                      status_dot_class = case audition.response_status
                                         when :accepted then "bg-green-500"
                                         when :pending  then "bg-yellow-400"
                                         end
                      tooltip_text = "#{auditionable.name} (#{audition.response_status.to_s.capitalize})"
                    %>
                    <div class="relative">
                      <% if headshot %>
                        <%= image_tag headshot,
                              class: "w-9 h-9 rounded-md object-cover cursor-pointer",
                              onclick: click_handler,
                              data: { controller: "tooltip", tooltip_text: tooltip_text } %>
                      <% else %>
                        <div class="w-9 h-9 rounded-md bg-gray-200 text-gray-700 flex items-center justify-center font-bold text-xs cursor-pointer"
                             onclick="<%= click_handler %>"
                             data-controller="tooltip"
                             data-tooltip-text="<%= tooltip_text %>">
                          <%= auditionable.respond_to?(:initials) ? auditionable.initials : auditionable.name.to_s[0..1].upcase %>
                        </div>
                      <% end %>
                      <% if status_dot_class %>
                        <span class="absolute -top-0.5 -right-0.5 w-2.5 h-2.5 rounded-full ring-2 ring-white <%= status_dot_class %>"></span>
                      <% end %>
                    </div>
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>
      <% else %>
        <p class="text-gray-500 text-sm">No sessions scheduled yet.</p>
      <% end %>
    </div>

    <!-- Action Buttons -->
    <div class="mt-3 flex flex-wrap gap-2">
      <% if @audition_sessions.any? %>
        <%= render "shared/button",
          text: "Schedule Auditionees",
          variant: "primary",
          size: "medium",
          icon: "user-group",
          path: manage_schedule_auditions_signups_auditions_cycle_path(@production, @audition_cycle) %>
      <% end %>
      <%= render "shared/button",
        text: "New Audition Session",
        variant: "secondary",
        size: "medium",
        type: :button,
        icon: "plus",
        data: {
          action: "click->audition-session-modal#openNewModal"
        } %>
    </div>
  </div>

  <%= render "modals" %>

</div>
