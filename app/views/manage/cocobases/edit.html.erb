<% content_for :title, "Edit Cocobase" %>

<div class="w-full mb-10">
  <%= render partial: "shared/notice", locals: { notice: notice } %>
  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      ["Shows & Events", manage_shows_path],
      [@production.name, manage_production_shows_path(@production)],
      [@show.event_type.titleize, manage_production_show_path(@production, @show)],
      ["Cocobase", manage_show_cocobase_path(@production, @show)]
    ],
    text: "Edit Cocobase",
    links: []
  } %>

  <div class="max-w-3xl mx-auto space-y-6">
    <!-- Settings -->
    <%= form_with model: @cocobase, url: manage_update_show_cocobase_path(@production, @show), method: :patch, class: "space-y-6" do |f| %>
      <div class="bg-white border border-gray-200 rounded-lg shadow-sm p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-1">Cocobase Settings</h2>
        <p class="text-sm text-gray-500 mb-6">Adjust the deadline and status for this show's Cocobase.</p>

        <!-- Status -->
        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
          <%= f.select :status, [["Open", "open"], ["Closed", "closed"]],
            {}, class: "w-40 rounded-lg border-gray-300 text-sm focus:ring-pink-500 focus:border-pink-500" %>
        </div>

        <!-- Deadline -->
        <div class="mb-6">
          <label class="block text-sm font-medium text-gray-700 mb-1">Submission deadline</label>
          <p class="text-xs text-gray-500 mb-2">When cast members should have their submissions in by.</p>
          <%= f.datetime_local_field :deadline,
            class: "rounded-lg border-gray-300 text-sm focus:ring-pink-500 focus:border-pink-500" %>
        </div>

        <div class="flex justify-end">
          <%= render "shared/button", text: "Save Settings", variant: "primary", size: "medium", type: :submit %>
        </div>
      </div>
    <% end %>

    <!-- Fields (per-show customizable) -->
    <div class="bg-white border border-gray-200 rounded-lg shadow-sm p-6">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="text-lg font-semibold text-gray-900">Fields</h2>
          <p class="text-sm text-gray-500">Customize fields for this specific show. Changes here don't affect the template.</p>
        </div>
      </div>

      <% if @fields.any? %>
        <div class="space-y-3 mb-6">
          <% @fields.each do |field| %>
            <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-lg border border-gray-200 group" data-field-id="<%= field.id %>">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <span class="text-sm font-medium text-gray-900"><%= field.label %></span>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-200 text-gray-600">
                    <%= { "text" => "Short text", "textarea" => "Long text", "file_upload" => "File upload", "url" => "URL / Link", "yesno" => "Yes / No" }[field.field_type] %>
                  </span>
                  <% if field.required? %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-pink-100 text-pink-700">Required</span>
                  <% end %>
                </div>
                <% if field.description.present? %>
                  <p class="text-xs text-gray-500 mt-0.5 truncate"><%= field.description %></p>
                <% end %>
              </div>

              <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                <%= link_to manage_destroy_show_cocobase_field_path(@production, @show, field),
                  data: { turbo_method: :delete, turbo_confirm: "Remove this field?" },
                  class: "p-1 text-gray-400 hover:text-red-500 rounded" do %>
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-6 text-gray-500 mb-6">
          <p class="text-sm">No fields defined. Add fields below.</p>
        </div>
      <% end %>

      <!-- Add Field Form -->
      <div class="border-t border-gray-200 pt-6">
        <h3 class="text-sm font-medium text-gray-700 mb-4">Add a field</h3>
        <%= form_with url: manage_create_show_cocobase_field_path(@production, @show), method: :post, class: "space-y-4" do |f| %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Label</label>
              <%= f.text_field :label, placeholder: "e.g., Performance Song", required: true,
                class: "w-full rounded-lg border-gray-300 text-sm focus:ring-pink-500 focus:border-pink-500" %>
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 mb-1">Type</label>
              <%= f.select :field_type,
                [["Short text", "text"], ["Long text", "textarea"], ["File upload", "file_upload"], ["URL / Link", "url"], ["Yes / No", "yesno"]],
                {}, class: "w-full rounded-lg border-gray-300 text-sm focus:ring-pink-500 focus:border-pink-500" %>
            </div>
          </div>
          <div>
            <label class="block text-xs font-medium text-gray-600 mb-1">Description / Instructions (optional)</label>
            <%= f.text_area :description, rows: 2, placeholder: "Describe what you'd like the performer to provide...",
              class: "w-full rounded-lg border-gray-300 text-sm focus:ring-pink-500 focus:border-pink-500" %>
          </div>
          <div class="flex items-center justify-between">
            <label class="flex items-center gap-2">
              <%= f.check_box :required, class: "h-4 w-4 text-pink-600 border-gray-300 rounded focus:ring-pink-500 accent-pink-500" %>
              <span class="text-sm text-gray-700">Required</span>
            </label>
            <%= render "shared/button", text: "Add Field", variant: "secondary", size: "small", type: :submit %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
