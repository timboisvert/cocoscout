<% content_for :title, "Finances" %>

<%
  format_cents = ->(cents) {
    negative = cents < 0
    abs = cents.abs
    dollars = abs / 100
    remainder = abs % 100
    formatted = "$#{number_with_delimiter(dollars)}.#{'%02d' % remainder}"
    negative ? "-#{formatted}" : formatted
  }

  periods = [
    ["All Time", "all_time"],
    ["This Month", "this_month"],
    ["Last Month", "last_month"],
    ["Last 30 Days", "last_30_days"],
    ["This Year", "this_year"]
  ]
%>

<div class="w-full px-5 pt-5">

  <%= render partial: "shared/notice", locals: { notice: notice } %>

  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      ["Superadmin", superadmin_path]
    ],
    text: "Finances",
    links: []
  } %>

  <!-- Period Filter -->
  <div class="flex flex-wrap gap-2 mt-4">
    <% periods.each do |label, value| %>
      <%= link_to label, finances_path(period: value),
          class: "px-3 py-1.5 text-sm font-medium rounded-full transition-colors #{@period == value ? 'bg-pink-500 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}" %>
    <% end %>
  </div>

  <% if @missing_stripe_fee_count > 0 %>
    <div class="mt-4 p-3 bg-blue-50 border border-blue-200 rounded-lg flex items-start gap-2">
      <svg class="w-5 h-5 text-blue-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <div class="text-sm text-blue-800">
        <strong><%= @missing_stripe_fee_count %> registration<%= @missing_stripe_fee_count == 1 ? '' : 's' %></strong> backfilling Stripe fee data.
        This runs automatically every hour and will be complete shortly.
      </div>
    </div>
  <% end %>

  <!-- Summary Cards -->
  <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mt-4">
    <!-- Gross Revenue -->
    <div class="border border-gray-200 rounded-lg p-4">
      <div class="text-xs text-gray-500 font-medium uppercase tracking-wide">Gross Course Revenue</div>
      <div class="text-2xl font-bold text-gray-900 mt-1"><%= format_cents.call(@gross_revenue_cents) %></div>
      <div class="text-xs text-gray-400 mt-1">Total paid by students</div>
    </div>

    <!-- CocoScout Fees -->
    <div class="border border-gray-200 rounded-lg p-4">
      <div class="text-xs text-gray-500 font-medium uppercase tracking-wide">CocoScout Fees Earned</div>
      <div class="text-2xl font-bold text-green-600 mt-1"><%= format_cents.call(@cocoscout_fees_cents) %></div>
      <div class="text-xs text-gray-400 mt-1">5% platform fee</div>
    </div>

    <!-- Stripe Fees -->
    <div class="border border-gray-200 rounded-lg p-4">
      <div class="text-xs text-gray-500 font-medium uppercase tracking-wide">Stripe Fees Paid</div>
      <div class="text-2xl font-bold text-red-600 mt-1"><%= format_cents.call(@stripe_fees_cents) %></div>
      <div class="text-xs text-gray-400 mt-1">2.9% + 30¢ per txn</div>
    </div>

    <!-- Net Income -->
    <div class="border border-gray-200 rounded-lg p-4">
      <div class="text-xs text-gray-500 font-medium uppercase tracking-wide">Net Income</div>
      <div class="text-2xl font-bold <%= @net_income_cents >= 0 ? 'text-green-600' : 'text-red-600' %> mt-1"><%= format_cents.call(@net_income_cents) %></div>
      <div class="text-xs text-gray-400 mt-1">Fees earned − Stripe costs</div>
    </div>

    <!-- Registrations -->
    <div class="border border-gray-200 rounded-lg p-4">
      <div class="text-xs text-gray-500 font-medium uppercase tracking-wide">Registrations</div>
      <div class="text-2xl font-bold text-gray-900 mt-1"><%= number_with_delimiter(@total_registrations) %></div>
      <% if @waived_count > 0 %>
        <div class="text-xs text-amber-600 mt-1"><%= @waived_count %> fee-waived</div>
      <% else %>
        <div class="text-xs text-gray-400 mt-1">Confirmed payments</div>
      <% end %>
    </div>
  </div>

  <!-- Transaction Table -->
  <div class="mt-6 border border-gray-200 rounded-lg overflow-hidden">
    <%= render "shared/card_header", title: "Transactions" %>

    <%# Organization Obligations %>
    <% if @org_obligations.any? %>
      <div class="mt-6 border border-gray-200 rounded-lg overflow-hidden">
        <% total_owed = @org_obligations.sum { |o| o[:owed_cents] } %>
        <% total_paid = @org_obligations.sum { |o| o[:paid_cents] } %>
        <% total_balance = total_owed - total_paid %>

        <%= render "shared/card_header", title: "Organization Obligations" %>

        <%# Obligation summary cards %>
        <div class="grid grid-cols-3 gap-4 p-4 border-b border-gray-200 bg-gray-50">
          <div class="text-center">
            <div class="text-xs text-gray-500 font-medium uppercase tracking-wide">Total Owed</div>
            <div class="text-xl font-bold text-gray-900 mt-1"><%= format_cents.call(total_owed) %></div>
          </div>
          <div class="text-center">
            <div class="text-xs text-gray-500 font-medium uppercase tracking-wide">Total Paid</div>
            <div class="text-xl font-bold text-green-600 mt-1"><%= format_cents.call(total_paid) %></div>
          </div>
          <div class="text-center">
            <div class="text-xs text-gray-500 font-medium uppercase tracking-wide">Outstanding</div>
            <div class="text-xl font-bold <%= total_balance > 0 ? 'text-red-600' : 'text-green-600' %> mt-1"><%= format_cents.call(total_balance) %></div>
          </div>
        </div>

        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Organization</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Courses</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Gross Revenue</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Owed (95%)</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Paid</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Balance</th>
                <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider"></th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <% @org_obligations.each do |obl| %>
                <tr>
                  <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= obl[:org].name %></td>
                  <td class="px-4 py-3 text-sm text-gray-600 text-right"><%= obl[:course_count] %></td>
                  <td class="px-4 py-3 text-sm text-gray-900 text-right"><%= format_cents.call(obl[:gross_cents]) %></td>
                  <td class="px-4 py-3 text-sm text-gray-900 text-right"><%= format_cents.call(obl[:owed_cents]) %></td>
                  <td class="px-4 py-3 text-sm text-green-600 text-right font-medium"><%= format_cents.call(obl[:paid_cents]) %></td>
                  <td class="px-4 py-3 text-sm text-right font-bold <%= obl[:balance_cents] > 0 ? 'text-red-600' : 'text-green-600' %>">
                    <%= format_cents.call(obl[:balance_cents]) %>
                  </td>
                  <td class="px-4 py-3 text-right">
                    <%= link_to finances_org_detail_path(org_id: obl[:org].id) do %>
                      <%= render "shared/button", text: "Details", variant: "secondary", size: "small" %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>

  <%# CocoScout Income Transactions (existing) %>
  <div class="mt-6 border border-gray-200 rounded-lg overflow-hidden">
    <%= render "shared/card_header", title: "CocoScout Income Transactions" %>

    <% if @rows.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Course</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Organization</th>
              <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Student</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">CocoScout Fee</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Stripe Fee</th>
              <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Net</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% @rows.each do |row| %>
              <% reg = row[:registration] %>
              <tr>
                <td class="px-4 py-3 whitespace-nowrap text-sm text-gray-600">
                  <%= reg.paid_at&.strftime("%b %-d, %Y") || "—" %>
                </td>
                <td class="px-4 py-3 text-sm text-gray-900 max-w-xs truncate">
                  <%= reg.course_offering.title %>
                </td>
                <td class="px-4 py-3 text-sm text-gray-600 max-w-xs truncate">
                  <%= reg.course_offering.organization&.name || "—" %>
                </td>
                <td class="px-4 py-3 text-sm text-gray-600 whitespace-nowrap">
                  <%= reg.person.name %>
                </td>
                <td class="px-4 py-3 text-sm text-gray-900 text-right whitespace-nowrap font-medium">
                  <%= format_cents.call(row[:amount_cents]) %>
                </td>
                <td class="px-4 py-3 text-sm text-right whitespace-nowrap">
                  <% if row[:waived] %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-800">Waived</span>
                  <% else %>
                    <span class="text-green-600 font-medium"><%= format_cents.call(row[:cocoscout_fee_cents]) %></span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-sm text-right whitespace-nowrap font-medium">
                  <% if row[:stripe_fee_cents].nil? %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-500">Pending</span>
                  <% else %>
                    <span class="text-red-600"><%= format_cents.call(row[:stripe_fee_cents]) %></span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-sm text-right whitespace-nowrap font-bold">
                  <% if row[:stripe_fee_cents].nil? %>
                    <span class="text-gray-400">—</span>
                  <% else %>
                    <span class="<%= row[:net_cents] >= 0 ? 'text-green-600' : 'text-red-600' %>"><%= format_cents.call(row[:net_cents]) %></span>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
          <tfoot class="bg-gray-50">
            <tr class="font-semibold">
              <td class="px-4 py-3 text-sm text-gray-900" colspan="4">Totals</td>
              <td class="px-4 py-3 text-sm text-gray-900 text-right"><%= format_cents.call(@gross_revenue_cents) %></td>
              <td class="px-4 py-3 text-sm text-green-600 text-right"><%= format_cents.call(@cocoscout_fees_cents) %></td>
              <td class="px-4 py-3 text-sm text-red-600 text-right"><%= format_cents.call(@stripe_fees_cents) %></td>
              <td class="px-4 py-3 text-sm text-right <%= @net_income_cents >= 0 ? 'text-green-600' : 'text-red-600' %>"><%= format_cents.call(@net_income_cents) %></td>
            </tr>
          </tfoot>
        </table>
      </div>
    <% else %>
      <div class="p-8 text-center text-gray-500">
        <p class="text-sm">No confirmed registrations found for this period.</p>
      </div>
    <% end %>
  </div>
</div>
