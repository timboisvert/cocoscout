<% content_for :title, "Edit #{@course_offering.title}" %>

<div class="w-full pb-24" data-controller="tabs instructor-search"
     data-tabs-initial-tab-value="<%= params[:tab].to_i %>"
     data-instructor-search-search-url-value="<%= manage_course_offering_search_instructor_path(@course_offering) %>"
     data-instructor-search-invite-url-value="<%= manage_course_offering_invite_instructor_path(@course_offering) %>"
     <% current_person = Current.user&.person %>
     <% current_person_headshot = current_person&.safe_headshot_variant(:thumb) %>
     <% if current_person %>
     data-instructor-search-current-person-id-value="<%= current_person.id %>"
     data-instructor-search-current-person-name-value="<%= current_person.name %>"
     data-instructor-search-current-person-email-value="<%= current_person.email %>"
     data-instructor-search-current-person-headshot-url-value="<%= current_person_headshot ? url_for(current_person_headshot) : '' %>"
     <% end %>>

  <%= render partial: "shared/notice", locals: { notice: notice, alert: alert } %>

  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      ["Courses", manage_course_offerings_path],
      [@course_offering.title, manage_course_offering_path(@course_offering)]
    ],
    text: "Edit",
    links: []
  } %>

  <%# Tab Navigation %>
  <nav class="flex space-x-2 border-b border-gray-200 mb-6 overflow-x-auto">
    <button type="button" data-tabs-target="tab" data-index="0" data-action="tabs#select" class="px-4 py-2 text-sm font-medium border-b-2 cursor-pointer whitespace-nowrap">Basics</button>
    <button type="button" data-tabs-target="tab" data-index="1" data-action="tabs#select" class="px-4 py-2 text-sm font-medium border-b-2 cursor-pointer whitespace-nowrap">Instructor</button>
    <button type="button" data-tabs-target="tab" data-index="2" data-action="tabs#select" class="px-4 py-2 text-sm font-medium border-b-2 cursor-pointer whitespace-nowrap">Sessions</button>
    <button type="button" data-tabs-target="tab" data-index="3" data-action="tabs#select" class="px-4 py-2 text-sm font-medium border-b-2 cursor-pointer whitespace-nowrap">Pricing</button>
    <button type="button" data-tabs-target="tab" data-index="4" data-action="tabs#select" class="px-4 py-2 text-sm font-medium border-b-2 cursor-pointer whitespace-nowrap">Details</button>
  </nav>

  <%# ==================== TAB 0: BASICS ==================== %>
  <div data-tabs-target="panel">
    <%= form_with model: @course_offering, url: manage_course_offering_path(@course_offering), method: :patch, local: true, class: "space-y-6" do |form| %>
      <%= hidden_field_tag :tab, "0" %>

      <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
        <%= render "shared/card_header", title: "Course Title & Description" %>
        <div class="p-5 space-y-5">
          <div>
            <label for="course_offering_title" class="block text-sm font-medium text-gray-900 mb-1.5">
              Course Title <span class="text-pink-500">*</span>
            </label>
            <%= form.text_field :title, required: true,
                placeholder: "e.g., Intro to Improv - Spring 2025",
                class: "block w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition" %>
          </div>

          <div>
            <label for="course_offering_subtitle" class="block text-sm font-medium text-gray-900 mb-1.5">
              Subtitle
            </label>
            <%= form.text_field :subtitle,
                placeholder: "e.g., A 6-week course for beginners",
                class: "block w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition" %>
          </div>

          <div>
            <label for="course_offering_description" class="block text-sm font-medium text-gray-900 mb-1.5">
              Description
            </label>
            <p class="text-xs text-gray-500 mb-2">Describe what students will learn — this is shown on the public registration page.</p>
            <%= form.rich_text_area :description, class: "w-full min-h-[150px]" %>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <%= render "shared/button", text: "Save Basics", variant: "primary", size: "medium", type: :submit %>
      </div>
    <% end %>
  </div>

  <%# ==================== TAB 1: INSTRUCTOR ==================== %>
  <div data-tabs-target="panel" class="hidden">
    <div class="space-y-6">
      <%= form_with url: manage_course_offering_update_instructor_path(@course_offering), method: :post, local: true, multipart: true, class: "space-y-6", id: "instructor-form" do |form| %>

        <%# Instructor Selection Card %>
        <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
          <%= render "shared/card_header", title: "Instructors" %>
          <div class="p-5">

            <%# Hidden inputs container for selected instructor IDs %>
            <%
              coi_by_person = @course_offering.course_offering_instructors.index_by(&:person_id)
            %>
            <div data-instructor-search-target="personIdsContainer">
              <% (@instructor_people || []).each do |person| %>
                <% headshot_variant = person.safe_headshot_variant(:thumb) %>
                <% coi = coi_by_person[person.id] %>
                <input type="hidden" name="instructor_person_ids[]"
                       value="<%= person.id %>"
                       data-name="<%= person.name %>"
                       data-email="<%= person.email %>"
                       data-headshot-url="<%= headshot_variant ? url_for(headshot_variant) : '' %>"
                       data-bio="<%= CGI.escapeHTML(coi&.bio&.body&.to_s || '') %>"
                       data-has-existing-headshot="<%= coi&.headshot&.attached? ? 'true' : 'false' %>">
              <% end %>
            </div>

            <%# Selected instructors list with per-instructor bio/headshot %>
            <div data-instructor-search-target="selectedList"
                 class="space-y-3 mb-4 <%= 'hidden' if (@instructor_people || []).empty? %>">
              <label class="block text-sm font-medium text-gray-900 mb-1.5">Current Instructors</label>
              <% (@instructor_people || []).each do |person| %>
                <% coi = coi_by_person[person.id] %>
                <div class="border border-gray-200 bg-white rounded-lg shadow-sm overflow-hidden">
                  <div class="flex items-center gap-3 px-4 py-3 bg-gray-50 border-b border-gray-100">
                    <% headshot_variant = person.safe_headshot_variant(:thumb) %>
                    <% if headshot_variant %>
                      <%= image_tag headshot_variant, alt: person.name, class: "w-10 h-10 rounded-lg object-cover flex-shrink-0" %>
                    <% else %>
                      <div class="w-10 h-10 rounded-lg bg-pink-100 flex items-center justify-center text-pink-700 font-bold text-xs flex-shrink-0">
                        <%= person.initials %>
                      </div>
                    <% end %>
                    <div class="flex-grow min-w-0">
                      <div class="font-medium text-sm text-gray-900"><%= person.name %></div>
                      <% if person.email.present? %>
                        <div class="text-xs text-gray-500"><%= person.email %></div>
                      <% end %>
                    </div>
                    <button type="button"
                            data-action="instructor-search#removeInstructor"
                            data-person-id="<%= person.id %>"
                            class="text-gray-400 hover:text-red-500 cursor-pointer flex-shrink-0 p-1"
                            title="Remove instructor">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                      </svg>
                    </button>
                  </div>
                  <div class="p-4 space-y-4">
                    <div>
                      <label class="block text-xs font-medium text-gray-700 mb-1.5">Alternate Photo</label>
                      <% if coi&.headshot&.attached? %>
                        <div class="mb-2 flex items-center gap-2">
                          <%= image_tag coi.headshot.variant(resize_to_fill: [80, 80]), alt: "#{person.name} photo", class: "w-10 h-10 rounded-lg object-cover" %>
                          <span class="text-xs text-green-600">Alternate photo uploaded</span>
                        </div>
                      <% end %>
                      <input type="file" name="instructor_headshots[<%= person.id %>]" accept="image/*"
                             class="block w-full text-xs text-gray-500 file:mr-3 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-medium file:bg-pink-50 file:text-pink-700 hover:file:bg-pink-100 cursor-pointer">
                      <p class="text-[11px] text-gray-400 mt-1">Overrides their profile photo on the registration page.</p>
                    </div>
                    <div>
                      <label class="block text-xs font-medium text-gray-700 mb-1.5">Bio</label>
                      <%= rich_text_area_tag "instructor_bios[#{person.id}]", coi&.bio&.body %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>

            <%# Quick self-select button %>
            <% if current_person %>
              <% already_selected = (@instructor_people || []).any? { |p| p.id == current_person.id } %>
              <button type="button"
                      data-action="instructor-search#selectSelf"
                      class="w-full flex items-center gap-3 p-3 border-2 border-dashed border-gray-300 rounded-lg hover:border-pink-400 hover:bg-pink-50 transition cursor-pointer mb-4 <%= 'hidden' if already_selected %>">
                <% if current_person_headshot %>
                  <%= image_tag current_person_headshot, alt: current_person.name, class: "w-8 h-8 rounded-lg object-cover flex-shrink-0" %>
                <% else %>
                  <div class="w-8 h-8 rounded-lg bg-pink-100 flex items-center justify-center text-pink-700 font-bold text-xs flex-shrink-0">
                    <%= current_person.initials %>
                  </div>
                <% end %>
                <span class="text-sm font-medium text-gray-700">I'm the instructor</span>
              </button>
            <% end %>

            <%# Search section (always visible) %>
            <div data-instructor-search-target="searchSection">
              <label for="instructor_search" class="block text-sm font-medium text-gray-900 mb-1.5">
                <% if (@instructor_people || []).any? %>
                  Add Another Instructor
                <% else %>
                  Search for Instructor
                <% end %>
              </label>
              <input type="text" id="instructor_search"
                     data-instructor-search-target="searchInput"
                     data-action="input->instructor-search#search"
                     placeholder="Search by name or email..."
                     autocomplete="off"
                     class="block w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition">

              <div data-instructor-search-target="searchResults" class="mt-3 max-h-80 overflow-y-auto"></div>
            </div>
          </div>
        </div>

        <%# Instructor Preface (shown when 2+ instructors) %>
        <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden <%= 'hidden' if (@instructor_people || []).size < 2 %>"
             data-instructor-search-target="prefaceSection">
          <%= render "shared/card_header", title: "Instructor Preface" %>
          <div class="p-5">
            <p class="text-xs text-gray-500 mb-2">Optional paragraph shown above the instructor cards on the registration page. Useful for describing the group of instructors together.</p>
            <%= rich_text_area_tag "course_offering[instructor_preface]", @course_offering.instructor_preface&.body %>
          </div>
        </div>

        <%# Group Photo %>
        <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden"
             data-instructor-search-target="groupPhotoSection"
             style="<%= 'display:none' if (@instructor_people || []).empty? %>">
          <%= render "shared/card_header", title: "Group Photo" %>
          <div class="p-5">
            <p class="text-xs text-gray-500 mb-2">Optional shared photo shown at the top of the instructor section (enable via display options below).</p>
            <% if @course_offering.group_photo.attached? %>
              <div class="mb-3 flex items-center gap-3">
                <%= image_tag @course_offering.group_photo.variant(resize_to_limit: [200, 200]), alt: "Group photo", class: "w-16 h-16 rounded-lg object-cover" %>
                <span class="text-xs text-green-600">Group photo uploaded</span>
              </div>
            <% end %>
            <input type="file" name="group_photo" accept="image/*"
                   class="block w-full text-xs text-gray-500 file:mr-3 file:py-1.5 file:px-3 file:rounded-md file:border-0 file:text-xs file:font-medium file:bg-pink-50 file:text-pink-700 hover:file:bg-pink-100 cursor-pointer">
          </div>
        </div>

        <%# Add to Production Team toggle %>
        <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden"
             data-instructor-search-target="teamToggleSection"
             style="<%= 'display:none' if (@instructor_people || []).empty? %>">

          <%# Instructor Display Options %>
          <%= render "shared/card_header", title: "Instructor Display Options" %>
          <div class="p-5">
            <p class="text-xs text-gray-500 mb-3">Choose how instructors appear on the course registration page.</p>
            <div class="space-y-3">
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input type="hidden" name="show_individual_photos" value="0">
                <input type="checkbox" name="show_individual_photos" value="1"
                       <%= 'checked' if @course_offering.show_individual_photos? %>
                       class="h-4 w-4 text-pink-600 border-gray-300 rounded focus:ring-pink-500 accent-pink-500">
                <span class="text-sm text-gray-700">Show individual instructor photos</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input type="hidden" name="show_individual_bios" value="0">
                <input type="checkbox" name="show_individual_bios" value="1"
                       <%= 'checked' if @course_offering.show_individual_bios? %>
                       class="h-4 w-4 text-pink-600 border-gray-300 rounded focus:ring-pink-500 accent-pink-500">
                <span class="text-sm text-gray-700">Show individual instructor bios</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input type="hidden" name="show_group_photo" value="0">
                <input type="checkbox" name="show_group_photo" value="1"
                       <%= 'checked' if @course_offering.show_group_photo? %>
                       class="h-4 w-4 text-pink-600 border-gray-300 rounded focus:ring-pink-500 accent-pink-500">
                <span class="text-sm text-gray-700">Show group photo</span>
              </label>
              <label class="flex items-center gap-2.5 cursor-pointer">
                <input type="hidden" name="show_group_bio" value="0">
                <input type="checkbox" name="show_group_bio" value="1"
                       <%= 'checked' if @course_offering.show_group_bio? %>
                       class="h-4 w-4 text-pink-600 border-gray-300 rounded focus:ring-pink-500 accent-pink-500">
                <span class="text-sm text-gray-700">Show group bio (preface text above instructor cards)</span>
              </label>
            </div>
          </div>

          <%# Production Team Toggle %>
          <%= render "shared/card_header", title: "Production Team" %>
          <div class="p-5">
            <div class="flex items-center justify-between">
              <div>
                <span class="text-sm font-medium text-gray-900">Add to production team</span>
                <p class="text-xs text-gray-500 mt-0.5">Add the instructors to the production team for this course. Production team members can view registrations, view registration notifications, and manage students.</p>
              </div>
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="hidden" name="instructor_on_team" value="0">
                <input type="checkbox" name="instructor_on_team" value="1"
                       <%= 'checked' if @course_offering.instructor_on_team? %>
                       class="sr-only peer">
                <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-pink-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-pink-500"></div>
              </label>
            </div>
          </div>
        </div>

        <div class="flex items-center gap-3">
          <%= render "shared/button", text: "Save Instructors", variant: "primary", size: "medium", type: :submit %>
        </div>
      <% end %>
    </div>
  </div>

  <%# ==================== TAB 2: SESSIONS ==================== %>
  <div data-tabs-target="panel" class="hidden">
    <div class="space-y-6">
      <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
        <%= render "shared/card_header", title: "Class Sessions" %>
        <div class="p-5">
          <p class="text-sm text-gray-600 mb-4">
            Sessions are managed as events on this course's production.
            You can edit dates, times, locations, and other details from the shows page.
          </p>

          <% if @sessions.any? %>
            <div class="space-y-2">
              <% @sessions.each do |show| %>
                <div class="flex items-center gap-3 py-2 px-3 border border-gray-100 rounded-lg hover:bg-gray-50">
                  <div class="flex-shrink-0 w-10 h-10 bg-pink-50 border border-pink-100 rounded-md flex flex-col items-center justify-center">
                    <span class="text-[10px] font-medium text-pink-600 uppercase leading-none"><%= show.date_and_time.strftime("%b") %></span>
                    <span class="text-sm font-bold text-pink-700 leading-tight"><%= show.date_and_time.strftime("%-d") %></span>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-900">
                      <%= show.date_and_time.strftime("%A, %B %-d, %Y") %>
                    </p>
                    <p class="text-xs text-gray-500">
                      <%= show.date_and_time.strftime("%-I:%M %p") %>
                      <% if show.duration_minutes.present? %>
                        &middot; <%= show.duration_minutes %> min
                      <% end %>
                      <% if show.location.present? %>
                        &middot; <%= show.location.name %>
                      <% end %>
                    </p>
                  </div>
                  <% if show.secondary_name.present? %>
                    <span class="text-xs text-gray-400"><%= show.secondary_name %></span>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-400 italic">No sessions scheduled yet.</p>
          <% end %>
        </div>
      </div>

      <%# Add new sessions %>
      <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
        <%= render "shared/card_header", title: "Add Sessions" %>
        <div class="p-5">
          <p class="text-sm text-gray-600 mb-3">Add single sessions or a recurring series to this course.</p>

          <%= form_with url: manage_course_offering_add_sessions_path(@course_offering), method: :post, local: true do %>
            <div data-controller="course-sessions">
              <input type="hidden" name="session_rules_json" data-course-sessions-target="rulesJson" value="">

              <div data-course-sessions-target="sessionsList" class="space-y-3"></div>

              <div class="flex gap-3 mt-3">
                <button type="button" data-action="click->course-sessions#addSingleSession"
                        class="flex-1 py-2.5 border-2 border-dashed border-gray-300 rounded-lg text-sm font-medium text-gray-600 hover:border-pink-400 hover:text-pink-600 transition flex items-center justify-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                  </svg>
                  Add Single Session
                </button>
                <button type="button" data-action="click->course-sessions#addRecurringSeries"
                        class="flex-1 py-2.5 border-2 border-dashed border-gray-300 rounded-lg text-sm font-medium text-gray-600 hover:border-pink-400 hover:text-pink-600 transition flex items-center justify-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" stroke-width="1.5"/>
                  </svg>
                  Add Recurring Series
                </button>
              </div>

              <%# Single session template %>
              <template data-course-sessions-target="singleTemplate">
                <div class="session-item bg-gray-50 border border-gray-200 rounded-lg p-4 space-y-3" data-session-type="single">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2">
                      <div class="w-7 h-7 rounded-lg bg-pink-100 flex items-center justify-center flex-shrink-0">
                        <svg class="w-3.5 h-3.5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                      </div>
                      <span class="text-sm font-medium text-gray-900">Single Session</span>
                    </div>
                    <button type="button" data-action="click->course-sessions#removeSession" class="text-gray-400 hover:text-red-500 transition p-1">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                      </svg>
                    </button>
                  </div>
                  <div class="grid grid-cols-2 gap-3">
                    <div>
                      <label class="block text-xs font-medium text-gray-700 mb-1">Date & Time</label>
                      <input type="datetime-local" data-field="datetime"
                             data-action="change->course-sessions#inputChanged"
                             class="block w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition">
                    </div>
                    <div>
                      <label class="block text-xs font-medium text-gray-700 mb-1">Duration</label>
                      <select data-field="duration"
                              data-action="change->course-sessions#inputChanged"
                              class="block w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition">
                        <option value="30">30 minutes</option>
                        <option value="60" selected>1 hour</option>
                        <option value="90">1 hour 30 minutes</option>
                        <option value="120">2 hours</option>
                        <option value="180">3 hours</option>
                        <option value="240">4 hours</option>
                        <option value="300">5 hours</option>
                        <option value="360">6 hours</option>
                        <option value="420">7 hours</option>
                        <option value="480">8 hours</option>
                      </select>
                    </div>
                  </div>
                </div>
              </template>

              <%# Recurring series template %>
              <template data-course-sessions-target="recurringTemplate">
                <div class="session-item bg-gray-50 border border-gray-200 rounded-lg p-4 space-y-3" data-session-type="recurring">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2">
                      <div class="w-7 h-7 rounded-lg bg-pink-100 flex items-center justify-center flex-shrink-0">
                        <svg class="w-3.5 h-3.5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"/>
                        </svg>
                      </div>
                      <span class="text-sm font-medium text-gray-900">Recurring Series</span>
                    </div>
                    <button type="button" data-action="click->course-sessions#removeSession" class="text-gray-400 hover:text-red-500 transition p-1">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                      </svg>
                    </button>
                  </div>
                  <div class="grid grid-cols-2 gap-3">
                    <div>
                      <label class="block text-xs font-medium text-gray-700 mb-1">Frequency</label>
                      <select data-field="frequency"
                              data-action="change->course-sessions#inputChanged"
                              class="block w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition">
                        <option value="weekly" selected>Weekly</option>
                        <option value="biweekly">Every 2 weeks</option>
                      </select>
                    </div>
                    <div>
                      <label class="block text-xs font-medium text-gray-700 mb-1">Day of Week</label>
                      <select data-field="day_of_week"
                              data-action="change->course-sessions#inputChanged"
                              class="block w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition">
                        <option value="0">Sunday</option>
                        <option value="1" selected>Monday</option>
                        <option value="2">Tuesday</option>
                        <option value="3">Wednesday</option>
                        <option value="4">Thursday</option>
                        <option value="5">Friday</option>
                        <option value="6">Saturday</option>
                      </select>
                    </div>
                  </div>
                  <div class="grid grid-cols-2 gap-3">
                    <div>
                      <label class="block text-xs font-medium text-gray-700 mb-1">Time</label>
                      <input type="time" data-field="time" value="19:00"
                             data-action="change->course-sessions#inputChanged"
                             class="block w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition">
                    </div>
                    <div>
                      <label class="block text-xs font-medium text-gray-700 mb-1">Duration</label>
                      <select data-field="duration"
                              data-action="change->course-sessions#inputChanged"
                              class="block w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition">
                        <option value="30">30 minutes</option>
                        <option value="60" selected>1 hour</option>
                        <option value="90">1 hour 30 minutes</option>
                        <option value="120">2 hours</option>
                        <option value="180">3 hours</option>
                        <option value="240">4 hours</option>
                        <option value="300">5 hours</option>
                        <option value="360">6 hours</option>
                        <option value="420">7 hours</option>
                        <option value="480">8 hours</option>
                      </select>
                    </div>
                  </div>
                  <div class="grid grid-cols-2 gap-3">
                    <div>
                      <label class="block text-xs font-medium text-gray-700 mb-1">Start Date</label>
                      <input type="date" data-field="start_date" value="<%= Date.current.to_s %>"
                             data-action="change->course-sessions#inputChanged"
                             class="block w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition">
                    </div>
                    <div>
                      <label class="block text-xs font-medium text-gray-700 mb-1">Until</label>
                      <input type="date" data-field="end_date" value="<%= (Date.current + 3.months).to_s %>"
                             data-action="change->course-sessions#inputChanged"
                             class="block w-full px-3 py-2 bg-white border border-gray-300 rounded-lg shadow-sm text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition">
                    </div>
                  </div>
                </div>
              </template>
            </div>

            <div class="mt-4">
              <%= render "shared/button", text: "Add Sessions", variant: "primary", size: "medium", type: :submit %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <%= link_to manage_production_shows_path(@course_offering.production) do %>
          <%= render "shared/button", text: "Manage Sessions", variant: "secondary", size: "medium" %>
        <% end %>
      </div>
    </div>
  </div>

  <%# ==================== TAB 3: PRICING ==================== %>
  <div data-tabs-target="panel" class="hidden">
    <%= form_with model: @course_offering, url: manage_course_offering_path(@course_offering), method: :patch, local: true, class: "space-y-6" do |form| %>
      <%= hidden_field_tag :tab, "3" %>

      <div data-controller="fee-calculator"
           data-fee-calculator-validate-url-value="<%= manage_course_validate_promo_code_path %>"
           data-fee-calculator-promo-applied-value="<%= @course_offering.feature_credit_redemption.present? %>">

        <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
          <%= render "shared/card_header", title: "Pricing" %>
          <div class="p-5 space-y-5">
            <div>
              <label for="course_offering_price_dollars" class="block text-sm font-medium text-gray-900 mb-1.5">
                Registration Price <span class="text-pink-500">*</span>
              </label>
              <div class="relative w-48">
                <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500 pointer-events-none">$</span>
                <%= number_field_tag "course_offering[price_dollars]",
                    @course_offering.price_cents.present? ? format("%.2f", @course_offering.price_cents / 100.0) : nil,
                    min: 0, step: 0.01,
                    placeholder: "150.00",
                    data: { fee_calculator_target: "priceInput", action: "input->fee-calculator#calculate" },
                    class: "block w-full pl-7 px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition" %>
              </div>
              <p class="text-xs text-gray-400 mt-1">plus applicable tax</p>
            </div>

            <div class="border-t border-gray-200 pt-5" data-fee-calculator-target="earlyBirdSection"
                 <% unless @course_offering.price_cents.present? && @course_offering.price_cents > 0 %>style="display:none"<% end %>>
              <%
                first_session = @sessions.first
                first_session_iso = first_session&.date_and_time&.iso8601
              %>
              <div class="flex items-center justify-between mb-3">
                <span class="text-sm font-medium text-gray-900">Also offer early bird pricing</span>
                <label class="relative inline-flex items-center cursor-pointer">
                  <input type="checkbox" id="enable_early_bird"
                         <%= 'checked' if @course_offering.early_bird_price_cents.present? %>
                         class="sr-only peer"
                         data-first-session="<%= first_session_iso %>"
                         onchange="
                           var fields = document.getElementById('early-bird-fields');
                           var hint = document.getElementById('early-bird-auto-hint');
                           fields.classList.toggle('hidden', !this.checked);
                           if (!this.checked) {
                             fields.querySelectorAll('input').forEach(function(i) { i.value = ''; });
                             if (hint) hint.style.display = 'none';
                           } else {
                             var deadlineField = document.getElementById('course_offering_early_bird_deadline');
                             if (deadlineField && !deadlineField.value && this.dataset.firstSession) {
                               var now = new Date();
                               var firstSession = new Date(this.dataset.firstSession);
                               var midpoint = new Date(now.getTime() + (firstSession.getTime() - now.getTime()) / 2);
                               midpoint.setHours(23, 59, 0, 0);
                               var y = midpoint.getFullYear();
                               var m = String(midpoint.getMonth() + 1).padStart(2, '0');
                               var d = String(midpoint.getDate()).padStart(2, '0');
                               deadlineField.value = y + '-' + m + '-' + d + 'T23:59';
                               if (hint) hint.style.display = 'block';
                             }
                           }
                         ">
                  <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-pink-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-pink-500"></div>
                </label>
              </div>
              <div id="early-bird-fields" class="<%= 'hidden' unless @course_offering.early_bird_price_cents.present? %>">
                <div class="grid grid-cols-2 gap-4">
                  <div>
                    <label for="course_offering_early_bird_price_dollars" class="block text-sm font-medium text-gray-700 mb-1.5">
                      Early Bird Price
                    </label>
                    <div class="relative">
                      <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-gray-500 pointer-events-none">$</span>
                      <%= number_field_tag "course_offering[early_bird_price_dollars]",
                          @course_offering.early_bird_price_cents.present? ? format("%.2f", @course_offering.early_bird_price_cents / 100.0) : nil,
                          min: 0, step: 0.01,
                          placeholder: "120.00",
                          data: { fee_calculator_target: "earlyBirdInput", action: "input->fee-calculator#calculate" },
                          class: "block w-full pl-7 px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition" %>
                    </div>
                    <p class="text-xs text-gray-400 mt-1">plus applicable tax</p>
                  </div>
                  <div>
                    <label for="course_offering_early_bird_deadline" class="block text-sm font-medium text-gray-700 mb-1.5">
                      Early Bird Deadline
                    </label>
                    <%= form.datetime_local_field :early_bird_deadline,
                        class: "block w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition" %>
                    <p id="early-bird-auto-hint" class="text-xs text-gray-400 mt-1" style="display:none">
                      We've selected a date halfway between now and the start of your course. Feel free to change it.
                    </p>
                  </div>
                </div>
              </div>
            </div>

          </div>
        </div>

        <%# Processing & Fees card %>
        <div class="mt-6 bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
          <%= render "shared/card_header", title: "Processing & Fees" %>
          <div class="p-5">
            <% existing_promo = @course_offering.feature_credit_redemption&.feature_credit&.code %>
            <% existing_coverage = @course_offering.feature_credit_redemption&.feature_credit&.coverage_type || "none" %>
            <%= render "manage/course_offerings/fee_breakdown",
                       promo_code: existing_promo,
                       promo_field_name: "course_offering[promo_code]",
                       promo_coverage_type: existing_promo.present? ? existing_coverage : "none" %>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <%= render "shared/button", text: "Save Pricing", variant: "primary", size: "medium", type: :submit %>
      </div>
    <% end %>
  </div>

  <%# ==================== TAB 4: DETAILS ==================== %>
  <div data-tabs-target="panel" class="hidden">
    <%= form_with model: @course_offering, url: manage_course_offering_path(@course_offering), method: :patch, local: true, class: "space-y-6" do |form| %>
      <%= hidden_field_tag :tab, "4" %>

      <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
        <%= render "shared/card_header", title: "Capacity" %>
        <div class="p-5">
          <label for="course_offering_capacity" class="block text-sm font-medium text-gray-900 mb-1.5">
            Max Registrations
          </label>
          <p class="text-xs text-gray-500 mb-2">Leave blank for unlimited spots.</p>
          <%= form.number_field :capacity, min: 1,
              placeholder: "12",
              class: "block w-48 px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition" %>
        </div>
      </div>

      <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
        <%= render "shared/card_header", title: "Registration Window" %>
        <div class="p-5">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="course_offering_opens_at" class="block text-sm font-medium text-gray-700 mb-1.5">
                Opens At
              </label>
              <p class="text-xs text-gray-500 mb-2">When registration becomes available. Status must also be "Open".</p>
              <%= form.datetime_local_field :opens_at,
                  class: "block w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition" %>
            </div>
            <div>
              <label for="course_offering_closes_at" class="block text-sm font-medium text-gray-700 mb-1.5">
                Closes At
              </label>
              <p class="text-xs text-gray-500 mb-2">Auto-close registration date.</p>
              <%= form.datetime_local_field :closes_at,
                  class: "block w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition" %>
            </div>
          </div>
        </div>
      </div>

      <%# Questionnaire Section %>
      <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
        <%= render "shared/card_header", title: "Questionnaire" %>
        <div class="p-5 space-y-5">
          <% if @course_offering.questionnaire.present? %>
            <div class="flex items-center justify-between p-4 bg-green-50 border border-green-200 rounded-lg">
              <div>
                <p class="text-sm font-medium text-green-800">Questionnaire enabled</p>
                <p class="text-xs text-green-600 mt-0.5"><%= @course_offering.questionnaire.title %></p>
              </div>
              <div class="flex items-center gap-2">
                <%= link_to manage_form_contacts_questionnaire_path(@course_offering.questionnaire) do %>
                  <%= render "shared/button", text: "Edit Questions", variant: "secondary", size: "small" %>
                <% end %>
                <%= link_to manage_contacts_questionnaire_path(@course_offering.questionnaire) do %>
                  <%= render "shared/button", text: "View Responses", variant: "secondary", size: "small" %>
                <% end %>
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-900 mb-1.5">Delivery Mode</label>
              <p class="text-xs text-gray-500 mb-2">When should the questionnaire be sent to registrants?</p>
              <%= form.select :delivery_mode,
                  [["Immediately after registration", "immediate"],
                   ["After a delay", "delayed"],
                   ["At a scheduled time", "scheduled"],
                   ["Manually (I'll send it myself)", "manual"]],
                  { include_blank: false },
                  class: "block w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition",
                  onchange: "
                    document.getElementById('delay-fields').classList.toggle('hidden', this.value !== 'delayed');
                    document.getElementById('scheduled-fields').classList.toggle('hidden', this.value !== 'scheduled');
                  " %>
            </div>

            <div id="delay-fields" class="<%= 'hidden' unless @course_offering.delivery_mode == 'delayed' %>">
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Delay (minutes)</label>
              <%= form.number_field :delivery_delay_minutes, min: 1,
                  placeholder: "60",
                  class: "block w-48 px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition" %>
            </div>

            <div id="scheduled-fields" class="<%= 'hidden' unless @course_offering.delivery_mode == 'scheduled' %>">
              <label class="block text-sm font-medium text-gray-700 mb-1.5">Send At</label>
              <%= form.datetime_local_field :delivery_scheduled_at,
                  class: "block w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition" %>
            </div>

            <div class="flex items-center gap-3 pt-2 border-t border-gray-200">
              <%= link_to manage_course_offering_disable_questionnaire_path(@course_offering), method: :post, data: { turbo_method: :post, turbo_confirm: "This will unlink the questionnaire from this course. The questionnaire itself will not be deleted." } do %>
                <%= render "shared/button", text: "Disable Questionnaire", variant: "ghost-cancel", size: "small" %>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-600 mb-3">
              Send a questionnaire to students after they register. Collect additional info, preferences, or requirements.
            </p>
            <%= link_to manage_course_offering_enable_questionnaire_path(@course_offering), method: :post, data: { turbo_method: :post } do %>
              <%= render "shared/button", text: "Enable Questionnaire", variant: "secondary", size: "medium" %>
            <% end %>
          <% end %>
        </div>
      </div>

      <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
        <%= render "shared/card_header", title: "Course Directory" %>
        <div class="p-5">
          <div class="flex items-center justify-between">
            <div>
              <span class="text-sm font-medium text-gray-900">List in course directory</span>
              <p class="text-xs text-gray-500 mt-0.5">Make this course discoverable to other CocoScout users in the global course directory.</p>
            </div>
            <label class="relative inline-flex items-center cursor-pointer flex-shrink-0 ml-4">
              <%= form.check_box :listed_in_directory, { class: "sr-only peer", include_hidden: true }, "1", "0" %>
              <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-pink-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-pink-500"></div>
            </label>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3">
        <%= render "shared/button", text: "Save Details", variant: "primary", size: "medium", type: :submit %>
      </div>
    <% end %>
  </div>

</div>
