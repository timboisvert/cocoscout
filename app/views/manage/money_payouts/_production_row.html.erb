<%#
  Money Payouts Production Row — delegates chrome to shared/_production_row.
  Required: summary (Hash with production payout data)
  Optional: link_path (defaults to this production's payouts)

  Panels: Awaiting Payout, Total Paid, Advances
%>
<%
  production = summary[:production]
  awaiting_payout = summary[:awaiting_payout_amount] || 0
  awaiting_count = summary[:awaiting_payout_count] || 0
  paid_amount = summary[:paid_amount] || 0
  paid_count = summary[:paid_count] || 0
  outstanding_advances = summary[:outstanding_advances] || 0
  total_advances = summary[:total_advances] || 0

  panels = [
    if awaiting_payout > 0
      { label: "Awaiting Payout", value: number_to_currency(awaiting_payout), value_class: "text-sm font-medium text-pink-600", sub: "#{awaiting_count} #{'show'.pluralize(awaiting_count)}" }
    else
      { label: "Awaiting Payout", value: "$0.00", value_class: "text-sm text-gray-400" }
    end,
    if paid_amount > 0
      { label: "Total Paid", value: number_to_currency(paid_amount), value_class: "text-sm font-medium text-green-600", sub: "#{paid_count} #{'show'.pluralize(paid_count)}" }
    else
      { label: "Total Paid", value: "$0.00", value_class: "text-sm text-gray-400" }
    end,
    if total_advances > 0
      { label: "Advances", value: number_to_currency(total_advances), value_class: "text-sm font-medium text-gray-900",
        sub: outstanding_advances > 0 ? "#{number_to_currency(outstanding_advances)} outstanding" : "All settled",
        sub_class: outstanding_advances > 0 ? "text-xs text-amber-600" : "text-xs text-green-600" }
    else
      { label: "Advances", value: "$0.00", value_class: "text-sm text-gray-400" }
    end
  ]
%>

<%= render "shared/production_row",
  production: production,
  link_path: local_assigns[:link_path] || manage_money_production_payouts_path(production),
  subtitle: "#{summary[:revenue_shows]} revenue #{'event'.pluralize(summary[:revenue_shows])}",
  panels: panels %>
