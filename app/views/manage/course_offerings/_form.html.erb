<%
  # This form is used for editing only. Course creation happens through the wizard.
  form_url = manage_course_offering_path(course_offering)
%>

<%= form_with model: course_offering, url: form_url, method: :patch, class: "space-y-6", data: { turbo: false } do |form| %>
  <% if course_offering.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <ul class="list-disc list-inside text-red-700 text-sm">
        <% course_offering.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="max-w-2xl space-y-6">

    <!-- Production & Title -->
    <div class="bg-white rounded-lg border border-gray-200 p-5">
      <h3 class="font-semibold text-gray-900 mb-4">Basic Info</h3>
      <div class="space-y-4">
        <div>
          <%= form.label :production_id, "Production", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <p class="text-sm text-gray-900 font-medium"><%= course_offering.production.name %></p>
          <%= form.hidden_field :production_id %>
        </div>

        <div>
          <%= form.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :title, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-pink-500 focus:ring-pink-500", placeholder: "e.g., Intro to Improv - Spring 2025" %>
        </div>

        <div>
          <%= form.label :subtitle, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :subtitle, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-pink-500 focus:ring-pink-500", placeholder: "e.g., A 6-week course for beginners" %>
        </div>

        <div>
          <%= form.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <p class="text-xs text-gray-500 mb-2">Shown on the public registration page.</p>
          <%= form.rich_text_area :description, class: "w-full min-h-[150px]" %>
        </div>
      </div>
    </div>

    <!-- Instructor -->
    <div class="bg-white rounded-lg border border-gray-200 p-5">
      <h3 class="font-semibold text-gray-900 mb-4">Instructor</h3>
      <div class="space-y-4">
        <div>
          <%= form.label :instructor_name, "Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :instructor_name, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-pink-500 focus:ring-pink-500", placeholder: "e.g., Jane Smith" %>
        </div>
        <div>
          <%= form.label :instructor_bio, "Bio (optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.rich_text_area :instructor_bio, class: "w-full min-h-[120px]" %>
        </div>
      </div>
    </div>

    <!-- Pricing -->
    <div class="bg-white rounded-lg border border-gray-200 p-5">
      <h3 class="font-semibold text-gray-900 mb-4">Pricing</h3>
      <div class="space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= form.label :price_cents, "Price (cents)", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <p class="text-xs text-gray-500 mb-2">In cents, e.g. 15000 = $150.00</p>
            <%= form.number_field :price_cents, min: 0, step: 1, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-pink-500 focus:ring-pink-500", placeholder: "15000" %>
          </div>
          <div>
            <%= form.label :currency, class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= form.select :currency, [["USD", "usd"], ["CAD", "cad"], ["GBP", "gbp"], ["EUR", "eur"]], {}, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-pink-500 focus:ring-pink-500" %>
          </div>
        </div>

        <div class="border-t border-gray-200 pt-4">
          <p class="text-sm font-medium text-gray-700 mb-3">Early Bird Pricing (optional)</p>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <%= form.label :early_bird_price_cents, "Early Bird Price (cents)", class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= form.number_field :early_bird_price_cents, min: 0, step: 1, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-pink-500 focus:ring-pink-500", placeholder: "12000" %>
            </div>
            <div>
              <%= form.label :early_bird_deadline, class: "block text-sm font-medium text-gray-700 mb-1" %>
              <%= form.datetime_local_field :early_bird_deadline, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-pink-500 focus:ring-pink-500" %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Capacity & Schedule -->
    <div class="bg-white rounded-lg border border-gray-200 p-5">
      <h3 class="font-semibold text-gray-900 mb-4">Capacity & Schedule</h3>
      <div class="space-y-4">
        <div>
          <%= form.label :capacity, "Max Registrations (optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <p class="text-xs text-gray-500 mb-2">Leave blank for unlimited.</p>
          <%= form.number_field :capacity, min: 1, class: "block w-48 rounded-lg border border-gray-300 px-3 py-2 focus:border-pink-500 focus:ring-pink-500", placeholder: "20" %>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= form.label :opens_at, "Registration Opens", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <p class="text-xs text-gray-500 mb-2">Optional. Registration must also be "Open" status.</p>
            <%= form.datetime_local_field :opens_at, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-pink-500 focus:ring-pink-500" %>
          </div>
          <div>
            <%= form.label :closes_at, "Registration Closes", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <p class="text-xs text-gray-500 mb-2">Optional auto-close date.</p>
            <%= form.datetime_local_field :closes_at, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-pink-500 focus:ring-pink-500" %>
          </div>
        </div>
      </div>
    </div>

    <!-- Messages -->
    <div class="bg-white rounded-lg border border-gray-200 p-5">
      <h3 class="font-semibold text-gray-900 mb-4">Page Content</h3>
      <div class="space-y-4">
        <div>
          <%= form.label :instruction_text, "Additional Instructions (optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <p class="text-xs text-gray-500 mb-2">Extra details shown on the registration page, e.g. what to bring, parking info.</p>
          <%= form.text_area :instruction_text, rows: 3, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-pink-500 focus:ring-pink-500" %>
        </div>

        <div>
          <%= form.label :success_text, "Success Message (optional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <p class="text-xs text-gray-500 mb-2">Shown after payment is complete. Leave blank for default message.</p>
          <%= form.text_area :success_text, rows: 3, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-pink-500 focus:ring-pink-500" %>
        </div>
      </div>
    </div>

    <!-- Submit -->
    <div class="flex items-center gap-3">
      <%= render "shared/button", text: "Update Offering", variant: "primary", size: "medium", type: :submit %>
      <%= link_to manage_course_offering_path(course_offering), class: "text-sm text-gray-500 hover:text-gray-700" do %>
        Cancel
      <% end %>
    </div>
  </div>
<% end %>
