<%#
  Live-cycle equivalent of the wizard's "Set up audition sessions" step.
  Two sections in one modal:
    1. Generate N consecutive sessions starting at a time, all sharing
       the same duration + location.
    2. Add one session manually with full date + location control.

  The bulk-generate posts to the new #generate action; the single-add
  posts to the existing #create action. Both redirect back to the index.
%>
<div id="generateSessionsModal"
     data-audition-session-modal-target="generateModal"
     class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4"
     data-action="click->audition-session-modal#closeOnBackdrop keydown.esc@window->audition-session-modal#closeGenerate">
  <div class="bg-white rounded-lg shadow-xl w-full max-w-xl max-h-[90vh] overflow-y-auto"
       data-action="click->audition-session-modal#stopPropagation">
    <div class="sticky top-0 bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between">
      <h2 class="text-xl font-semibold text-gray-900 coustard-regular">New Audition Sessions</h2>
      <button type="button" data-action="click->audition-session-modal#closeGenerate" class="text-gray-500 hover:text-gray-700">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <div class="px-6 py-6 space-y-6">
      <%# ---------------- Bulk-generate ---------------- %>
      <section class="p-4 bg-gray-50 rounded-lg border border-gray-200">
        <h3 class="font-medium text-gray-900 mb-1">Generate consecutive sessions</h3>
        <p class="text-sm text-gray-500 mb-4">Best when you have a whole afternoon of back-to-back slots.</p>

        <%= form_with url: manage_generate_signups_auditions_cycle_sessions_path(@production, @audition_cycle),
              method: :post, local: true, class: "space-y-4" do %>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Number of sessions</label>
              <%= number_field_tag :session_count, 6, min: 1, max: 50, required: true,
                  class: "block w-full shadow-sm rounded-lg border border-gray-300 px-3 py-2 focus:ring-pink-500 focus:border-pink-500" %>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Duration each (min)</label>
              <%= number_field_tag :duration_minutes, 15, min: 5, step: 5, required: true,
                  class: "block w-full shadow-sm rounded-lg border border-gray-300 px-3 py-2 focus:ring-pink-500 focus:border-pink-500" %>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Starting at</label>
            <%= datetime_field_tag :start_at, nil, required: true,
                class: "block w-full shadow-sm rounded-lg border border-gray-300 px-3 py-2 focus:ring-pink-500 focus:border-pink-500" %>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Location</label>
            <% default_location = Current.organization.locations.find_by(default: true) || Current.organization.locations.order(:created_at).first %>
            <%= select_tag :location_id,
                options_from_collection_for_select(Current.organization.locations.order(:created_at), :id, :name, default_location&.id),
                prompt: "Select a location", required: true,
                class: "block w-full shadow-sm rounded-lg border border-gray-300 px-3 py-2 focus:ring-pink-500 focus:border-pink-500",
                data: { "location-modal-target": "locationSelect", action: "change->location-modal#handleLocationChange" } %>
            <a href="#" data-action="click->location-modal#openModal" class="text-pink-500 underline text-sm mt-1 inline-block">Add a Location</a>
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Max auditionees per session (optional)</label>
            <%= number_field_tag :maximum_auditionees, nil, min: 1, placeholder: "Leave empty for unlimited",
                class: "block w-full shadow-sm rounded-lg border border-gray-300 px-3 py-2 focus:ring-pink-500 focus:border-pink-500" %>
          </div>

          <div class="flex justify-end gap-2 pt-2">
            <button type="button" class="px-4 py-2 text-gray-600 hover:text-gray-800" data-action="click->audition-session-modal#closeGenerate">Cancel</button>
            <%= render "shared/button", text: "Generate sessions", variant: "primary", size: "medium", type: :submit %>
          </div>
        <% end %>
      </section>

      <%# ---------------- Single add ---------------- %>
      <details class="p-4 bg-white rounded-lg border border-gray-200">
        <summary class="cursor-pointer font-medium text-gray-900">Add a single session instead</summary>
        <div class="mt-4">
          <%= render "manage/audition_sessions/session_form", audition_session: AuditionSession.new %>
        </div>
      </details>
    </div>
  </div>
</div>
