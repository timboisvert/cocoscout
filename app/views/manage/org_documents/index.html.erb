<% content_for :title, "Documents" %>

<div class="w-full mb-10">
  <%= render partial: "shared/notice", locals: { notice: notice, alert: alert } %>
  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [],
    text: "Documents",
    links: [
      { text: "New document", icon: "plus", path: manage_new_org_document_path }
    ]
  } %>

  <% if @documents_by_production.any? %>
    <div class="space-y-8">
      <% @documents_by_production.sort_by { |prod, _| prod.name.to_s.downcase }.each do |production, docs| %>
        <div>
          <div class="flex items-center justify-between mb-2">
            <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide"><%= production.name %></h2>
            <%= link_to "View all", manage_production_documents_path(production),
                  class: "text-xs text-pink-600 hover:text-pink-700" %>
          </div>
          <div class="space-y-2">
            <% docs.each do |doc| %>
              <%= link_to manage_production_document_path(production, doc),
                    class: "group bg-white border border-gray-200 rounded-lg px-4 py-3 flex items-center gap-4 hover:border-gray-300 hover:bg-gray-50 transition-colors" do %>
                <div class="w-9 h-9 rounded-lg bg-pink-50 flex items-center justify-center text-pink-600 flex-shrink-0">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="font-medium text-gray-900 group-hover:text-pink-600 truncate"><%= doc.title %></div>
                  <div class="text-xs text-gray-500 mt-0.5">
                    Shared with: <%= doc.audience_summary %> · Updated <%= doc.updated_at.strftime("%b %-d, %Y") %>
                  </div>
                </div>
                <svg class="w-5 h-5 text-gray-300 group-hover:text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-gray-50 border border-dashed border-gray-300 rounded-lg p-8 text-center">
      <p class="text-sm text-gray-600 mb-3">
        <% if @managed_productions.any? %>
          No documents yet. Create a performer handbook or any document your team needs.
        <% else %>
          You don't manage any productions yet, so there are no documents to show.
        <% end %>
      </p>
      <% if @managed_productions.any? %>
        <%= link_to manage_new_org_document_path do %>
          <%= render "shared/button", text: "Create your first document", variant: "primary", size: "medium" %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
