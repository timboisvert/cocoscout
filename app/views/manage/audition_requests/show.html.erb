<% content_for :title, "Audition Requests" %>
<% can_vote = (current_user_can_review?(@production) || current_user_can_manage?(@production)) && current_user_can_review?(@production) && @audition_cycle.voting_enabled && @audition_cycle.active %>
<div class="w-full <%= can_vote ? 'pb-48 lg:pb-40' : 'pb-8' %> relative">
  <%= render partial: "shared/notice", locals: { notice: notice } %>

  <%# Archived stamp - inky rubber stamp effect %>
  <% unless @audition_cycle.active %>
    <div class="absolute top-20 right-24 z-30 pointer-events-none">
      <div class="transform rotate-12 px-6 py-3 relative" style="filter: url(#inkFilter);">
        <%# SVG filter for inky/distressed effect %>
        <svg class="absolute" width="0" height="0">
          <defs>
            <filter id="inkFilter" x="-20%" y="-20%" width="140%" height="140%">
              <feTurbulence type="fractalNoise" baseFrequency="0.04" numOctaves="5" result="noise"/>
              <feDisplacementMap in="SourceGraphic" in2="noise" scale="3" xChannelSelector="R" yChannelSelector="G"/>
            </filter>
          </defs>
        </svg>
        <div class="border-4 border-red-400/60 rounded px-5 py-2 bg-transparent text-center" style="border-style: double; border-width: 4px;">
          <span class="text-red-400/70 font-black text-3xl tracking-widest uppercase block" style="font-family: 'Courier New', monospace; text-shadow: 1px 1px 0 rgba(239,68,68,0.2), -1px -1px 0 rgba(239,68,68,0.1);">ARCHIVED</span>
          <span class="text-red-400/50 text-xs tracking-wide block mt-1" style="font-family: 'Courier New', monospace;"><%= @audition_cycle.updated_at.strftime("%b %-d, %Y") %></span>
        </div>
        <%# Ink splotches for authenticity %>
        <div class="absolute -top-1 -left-1 w-2 h-2 bg-red-400/30 rounded-full blur-[1px]"></div>
        <div class="absolute -bottom-1 -right-2 w-3 h-1 bg-red-400/20 rounded-full blur-[1px]"></div>
        <div class="absolute top-1/2 -left-2 w-1 h-3 bg-red-400/25 rounded-full blur-[1px]"></div>
      </div>
    </div>
  <% end %>

  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      ["Sign-ups", manage_signups_path],
      [@production.name, manage_signups_production_path(@production)],
      ["Auditions", manage_signups_auditions_path(@production)],
      ["Review", manage_review_signups_auditions_cycle_path(@production, @audition_cycle)],
      [(@audition_cycle.video_only? ? "Video Auditions" : "Audition Requests"), manage_signups_auditions_cycle_requests_path(@production, @audition_cycle)]
    ],
    text: @requestable&.name&.truncate(40, omission: "...") || "Deleted",
    links: []
  } %>

  <%# Hero Section with Headshot, Name, Email, Profile Link %>
  <% if @requestable.present? %>
    <div class="flex flex-col md:flex-row md:items-center gap-3 md:gap-4 mb-4">
      <%# Top row: Headshot + Name/Email %>
      <div class="flex items-center gap-4 flex-1 min-w-0">
        <% if @requestable.respond_to?(:safe_headshot_variant) %>
          <% headshot_variant = @requestable.safe_headshot_variant(:thumb) %>
          <% if headshot_variant %>
            <%= image_tag headshot_variant, class: "w-12 h-12 rounded-lg object-cover flex-shrink-0" %>
          <% else %>
            <div class="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center text-black font-bold flex-shrink-0">
              <%= @requestable.respond_to?(:initials) ? @requestable.initials : @requestable.name[0..1].upcase %>
            </div>
          <% end %>
        <% end %>
        <div class="flex-1 min-w-0">
          <div class="flex items-baseline gap-2 min-w-0">
            <div class="font-bold text-xl text-gray-900 truncate flex-shrink"><%= @requestable.name %></div>
            <% if @requestable.respond_to?(:pronouns) && @requestable.pronouns.present? %>
              <div class="text-sm text-gray-500 flex-shrink-0">(<%= @requestable.pronouns %>)</div>
            <% end %>
          </div>
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-gray-500">
            <% if @requestable.respond_to?(:email) && @requestable.email.present? %>
              <%= link_to @requestable.email, "mailto:#{@requestable.email}", class: "text-pink-500 hover:underline" %>
            <% end %>
          </div>
        </div>
      </div>
      <%# Buttons: Own row on mobile, inline on desktop %>
      <% if @requestable.respond_to?(:public_key) && @requestable.public_key.present? %>
        <div class="flex items-center gap-2 flex-shrink-0"
             data-controller="compose-message"
             data-compose-message-recipient-type-value="person"
             data-compose-message-recipient-id-value="<%= @requestable.id %>"
             data-compose-message-recipient-name-value="<%= @requestable.name %>"
             data-compose-message-recipient-headshot-value="<%= @requestable.safe_headshot_variant(:thumb) ? url_for(@requestable.safe_headshot_variant(:thumb)) : '' %>">
          <% if @requestable.is_a?(Person) %>
            <%= render "shared/button", text: "Contact", variant: "outline", size: "small", type: :button, data: { action: "click->compose-message#open" } %>
          <% end %>
          <%= render partial: "shared/button", locals: { text: "Public Profile", path: public_profile_path(@requestable.public_key), variant: "outline", size: "small", target: "_blank" } %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="space-y-4">

    <%# Headshots, Resume & Socials %>
    <% if @requestable.present? %>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        <div class="border border-gray-200 rounded-lg p-3">
          <%= render "shared/media_thumbnails", items: @profile_headshots, type: "headshot", label: "Headshots" %>
        </div>
        <div class="border border-gray-200 rounded-lg p-3">
          <%= render "shared/media_thumbnails", items: @profile_resumes, type: "resume", label: "Resume" %>
        </div>
        <div class="border border-gray-200 rounded-lg p-3">
          <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Socials</div>
          <% if @socials.any? %>
            <div class="space-y-1.5">
              <% @socials.each do |social| %>
                <div class="flex items-center gap-2">
                  <span class="text-gray-400 flex-shrink-0"><%= social.icon(18) %></span>
                  <% if social.url.present? %>
                    <%= link_to social.display_name, social.url, target: "_blank", rel: "noopener", class: "text-sm text-pink-500 hover:underline truncate" %>
                  <% else %>
                    <span class="text-sm text-gray-700 truncate"><%= social.display_name %></span>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-400 italic">No socials</p>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Video %>
    <% if @audition_cycle.accepts_video_submissions? && @audition_request.video_url.present? %>
      <div class="border border-gray-200 rounded-lg p-3">
        <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Video</div>
        <%= render "manage/audition_requests/video", audition_request: @audition_request %>
        <% if @audition_cycle.active && current_user_can_manage?(@production) %>
          <div class="mt-2">
            <%= link_to manage_edit_video_signups_auditions_cycle_request_path(@production, @audition_cycle, @audition_request) do %>
              <%= render "shared/button", text: "Edit Video", variant: "outline", size: "small" %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# Actions - full width %>
    <% if current_user_can_manage? && @audition_request.present? %>
      <div class="border border-gray-200 rounded-lg p-3">
        <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Actions</div>
        <% if @audition_request.archived? %>
          <div class="p-2 bg-amber-50 border border-amber-200 rounded-lg mb-2">
            <p class="text-sm text-amber-800">
              Archived on <%= @audition_request.archived_at.strftime("%b %-d, %Y") %>
            </p>
          </div>
        <% end %>
        <div class="flex flex-wrap gap-2">
          <% if @audition_request.archived? %>
            <%= link_to manage_unarchive_signups_auditions_cycle_request_path(@production, @audition_cycle, @audition_request), data: { turbo_method: :post, turbo_confirm: "Are you sure you want to restore this sign-up? It will appear in the active sign-ups list again." } do %>
              <%= render "shared/button", text: "Restore Sign-up", variant: "outline", size: "small" %>
            <% end %>
          <% else %>
            <%= link_to manage_archive_signups_auditions_cycle_request_path(@production, @audition_cycle, @audition_request), data: { turbo_method: :post, turbo_confirm: "Are you sure you want to archive this sign-up? They will be removed from the active sign-ups list but their request will be preserved." } do %>
              <%= render "shared/button", text: "Archive Sign-up", variant: "outline", size: "small" %>
            <% end %>
          <% end %>
          <%= link_to manage_signups_auditions_cycle_request_path(@production, @audition_cycle, @audition_request), data: { turbo_method: :delete, turbo_confirm: "⚠️ PERMANENTLY DELETE this sign-up?\n\nThis will completely remove their audition request, answers, votes, and all associated data. This cannot be undone.\n\nIf you just want to remove them from the active list, use 'Archive' instead." } do %>
            <%= render "shared/button", text: "Delete Sign-up", variant: "outline", size: "small" %>
          <% end %>
          <% if Current.user&.superadmin? && @requestable.is_a?(Person) && @requestable.user %>
            <%= button_to impersonate_user_path, method: :post, params: { email: @requestable.user.email_address }, class: "inline-block" do %>
              <%= render "shared/button", text: "Impersonate User", variant: "outline", size: "small" %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Questions & Availability side by side %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <%# Audition Questions %>
      <div class="border border-gray-200 rounded-lg p-3">
        <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Audition Questions</div>
        <% if @answers&.any? %>
          <%= render "manage/audition_requests/answers", answers: @answers %>
          <% if current_user_can_manage?(@production) && @audition_cycle.active %>
            <div class="mt-3 pt-3 border-t border-gray-100">
              <%= link_to manage_edit_answers_signups_auditions_cycle_request_path(@production, @audition_cycle, @audition_request) do %>
                <%= render "shared/button", text: "Edit Answers", variant: "outline", size: "small" %>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <p class="text-sm text-gray-400 italic">No questions asked</p>
        <% end %>
      </div>

      <%# Availability %>
      <% can_manage_active = current_user_can_manage?(@production) && @audition_cycle.active %>
      <div class="border border-gray-200 rounded-lg p-3"<%= ' data-controller=availability-edit'.html_safe if can_manage_active %>>
        <div class="flex items-center justify-between mb-2">
          <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Availability</div>
          <% if can_manage_active %>
            <a href="#" data-action="click->availability-edit#toggle" data-availability-edit-target="link" class="text-xs text-pink-500 hover:underline">Change</a>
          <% end %>
        </div>
        <% has_show_availability = @audition_cycle.include_availability_section && @shows&.present? %>
        <% has_session_availability = @audition_cycle.include_audition_availability_section && @audition_sessions&.present? %>
        <% if has_show_availability || has_session_availability %>
          <div class="divide-y divide-gray-100">
            <% if has_show_availability %>
              <% @shows.each do |show| %>
                <% availability = @show_availabilities[show.id] %>
                <div class="flex items-center justify-between py-1.5 gap-2 text-xs"
                  <% if can_manage_active %>
                     data-controller="availability"
                     data-availability-show-id-value="<%= show.id %>"
                     data-availability-status-value="<%= availability&.status || 'unset' %>"
                     data-availability-entity-key-value="show_<%= show.id %>"
                     data-availability-entity-type-value="<%= @requestable.class.name %>"
                     data-availability-update-url-value="<%= manage_update_show_availability_signups_auditions_cycle_request_path(@production, @audition_cycle, @audition_request) %>"
                  <% end %>>
                  <div class="flex items-center gap-1.5 min-w-0 flex-1">
                    <span class="text-gray-500 flex-shrink-0 w-12"><%= show.date_and_time.strftime("%b %-d") %></span>
                    <span class="text-gray-900 truncate"><%= show.display_name %></span>
                  </div>
                  <%# Read-only A/U indicator (default visible) %>
                  <span data-availability-edit-target="readView" data-availability-target="readIndicator" class="flex-shrink-0 text-xs font-medium <%= availability&.status == 'available' ? 'text-pink-500' : availability&.status == 'unavailable' ? 'text-gray-400' : 'text-gray-300' %>"><%= availability&.status == 'available' ? 'A' : availability&.status == 'unavailable' ? 'U' : '–' %></span>
                  <% if can_manage_active %>
                    <%# Edit buttons (hidden by default) %>
                    <div data-availability-edit-target="editView" class="hidden flex gap-0 flex-shrink-0">
                      <% [:available, :unavailable].each do |status| %>
                        <% classes = "px-4 py-1.5 sm:px-0 sm:w-[5.5rem] sm:py-1 text-xs text-center border border-gray-200 cursor-pointer" %>
                        <% classes += status == :available ? " rounded-l border-r-0" : " rounded-r" %>
                        <% classes += (availability&.status == status.to_s) ? " bg-pink-500 text-white" : " bg-white text-gray-600 hover:bg-gray-50" %>
                        <%= link_to "#", class: classes, data: { action: "click->availability#setStatus", availability_status: status, availability_target: "#{status}Btn" } do %>
                          <span data-availability-target="<%= status %>Check" class="hidden">✓</span>
                          <span data-availability-target="<%= status %>Text"><span class="sm:hidden"><%= status == :available ? 'A' : 'U' %></span><span class="hidden sm:inline"><%= status == :available ? 'Available' : 'Unavailable' %></span></span>
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% end %>
            <% end %>

            <% if has_session_availability %>
              <% if has_show_availability %>
                <div class="pt-2 pb-1">
                  <span class="text-[10px] font-semibold text-gray-400 uppercase tracking-wide">Audition Sessions</span>
                </div>
              <% end %>
              <% @audition_sessions.each do |session| %>
                <% current_status = @audition_availability&.dig("#{session.id}") %>
                <div class="flex items-center justify-between py-1.5 gap-2 text-xs"
                  <% if can_manage_active %>
                     data-controller="availability"
                     data-availability-show-id-value="<%= session.id %>"
                     data-availability-status-value="<%= current_status || 'unset' %>"
                     data-availability-entity-key-value="audition_session"
                     data-availability-entity-id="<%= @requestable.id %>"
                     data-availability-entity-type="<%= @requestable.class.name %>"
                     data-availability-update-url-value="<%= manage_update_session_availability_signups_auditions_cycle_request_path(@production, @audition_cycle, @audition_request) %>"
                     data-availability-person-id-value="<%= @requestable.is_a?(Person) ? @requestable.id : nil %>"
                  <% end %>>
                  <div class="flex items-center gap-1.5 min-w-0 flex-1">
                    <span class="text-gray-500 flex-shrink-0 w-12"><%= session.start_at.strftime("%b %-d") %></span>
                    <span class="text-gray-900 truncate"><%= session.start_at.strftime("%l:%M %p").strip %></span>
                  </div>
                  <%# Read-only A/U indicator (default visible) %>
                  <span data-availability-edit-target="readView" data-availability-target="readIndicator" class="flex-shrink-0 text-xs font-medium <%= current_status == 'available' ? 'text-pink-500' : current_status == 'unavailable' ? 'text-gray-400' : 'text-gray-300' %>"><%= current_status == 'available' ? 'A' : current_status == 'unavailable' ? 'U' : '–' %></span>
                  <% if can_manage_active %>
                    <%# Edit buttons (hidden by default) %>
                    <div data-availability-edit-target="editView" class="hidden flex gap-0 flex-shrink-0">
                      <% [:available, :unavailable].each do |status| %>
                        <% classes = "px-4 py-1.5 sm:px-0 sm:w-[5.5rem] sm:py-1 text-xs text-center border border-gray-200 cursor-pointer" %>
                        <% classes += status == :available ? " rounded-l border-r-0" : " rounded-r" %>
                        <% classes += current_status == status.to_s ? " bg-pink-500 text-white" : " bg-white text-gray-600 hover:bg-gray-50" %>
                        <%= link_to "#", class: classes, data: { action: "click->availability#setStatus", availability_status: status, availability_target: "#{status}Btn" } do %>
                          <span data-availability-target="<%= status %>Check" class="hidden">✓</span>
                          <span data-availability-target="<%= status %>Text"><span class="sm:hidden"><%= status == :available ? 'A' : 'U' %></span><span class="hidden sm:inline"><%= status == :available ? 'Available' : 'Unavailable' %></span></span>
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <p class="text-sm text-gray-400 italic">No availability requested</p>
        <% end %>
      </div>
    </div>

    <%# Votes box - shows how everyone has voted %>
    <% if @votes.any? %>
      <div class="border border-gray-200 rounded-lg p-3">
        <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Votes</div>
        <div class="space-y-2">
          <% @votes.order(created_at: :desc).each do |vote| %>
            <% voter_person = vote.user&.person %>
            <% next unless voter_person %>
            <div class="flex items-center gap-2">
              <% headshot = voter_person.safe_headshot_variant(:thumb) %>
              <% if headshot %>
                <%= image_tag headshot, class: "w-7 h-7 rounded-lg object-cover flex-shrink-0" %>
              <% else %>
                <div class="w-7 h-7 rounded-lg bg-gray-100 flex items-center justify-center text-[10px] font-bold text-gray-600 flex-shrink-0">
                  <%= voter_person.initials %>
                </div>
              <% end %>
              <div class="flex-1 min-w-0">
                <span class="text-sm font-medium text-gray-900"><%= voter_person.name %></span>
                <% if vote.comment.present? %>
                  <span class="text-sm text-gray-500 ml-1">&mdash; <%= vote.comment %></span>
                <% end %>
              </div>
              <% vote_badge = case vote.vote
                 when "yes" then { text: "Yes", classes: "bg-green-100 text-green-700" }
                 when "no" then { text: "No", classes: "bg-red-100 text-red-700" }
                 when "maybe" then { text: "Not Sure", classes: "bg-amber-100 text-amber-700" }
                 end %>
              <% if vote_badge %>
                <span class="px-2 py-0.5 text-xs font-medium rounded-full flex-shrink-0 <%= vote_badge[:classes] %>"><%= vote_badge[:text] %></span>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

  </div>
</div>


<% if can_vote %>
  <%# Fade overlay for bottom of content %>
  <div class="fixed bottom-0 left-0 right-0 lg:left-56 h-40 sm:h-56 bg-gradient-to-t from-gray-100 via-gray-100 via-50% to-transparent pointer-events-none z-10"></div>

  <% votes = @audition_request.audition_request_votes.includes(user: :default_person).order(created_at: :desc) %>
  <% current_vote = @audition_request.vote_for(Current.user) %>
  <% vote_counts = @audition_request.vote_counts %>

  <div class="fixed bottom-4 left-4 right-4 lg:left-60 lg:right-4 bg-white rounded-lg shadow-lg border border-gray-200 z-20 overflow-hidden"
       data-controller="vote-form"
       data-vote-form-save-url-value="<%= manage_cast_vote_signups_auditions_cycle_request_path(@production, @audition_cycle, @audition_request) %>">
    <div class="bg-gray-50 px-3 py-2 border-b border-gray-200">
      <h3 class="text-sm font-semibold text-gray-900 coustard-regular">
        <% if @audition_cycle.video_only? %>
          Should this <%= @requestable.is_a?(Person) ? 'person' : 'group' %> be added to <%= @production.name %>'s talent pool?
        <% else %>
          Should this <%= @requestable.is_a?(Person) ? 'person' : 'group' %> get an audition?
        <% end %>
      </h3>
    </div>
    <div class="p-3 flex flex-col sm:flex-row sm:items-center gap-3">
      <!-- Navigation row on mobile, left side on desktop -->
      <div class="flex items-center gap-2 sm:gap-3">
        <!-- Previous button -->
        <div class="flex-shrink-0">
          <% if @audition_request.previous %>
            <%= link_to manage_signups_auditions_cycle_request_path(@production, @audition_cycle, @audition_request.previous),
                class: "flex items-center justify-center w-10 h-10 rounded text-pink-500 hover:bg-pink-50 transition-all",
                data: { action: "click->vote-form#navigateWithSave" } do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
              </svg>
            <% end %>
          <% else %>
            <div class="flex items-center justify-center w-10 h-10 text-gray-300">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
              </svg>
            </div>
          <% end %>
        </div>

        <!-- Vote buttons inline on mobile nav row -->
        <div class="flex items-center gap-1 sm:hidden flex-1 justify-center">
          <%# Yes button - mobile %>
          <% is_yes = current_vote&.vote == "yes" %>
          <button type="button"
                  data-action="click->vote-form#submitVote"
                  data-vote-form-vote-param="yes"
                  data-vote-form-url-param="<%= manage_cast_vote_signups_auditions_cycle_request_path(@production, @audition_cycle, @audition_request) %>"
                  class="inline-flex items-center justify-center gap-1 px-2.5 py-1.5 text-xs font-medium rounded transition-colors cursor-pointer <%= is_yes ? 'bg-pink-500 hover:bg-pink-600 text-white' : 'bg-white border border-gray-300 hover:bg-gray-50 text-gray-700' %>">
            <span>👍</span>
            <span class="opacity-75"><%= vote_counts[:yes] %></span>
          </button>

          <%# No button - mobile %>
          <% is_no = current_vote&.vote == "no" %>
          <button type="button"
                  data-action="click->vote-form#submitVote"
                  data-vote-form-vote-param="no"
                  data-vote-form-url-param="<%= manage_cast_vote_signups_auditions_cycle_request_path(@production, @audition_cycle, @audition_request) %>"
                  class="inline-flex items-center justify-center gap-1 px-2.5 py-1.5 text-xs font-medium rounded transition-colors cursor-pointer <%= is_no ? 'bg-pink-500 hover:bg-pink-600 text-white' : 'bg-white border border-gray-300 hover:bg-gray-50 text-gray-700' %>">
            <span>👎</span>
            <span class="opacity-75"><%= vote_counts[:no] %></span>
          </button>

          <%# Not Sure button - mobile %>
          <% is_maybe = current_vote&.vote == "maybe" %>
          <button type="button"
                  data-action="click->vote-form#submitVote"
                  data-vote-form-vote-param="maybe"
                  data-vote-form-url-param="<%= manage_cast_vote_signups_auditions_cycle_request_path(@production, @audition_cycle, @audition_request) %>"
                  class="inline-flex items-center justify-center gap-1 px-2.5 py-1.5 text-xs font-medium rounded transition-colors cursor-pointer <%= is_maybe ? 'bg-pink-500 hover:bg-pink-600 text-white' : 'bg-white border border-gray-300 hover:bg-gray-50 text-gray-700' %>">
            <span>🤔</span>
            <span class="opacity-75"><%= vote_counts[:maybe] %></span>
          </button>
        </div>

        <!-- Next button on mobile -->
        <div class="flex-shrink-0 sm:hidden">
          <% if @audition_request.next %>
            <%= link_to manage_signups_auditions_cycle_request_path(@production, @audition_cycle, @audition_request.next),
                class: "flex items-center justify-center w-10 h-10 rounded text-pink-500 hover:bg-pink-50 transition-all",
                data: { action: "click->vote-form#navigateWithSave" } do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
              </svg>
            <% end %>
          <% else %>
            <div class="flex items-center justify-center w-10 h-10 text-gray-300">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
              </svg>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Mobile comment row -->
      <div class="sm:hidden flex items-center gap-2 border-t border-gray-200 pt-2">
        <input type="text"
               data-vote-form-target="comment"
               placeholder="Add a comment..."
               value="<%= current_vote&.comment %>"
               class="flex-1 px-3 py-1.5 border border-gray-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-pink-500 focus:border-pink-500 min-w-0" />
        <button type="button"
                data-action="click->vote-form#submitComment"
                data-vote-form-url-param="<%= manage_cast_vote_signups_auditions_cycle_request_path(@production, @audition_cycle, @audition_request) %>"
                class="inline-flex items-center justify-center px-3 py-1.5 text-sm font-medium rounded bg-pink-500 hover:bg-pink-600 text-white transition-colors cursor-pointer whitespace-nowrap">
          Save
        </button>
      </div>

      <!-- Separator - desktop only -->
      <div class="hidden sm:block w-px h-12 bg-gray-200"></div>

      <!-- Content rows - desktop only -->
      <div class="hidden sm:block flex-1 space-y-2">
        <!-- Row 1: Cast your vote -->
        <div class="flex items-center gap-2">
          <span class="text-sm text-gray-500 whitespace-nowrap hidden sm:inline w-28">Cast your vote</span>
          <%# Yes button %>
          <% is_yes = current_vote&.vote == "yes" %>
          <button type="button"
                  data-action="click->vote-form#submitVote"
                  data-vote-form-vote-param="yes"
                  data-vote-form-url-param="<%= manage_cast_vote_signups_auditions_cycle_request_path(@production, @audition_cycle, @audition_request) %>"
                  class="inline-flex items-center justify-center gap-1 px-4 py-2 text-sm font-medium rounded transition-colors cursor-pointer whitespace-nowrap w-32 <%= is_yes ? 'bg-pink-500 hover:bg-pink-600 text-white' : 'bg-white border border-gray-300 hover:bg-gray-50 text-gray-700' %>">
            <span>Yes</span>
            <span class="opacity-75">(<%= vote_counts[:yes] %>)</span>
          </button>

          <%# No button %>
          <% is_no = current_vote&.vote == "no" %>
          <button type="button"
                  data-action="click->vote-form#submitVote"
                  data-vote-form-vote-param="no"
                  data-vote-form-url-param="<%= manage_cast_vote_signups_auditions_cycle_request_path(@production, @audition_cycle, @audition_request) %>"
                  class="inline-flex items-center justify-center gap-1 px-4 py-2 text-sm font-medium rounded transition-colors cursor-pointer whitespace-nowrap w-32 <%= is_no ? 'bg-pink-500 hover:bg-pink-600 text-white' : 'bg-white border border-gray-300 hover:bg-gray-50 text-gray-700' %>">
            <span>No</span>
            <span class="opacity-75">(<%= vote_counts[:no] %>)</span>
          </button>

          <%# Not Sure button %>
          <% is_maybe = current_vote&.vote == "maybe" %>
          <button type="button"
                  data-action="click->vote-form#submitVote"
                  data-vote-form-vote-param="maybe"
                  data-vote-form-url-param="<%= manage_cast_vote_signups_auditions_cycle_request_path(@production, @audition_cycle, @audition_request) %>"
                  class="inline-flex items-center justify-center gap-1 px-4 py-2 text-sm font-medium rounded transition-colors cursor-pointer whitespace-nowrap w-32 <%= is_maybe ? 'bg-pink-500 hover:bg-pink-600 text-white' : 'bg-white border border-gray-300 hover:bg-gray-50 text-gray-700' %>">
            <span>Not Sure</span>
            <span class="opacity-75">(<%= vote_counts[:maybe] %>)</span>
          </button>
        </div>

        <!-- Row 2: Add a comment -->
        <div class="flex items-center gap-2 border-t border-gray-200 pt-2">
          <span class="text-sm text-gray-500 whitespace-nowrap w-28">Add a comment</span>
          <input type="text"
                 id="vote-comment"
                 data-vote-form-target="comment"
                 placeholder="Optional comment..."
                 value="<%= current_vote&.comment %>"
                 class="flex-1 px-3 py-2 border border-gray-300 rounded text-sm focus:outline-none focus:ring-1 focus:ring-pink-500 focus:border-pink-500 min-w-0" />
          <button type="button"
                  data-action="click->vote-form#submitComment"
                  data-vote-form-url-param="<%= manage_cast_vote_signups_auditions_cycle_request_path(@production, @audition_cycle, @audition_request) %>"
                  class="inline-flex items-center justify-center px-4 py-2 text-sm font-medium rounded bg-pink-500 hover:bg-pink-600 text-white transition-colors cursor-pointer whitespace-nowrap">
            Save
          </button>
        </div>
      </div>

      <!-- Separator - desktop only -->
      <div class="hidden sm:block w-px h-12 bg-gray-200"></div>

      <!-- Next button - desktop only -->
      <div class="hidden sm:block flex-shrink-0">
        <% if @audition_request.next %>
          <%= link_to manage_signups_auditions_cycle_request_path(@production, @audition_cycle, @audition_request.next),
              class: "flex items-center justify-center w-10 h-10 rounded text-pink-500 hover:bg-pink-50 transition-all",
              data: { action: "click->vote-form#navigateWithSave" } do %>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
          <% end %>
        <% else %>
          <div class="flex items-center justify-center w-10 h-10 text-gray-300">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<%# Compose Message Modal %>
<%= render "shared/compose_message_modal" %>
