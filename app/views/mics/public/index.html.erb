<%
  title = "Find a Mic — every active mic, every city"
  description = "Every active open mic in the U.S., as up-to-the-minute as the people who run them. Chicago first."
  mics_seo title: title, description: description
%>
<%= render "mics/header" %>

<main class="w-full">
  <%# Big pink hero strip. Acts as visual identity, no search here — search lives in the header. %>
  <section class="bg-pink-50 border-b border-pink-100">
    <div class="w-full px-4 sm:px-8 py-10 sm:py-16">
      <h1 class="coustard-regular text-4xl sm:text-6xl text-pink-900 leading-[1.05] max-w-4xl">
        Find an open mic tonight.
      </h1>
      <p class="mt-4 text-pink-900/80 text-base sm:text-lg max-w-2xl">
        <span class="font-bold tabular-nums"><%= @total_active_mics %></span>
        active <%= "mic".pluralize(@total_active_mics) %> across
        <span class="font-bold tabular-nums"><%= @total_cities %></span>
        <%= "city".pluralize(@total_cities) %>.
        Updated by the people who run them.
      </p>
    </div>
  </section>

  <% if @active_hubs.any? %>
    <section class="border-b border-gray-100 bg-white">
      <div class="w-full px-4 sm:px-8 py-8">
        <div class="text-xs uppercase tracking-wider text-gray-500 font-bold mb-3">Cities</div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          <% @active_hubs.each do |hub| %>
            <a href="<%= mics_city_path(hub.slug) %>"
               class="block p-5 sm:p-6 bg-pink-500 hover:bg-pink-600 text-white transition-colors">
              <div class="coustard-regular text-2xl sm:text-3xl"><%= hub.name %></div>
            </a>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>

  <section class="bg-white border-b border-gray-100">
    <div class="w-full px-4 sm:px-8 py-10 grid grid-cols-1 sm:grid-cols-3 gap-6">
      <div>
        <div class="coustard-regular text-2xl text-gray-900">I perform at mics</div>
        <p class="mt-2 text-sm text-gray-600">Favorite your regular mics and set sign-up alerts before the bucket draw.</p>
        <a href="<%= mics_my_path %>" class="mt-3 inline-block text-pink-600 font-bold hover:underline">Go to My Mics →</a>
      </div>
      <div>
        <div class="coustard-regular text-2xl text-gray-900">I run a mic</div>
        <p class="mt-2 text-sm text-gray-600">Claim your mic to manage the listing, cancel a date in one click, invite co-owners, and unlock CocoScout-powered sign-ups.</p>
        <a href="<%= mics_my_path %>" class="mt-3 inline-block text-pink-600 font-bold hover:underline">Manage your mic →</a>
      </div>
      <div>
        <div class="coustard-regular text-2xl text-gray-900">Got a mic we're missing?</div>
        <p class="mt-2 text-sm text-gray-600">Anyone with an account can list a new mic anywhere in the U.S. Goes live within a day.</p>
        <a href="<%= mics_submit_path %>" class="mt-3 inline-block text-pink-600 font-bold hover:underline">Submit a mic →</a>
      </div>
    </div>
  </section>
</main>

<%= render "mics/site_footer" %>
