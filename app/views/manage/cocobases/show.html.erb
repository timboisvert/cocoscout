<% content_for :title, "Cocobase - #{@show.event_type.titleize}" %>

<div class="w-full mb-10">
  <%= render partial: "shared/notice", locals: { notice: notice } %>
  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      ["Shows & Events", manage_shows_path],
      [@production.name, manage_production_shows_path(@production)],
      [@show.event_type.titleize, manage_production_show_path(@production, @show)]
    ],
    text: "Cocobase",
    links: [
      { text: "Edit", path: manage_edit_show_cocobase_path(@production, @show), icon: "pencil" },
      { text: "Submissions", path: manage_show_cocobase_submissions_path(@production, @show), icon: "clipboard-list" }
    ]
  } %>

  <div class="max-w-3xl mx-auto space-y-6">
    <!-- Status & Deadline -->
    <div class="bg-white border border-gray-200 rounded-lg shadow-sm p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900">Overview</h2>
        <% if @cocobase.open? %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Open</span>
        <% else %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Closed</span>
        <% end %>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Show Date</p>
          <p class="text-sm font-medium text-gray-900"><%= @show.date_and_time.strftime("%b %-d, %Y %l:%M %p") %></p>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Deadline</p>
          <p class="text-sm font-medium <%= @cocobase.past_deadline? ? 'text-red-600' : 'text-gray-900' %>">
            <% if @cocobase.deadline.present? %>
              <%= @cocobase.deadline.strftime("%b %-d, %Y %l:%M %p") %>
              <% if @cocobase.past_deadline? %>
                <span class="text-xs">(past)</span>
              <% end %>
            <% else %>
              No deadline
            <% end %>
          </p>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Submitted</p>
          <p class="text-sm font-medium text-gray-900"><%= @summary[:submitted] %> / <%= @summary[:total] %></p>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wide">Pending</p>
          <p class="text-sm font-medium <%= @summary[:pending] > 0 ? 'text-amber-600' : 'text-gray-900' %>"><%= @summary[:pending] %></p>
        </div>
      </div>
    </div>

    <!-- Fields -->
    <div class="bg-white border border-gray-200 rounded-lg shadow-sm p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-1">Fields</h2>
      <p class="text-sm text-gray-500 mb-4">The information cast members are asked to submit.</p>

      <% if @fields.any? %>
        <div class="space-y-3">
          <% @fields.each do |field| %>
            <%= render "manage/cocobase_templates/field_row", field: field, production: @production %>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-6 text-gray-500">
          <p class="text-sm">No fields defined.</p>
        </div>
      <% end %>
    </div>

    <!-- Submissions Summary -->
    <div class="bg-white border border-gray-200 rounded-lg shadow-sm p-6">
      <div class="flex items-center justify-between mb-4">
        <div>
          <h2 class="text-lg font-semibold text-gray-900">Submissions</h2>
          <p class="text-sm text-gray-500"><%= @summary[:submitted] %> of <%= @summary[:total] %> submitted</p>
        </div>
        <%= link_to manage_show_cocobase_submissions_path(@production, @show) do %>
          <%= render "shared/button", text: "View All", variant: "secondary", size: "small" %>
        <% end %>
      </div>

      <% if @submissions.any? %>
        <div class="space-y-2">
          <% @submissions.each do |submission| %>
            <% entity = submission.submittable %>
            <% next unless entity %>
            <% headshot_variant = entity.safe_headshot_variant(:thumb) %>
            <%= link_to manage_show_cocobase_submission_path(@production, @show, submission),
              class: "flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 transition-colors" do %>
              <% if headshot_variant %>
                <%= image_tag headshot_variant, alt: entity.name, class: "w-8 h-8 rounded-lg object-cover" %>
              <% else %>
                <div class="w-8 h-8 rounded-lg bg-gray-200 flex items-center justify-center text-gray-600 font-bold text-xs">
                  <%= entity.initials %>
                </div>
              <% end %>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900 truncate"><%= entity.name %></p>
              </div>
              <% case submission.status %>
              <% when "submitted" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">Submitted</span>
              <% when "in_progress" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-700">In Progress</span>
              <% else %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-600">Pending</span>
              <% end %>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-6 text-gray-500">
          <p class="text-sm">No submissions yet. Submissions are created when casting is finalized.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
