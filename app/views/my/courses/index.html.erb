<% content_for :title, "My Courses" %>

<div class="w-full">

  <%= render partial: "shared/notice", locals: { notice: notice } %>

  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [],
    text: "My Courses",
    links: []
  } %>

  <% if @upcoming_courses.any? || @past_courses.any? %>

    <!-- Upcoming Courses -->
    <div class="border border-gray-200 rounded-lg overflow-hidden mb-6">
      <%= render "shared/card_header", title: "Upcoming Courses" %>
      <div class="p-4">
        <% if @upcoming_courses.any? %>
          <div class="space-y-1">
            <% @upcoming_courses.each do |course_data| %>
              <% offering = course_data[:offering] %>
              <% next_session = course_data[:next_session] %>
              <% first_session = course_data[:all_sessions].first %>
              <% last_session = course_data[:all_sessions].last %>
              <% location = course_data[:location] %>
              <% date_range = if first_session.date_and_time.to_date == last_session.date_and_time.to_date
                               first_session.date_and_time.strftime("%B %-d, %Y")
                             elsif first_session.date_and_time.year == last_session.date_and_time.year
                               "#{first_session.date_and_time.strftime("%b %-d")} – #{last_session.date_and_time.strftime("%b %-d, %Y")}"
                             else
                               "#{first_session.date_and_time.strftime("%b %-d, %Y")} – #{last_session.date_and_time.strftime("%b %-d, %Y")}"
                             end %>
              <%= link_to my_course_path(offering), class: "block" do %>
                <div class="flex items-stretch px-3 py-2 border border-gray-200 bg-white rounded-lg hover:border-gray-400 transition-all group">
                  <div class="flex flex-col md:flex-row md:items-center gap-2 md:gap-0 w-full">
                    <%# Left Section: Course Details %>
                    <div class="w-full md:w-1/2 flex items-center">
                      <div class="flex-1 min-w-0">
                        <div class="font-medium text-gray-900 truncate"><%= offering.title %></div>
                        <div class="text-sm text-gray-600">
                          <%= date_range %> · <%= course_data[:total_sessions] %> sessions
                        </div>
                        <% if location %>
                          <div class="text-sm text-gray-600 flex items-center gap-1">
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                            <%= location.name %>
                          </div>
                        <% end %>
                      </div>
                    </div>
                    <%# Right Section: Next Session & Progress %>
                    <div class="w-full md:w-1/2 border-t border-gray-100 md:border-t-0 md:border-l md:border-gray-200 md:pl-4 mt-2 md:mt-0 pt-2 md:pt-0 flex items-center">
                      <div class="flex-1 min-w-0">
                        <div class="text-[10px] text-gray-400 uppercase tracking-wide">Next session</div>
                        <div class="text-sm text-gray-900 font-medium"><%= next_session.date_and_time.strftime("%A, %b %-d at %-I:%M %p") %></div>
                        <div class="flex items-center gap-2 mt-1">
                          <span class="text-xs text-gray-500"><%= course_data[:completed_sessions] %>/<%= course_data[:total_sessions] %> completed</span>
                          <% if course_data[:total_sessions] > 0 %>
                            <div class="w-16">
                              <div class="w-full bg-gray-200 rounded-full h-1.5">
                                <div class="bg-pink-500 h-1.5 rounded-full" style="width: <%= (course_data[:completed_sessions].to_f / course_data[:total_sessions] * 100).round %>%"></div>
                              </div>
                            </div>
                          <% end %>
                        </div>
                      </div>
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 flex-shrink-0 ml-2">Registered</span>
                    </div>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-500 text-sm">No upcoming courses.</p>
        <% end %>
      </div>
    </div>

    <!-- Completed Courses -->
    <div class="border border-gray-200 rounded-lg overflow-hidden mb-6">
      <%= render "shared/card_header", title: "Completed Courses" %>
      <div class="p-4">
        <% if @past_courses.any? %>
          <div class="space-y-1">
            <% @past_courses.each do |course_data| %>
              <% offering = course_data[:offering] %>
              <% first_session = course_data[:all_sessions].first %>
              <% last_session = course_data[:all_sessions].last %>
              <% date_range = if first_session.date_and_time.to_date == last_session.date_and_time.to_date
                               first_session.date_and_time.strftime("%B %-d, %Y")
                             elsif first_session.date_and_time.year == last_session.date_and_time.year
                               "#{first_session.date_and_time.strftime("%b %-d")} – #{last_session.date_and_time.strftime("%b %-d, %Y")}"
                             else
                               "#{first_session.date_and_time.strftime("%b %-d, %Y")} – #{last_session.date_and_time.strftime("%b %-d, %Y")}"
                             end %>
              <%= link_to my_course_path(offering), class: "block" do %>
                <div class="flex items-stretch px-3 py-2 border border-gray-200 bg-white rounded-lg hover:border-gray-400 transition-all group">
                  <div class="flex flex-col md:flex-row md:items-center gap-2 md:gap-0 w-full">
                    <%# Left Section: Course Details %>
                    <div class="w-full md:w-1/2 flex items-center">
                      <div class="flex-1 min-w-0">
                        <div class="font-medium text-gray-900 truncate"><%= offering.title %></div>
                        <div class="text-sm text-gray-600">
                          <%= date_range %> · <%= course_data[:total_sessions] %> sessions
                        </div>
                      </div>
                    </div>
                    <%# Right Section: Completed info %>
                    <div class="w-full md:w-1/2 border-t border-gray-100 md:border-t-0 md:border-l md:border-gray-200 md:pl-4 mt-2 md:mt-0 pt-2 md:pt-0 flex items-center">
                      <div class="flex-1 min-w-0">
                        <div class="text-[10px] text-gray-400 uppercase tracking-wide">Completed</div>
                        <div class="text-sm text-gray-700"><%= last_session.date_and_time.strftime("%B %-d, %Y") %></div>
                      </div>
                      <span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-medium bg-gray-200 text-gray-600 flex-shrink-0 ml-2">Completed</span>
                    </div>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-500 text-sm">No completed courses.</p>
        <% end %>
      </div>
    </div>

  <% else %>
    <p class="text-gray-500 text-sm">You aren't registered for any courses.</p>
  <% end %>

</div>
