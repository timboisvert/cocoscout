<% content_for :title, "Select Organization" %>

<%
  intent = @onboarding_intent || ""
  intent_is_course = intent.include?("course")
  intent_is_production = intent.include?("production")
  intent_label = if intent_is_course
                   "create your course"
                 elsif intent_is_production
                   "set up your production"
                 else
                   "get started"
                 end
%>

<div class="max-w-md mx-auto py-8">

  <% if @organizations.any? || @demo_organizations.any? %>

    <% if @onboarding_intent.present? %>
      <%# Intent context banner %>
      <div class="mb-6 bg-pink-50 border border-pink-200 rounded-lg px-4 py-3">
        <p class="text-sm text-pink-800">
          <strong>Almost there!</strong> Select an organization to <%= intent_label %>, or
          <%= link_to "create a new one", new_manage_organization_path, class: "underline font-medium hover:text-pink-900" %>.
        </p>
      </div>
    <% end %>

    <!-- Organization Selection -->
    <div class="mb-6">
      <h2 class="text-xl font-bold text-gray-900 mb-1">Select an organization</h2>
      <p class="text-sm text-gray-600">Choose which organization you'd like to work with</p>
    </div>

    <% if @organizations.any? %>
      <div class="bg-white border border-gray-200 rounded-lg overflow-hidden mb-4">
        <% @organizations.each_with_index do |org, index| %>
          <%= form_with url: set_organization_path(id: org.id), method: :post do |form| %>
            <button type="submit" class="w-full flex items-center gap-3 hover:bg-slate-50 px-4 py-3 transition cursor-pointer text-left <%= index > 0 ? 'border-t border-gray-200' : '' %>">
              <% if org.logo.attached? %>
                <div class="w-16 h-8 flex items-center justify-center flex-shrink-0 rounded">
                  <%= image_tag org.logo, alt: "#{org.name} logo", class: "w-16 h-8 object-cover rounded" %>
                </div>
              <% else %>
                <div class="w-16 h-8 flex items-center justify-center flex-shrink-0 rounded bg-gray-100 text-gray-600 font-bold text-xs">
                  <%= org.name[0..1].upcase %>
                </div>
              <% end %>
              <span class="text-sm font-medium text-slate-700 truncate flex-1"><%= org.name %></span>
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </button>
          <% end %>
        <% end %>

        <!-- Create New Organization Button -->
        <%= link_to new_manage_organization_path, data: { turbo: false }, class: "flex items-center gap-3 px-4 py-3 text-sm text-pink-500 hover:bg-slate-50 transition cursor-pointer font-medium border-t border-gray-200" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Create an Organization
        <% end %>
      </div>
    <% end %>

    <% if @demo_organizations.any? %>
      <div class="mb-2 mt-6">
        <p class="text-xs font-medium text-gray-400 uppercase tracking-wide">Demo</p>
      </div>
      <div class="bg-white border border-gray-200 rounded-lg overflow-hidden border-dashed">
        <% @demo_organizations.each_with_index do |org, index| %>
          <%= form_with url: set_organization_path(id: org.id), method: :post do |form| %>
            <button type="submit" class="w-full flex items-center gap-3 hover:bg-slate-50 px-4 py-3 transition cursor-pointer text-left <%= index > 0 ? 'border-t border-gray-200' : '' %>">
              <% if org.logo.attached? %>
                <div class="w-16 h-8 flex items-center justify-center flex-shrink-0 rounded">
                  <%= image_tag org.logo, alt: "#{org.name} logo", class: "w-16 h-8 object-cover rounded" %>
                </div>
              <% else %>
                <div class="w-16 h-8 flex items-center justify-center flex-shrink-0 rounded bg-gray-100 text-gray-600 font-bold text-xs">
                  <%= org.name[0..1].upcase %>
                </div>
              <% end %>
              <span class="text-sm font-medium text-slate-500 truncate flex-1"><%= org.name %></span>
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </button>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <% if @organizations.empty? %>
      <!-- Only has demo orgs, show create button -->
      <div class="mt-4">
        <%= link_to new_manage_organization_path, data: { turbo: false }, class: "flex items-center justify-center gap-2 px-4 py-2 bg-pink-600 hover:bg-pink-700 text-white font-medium rounded-lg text-sm transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          Create an Organization
        <% end %>
      </div>
    <% end %>

  <% else %>
    <!-- Educational Onboarding -->
    <div class="max-w-lg mx-auto">

      <%# Header %>
      <div class="text-center mb-8">
        <%= render "shared/cocoscout_logo", size: :medium, class: "mx-auto mb-3" %>
        <h1 class="text-2xl font-bold text-gray-900 coustard-regular mb-2">Welcome to the Production Side</h1>
        <% if intent_is_course %>
          <p class="text-sm text-gray-600">To create a course, you'll first set up an organization — it only takes a minute.</p>
        <% elsif intent_is_production %>
          <p class="text-sm text-gray-600">To set up a production, you'll first create an organization — it only takes a minute.</p>
        <% else %>
          <p class="text-sm text-gray-600">This is where you manage the things you're producing — shows, courses, casting, and more. To get started, create an organization.</p>
        <% end %>
      </div>

      <% if @onboarding_intent.present? %>
        <%# Step indicator — only show when user has a specific destination in mind %>
        <div class="flex items-center justify-center gap-3 mb-8">
          <div class="flex items-center gap-2">
            <div class="w-7 h-7 rounded-full bg-pink-500 text-white flex items-center justify-center text-xs font-bold">1</div>
            <span class="text-sm font-medium text-pink-600">Create org</span>
          </div>
          <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
          <div class="flex items-center gap-2">
            <div class="w-7 h-7 rounded-full bg-gray-200 text-gray-500 flex items-center justify-center text-xs font-bold">2</div>
            <span class="text-sm text-gray-400"><%= intent_is_course ? "Create course" : "Create production" %></span>
          </div>
          <svg class="w-4 h-4 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
          <div class="flex items-center gap-2">
            <div class="w-7 h-7 rounded-full bg-gray-200 text-gray-500 flex items-center justify-center text-xs font-bold">3</div>
            <span class="text-sm text-gray-400">Go live</span>
          </div>
        </div>
      <% end %>

      <%# What is an organization? %>
      <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 mb-6">
        <h3 class="text-sm font-semibold text-gray-900 mb-1">What's an organization?</h3>
        <p class="text-xs text-gray-600 leading-relaxed">
          An organization is your workspace for the things <strong>you're producing</strong>.
          It's separate from any shows or productions you perform in — those live on your Talent Dashboard.
          Think of it as your production company, teaching brand, or theater group — even if it's just you.
        </p>
      </div>

      <%# Inline org creation form %>
      <div class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm">
        <h2 class="text-lg font-bold text-gray-900 mb-1">Name your organization</h2>
        <p class="text-xs text-gray-500 mb-4">You can always change this later. Many people just use their own name to start.</p>

        <%= form_with(model: [:manage, @organization], class: "space-y-4") do |form| %>
          <div>
            <%= form.text_field :name,
                required: true,
                placeholder: "e.g., #{Current.user&.person&.name || 'Your Name'} Productions",
                class: "block w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition text-sm" %>
          </div>

          <%= render "shared/button", text: "Create Organization & Continue", variant: "primary", size: "medium", type: :submit %>
        <% end %>
      </div>

      <%# Reassurance %>
      <p class="text-center text-xs text-gray-400 mt-4">
        You'll be the owner. You can invite team members and create as many productions or courses as you like.
      </p>

    </div>
  <% end %>

</div>
