<%#
  Delete-confirmation modal for one document — replaces the browser confirm.
  Locals: document, production (the managed production whose route the DELETE
  runs through).
  Trigger with: data-controller="modal" data-action="click->modal#open"
                data-modal-id="delete-modal-<document.id>"
%>
<div id="delete-modal-<%= document.id %>"
     class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-[100] flex items-center justify-center p-4"
     data-controller="modal"
     data-action="click->modal#closeOnBackdrop keydown.escape->modal#close">
  <div class="bg-white rounded-xl shadow-2xl w-full max-w-md max-h-[88vh] overflow-y-auto"
       data-action="click->modal#stopPropagation">
    <div class="flex items-start gap-3 px-5 py-4 border-b border-gray-200">
      <span class="flex-shrink-0 w-9 h-9 rounded-full bg-red-100 text-red-600 flex items-center justify-center">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/></svg>
      </span>
      <div class="min-w-0">
        <h3 class="text-base font-semibold text-gray-900">Delete &ldquo;<%= document.title %>&rdquo;?</h3>
        <p class="text-xs text-gray-500 mt-0.5">This can't be undone.</p>
      </div>
    </div>

    <div class="px-5 py-4">
      <p class="text-sm text-gray-700">Anyone this document is shared with will lose access to it.</p>
    </div>

    <div class="flex items-center justify-end gap-2 px-5 py-3 border-t border-gray-200">
      <button type="button" data-action="click->modal#close" class="px-4 py-2 text-sm text-gray-700 hover:text-gray-900 cursor-pointer">Cancel</button>
      <%= button_to manage_production_document_path(production, document), method: :delete,
            class: "inline-flex items-center justify-center font-medium rounded transition-colors cursor-pointer px-4 py-2 text-sm bg-red-600 hover:bg-red-700 text-white" do %>
        Delete document
      <% end %>
    </div>
  </div>
</div>
