<%= form_with model: @document,
      url: (@document.persisted? ? manage_production_document_path(@production, @document) : manage_production_documents_path(@production)),
      method: (@document.persisted? ? :patch : :post) do |f| %>
  <% if @document.errors.any? %>
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
      <%= @document.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <%# Full-page document editor. A fixed-height card whose title, toolbar and
      footer stay put; only the body (contents rail + editor) scrolls. %>
  <div class="document-editor bg-white border border-gray-200 rounded-lg shadow-sm flex flex-col h-[calc(100vh-11rem)] min-h-[28rem] overflow-hidden"
       data-controller="document-editor">

    <%# Title + sharing (fixed) %>
    <div class="flex-shrink-0 flex items-start gap-3 px-6 sm:px-10 pt-5 pb-3">
      <%= f.text_field :title, required: true, placeholder: "Untitled document",
            class: "flex-1 min-w-0 text-2xl sm:text-3xl coustard-regular text-gray-900 border-0 px-0 py-1 focus:ring-0 placeholder:text-gray-300" %>
      <% if @document.persisted? %>
        <%# One small settings menu keeps the title row clean. Sharing
            (visibility) and Productions (ownership) live behind it, each with
            its own summary. Uses native <details> so no extra JS. %>
        <details class="mt-1 flex-shrink-0 relative" data-controller="details-menu">
          <summary class="list-none cursor-pointer inline-flex items-center justify-center w-9 h-9 rounded-lg border border-gray-300 bg-white hover:border-gray-400 text-gray-500 transition-colors" title="Document settings">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.24-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.281Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>
          </summary>
          <div class="absolute right-0 z-30 mt-1 w-72 rounded-lg border border-gray-200 bg-white shadow-xl py-1">
            <button type="button" onclick="this.closest('details').open=false"
                    data-controller="modal" data-action="click->modal#open"
                    data-modal-id="productions-modal-<%= @document.id %>"
                    class="w-full text-left px-3 py-2 hover:bg-gray-50 cursor-pointer flex items-start gap-2.5">
              <svg class="w-4 h-4 text-gray-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 6.878V6a2.25 2.25 0 0 1 2.25-2.25h7.5A2.25 2.25 0 0 1 18 6v.878m-12 0c.235-.083.487-.128.75-.128h10.5c.263 0 .515.045.75.128m-12 0A2.25 2.25 0 0 0 4.5 9v.878m13.5-3A2.25 2.25 0 0 1 19.5 9v.878m0 0a2.246 2.246 0 0 0-.75-.128H5.25c-.263 0-.515.045-.75.128m15 0A2.25 2.25 0 0 1 21 12v6a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 18v-6c0-.98.626-1.813 1.5-2.122"/></svg>
              <span class="min-w-0">
                <span class="block text-sm font-medium text-gray-800">Productions</span>
                <span class="block text-xs text-gray-400 truncate">Belongs to <%= @document.applies_to_summary %></span>
              </span>
            </button>
            <button type="button" onclick="this.closest('details').open=false"
                    data-controller="modal" data-action="click->modal#open"
                    data-modal-id="sharing-modal-<%= @document.id %>"
                    class="w-full text-left px-3 py-2 hover:bg-gray-50 cursor-pointer flex items-start gap-2.5">
              <svg class="w-4 h-4 text-gray-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 1 0 0 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186 9.566-5.314m-9.566 7.5 9.566 5.314m0 0a2.25 2.25 0 1 0 3.935 2.186 2.25 2.25 0 0 0-3.935-2.186Zm0-12.814a2.25 2.25 0 1 0 3.933-2.185 2.25 2.25 0 0 0-3.933 2.185Z"/></svg>
              <span class="min-w-0">
                <span class="block text-sm font-medium text-gray-800">Sharing</span>
                <span class="block text-xs text-gray-400 truncate"><%= @document.audience_summary %></span>
              </span>
            </button>
          </div>
        </details>
      <% end %>
    </div>

    <%# Toolbar (relocated here by the controller — stays pinned under the title) %>
    <div data-document-editor-target="toolbarSlot"
         class="flex-shrink-0 px-4 sm:px-8 py-1 border-y border-gray-100 bg-white min-h-[2.75rem]"></div>

    <%# Body: contents rail (pinned) + the editor (scrolls) %>
    <div class="flex-1 flex min-h-0">
      <aside class="hidden lg:block w-60 flex-shrink-0 border-r border-gray-100 px-4 py-5 overflow-y-auto">
        <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Contents</div>
        <nav data-document-editor-target="toc" class="space-y-0.5 text-sm"></nav>
        <p data-document-editor-target="tocEmpty" class="text-xs text-gray-400 leading-relaxed">
          Add headings (H1–H3) to build a table of contents.
        </p>
      </aside>

      <div class="flex-1 min-w-0 overflow-y-auto px-6 sm:px-10 pt-4 pb-24">
        <%# Mobile contents — collapsible (the sidebar rail is desktop-only). %>
        <details class="lg:hidden mb-4 border border-gray-200 rounded-lg bg-gray-50/60" data-controller="details-menu">
          <summary class="list-none cursor-pointer px-3 py-2 text-xs font-semibold text-gray-500 uppercase tracking-wide flex items-center justify-between">
            <span>Contents</span>
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/></svg>
          </summary>
          <nav data-document-editor-target="toc" class="px-3 pb-2 space-y-0.5 text-sm"></nav>
          <p data-document-editor-target="tocEmpty" class="px-3 pb-2 text-xs text-gray-400">Add headings (H1–H3) to build a table of contents.</p>
        </details>

        <%= f.rich_text_area :body, data: { document_editor_target: "editor" } %>
      </div>
    </div>

    <%# Footer (fixed — always reachable, no scrolling to save) %>
    <div class="flex-shrink-0 flex items-center justify-end gap-3 px-6 sm:px-10 py-3 border-t border-gray-100 bg-gray-50/70 rounded-b-lg">
      <%= link_to "Cancel",
            (@document.persisted? ? manage_production_document_path(@production, @document) : manage_production_documents_path(@production)),
            class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
      <%= render "shared/button", text: "Save document", variant: "primary", size: "medium", type: :submit %>
    </div>
  </div>
<% end %>
