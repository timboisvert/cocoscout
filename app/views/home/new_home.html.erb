<% content_for :title, "CocoScout — Run the show. Or find your next stage." %>

<div class="min-h-screen bg-[#f9f9f7]">
  <%= render "shared/marketing/header" %>

  <main class="flex flex-col min-w-full">
    <%# ===== Hero: two equal audiences ===== %>
    <section class="w-full px-6 pt-14 pb-10 sm:pt-20 sm:pb-14 bg-gradient-to-br from-pink-50 via-white to-slate-50">
      <div class="max-w-6xl mx-auto text-center">
        <div class="mb-6 flex justify-center">
          <%= image_tag "/icon.png", alt: "CocoScout", class: "h-16 w-16 sm:h-20 sm:w-20 drop-shadow" %>
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 mb-5 coustard-regular leading-tight">
          Run the show.<br class="sm:hidden"> Or find your next stage.
        </h1>
        <p class="text-lg sm:text-xl max-w-3xl mx-auto text-slate-600 leading-relaxed">
          CocoScout is the operating platform for people who run shows, theaters, courses, and open mics —
          and the home base for the performers who bring them to life.
        </p>
      </div>

      <%# Two doors %>
      <div class="grid md:grid-cols-2 gap-6 max-w-5xl mx-auto mt-12">
        <%= link_to producers_path, class: "group bg-white border-2 border-pink-200 rounded-2xl p-7 sm:p-8 shadow-md hover:shadow-xl hover:border-pink-400 transition-all text-left" do %>
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-pink-100 flex items-center justify-center">
              <svg class="w-6 h-6 text-pink-500" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 0 1 1.927-.184"/></svg>
            </div>
            <h2 class="text-2xl font-bold text-slate-900 coustard-regular group-hover:text-pink-600 transition">I run shows</h2>
          </div>
          <p class="text-slate-600 mb-4">Productions, theaters, courses, open mics. Casting, sign-ups, scheduling, payouts, and your whole team — in one platform.</p>
          <div class="flex items-center gap-2 text-pink-500 font-semibold">
            <span>Explore the producer platform</span>
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
          </div>
        <% end %>

        <%= link_to performers_path, class: "group bg-white border-2 border-pink-200 rounded-2xl p-7 sm:p-8 shadow-md hover:shadow-xl hover:border-pink-400 transition-all text-left" do %>
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-xl bg-pink-100 flex items-center justify-center">
              <svg class="w-6 h-6 text-pink-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/></svg>
            </div>
            <h2 class="text-2xl font-bold text-slate-900 coustard-regular group-hover:text-pink-600 transition">I perform</h2>
          </div>
          <p class="text-slate-600 mb-4">Find open mics, auditions, and courses. Track your schedule, share availability, get cast, and get paid — free.</p>
          <div class="flex items-center gap-4 text-pink-500 font-semibold">
            <span class="inline-flex items-center gap-2">See what performers get
              <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </span>
          </div>
        <% end %>
      </div>
    </section>

    <%# ===== Producer operating platform ===== %>
    <section class="w-full bg-white border-t border-slate-100 px-6 py-16 sm:py-20">
      <div class="max-w-6xl mx-auto">
        <div class="max-w-2xl mb-10">
          <span class="text-pink-500 font-bold text-sm uppercase tracking-wide">For producers</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mt-2 mb-4 coustard-regular">The operating platform for live entertainment.</h2>
          <p class="text-lg text-slate-600">If you run shows, a theater, a class, or a weekly open mic, CocoScout replaces the spreadsheets, group texts, and email chains with one place to run all of it.</p>
        </div>

        <div class="grid lg:grid-cols-2 gap-10 items-center">
          <div class="rounded-2xl shadow-2xl overflow-hidden border border-slate-200 bg-slate-50">
            <%= image_tag "screenshots/casting/1-casting-table.png", alt: "CocoScout casting table", class: "w-full" %>
          </div>
          <div class="grid sm:grid-cols-2 gap-x-6 gap-y-5">
            <% [
              ["Auditions", "Custom forms, video submissions, callbacks"],
              ["Casting", "Drag-and-drop tables with conflict detection"],
              ["Sign-ups", "One-off or recurring, with attendance"],
              ["Scheduling", "Rehearsals, call lists, calendar sync"],
              ["Courses", "Offerings, sessions, registrations"],
              ["Staffing", "House roles, shifts, and crew"],
              ["Money", "Payouts, financials, contracts"],
              ["Documents & contacts", "Handbooks, talent pools, directory"]
            ].each do |title, blurb| %>
              <div class="flex items-start gap-3">
                <span class="mt-1 w-5 h-5 rounded-full bg-pink-100 text-pink-600 flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                </span>
                <div>
                  <div class="font-semibold text-slate-900 coustard-regular"><%= title %></div>
                  <div class="text-sm text-slate-600"><%= blurb %></div>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <div class="mt-10 flex flex-col sm:flex-row gap-3">
          <%= render "shared/button", text: "Explore the producer platform", path: producers_path, variant: "primary", size: "large" %>
          <%= render "shared/button", text: "Start free", path: signup_path, variant: "outline", size: "large" %>
        </div>
      </div>
    </section>

    <%# ===== Performer toolkit (discover, then manage) ===== %>
    <section class="w-full bg-[#f9f9f7] border-t border-slate-100 px-6 py-16 sm:py-20">
      <div class="max-w-6xl mx-auto">
        <div class="max-w-2xl mb-12">
          <span class="text-pink-500 font-bold text-sm uppercase tracking-wide">For performers &amp; comics</span>
          <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mt-2 mb-4 coustard-regular">Find the stage. Manage the rest.</h2>
          <p class="text-lg text-slate-600">
            Running five-minute sets at open mics or auditioning for the mainstage — CocoScout helps you find
            where to perform, then keeps every commitment, conflict, and payment in one place. Always free.
          </p>
        </div>

        <%# Step 1 — discovery %>
        <div class="flex items-center gap-3 mb-5">
          <span class="w-7 h-7 rounded-full bg-pink-500 text-white text-sm font-bold flex items-center justify-center">1</span>
          <h3 class="text-xl font-bold text-slate-900 coustard-regular">Find where to perform</h3>
        </div>
        <div class="grid sm:grid-cols-3 gap-5">
          <%= link_to mics_home_path, class: "group bg-white rounded-2xl border-2 border-pink-200 p-6 hover:border-pink-400 hover:shadow-lg transition-all flex flex-col" do %>
            <div class="flex items-center justify-between mb-3">
              <span class="w-11 h-11 rounded-xl bg-pink-100 text-pink-500 flex items-center justify-center">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 0 1-3-3V4.5a3 3 0 1 1 6 0v8.25a3 3 0 0 1-3 3Z"/></svg>
              </span>
              <span class="text-[10px] uppercase tracking-wider px-1.5 py-0.5 rounded bg-pink-100 text-pink-700 font-bold">Find a Mic</span>
            </div>
            <h4 class="text-xl font-bold text-slate-900 coustard-regular group-hover:text-pink-600 mb-1.5">Open mics</h4>
            <p class="text-sm text-slate-600 mb-4 flex-1">Browse every active open mic by city on Find a Mic. Favorite your regulars and get an alert the moment sign-ups open.</p>
            <span class="inline-flex items-center gap-1.5 text-pink-600 font-semibold text-sm">Browse on findamic.com
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </span>
          <% end %>
          <div class="bg-white rounded-2xl border border-slate-200 p-6">
            <span class="w-11 h-11 rounded-xl bg-pink-100 text-pink-500 flex items-center justify-center mb-3">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 0 1-1.44-4.282m3.102.069a18.03 18.03 0 0 1-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 0 1 8.835 2.535M10.34 6.66a23.847 23.847 0 0 0 8.835-2.535m0 0A23.74 23.74 0 0 0 18.795 3m.38 1.125a23.91 23.91 0 0 1 1.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 0 0 1.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73"/></svg>
            </span>
            <h4 class="text-xl font-bold text-slate-900 coustard-regular mb-1.5">Auditions</h4>
            <p class="text-sm text-slate-600">Discover open calls, submit with your headshots and reels in one click, and track each one from submission to callback.</p>
          </div>
          <div class="bg-white rounded-2xl border border-slate-200 p-6">
            <span class="w-11 h-11 rounded-xl bg-pink-100 text-pink-500 flex items-center justify-center mb-3">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"/></svg>
            </span>
            <h4 class="text-xl font-bold text-slate-900 coustard-regular mb-1.5">Courses</h4>
            <p class="text-sm text-slate-600">Find classes and workshops, register in a tap, and keep every session on your calendar automatically.</p>
          </div>
        </div>

        <%# Step 2 — manage %>
        <div class="flex items-center gap-3 mt-12 mb-5">
          <span class="w-7 h-7 rounded-full bg-pink-500 text-white text-sm font-bold flex items-center justify-center">2</span>
          <h3 class="text-xl font-bold text-slate-900 coustard-regular">Then manage it all in one place</h3>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          <%
            performer_tools = [
              [ "Your calendar", "Shows, rehearsals, auditions, mics, and classes in one view — synced to your phone.",
                "M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" ],
              [ "Availability", "Submit your conflicts once; every team you're on sees exactly when you're free.",
                "M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" ],
              [ "Get paid", "Add Venmo or Zelle once and get paid directly, with a full history of every payout.",
                "M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z" ],
              [ "Messages", "Stay in the loop with every cast and team — no more scattered group texts.",
                "M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" ],
              [ "Documents", "Sign agreements and grab handbooks, scripts, and tax forms whenever you need them.",
                "M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" ],
              [ "Profile & credits", "Keep headshots, reels, skills, and credits in one profile producers actually see.",
                "M17.982 18.725A7.488 7.488 0 0 0 12 15.75a7.488 7.488 0 0 0-5.982 2.975m11.963 0a9 9 0 1 0-11.963 0m11.963 0A8.966 8.966 0 0 1 12 21a8.966 8.966 0 0 1-5.982-2.275M15 9.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" ]
            ]
          %>
          <% performer_tools.each do |title, blurb, icon| %>
            <div class="flex items-start gap-3 bg-white rounded-xl border border-slate-200 p-4">
              <span class="w-9 h-9 rounded-lg bg-pink-100 text-pink-500 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="<%= icon %>"/></svg>
              </span>
              <div>
                <div class="font-semibold text-slate-900 coustard-regular"><%= title %></div>
                <div class="text-sm text-slate-600 leading-snug"><%= blurb %></div>
              </div>
            </div>
          <% end %>
        </div>

        <div class="mt-10 flex flex-col sm:flex-row sm:items-center gap-x-4 gap-y-3">
          <%= render "shared/button", text: "Create your free profile", path: signup_path, variant: "primary", size: "large" %>
          <%= render "shared/button", text: "Find an open mic", path: mics_home_path, variant: "outline", size: "large" %>
          <%= link_to "See everything performers get →", performers_path, class: "text-pink-600 font-semibold hover:text-pink-700 sm:ml-1" %>
        </div>
      </div>
    </section>

    <%# ===== Find a Mic band ===== %>
    <section class="w-full bg-pink-500 text-white px-6 py-14">
      <div class="max-w-5xl mx-auto flex flex-col md:flex-row md:items-center gap-6 md:gap-10">
        <div class="flex-1">
          <div class="text-xs uppercase tracking-wider text-pink-100 font-bold mb-1">findamic.com</div>
          <h2 class="text-3xl sm:text-4xl coustard-regular mb-2">Looking for an open mic tonight?</h2>
          <p class="text-pink-50 max-w-2xl">Find a Mic is our open-mic finder — every active mic, kept current by the people who run them. It's its own site, powered by the same free CocoScout account.</p>
        </div>
        <div class="shrink-0">
          <%= link_to mics_home_path,
                class: "inline-flex items-center gap-2 px-6 py-3 bg-white text-pink-700 font-bold rounded-lg hover:bg-pink-50 transition-colors" do %>
            Browse open mics
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M12.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
          <% end %>
        </div>
      </div>
    </section>

    <%# ===== One account ===== %>
    <section class="w-full bg-white px-6 py-16 border-t border-slate-100">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl sm:text-3xl font-bold text-slate-900 mb-3 coustard-regular">One free account, the whole ecosystem.</h2>
        <p class="text-lg text-slate-600 mb-8">
          The same login favorites mics and gets sign-up alerts on Find a Mic, submits to auditions and gets you cast on CocoScout,
          and — when you're ready — runs your own shows, classes, or mics as a producer.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <%= render "shared/button", text: "Sign Up Free", path: signup_path, variant: "primary", size: "large" %>
          <%= render "shared/button", text: "Sign In", path: signin_path, variant: "secondary", size: "large" %>
        </div>
      </div>
    </section>
  </main>

  <%= render "shared/marketing/footer" %>
</div>
