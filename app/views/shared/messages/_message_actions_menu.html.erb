<%#
  Message Actions Menu Component

  Renders the 3-dot menu with delete and read receipts options

  Required:
    message: The message object
    message_path: The path to the message (for delete link)
    can_delete: Whether the current user can delete this message
    can_view_receipts: Whether the current user can view read receipts

  Optional:
    mark_unread_path: When set, shows a "Mark as unread" option that POSTs here.
    mute_path:        When set, shows "Mute thread" / "Unmute thread" (POST).
    is_muted:         Pair with mute_path so we know which label to render.
    archive_path:     When set, shows "Archive" (POST).
%>
<% mark_unread_path = local_assigns[:mark_unread_path] %>
<% mute_path        = local_assigns[:mute_path] %>
<% is_muted         = local_assigns[:is_muted] %>
<% archive_path     = local_assigns[:archive_path] %>
<% unarchive_path   = local_assigns[:unarchive_path] %>

<% if can_delete || can_view_receipts || mark_unread_path || mute_path || archive_path || unarchive_path %>
  <div class="relative z-10 flex-shrink-0" data-controller="dropdown modal">
    <button
      type="button"
      class="p-1 text-gray-400 hover:text-gray-600 rounded hover:bg-gray-100 transition-colors cursor-pointer"
      data-action="click->dropdown#toggle"
      title="More options">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z"/>
      </svg>
    </button>
    <div
      data-dropdown-target="menu"
      class="hidden absolute right-0 top-full mt-1 w-40 bg-white rounded-lg shadow-lg border border-gray-200 py-1 z-50">
      <% if can_view_receipts %>
        <button
          type="button"
          data-action="click->modal#open click->dropdown#close"
          data-modal-id="read-receipts-modal-<%= message.id %>"
          class="w-full flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors cursor-pointer">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
          </svg>
          Read Receipts
        </button>
      <% end %>
      <% if mark_unread_path %>
        <%= button_to mark_unread_path, method: :post, form_class: "block",
              class: "w-full flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors cursor-pointer bg-transparent border-0 text-left" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l9 6 9-6M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          Mark as unread
        <% end %>
      <% end %>
      <% if mute_path %>
        <%= button_to mute_path, method: :post, form_class: "block",
              class: "w-full flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors cursor-pointer bg-transparent border-0 text-left" do %>
          <% if is_muted %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"/>
            </svg>
            Unmute thread
          <% else %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15zm12 0l4-4m0 4l-4-4"/>
            </svg>
            Mute thread
          <% end %>
        <% end %>
      <% end %>
      <% if archive_path %>
        <%= button_to archive_path, method: :post, form_class: "block",
              class: "w-full flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors cursor-pointer bg-transparent border-0 text-left" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"/>
          </svg>
          Archive
        <% end %>
      <% end %>
      <% if unarchive_path %>
        <%= button_to unarchive_path, method: :post, form_class: "block",
              class: "w-full flex items-center gap-2 px-3 py-2 text-sm text-gray-700 hover:bg-gray-50 transition-colors cursor-pointer bg-transparent border-0 text-left" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-7 4l-2 2m0 0l-2-2m2 2V9"/>
          </svg>
          Unarchive
        <% end %>
      <% end %>
      <% if can_delete %>
        <%= link_to message_path,
            method: :delete,
            data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this message?" },
            class: "flex items-center gap-2 px-3 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors cursor-pointer" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
          Delete
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Read Receipts Modal - rendered outside dropdown for proper z-index %>
  <% if can_view_receipts %>
    <%= render "shared/messages/read_receipts_modal", message: message %>
  <% end %>
<% end %>
