<% content_for :title, "Response - #{@response.respondent.name}" %>

<div class="w-full mb-10">
  <%= render partial: "shared/notice", locals: { notice: notice } %>
  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      ["Contacts", manage_contacts_path],
      ["Questionnaires", manage_contacts_questionnaires_path],
      [@questionnaire.title, manage_contacts_questionnaire_path(@questionnaire)]
    ],
    text: @response.respondent.name,
    links: []
  } %>

  <!-- Person Information Card -->
  <div class="border border-gray-200 rounded-lg overflow-hidden bg-white mb-6">
    <div class="flex flex-col sm:flex-row">
      <!-- Headshot Section -->
      <div class="flex-shrink-0 sm:w-48 bg-gray-50 flex items-center justify-center p-4">
        <% headshot_variant = @response.respondent.respond_to?(:safe_headshot_variant) ? @response.respondent.safe_headshot_variant(:thumb) : nil %>
        <% if headshot_variant %>
          <%= image_tag headshot_variant, alt: @response.respondent.name, class: "rounded-lg shadow-sm w-full max-w-[180px] aspect-square object-cover border border-gray-200" %>
        <% else %>
          <div class="w-full max-w-[180px] aspect-square rounded-lg bg-pink-100 flex items-center justify-center border border-gray-300">
            <span class="text-pink-600 font-bold text-5xl"><%= @response.respondent.initials %></span>
          </div>
        <% end %>
      </div>

      <!-- Details Section -->
      <div class="flex-1 p-6">
        <div class="space-y-4">
          <!-- Name -->
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-2">
              <%= @response.respondent.name %>
            </h2>
          </div>

          <!-- Respondent Details -->
          <div class="space-y-2 text-sm">
            <div class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-gray-400 flex-shrink-0 mt-0.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
              <span class="text-gray-900 font-medium"><%= @response.respondent.email %></span>
            </div>

            <div class="flex items-start gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-gray-400 flex-shrink-0 mt-0.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
              <span class="text-gray-700">
                Submitted <%= @response.created_at.strftime("%B %-d, %Y") %> at <%= @response.created_at.strftime("%l:%M %p") %>
              </span>
            </div>

            <% if @response.updated_at != @response.created_at %>
              <div class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-gray-400 flex-shrink-0 mt-0.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
                </svg>
                <span class="text-gray-700">
                  Updated <%= @response.updated_at.strftime("%B %-d, %Y") %> at <%= @response.updated_at.strftime("%l:%M %p") %>
                </span>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Responses -->
  <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
    <%= render "shared/card_header", title: "Responses" %>
    <div class="p-6 space-y-6">
      <% @questions.each do |question| %>
        <div>
          <p class="text-sm font-medium text-gray-900 mb-2">
            <%= question.text %>
            <% if question.required %>
              <span class="text-pink-500 text-xs">(required)</span>
            <% end %>
          </p>
          <% answer_value = @answers["#{question.id}"] %>
          <% if answer_value.present? %>
            <div class="p-3 bg-gray-50 rounded-lg">
              <% type_class = question.question_type_class %>
              <% if type_class && type_class.key == "ranking" %>
                <% parsed_value = nil %>
                <% if answer_value.is_a?(Array) %>
                  <% parsed_value = answer_value %>
                <% elsif answer_value.is_a?(Hash) %>
                  <% parsed_value = answer_value %>
                <% elsif answer_value.is_a?(String) %>
                  <% begin %>
                    <% parsed_value = JSON.parse(answer_value) %>
                  <% rescue JSON::ParserError %>
                  <% end %>
                <% end %>

                <% if parsed_value.is_a?(Array) %>
                  <ol class="space-y-2">
                    <% parsed_value.each_with_index do |item, index| %>
                      <li class="flex items-start gap-3">
                        <span class="flex-shrink-0 w-6 h-6 rounded-full bg-pink-500 text-white flex items-center justify-center text-xs font-medium">
                          <%= index + 1 %>
                        </span>
                        <span class="text-sm text-gray-700 pt-0.5"><%= item %></span>
                      </li>
                    <% end %>
                  </ol>
                <% elsif parsed_value.is_a?(Hash) %>
                  <ol class="space-y-2">
                    <% parsed_value.select { |k, v| v.present? }.keys.each_with_index do |key, index| %>
                      <li class="flex items-start gap-3">
                        <span class="flex-shrink-0 w-6 h-6 rounded-full bg-pink-500 text-white flex items-center justify-center text-xs font-medium">
                          <%= index + 1 %>
                        </span>
                        <span class="text-sm text-gray-700 pt-0.5"><%= key %></span>
                      </li>
                    <% end %>
                  </ol>
                <% else %>
                  <p class="text-sm text-gray-700"><%= answer_value %></p>
                <% end %>
              <% elsif type_class && type_class.key == "multiple-multiple" %>
                <% parsed_value = nil %>
                <% if answer_value.is_a?(Hash) || answer_value.respond_to?(:keys) %>
                  <% parsed_value = answer_value %>
                <% elsif answer_value.is_a?(String) %>
                  <% begin %>
                    <% parsed_value = JSON.parse(answer_value) %>
                  <% rescue JSON::ParserError %>
                  <% end %>
                <% end %>

                <% if parsed_value.is_a?(Hash) || parsed_value.respond_to?(:keys) %>
                  <% all_options = question.question_options.pluck(:text) %>
                  <ul class="space-y-2">
                    <% all_options.each do |option| %>
                      <% is_checked = parsed_value.is_a?(Hash) ? (parsed_value[option].present? || parsed_value[option.to_sym].present?) : parsed_value[option].present? %>
                      <li class="flex items-start gap-3">
                        <span class="flex-shrink-0 w-5 h-5 rounded-full <%= is_checked ? 'bg-pink-500' : 'border-2 border-gray-300' %> flex items-center justify-center">
                          <% if is_checked %>
                            <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                            </svg>
                          <% end %>
                        </span>
                        <span class="text-sm <%= is_checked ? 'text-gray-900 font-medium' : 'text-gray-500' %> pt-0.5"><%= option %></span>
                      </li>
                    <% end %>
                  </ul>
                <% else %>
                  <p class="text-sm text-gray-700"><%= answer_value %></p>
                <% end %>
              <% elsif type_class && type_class.key == "multiple-single" %>
                <% if answer_value.is_a?(String) %>
                  <% all_options = question.question_options.pluck(:text) %>
                  <ul class="space-y-2">
                    <% all_options.each do |option| %>
                      <% is_checked = answer_value == option %>
                      <li class="flex items-start gap-3">
                        <span class="flex-shrink-0 w-5 h-5 rounded-full <%= is_checked ? 'bg-pink-500' : 'border-2 border-gray-300' %> flex items-center justify-center">
                          <% if is_checked %>
                            <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                            </svg>
                          <% end %>
                        </span>
                        <span class="text-sm <%= is_checked ? 'text-gray-900 font-medium' : 'text-gray-500' %> pt-0.5"><%= option %></span>
                      </li>
                    <% end %>
                  </ul>
                <% else %>
                  <p class="text-sm text-gray-700"><%= answer_value %></p>
                <% end %>
              <% elsif type_class && type_class.key == "file_upload" %>
                <% answer_obj = @answer_objects["#{question.id}"] %>
                <% if answer_obj&.file&.attached? %>
                  <% if answer_obj.image? %>
                    <%= image_tag answer_obj.file, class: "max-w-sm rounded-lg border border-gray-200" %>
                  <% elsif answer_obj.audio? %>
                    <audio controls class="w-full max-w-md">
                      <source src="<%= url_for(answer_obj.file) %>" type="<%= answer_obj.file.content_type %>">
                      Your browser does not support the audio element.
                    </audio>
                  <% else %>
                    <a href="<%= url_for(answer_obj.file) %>" target="_blank" class="inline-flex items-center gap-2 text-pink-600 hover:text-pink-800 text-sm font-medium">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                      </svg>
                      Download file (<%= number_to_human_size(answer_obj.file.byte_size) %>)
                    </a>
                  <% end %>
                <% else %>
                  <p class="text-sm text-gray-500 italic">File not available</p>
                <% end %>
              <% elsif type_class && type_class.key == "url" %>
                <% if answer_obj = @answer_objects["#{question.id}"] %>
                  <% if answer_obj.youtube_url? && answer_obj.youtube_embed_id %>
                    <div class="aspect-video max-w-md">
                      <iframe class="w-full h-full rounded-lg" src="https://www.youtube.com/embed/<%= answer_obj.youtube_embed_id %>" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                    </div>
                  <% elsif answer_obj.spotify_url? && answer_obj.spotify_embed_uri %>
                    <% spotify_match = answer_value.match(%r{open\.spotify\.com/(track|album|playlist|artist)/([a-zA-Z0-9]+)}) %>
                    <% if spotify_match %>
                      <iframe style="border-radius:12px" src="https://open.spotify.com/embed/<%= spotify_match[1] %>/<%= spotify_match[2] %>" width="100%" height="152" frameBorder="0" allowfullscreen="" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy" class="max-w-md"></iframe>
                    <% end %>
                  <% else %>
                    <a href="<%= answer_value %>" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-pink-600 hover:text-pink-800 text-sm font-medium break-all">
                      <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                      </svg>
                      <%= answer_value %>
                    </a>
                  <% end %>
                <% end %>
              <% else %>
                <p class="text-sm text-gray-700 whitespace-pre-wrap"><%= answer_value %></p>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-500 italic">No answer provided</p>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
