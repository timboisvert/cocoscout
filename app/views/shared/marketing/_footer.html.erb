<%# Shared public marketing footer. %>
<footer class="w-full border-t border-slate-200 bg-white">
  <div class="max-w-7xl mx-auto px-6 py-10">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-2 mb-3">
          <%= image_tag "/icon.png", alt: "CocoScout", class: "h-8 w-8" %>
          <span class="text-lg coustard-regular text-pink-500">CocoScout</span>
        </div>
        <p class="text-sm text-slate-500 max-w-xs">
          The operating platform for live-entertainment producers — and where performers find their next stage.
        </p>
      </div>

      <div>
        <div class="text-xs uppercase tracking-wider text-slate-400 font-bold mb-3">Producers</div>
        <ul class="space-y-2 text-sm text-slate-600">
          <li><%= link_to "For Producers", producers_path, class: "hover:text-pink-500 transition" %></li>
          <li><%= link_to "Start free", signup_path, class: "hover:text-pink-500 transition" %></li>
        </ul>
      </div>

      <div>
        <div class="text-xs uppercase tracking-wider text-slate-400 font-bold mb-3">Performers</div>
        <ul class="space-y-2 text-sm text-slate-600">
          <li><%= link_to "For Performers", performers_path, class: "hover:text-pink-500 transition" %></li>
          <li><%= link_to "Find a Mic", mics_home_path, class: "hover:text-pink-500 transition" %></li>
        </ul>
      </div>

      <div>
        <div class="text-xs uppercase tracking-wider text-slate-400 font-bold mb-3">Company</div>
        <ul class="space-y-2 text-sm text-slate-600">
          <li><%= link_to "Terms", terms_path, class: "hover:text-pink-500 transition" %></li>
          <li><%= link_to "Privacy", privacy_path, class: "hover:text-pink-500 transition" %></li>
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-slate-100 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between text-sm text-slate-500">
      <p>
        A <a href="https://cocorunseverything.com" target="_blank" rel="noopener" class="underline caprasimo-regular hover:text-pink-500 transition">Coco Runs Everything</a> Production
        · © <%= Date.current.year %>
      </p>
      <a href="https://instagram.com/cocoscout" target="_blank" rel="noopener" aria-label="CocoScout on Instagram"
         class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-slate-300 text-slate-600 transition hover:bg-pink-500 hover:border-pink-500 hover:text-white">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="18" height="18" rx="5" ry="5" />
          <path d="M16.5 7.5h.01" />
          <path d="M7 12a5 5 0 1 0 10 0a5 5 0 0 0-10 0" />
        </svg>
      </a>
    </div>
  </div>
</footer>
