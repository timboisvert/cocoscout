<% content_for :title, "Auditions" %>

<div class="w-full mb-10">
  <%= render partial: "shared/notice", locals: { notice: notice } %>
  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      ["Sign-ups", manage_signups_path],
      [@production.name, manage_signups_production_path(@production)]
    ],
    text: "Auditions",
    links: []
  } %>

  <% if @active_audition_cycle.present? %>
    <% if current_user_has_role?(@production) %>
    <%# Reimagined Active Audition Cycle box: shared status panel + casting-complete banner if applicable %>
    <% if @active_audition_cycle.casting_finalized_at.present? && @active_audition_cycle.closes_at.present? %>
      <div class="mb-4 p-4 bg-green-50 border border-green-200 rounded-lg">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <div class="flex-1">
            <h4 class="text-sm font-semibold text-green-900 mb-1">Audition Process Complete</h4>
            <p class="text-sm text-green-800">Casting notifications have been sent. You can archive this cycle and start a new one whenever you're ready.</p>
          </div>
        </div>
      </div>
    <% end %>

    <%= render partial: "cycle_status_panel", locals: { audition_cycle: @active_audition_cycle } %>
    <% end %>

    <%# Four independent topic boxes %>
    <%
      total_signups = @active_audition_cycle.audition_requests.active.count
      scheduled_count = @active_audition_cycle.audition_sessions.joins(:auditions).select('auditions.auditionable_type', 'auditions.auditionable_id').distinct.count
      cast_count = @active_audition_cycle.cast_assignment_stages.where(decision_type: :cast).select(:assignable_type, :assignable_id).distinct.count
      session_count = @active_audition_cycle.audition_sessions.count
      can_manage = current_user_has_role?(@production)
      show_sessions_box = @active_audition_cycle.accepts_in_person_auditions?
    %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">

      <% if can_manage %>
        <%# Form %>
        <%= link_to manage_form_signups_auditions_cycle_path(@production, @active_audition_cycle),
              class: "block bg-white border border-gray-200 rounded-lg shadow-sm p-5 hover:border-pink-400 transition-colors no-underline group cursor-pointer [&_*]:cursor-pointer" do %>
          <div class="flex items-center gap-3 mb-2">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-pink-100 flex items-center justify-center">
              <svg class="w-5 h-5 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9h8" />
              </svg>
            </div>
            <h4 class="text-lg font-semibold text-gray-900 group-hover:text-pink-500 transition-colors">Form</h4>
          </div>
          <p class="text-sm text-gray-600">Customize the questions auditionees answer when signing up.</p>
          <% if @active_audition_cycle.form_reviewed %>
            <p class="text-xs text-green-600 font-medium mt-2">✓ Form finalized</p>
          <% else %>
            <p class="text-xs text-amber-600 font-medium mt-2">Needs review</p>
          <% end %>
        <% end %>
      <% end %>

      <%# Requests %>
      <%= link_to manage_signups_auditions_cycle_requests_path(@production, @active_audition_cycle),
            class: "block bg-white border border-gray-200 rounded-lg shadow-sm p-5 hover:border-pink-400 transition-colors no-underline group cursor-pointer [&_*]:cursor-pointer" do %>
        <div class="flex items-center gap-3 mb-2">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-pink-100 flex items-center justify-center">
            <svg class="w-5 h-5 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
            </svg>
          </div>
          <h4 class="text-lg font-semibold text-gray-900 group-hover:text-pink-500 transition-colors">Requests</h4>
        </div>
        <p class="text-sm text-gray-600">Review who's signed up<%= " and watch their video submissions" if @active_audition_cycle.video_only? %>.</p>
        <p class="text-xs text-gray-500 mt-2"><%= pluralize(total_signups, "request") %></p>
      <% end %>

      <% if show_sessions_box %>
        <%# Sessions %>
        <%= link_to manage_signups_auditions_cycle_sessions_path(@production, @active_audition_cycle),
              class: "block bg-white border border-gray-200 rounded-lg shadow-sm p-5 hover:border-pink-400 transition-colors no-underline group cursor-pointer [&_*]:cursor-pointer" do %>
          <div class="flex items-center gap-3 mb-2">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-pink-100 flex items-center justify-center">
              <svg class="w-5 h-5 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
            </div>
            <h4 class="text-lg font-semibold text-gray-900 group-hover:text-pink-500 transition-colors">Sessions</h4>
          </div>
          <p class="text-sm text-gray-600">Schedule auditionees into sessions and vote during auditions.</p>
          <p class="text-xs text-gray-500 mt-2"><%= pluralize(session_count, "session") %> · <%= scheduled_count %> scheduled</p>
        <% end %>
      <% end %>

      <% if can_manage %>
        <%# Casting %>
        <%= link_to manage_casting_signups_auditions_cycle_path(@production, @active_audition_cycle),
              class: "block bg-white border border-gray-200 rounded-lg shadow-sm p-5 hover:border-pink-400 transition-colors no-underline group cursor-pointer [&_*]:cursor-pointer" do %>
          <div class="flex items-center gap-3 mb-2">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-pink-100 flex items-center justify-center">
              <svg class="w-5 h-5 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h4 class="text-lg font-semibold text-gray-900 group-hover:text-pink-500 transition-colors">Casting</h4>
          </div>
          <p class="text-sm text-gray-600">Decide who's in the cast and notify everyone of the outcome.</p>
          <% if @active_audition_cycle.casting_finalized_at.present? %>
            <p class="text-xs text-green-600 font-medium mt-2">✓ Casting finalized · <%= cast_count %> added</p>
          <% else %>
            <p class="text-xs text-gray-500 mt-2"><%= cast_count %> added to cast so far</p>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <%# Welcome state when no active audition cycle %>

    <% if @wizard_in_progress %>
      <%# Wizard in progress - show continue option %>
      <div class="bg-gradient-to-r from-pink-50 to-rose-50 border border-pink-200 rounded-lg p-5 mb-6">
        <div class="flex items-center justify-between flex-wrap gap-4">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-pink-100 flex items-center justify-center">
              <svg class="w-5 h-5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-base font-semibold text-pink-900">Audition Setup In Progress</h3>
              <p class="text-sm text-pink-700">You have an unfinished audition cycle setup.</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <%= render partial: "shared/button", locals: { text: "Continue Setup", path: manage_signups_auditions_wizard_path(@production), variant: "primary", size: "small", icon: "arrow-right" } %>
            <%= link_to "Start Over", manage_signups_auditions_wizard_cancel_path(@production), method: :delete, data: { turbo_method: :delete, turbo_confirm: "Are you sure? This will discard your progress." }, class: "text-sm text-pink-700 hover:text-pink-900 underline" %>
          </div>
        </div>
      </div>
    <% end %>

    <%# Main welcome card %>
    <div class="bg-gradient-to-br from-pink-50 via-white to-slate-50 border border-gray-200 rounded-lg shadow-sm overflow-hidden">
      <div class="p-6 sm:p-8">
        <%# Header %>
        <div class="text-center mb-6">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-pink-100 mb-3">
            <svg class="w-7 h-7 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-slate-900 coustard-regular">Ready to Hold Auditions?</h2>
          <p class="text-slate-600 mt-2 max-w-lg mx-auto">Set up an audition cycle to start accepting and reviewing submissions for your production.</p>
        </div>

        <%# Features Grid %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6 max-w-2xl mx-auto">
          <div class="flex items-start gap-3 p-3 bg-white/60 rounded-lg">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-pink-100 flex items-center justify-center">
              <svg class="w-4 h-4 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-slate-800">Custom audition forms</p>
              <p class="text-xs text-slate-500">Add your own questions</p>
            </div>
          </div>
          <div class="flex items-start gap-3 p-3 bg-white/60 rounded-lg">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-pink-100 flex items-center justify-center">
              <svg class="w-4 h-4 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-slate-800">Video or in-person</p>
              <p class="text-xs text-slate-500">Flexible audition formats</p>
            </div>
          </div>
          <div class="flex items-start gap-3 p-3 bg-white/60 rounded-lg">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-pink-100 flex items-center justify-center">
              <svg class="w-4 h-4 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-slate-800">Track availability</p>
              <p class="text-xs text-slate-500">Know who can make your shows</p>
            </div>
          </div>
          <div class="flex items-start gap-3 p-3 bg-white/60 rounded-lg">
            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-pink-100 flex items-center justify-center">
              <svg class="w-4 h-4 text-pink-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-medium text-slate-800">Cast notifications</p>
              <p class="text-xs text-slate-500">Send results automatically</p>
            </div>
          </div>
        </div>

        <%# CTA Button %>
        <% if current_user_can_manage?(@production) %>
          <% unless @wizard_in_progress %>
            <div class="text-center">
              <%= render "shared/button",
                text: "Start New Audition Cycle",
                variant: "primary",
                size: "large",
                icon: "plus",
                type: :link,
                path: manage_signups_auditions_wizard_path(@production) %>
            </div>
          <% end %>
        <% else %>
          <p class="text-sm text-slate-500 text-center">Contact a production manager to start a new audition cycle.</p>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Archive bar - always show if user has role, even without active cycle %>
  <% if current_user_has_role?(@production) %>
  <div class="mt-8 p-4 bg-white border border-gray-200 rounded-lg shadow-sm">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
      <div>
        <p class="text-base font-semibold text-gray-700">Archive</p>
        <p class="text-sm text-gray-600">
          <% if @active_audition_cycle.present? %>
            End this audition cycle or view past cycles.
          <% else %>
            View past audition cycles.
          <% end %>
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
        <% if @active_audition_cycle.present? && current_user_can_manage?(@production) %>
          <%= button_to "Archive This Audition Cycle", manage_archive_signups_auditions_cycle_path(@production, @active_audition_cycle), method: :patch, class: "text-sm text-pink-500 underline cursor-pointer whitespace-nowrap", data: { turbo_confirm: "Are you sure? This will close the current audition cycle and you can create a new one." } %>
        <% end %>
        <%= link_to "View Archive", manage_signups_auditions_archive_path(@production), class: "text-sm text-pink-500 underline whitespace-nowrap" %>
      </div>
    </div>
  </div>
  <% end %>
</div>
