<p>Hi,</p>

<p>
  <strong><%= @mic.name %></strong> just posted:
</p>

<% if @announcement.title.present? %>
  <h3 style="margin:0 0 8px 0"><%= @announcement.title %></h3>
<% end %>

<div style="white-space: pre-line; padding: 8px 12px; border-left: 3px solid #ec4899; background: #fdf2f8; margin: 12px 0;">
  <%= @announcement.body %>
</div>

<p>
  <a href="<%= mics_detail_url(@mic.slug) %>">See more on the mic page →</a>
</p>

<p style="margin-top:1.5em; font-size:12px; color:#888;">
  You get this because you're subscribed to alerts for <%= @mic.name %>.
  <a href="<%= mics_alerts_url %>">Manage your alerts</a>.
</p>
