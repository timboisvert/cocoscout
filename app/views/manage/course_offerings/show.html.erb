<% content_for :title, @course_offering.title %>

<div class="w-full mb-10" data-controller="registrant-modal">
  <%= render partial: "shared/notice", locals: { notice: notice, alert: alert } %>

  <%
    status_badge = case @course_offering.status
    when "draft"
      { bg: "bg-gray-100", text: "text-gray-700", label: "Draft" }
    when "open"
      { bg: "bg-green-100", text: "text-green-700", dot: true, label: "Registration Open" }
    when "closed"
      { bg: "bg-amber-100", text: "text-amber-700", label: "Registration Closed" }
    when "archived"
      { bg: "bg-gray-100", text: "text-gray-500", label: "Archived" }
    end

    confirmed_count = @course_offering.confirmed_registrations_count
    has_capacity = @course_offering.capacity.present?
    spots_remaining = @course_offering.spots_remaining
    registration_url = "#{request.base_url}/c/#{@course_offering.short_code}"
  %>

  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      ["Courses", manage_course_offerings_path]
    ],
    text: @course_offering.title,
    links: [
      { text: "Edit", path: manage_edit_course_offering_path(@course_offering) }
    ]
  } %>

  <%# Status bar %>
  <div class="bg-white border border-gray-200 rounded-lg mb-6">
    <div class="px-5 py-4">
      <%# Top row: status badge, capacity, and buttons %>
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-4">
          <span class="inline-flex items-center gap-2 rounded-full px-3 py-1 text-sm font-medium <%= status_badge[:bg] %> <%= status_badge[:text] %>">
            <% if @course_offering.open? %>
              <span class="relative flex h-2.5 w-2.5">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"></span>
              </span>
            <% else %>
              <span class="w-2 h-2 rounded-full bg-<%= @course_offering.draft? ? 'gray' : (@course_offering.closed? ? 'amber' : 'gray') %>-500"></span>
            <% end %>
            <%= status_badge[:label] %>
          </span>
          <span class="text-sm text-gray-500">
            <% if has_capacity %>
              <%= confirmed_count %> of <%= @course_offering.capacity %> spots filled
            <% else %>
              <%= confirmed_count %> registration<%= confirmed_count == 1 ? '' : 's' %>
            <% end %>
          </span>
        </div>
        <%# Desktop buttons %>
        <div class="hidden sm:flex items-center gap-2">
          <% if @course_offering.draft? || @course_offering.closed? %>
            <%= form_with url: manage_open_course_offering_path(@course_offering), method: :post do %>
              <%= render "shared/button", text: "Open Registration", variant: "primary", size: "small", type: :submit %>
            <% end %>
          <% elsif @course_offering.open? %>
            <%= form_with url: manage_close_course_offering_path(@course_offering), method: :post do %>
              <%= render "shared/button", text: "Close Registration", variant: "secondary", size: "small", type: :submit %>
            <% end %>
          <% end %>
        </div>
      </div>
      <%# Mobile buttons %>
      <div class="flex sm:hidden items-center gap-2 mt-3 pt-3 border-t border-gray-100">
        <% if @course_offering.draft? || @course_offering.closed? %>
          <%= form_with url: manage_open_course_offering_path(@course_offering), method: :post do %>
            <%= render "shared/button", text: "Open Registration", variant: "primary", size: "small", type: :submit %>
          <% end %>
        <% elsif @course_offering.open? %>
          <%= form_with url: manage_close_course_offering_path(@course_offering), method: :post do %>
            <%= render "shared/button", text: "Close Registration", variant: "secondary", size: "small", type: :submit %>
          <% end %>
        <% end %>
      </div>
    </div>

    <% if has_capacity %>
      <div class="px-5 pb-4">
        <div class="w-full bg-gray-100 rounded-full h-2">
          <% fill_pct = @course_offering.capacity > 0 ? [(confirmed_count.to_f / @course_offering.capacity * 100), 100].min : 0 %>
          <div class="<%= fill_pct >= 100 ? 'bg-red-500' : 'bg-pink-500' %> h-2 rounded-full transition-all" style="width: <%= fill_pct %>%"></div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <%# Left Column - Registrations %>
    <div class="space-y-6">

      <%# Registrations %>
      <%
        registrant_people = @registrations.map(&:person).uniq(&:id)
        registrant_people_data = registrant_people.map do |person|
          hv = person.safe_headshot_variant(:thumb)
          { id: person.id, name: person.name, headshot: hv ? url_for(hv) : nil }
        end
        contact_registrants_data = {
          recipientType: "batch",
          recipientName: "#{registrant_people.count} #{'registrant'.pluralize(registrant_people.count)}",
          castMembers: registrant_people_data,
          batchPersonIds: registrant_people.map(&:id)
        }
      %>
      <% if registrant_people.any? %>
        <script type="application/json" id="contact-registrants-data-<%= @course_offering.id %>"><%= contact_registrants_data.to_json.html_safe %></script>
      <% end %>
      <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
        <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between">
          <h3 class="text-sm font-medium text-gray-700">Registrations</h3>
          <div class="flex items-center gap-3">
            <% if registrant_people.any? %>
              <%= render "shared/button",
                text: "Contact Registrants",
                variant: "secondary",
                size: "small",
                type: :button,
                data: {
                  controller: "compose-message",
                  action: "click->compose-message#openFromScript",
                  compose_message_script_id_value: "contact-registrants-data-#{@course_offering.id}"
                } %>
            <% end %>
            <span class="text-sm text-gray-500"><%= @registrations.count %> total</span>
          </div>
        </div>
        <% if @registrations.any? %>
          <div class="divide-y divide-gray-200">
            <% @registrations.each do |registration| %>
              <%
                headshot_variant = registration.person.safe_headshot_variant(:thumb)
                headshot_url = headshot_variant ? url_for(headshot_variant) : nil
                can_refund = registration.confirmed? && registration.stripe_payment_intent_id.present?
              %>
              <div class="w-full px-4 py-3 flex items-center justify-between hover:bg-gray-50 transition-colors group">
                <button type="button"
                        class="flex items-center gap-3 cursor-pointer text-left flex-1 min-w-0"
                        data-action="click->registrant-modal#open"
                        data-registrant-name="<%= registration.person.name %>"
                        data-registrant-email="<%= registration.person.email %>"
                        data-registrant-headshot="<%= headshot_url %>"
                        data-registrant-initials="<%= registration.person.initials %>"
                        data-registrant-status="<%= registration.status %>"
                        data-registrant-amount="<%= registration.formatted_amount %>"
                        data-registrant-date="<%= registration.registered_at.strftime("%b %-d, %Y at %-I:%M %p") %>"
                        data-registrant-cancel-url="<%= manage_course_offering_cancel_registration_path(@course_offering, registration) %>"
                        data-registrant-refund-url="<%= manage_course_offering_refund_registration_path(@course_offering, registration) %>"
                        data-registrant-can-refund="<%= can_refund %>">
                  <% if headshot_variant %>
                    <%= image_tag headshot_variant, alt: registration.person.name, class: "w-8 h-8 rounded-lg object-cover" %>
                  <% else %>
                    <div class="w-8 h-8 rounded-lg bg-gray-200 flex items-center justify-center text-gray-600 font-bold text-xs">
                      <%= registration.person.initials %>
                    </div>
                  <% end %>
                  <div>
                    <p class="text-sm font-medium text-gray-900"><%= registration.person.name %></p>
                    <p class="text-xs text-gray-500">
                      Registered <%= registration.registered_at.strftime("%b %-d, %Y") %>
                    </p>
                  </div>
                </button>
                <div class="flex items-center gap-3 flex-shrink-0">
                  <div class="opacity-0 group-hover:opacity-100 transition-opacity">
                    <%= render "shared/button",
                        text: "Contact",
                        variant: "secondary",
                        size: "small",
                        type: :button,
                        data: {
                          controller: "compose-message",
                          action: "click->compose-message#open",
                          compose_message_recipient_type_value: "person",
                          compose_message_recipient_id_value: registration.person.id,
                          compose_message_recipient_name_value: registration.person.name
                        } %>
                  </div>
                  <% case registration.status %>
                  <% when "confirmed" %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">Paid</span>
                  <% when "pending" %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-700">Pending</span>
                  <% when "refunded" %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-700">Refunded</span>
                  <% when "cancelled" %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-500">Cancelled</span>
                  <% end %>
                  <button type="button" class="cursor-pointer"
                          data-action="click->registrant-modal#open"
                          data-registrant-name="<%= registration.person.name %>"
                          data-registrant-email="<%= registration.person.email %>"
                          data-registrant-headshot="<%= headshot_url %>"
                          data-registrant-initials="<%= registration.person.initials %>"
                          data-registrant-status="<%= registration.status %>"
                          data-registrant-amount="<%= registration.formatted_amount %>"
                          data-registrant-date="<%= registration.registered_at.strftime("%b %-d, %Y at %-I:%M %p") %>"
                          data-registrant-cancel-url="<%= manage_course_offering_cancel_registration_path(@course_offering, registration) %>"
                          data-registrant-refund-url="<%= manage_course_offering_refund_registration_path(@course_offering, registration) %>"
                          data-registrant-can-refund="<%= can_refund %>">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </button>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="p-6 text-center text-sm text-gray-500">
            No registrations yet.
          </div>
        <% end %>
      </div>
    </div>

    <%# Right Column - Schedule + Share + Details %>
    <div class="space-y-6">

      <%# Class Schedule %>
      <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
        <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between">
          <span class="text-sm font-medium text-gray-700">Class Schedule</span>
          <span class="text-sm text-gray-500"><%= @sessions.count %> session<%= @sessions.count == 1 ? '' : 's' %></span>
        </div>
        <% if @sessions.any? %>
          <div class="max-h-[280px] overflow-y-auto">
            <div class="p-2 space-y-1">
              <% @sessions.each do |show| %>
                <%= render "shared/show_row", show: show, compact: true, show_location: true %>
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="px-5 py-6 text-center text-gray-500 text-sm">
            No sessions scheduled yet.
          </div>
        <% end %>
      </div>

      <%# Registration Link %>
      <div class="bg-white border border-gray-200 rounded-lg">
        <%= render "shared/card_header", title: "Registration Page" %>
        <div class="p-5 space-y-4">
          <%= render "shared/copy_url", url: registration_url, label: "Public Registration Link", show_qr: true %>

          <% if @course_offering.opens_at.present? || @course_offering.closes_at.present? %>
            <div class="pt-4 border-t border-gray-100 space-y-1">
              <% if @course_offering.opens_at.present? %>
                <p class="text-xs text-gray-500">Opens <span class="font-medium text-gray-700"><%= @course_offering.opens_at.strftime("%b %-d, %Y %-I:%M %p") %></span></p>
              <% end %>
              <% if @course_offering.closes_at.present? %>
                <p class="text-xs text-gray-500">Closes <span class="font-medium text-gray-700"><%= @course_offering.closes_at.strftime("%b %-d, %Y %-I:%M %p") %></span></p>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <% if @course_offering.questionnaire.present? %>
        <%# Questionnaire %>
        <div class="bg-white border border-gray-200 rounded-lg">
          <%= render "shared/card_header", title: "Questionnaire" %>
          <div class="p-5 space-y-3">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-gray-900"><%= @course_offering.questionnaire.title %></p>
                <% stats = @course_offering.questionnaire.cached_response_stats %>
                <p class="text-xs text-gray-500 mt-0.5"><%= stats[:responded] %> response<%= stats[:responded] == 1 ? '' : 's' %></p>
              </div>
              <%= link_to manage_contacts_questionnaire_path(@course_offering.production, @course_offering.questionnaire) do %>
                <%= render "shared/button", text: "View", variant: "secondary", size: "small" %>
              <% end %>
            </div>

            <% if @course_offering.delivery_mode == "manual" %>
              <div class="pt-3 border-t border-gray-100">
                <%= form_with url: manage_course_offering_send_questionnaire_path(@course_offering), method: :post do %>
                  <%= render "shared/button", text: "Send to All Registrants", variant: "secondary", size: "small", type: :submit %>
                <% end %>
              </div>
            <% else %>
              <p class="text-xs text-gray-400">
                Delivery: <%= { "immediate" => "Immediately after registration", "delayed" => "#{@course_offering.delivery_delay_minutes} minutes after registration", "scheduled" => @course_offering.delivery_scheduled_at&.strftime("%b %-d, %Y %-I:%M %p") || "Scheduled", "manual" => "Manual" }[@course_offering.delivery_mode] || "Immediate" %>
              </p>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# Course Details - collapsible %>
      <div class="bg-white border border-gray-200 rounded-lg overflow-hidden" data-controller="disclosure">
        <button type="button"
                class="w-full px-5 py-3 flex items-center justify-between text-left hover:bg-gray-50 cursor-pointer"
                data-action="click->disclosure#toggle">
          <span class="text-sm font-medium text-gray-700">Course Details</span>
          <svg class="w-4 h-4 text-gray-400 transition-transform duration-200" data-disclosure-target="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m19.5 8.25-7.5 7.5-7.5-7.5"/>
          </svg>
        </button>
        <div class="hidden border-t border-gray-100" data-disclosure-target="content">
          <div class="p-4">
            <dl class="space-y-3">
              <div class="flex justify-between">
                <dt class="text-sm text-gray-500">Price</dt>
                <dd class="text-sm font-medium text-gray-900"><%= @course_offering.formatted_price %></dd>
              </div>
              <% if @course_offering.early_bird_price_cents.present? %>
                <div class="flex justify-between">
                  <dt class="text-sm text-gray-500">Early Bird</dt>
                  <dd class="text-sm font-medium text-green-700"><%= @course_offering.formatted_early_bird_price %></dd>
                </div>
                <% if @course_offering.early_bird_deadline.present? %>
                  <div class="flex justify-between">
                    <dt class="text-sm text-gray-500">Early Bird Until</dt>
                    <dd class="text-sm text-gray-900"><%= @course_offering.early_bird_deadline.strftime("%b %-d, %Y") %></dd>
                  </div>
                <% end %>
              <% end %>
              <div class="flex justify-between">
                <dt class="text-sm text-gray-500">Capacity</dt>
                <dd class="text-sm font-medium text-gray-900"><%= @course_offering.capacity.present? ? "#{@course_offering.capacity} spots" : "Unlimited" %></dd>
              </div>
              <% if @course_offering.instructor_name.present? %>
                <div class="flex justify-between">
                  <dt class="text-sm text-gray-500">Instructor</dt>
                  <dd class="text-sm font-medium text-gray-900"><%= @course_offering.instructor_name %></dd>
                </div>
              <% end %>
              <div class="flex justify-between">
                <dt class="text-sm text-gray-500">Currency</dt>
                <dd class="text-sm font-medium text-gray-900 uppercase"><%= @course_offering.currency %></dd>
              </div>
            </dl>
          </div>
        </div>
      </div>

      <%# Linked Contract %>
      <% if @course_offering.contract.present? %>
        <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
          <div class="px-5 py-4 flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-gray-900"><%= @course_offering.contract.contractor_name %></p>
              <% if @course_offering.contract.production_name.present? %>
                <p class="text-xs text-gray-500"><%= @course_offering.contract.production_name %></p>
              <% end %>
            </div>
            <%= link_to manage_contract_path(@course_offering.contract) do %>
              <%= render "shared/button", text: "View Contract", variant: "secondary", size: "small" %>
            <% end %>
          </div>
        </div>
      <% end %>

    </div>
  </div>

  <%# Registrant Modal %>
  <div data-registrant-modal-target="backdrop"
       class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50"
       data-action="click->registrant-modal#backdropClick"></div>

  <div data-registrant-modal-target="modal"
       class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-xl shadow-2xl max-w-md w-full overflow-hidden">
      <%# Header with pink gradient %>
      <div class="bg-gradient-to-r from-pink-500 to-pink-600 px-6 py-4 flex items-center justify-between">
        <h3 class="text-lg font-semibold text-white">Registrant Details</h3>
        <button type="button" data-action="click->registrant-modal#close" class="text-white/80 hover:text-white cursor-pointer">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <%# Person info %>
      <div class="px-6 py-4 border-b border-gray-200">
        <div class="flex items-center gap-4">
          <div data-registrant-modal-target="headshot"></div>
          <div>
            <div class="text-lg font-semibold text-gray-900" data-registrant-modal-target="name"></div>
            <div class="text-sm text-gray-500" data-registrant-modal-target="email"></div>
          </div>
        </div>
      </div>

      <%# Registration details %>
      <div class="px-6 py-4 border-b border-gray-200 space-y-3">
        <div class="flex justify-between items-center">
          <span class="text-sm text-gray-500">Status</span>
          <span data-registrant-modal-target="status"></span>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-sm text-gray-500">Amount</span>
          <span class="text-sm font-medium text-gray-900" data-registrant-modal-target="amount"></span>
        </div>
        <div class="flex justify-between items-center">
          <span class="text-sm text-gray-500">Registered</span>
          <span class="text-sm text-gray-900" data-registrant-modal-target="date"></span>
        </div>
      </div>

      <%# Action panel %>
      <div data-registrant-modal-target="actionPanel" class="px-6 py-4 space-y-2">
        <div data-cancel-section>
          <button type="button"
                  class="w-full flex items-center gap-3 px-4 py-3 rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors text-left cursor-pointer"
                  data-action="click->registrant-modal#showConfirmCancel">
            <div class="flex-shrink-0 w-9 h-9 rounded-full bg-amber-100 flex items-center justify-center">
              <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
              </svg>
            </div>
            <div>
              <div class="text-sm font-medium text-gray-900">Remove without refund</div>
              <div class="text-xs text-gray-500">Remove from course, no refund issued</div>
            </div>
          </button>
        </div>

        <div data-refund-section>
          <button type="button"
                  class="w-full flex items-center gap-3 px-4 py-3 rounded-lg border border-gray-200 hover:bg-gray-50 transition-colors text-left cursor-pointer"
                  data-action="click->registrant-modal#showConfirmRefund">
            <div class="flex-shrink-0 w-9 h-9 rounded-full bg-red-100 flex items-center justify-center">
              <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6" />
              </svg>
            </div>
            <div>
              <div class="text-sm font-medium text-gray-900">Refund & remove</div>
              <div class="text-xs text-gray-500">Issue full refund via Stripe and remove</div>
            </div>
          </button>
        </div>
      </div>

      <%# Confirmation panel (hidden by default) %>
      <div data-registrant-modal-target="confirmPanel" class="hidden px-6 py-4">
        <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-4">
          <h4 class="text-sm font-semibold text-amber-800" data-confirm-title></h4>
          <p class="text-sm text-amber-700 mt-1" data-confirm-message></p>
        </div>
        <div class="flex items-center gap-3">
          <button type="button"
                  class="flex-1 px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 cursor-pointer"
                  data-action="click->registrant-modal#showActionPanel">
            Back
          </button>
          <%= form_with url: "#", method: :post, data: { registrant_modal_target: "cancelForm" }, class: "hidden flex-1" do %>
            <%= render "shared/button", text: "Remove", variant: "secondary", size: "medium", type: :submit, full_width: true %>
          <% end %>
          <%= form_with url: "#", method: :post, data: { registrant_modal_target: "refundForm" }, class: "hidden flex-1" do %>
            <%= render "shared/button", text: "Refund & Remove", variant: "primary", size: "medium", type: :submit, full_width: true %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<%= render "shared/compose_message_modal" %>