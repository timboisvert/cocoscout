<%#
  Advances Production Row — delegates chrome to shared/_production_row.
  Required: summary (Hash with production advance data)

  Panels: Unpaid (we owe them), Outstanding (they owe us), Repaid
%>
<%
  production = summary[:production]
  unpaid_amount = summary[:unpaid_amount] || 0
  unpaid_count = summary[:unpaid_count] || 0
  outstanding_amount = summary[:outstanding_amount] || 0
  outstanding_count = summary[:outstanding_count] || 0
  repaid_count = summary[:repaid_count] || 0

  panels = [
    if unpaid_count > 0
      { label: "Unpaid", value: number_to_currency(unpaid_amount), value_class: "text-sm font-medium text-pink-600", sub: "#{unpaid_count} to pay out" }
    else
      { label: "Unpaid", value: "—", value_class: "text-sm text-gray-400" }
    end,
    if outstanding_count > 0
      { label: "Outstanding", value: number_to_currency(outstanding_amount), value_class: "text-sm font-medium text-amber-600", sub: "#{outstanding_count} to repay" }
    else
      { label: "Outstanding", value: "—", value_class: "text-sm text-gray-400" }
    end,
    if repaid_count > 0
      { label: "Repaid", value: repaid_count, value_class: "text-sm font-medium text-green-600" }
    else
      { label: "Repaid", value: "—", value_class: "text-sm text-gray-400" }
    end
  ]
%>

<%= render "shared/production_row",
  production: production,
  link_path: manage_money_production_advances_path(production),
  panels: panels %>
