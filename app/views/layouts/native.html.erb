<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "CocoScout" %></title>
    <%# viewport-fit=cover exposes safe area insets for iPhone notch + home indicator %>
    <meta name="viewport" content="width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=5">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "actiontext", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= Sentry.get_trace_propagation_meta.html_safe %>
  </head>

  <body class="inter-regular text-slate-700 bg-[#f9f9f7]"
        data-turbo-native="true"
        <% if Current.user.present? %>
          data-controller="user-notifications"
          data-user-notifications-user-id-value="<%= Current.user.id %>"
        <% end %>>

    <%# data-turbo-permanent keeps this element alive when Turbo replaces the page body %>
    <style id="coco-loader-style" data-turbo-permanent>
      @keyframes coco-pulse {
        0%, 100% { transform: scale(1);    opacity: 1;   }
        50%       { transform: scale(0.88); opacity: 0.65; }
      }
    </style>

    <div id="native-loader"
         data-turbo-permanent
         style="display:none; position:fixed; inset:0; z-index:9999;
                background:#f9f9f7; align-items:center; justify-content:center;">
      <img src="/icon.png" alt="" width="80" height="80"
           style="animation: coco-pulse 1.1s ease-in-out infinite;">
    </div>

    <script>
      // Guard: only attach listeners once — Turbo re-runs scripts on each page load
      if (!window._cocoLoaderReady) {
        window._cocoLoaderReady = true;

        function cocoShow() {
          var el = document.getElementById("native-loader");
          if (el) el.style.display = "flex";
        }
        function cocoHide() {
          var el = document.getElementById("native-loader");
          if (el) el.style.display = "none";
        }

        document.addEventListener("turbo:visit",  cocoShow);
        document.addEventListener("turbo:load",   cocoHide);
        document.addEventListener("turbo:render", cocoHide);
      }
    </script>

    <main class="px-4 pt-4 pb-8 overflow-x-hidden" data-controller="bridge--form">
      <div id="flash-messages"></div>
      <%= yield %>
    </main>

    <%# Global modal turbo frames %>
    <%= turbo_frame_tag "contact_modal" %>
    <%= yield :modals %>
  </body>
</html>
