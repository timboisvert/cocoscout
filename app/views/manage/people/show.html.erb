<% content_for :title, @person.name %>

<div class="w-full">

  <%= render partial: "shared/notice", locals: { notice: notice } %>

  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      ["Contacts", manage_contacts_path]
    ],
    text: @person.name,
    links: []
  } %>

  <%# Hero Section %>
  <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-4 mb-4">
    <div class="flex items-center gap-3 sm:gap-4 flex-1 min-w-0">
      <% headshot_variant = @person.safe_headshot_variant(:thumb) %>
      <% if headshot_variant %>
        <%= image_tag headshot_variant, class: "w-12 h-12 rounded-lg object-cover flex-shrink-0" %>
      <% else %>
        <div class="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center text-black font-bold flex-shrink-0">
          <%= @person.initials %>
        </div>
      <% end %>
      <div class="min-w-0 flex-1">
        <div class="flex flex-wrap items-baseline gap-x-2 gap-y-0.5 min-w-0">
          <div class="font-bold text-lg sm:text-xl text-gray-900 truncate"><%= @person.name %></div>
          <% if @person.pronouns.present? %>
            <div class="text-sm text-gray-500 flex-shrink-0">(<%= @person.pronouns %>)</div>
          <% end %>
        </div>
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-gray-500">
          <% if @person.email.present? %>
            <%= link_to @person.email, "mailto:#{@person.email}", class: "text-pink-500 hover:underline truncate max-w-[200px] sm:max-w-none" %>
          <% end %>
          <% if @person.phone.present? %>
            <span class="text-gray-400">·</span>
            <span><%= @person.formatted_phone %></span>
          <% end %>
        </div>
      </div>
    </div>
    <div class="flex-shrink-0 flex items-center gap-2"
         data-controller="compose-message"
         data-compose-message-recipient-type-value="person"
         data-compose-message-recipient-id-value="<%= @person.id %>"
         data-compose-message-recipient-name-value="<%= @person.name %>"
         data-compose-message-recipient-headshot-value="<%= @person.safe_headshot_variant(:thumb) ? url_for(@person.safe_headshot_variant(:thumb)) : '' %>">
      <%= render "shared/button", text: "Contact", variant: "outline", size: "small", type: :button, data: { action: "click->compose-message#open" } %>
      <% if @person.public_key.present? && @person.public_key.match?(/\A[a-z0-9][a-z0-9-]{2,29}\z/) %>
        <%= render partial: "shared/button", locals: { text: "Public Profile", path: public_profile_path(@person.public_key), variant: "outline", size: "small", target: "_blank" } %>
      <% end %>
    </div>
  </div>

  <%# Dashboard tiles %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">

    <%# Headshots %>
    <div class="border border-gray-200 rounded-lg p-3">
      <%= render "shared/media_thumbnails", items: @profile_headshots, type: "headshot", label: "Headshots" %>
    </div>

    <%# Resume %>
    <div class="border border-gray-200 rounded-lg p-3">
      <%= render "shared/media_thumbnails", items: @profile_resumes, type: "resume", label: "Resume" %>
    </div>

    <%# Videos %>
    <% if @profile_videos.any? %>
      <div class="border border-gray-200 rounded-lg p-3">
        <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Videos (<%= @profile_videos.size %>)</div>
        <div class="space-y-1">
          <% @profile_videos.first(5).each do |video| %>
            <%= link_to video.url, target: "_blank", rel: "noopener noreferrer", class: "block truncate" do %>
              <span class="inline-flex items-center gap-1 text-sm text-pink-500 hover:underline">
                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <%= video.title.presence || video.url.truncate(30) %>
              </span>
            <% end %>
          <% end %>
          <% if @profile_videos.size > 5 %>
            <p class="text-xs text-gray-400">+<%= @profile_videos.size - 5 %> more</p>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# Socials %>
    <div class="border border-gray-200 rounded-lg p-3">
      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Socials</div>
      <% if @socials.any? %>
        <div class="space-y-1.5">
          <% @socials.each do |social| %>
            <div class="flex items-center gap-2">
              <span class="text-gray-400 flex-shrink-0"><%= social.icon(18) %></span>
              <% if social.url.present? %>
                <%= link_to social.display_name, social.url, target: "_blank", rel: "noopener", class: "text-sm text-pink-500 hover:underline truncate" %>
              <% else %>
                <span class="text-sm text-gray-700 truncate"><%= social.display_name %></span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-gray-400">None</p>
      <% end %>
    </div>

    <%# Actions %>
    <% if current_user_can_manage? || Current.user&.superadmin? %>
      <div class="border border-gray-200 rounded-lg p-3">
        <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Actions</div>
        <div class="flex flex-wrap gap-2">
          <% if current_user_can_manage? && @person.organizations.include?(Current.organization) %>
            <%= link_to remove_from_organization_manage_person_path(@person), data: { turbo_method: :post, turbo_confirm: "Are you sure you want to remove #{@person.name} from #{Current.organization.name}?" } do %>
              <%= render "shared/button", text: "Remove from org", variant: "outline", size: "small" %>
            <% end %>
          <% end %>
          <% if Current.user&.superadmin? && @person.user %>
            <%= button_to impersonate_user_path, method: :post, params: { email: @person.user.email_address }, class: "inline-block" do %>
              <%= render "shared/button", text: "Impersonate", variant: "outline", size: "small" %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

  </div>

  <%# Producer Notes %>
  <% if current_user_can_manage? || Current.user&.superadmin? %>
    <div class="mt-3 border border-gray-200 rounded-lg p-3">
      <div class="flex items-center justify-between mb-2">
        <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Producer Notes</span>
        <button type="button" onclick="document.getElementById('producer-notes-modal').classList.remove('hidden')" class="text-xs text-pink-500 hover:underline cursor-pointer">Edit</button>
      </div>
      <% if @person.producer_notes.present? %>
        <div class="text-sm text-gray-700 prose prose-sm max-w-none"><%= @person.producer_notes %></div>
      <% else %>
        <p class="text-sm text-gray-400 italic">No notes yet</p>
      <% end %>
    </div>

    <%# Producer Notes Edit Modal %>
    <div id="producer-notes-modal" class="hidden fixed inset-0 z-50 overflow-y-auto" role="dialog" aria-modal="true">
      <div class="fixed inset-0 bg-gray-900/60 backdrop-blur-sm" onclick="document.getElementById('producer-notes-modal').classList.add('hidden')"></div>
      <div class="flex min-h-full items-center justify-center p-4">
        <div class="relative w-full max-w-lg bg-white rounded-xl shadow-2xl" onclick="event.stopPropagation()">
          <div class="flex items-center justify-between px-4 py-3 border-b border-gray-200">
            <h3 class="text-sm font-semibold text-gray-900">Edit Producer Notes</h3>
            <button type="button" onclick="document.getElementById('producer-notes-modal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 cursor-pointer">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>
          <div class="p-4">
            <%= form_with model: [:manage, @person], url: manage_person_path(@person), method: :patch, data: { turbo: true } do |form| %>
              <%= form.rich_text_area :producer_notes, class: "min-h-[150px]" %>
              <div class="mt-3 flex justify-end gap-2">
                <button type="button" onclick="document.getElementById('producer-notes-modal').classList.add('hidden')" class="px-3 py-1.5 text-sm text-gray-600 hover:text-gray-800 cursor-pointer">Cancel</button>
                <%= render "shared/button", text: "Save", variant: "primary", size: "small", type: :submit %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

</div>

<%# Compose Message Modal %>
<%= render "shared/compose_message_modal" %>
