<% content_for :title, "CocoScout for Producers — the operating platform for live entertainment" %>

<div class="min-h-screen bg-[#f9f9f7]">
  <%= render "shared/marketing/header" %>

  <main class="flex flex-col min-w-full">
    <!-- Hero Section -->
    <section class="w-full px-6 py-16 sm:py-20 bg-gradient-to-br from-pink-50 via-white to-slate-50">
      <div class="max-w-7xl mx-auto">
        <div class="text-center max-w-4xl mx-auto">
          <div class="inline-flex items-center gap-2 bg-pink-100 text-pink-600 px-4 py-2 rounded-full text-sm font-medium mb-8">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"/>
            </svg>
            Shows · theaters · courses · open mics
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 mb-6 coustard-regular leading-tight">
            The operating platform for<br>live entertainment.
          </h1>

          <p class="text-lg sm:text-xl text-slate-600 mb-10 leading-relaxed">
            Whether you run a show, a theater, a class, or a weekly open mic — CocoScout is the producer's platform.
            Auditions, casting, sign-ups, scheduling, staffing, payouts, and your whole team, in one place.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <%= render "shared/button", text: "Start Your Production", path: signup_path, variant: "primary", size: "large" %>
            <%= render "shared/button", text: "See Features", path: "#features", variant: "secondary", size: "large" %>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="w-full bg-white border-t border-slate-200">
      <div class="text-center px-6 py-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4 coustard-regular">Everything you need to run a show</h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">Replace the spreadsheets, email chains, and group texts with one unified platform.</p>
      </div>

      <!-- Feature Showcase 1: Auditions -->
      <div class="w-full bg-gradient-to-br from-pink-50 to-white px-6 py-16">
        <div class="max-w-7xl mx-auto">
