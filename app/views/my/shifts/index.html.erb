<% content_for :title, "My Shifts" %>

<div class="w-full">

  <%= render partial: "shared/notice", locals: { notice: notice } %>

  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [],
    text: "My Shifts",
    links: []
  } %>

  <%# === Availability summary + editor === %>
  <div data-controller="unavailability"
       data-unavailability-entries-value="<%= @unavailability_entries.to_json %>"
       data-unavailability-create-url-value="<%= my_create_shift_unavailability_path %>"
       class="border border-gray-200 rounded-lg bg-white px-4 py-3 mb-6">
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0" data-unavailability-target="summary"></div>
      <button type="button" data-action="click->unavailability#open"
              class="flex-shrink-0 bg-pink-500 hover:bg-pink-600 text-white text-sm font-medium rounded px-3 py-1.5 cursor-pointer transition-colors">
        Manage availability
      </button>
    </div>

    <%# Modal %>
    <div data-unavailability-target="modal"
         class="hidden fixed inset-0 z-[60] bg-black/60 backdrop-blur-sm overflow-y-auto"
         data-action="click->unavailability#backdropClose keydown.esc@window->unavailability#close">
      <div class="flex min-h-full items-start justify-center p-4 py-12">
        <div class="relative w-full max-w-md bg-white rounded-xl shadow-2xl" data-action="click->unavailability#stopPropagation">
          <div class="flex items-center justify-between px-5 py-4 border-b border-gray-200">
            <div>
              <h3 class="text-base font-semibold text-gray-900">Mark your unavailability</h3>
              <p class="text-xs text-gray-500">Block off the days you can't work. Unmarked dates assume availability.</p>
            </div>
            <button type="button" data-action="click->unavailability#close" class="text-gray-400 hover:text-gray-600 cursor-pointer">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>

          <div class="px-5 py-4">
            <%# Month nav %>
            <div class="flex items-center justify-between mb-3">
              <button type="button" data-action="click->unavailability#prevMonth"
                      class="px-2.5 py-1 text-sm rounded border border-gray-300 bg-white hover:border-gray-400 cursor-pointer">←</button>
              <div class="font-semibold text-gray-900" data-unavailability-target="monthLabel"></div>
              <button type="button" data-action="click->unavailability#nextMonth"
                      class="px-2.5 py-1 text-sm rounded border border-gray-300 bg-white hover:border-gray-400 cursor-pointer">→</button>
            </div>

            <div class="flex items-center justify-between mb-2">
              <button type="button" data-action="click->unavailability#toggleMulti" data-unavailability-target="multiButton"
                      class="text-xs font-medium px-2 py-1 rounded border border-gray-300 text-gray-600 hover:border-pink-400 cursor-pointer">
                Select multiple days
              </button>
              <div class="flex items-center gap-2 text-[10px] text-gray-500">
                <span class="inline-flex items-center gap-1"><span class="w-2.5 h-2.5 rounded bg-red-200"></span> All day</span>
                <span class="inline-flex items-center gap-1"><span class="w-2.5 h-2.5 rounded bg-amber-200"></span> Afternoon</span>
                <span class="inline-flex items-center gap-1"><span class="w-2.5 h-2.5 rounded bg-indigo-200"></span> Evening</span>
              </div>
            </div>

            <div class="grid grid-cols-7 gap-1 text-center text-[11px] font-medium text-gray-400 mb-1">
              <% %w[Sun Mon Tue Wed Thu Fri Sat].each do |d| %><div><%= d %></div><% end %>
            </div>
            <div class="grid grid-cols-7 gap-1" data-unavailability-target="calendar"></div>

            <%# Scope chooser — appears once one or more days are selected %>
            <div data-unavailability-target="actionBar" class="hidden mt-4 pt-3 border-t border-gray-100">
              <div class="text-xs text-gray-600 mb-2" data-unavailability-target="selectedCount"></div>
              <div class="flex flex-wrap gap-2">
                <button type="button" data-action="click->unavailability#apply" data-scope="all_day"
                        class="text-xs font-medium px-3 py-1.5 rounded bg-red-500 hover:bg-red-600 text-white cursor-pointer">Unavailable All Day</button>
                <button type="button" data-action="click->unavailability#apply" data-scope="day_shifts"
                        class="text-xs font-medium px-3 py-1.5 rounded bg-amber-500 hover:bg-amber-600 text-white cursor-pointer">Unavailable Afternoon</button>
                <button type="button" data-action="click->unavailability#apply" data-scope="evening_shifts"
                        class="text-xs font-medium px-3 py-1.5 rounded bg-indigo-500 hover:bg-indigo-600 text-white cursor-pointer">Unavailable Evening</button>
                <button type="button" data-action="click->unavailability#apply" data-scope="clear"
                        class="text-xs font-medium px-3 py-1.5 rounded border border-gray-300 text-gray-600 hover:bg-gray-100 cursor-pointer">Clear</button>
                <button type="button" data-action="click->unavailability#cancelSelect"
                        class="text-xs font-medium px-3 py-1.5 rounded text-gray-500 hover:text-gray-700 cursor-pointer">Cancel</button>
              </div>
            </div>

            <p class="text-[11px] text-gray-500 mt-3">Tap a day to select it, then choose a time. Use "Select multiple days" to block several at once.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <% if @has_any %>
    <p class="text-sm text-gray-500 mb-4">Your upcoming house staffing shifts.</p>

    <div class="space-y-6">
      <% @rows_by_day.each do |day, rows| %>
        <div>
          <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">
            <%= day.strftime("%A, %B %-d, %Y") %>
          </h2>
          <div class="space-y-2">
            <% rows.each do |row| %>
              <% shift = row[:shift] %>
              <% person = row[:person] %>
              <% assignment = row[:assignment] %>
              <% org = shift.organization %>
              <% location_name = shift.source.try(:location).try(:name) %>
              <div class="p-3 bg-white border border-gray-200 rounded-lg shadow-sm">
                <div class="flex items-center gap-4">
                  <%# Date block %>
                  <div class="flex-shrink-0 w-14 text-center">
                    <div class="text-xs font-semibold text-pink-600 uppercase"><%= shift.starts_at.strftime("%b") %></div>
                    <div class="text-2xl font-bold text-gray-900"><%= shift.starts_at.strftime("%-d") %></div>
                    <div class="text-xs text-gray-500"><%= shift.starts_at.strftime("%a") %></div>
                  </div>

                  <%# Details %>
                  <div class="flex-1 min-w-0">
                    <div class="font-medium text-gray-900 truncate"><%= shift.house_role.name %></div>
                    <div class="text-sm text-gray-600">
                      <span class="tabular-nums"><%= shift.starts_at.strftime("%-l:%M %p") %>–<%= shift.ends_at.strftime("%-l:%M %p") %></span>
                      <% if org %>· <%= org.name %><% end %>
                    </div>
                    <% if location_name.present? %>
                      <div class="text-xs text-gray-500 truncate mt-0.5"><%= location_name %></div>
                    <% end %>
                  </div>

                  <%# Response status + which profile (when the user has more than one) %>
                  <div class="flex-shrink-0 text-right">
                    <% case assignment.response_status %>
                    <% when :accepted %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded bg-green-100 text-green-700 text-xs font-medium">Accepted</span>
                    <% when :declined %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded bg-red-100 text-red-700 text-xs font-medium">Declined</span>
                    <% else %>
                      <span class="inline-flex items-center px-2 py-0.5 rounded bg-gray-100 text-gray-600 text-xs font-medium">Scheduled</span>
                    <% end %>
                    <% if @people.size > 1 %>
                      <div class="text-[11px] text-gray-400 mt-1 truncate max-w-[8rem]"><%= person.name %></div>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-500 text-sm">You don't have any upcoming shifts.</p>
  <% end %>

</div>
