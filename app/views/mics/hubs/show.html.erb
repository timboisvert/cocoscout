<%
  mics_seo title: "#{@hub.name} captain — Find a Mic",
            description: "City captain dashboard for #{@hub.name}, #{@hub.state}."
%>
<%= render "mics/header" %>

<main class="w-full bg-white">
  <%# Hero %>
  <section class="bg-pink-500 text-white border-b border-pink-600">
    <div class="w-full px-4 sm:px-8 py-6 sm:py-10">
      <div class="text-xs uppercase tracking-wider text-pink-100 font-bold mb-2">City captain</div>
      <h1 class="coustard-regular text-3xl sm:text-5xl"><%= @hub.name %>, <%= @hub.state %></h1>
      <p class="mt-2 text-pink-100 text-sm sm:text-base max-w-3xl">
        Same powers as a superadmin — scoped to this city. Edit any mic, post status, approve community input.
      </p>
      <div class="mt-4 flex flex-wrap gap-2 text-sm">
        <%= link_to "Public hub page →", mics_city_path(@hub.slug),
              class: "px-3 py-1.5 bg-white text-pink-700 font-bold hover:bg-pink-50 rounded" %>
      </div>
    </div>
  </section>

  <% if flash[:notice] %>
    <div class="w-full px-4 sm:px-8 py-3 bg-emerald-50 border-b border-emerald-200 text-emerald-700 text-sm"><%= flash[:notice] %></div>
  <% end %>

  <div id="queue-top" class="w-full px-4 sm:px-8 py-6">

    <%# ── Queue chips strip — only types with > 0 are shown. ── %>
    <%
      pending_total = @pending_mic_ct + @pending_claim_ct +
                      @pending_challenge_ct + @pending_suggestion_ct
    %>
    <% if pending_total.zero? %>
      <div class="mb-5 inline-flex items-center gap-2 px-3 py-1.5 bg-emerald-50 border border-emerald-200 text-emerald-700 text-xs font-bold rounded">
        <span>✓</span><span>Queue is clear — nothing pending in <%= @hub.name %>.</span>
      </div>
    <% else %>
      <div class="mb-5 flex flex-wrap gap-2 items-center">
        <span class="text-xs uppercase tracking-wider text-gray-500 font-bold">Needs review:</span>
        <% [
          [ "submissions", @pending_mic_ct,        "submission" ],
          [ "claims",      @pending_claim_ct,      "claim" ],
          [ "challenges",  @pending_challenge_ct,  "challenge" ],
          [ "suggestions", @pending_suggestion_ct, "suggestion" ]
        ].each do |anchor, count, singular| %>
          <% next if count.zero? %>
          <a href="#<%= anchor %>" class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-pink-50 hover:bg-pink-100 border border-pink-200 text-pink-700 text-xs font-bold rounded">
            <%= count %> <%= count == 1 ? singular : singular.pluralize %>
          </a>
        <% end %>
      </div>
    <% end %>

    <%# ── Pending submissions ── %>
    <% if @pending_mics.any? %>
      <section id="submissions" class="mb-8">
        <h2 class="text-sm uppercase tracking-wider text-gray-700 font-bold mb-3">
          Pending submissions <span class="ml-2 text-xs text-gray-500"><%= @pending_mic_ct %></span>
        </h2>
        <ul class="space-y-3">
          <% @pending_mics.each do |mic| %>
            <% submitter = mic.mic_edits.find { |e| e.field == "submission" }&.editor %>
            <li class="bg-white border border-gray-200 rounded p-4">
              <div class="flex items-baseline justify-between gap-3 flex-wrap mb-2">
                <div class="min-w-0">
                  <div class="font-bold text-gray-900"><%= mic.name %></div>
                  <div class="text-xs text-gray-500"><%= mic.venue&.name %> · <%= mic.venue&.neighborhood_city %></div>
                </div>
                <div class="text-xs text-gray-500 tabular-nums shrink-0">
                  Submitted <%= mic.created_at.strftime("%b %-d, %-l:%M%p") %><% if submitter %> · by <%= submitter.email_address %><% end %>
                </div>
              </div>
              <dl class="grid grid-cols-2 sm:grid-cols-4 gap-3 text-xs text-gray-700 my-3">
                <% if mic.day_of_week %>
                  <div><dt class="text-[10px] uppercase tracking-wider text-gray-500 font-bold">When</dt><dd><%= mics_recurrence_day_label(mic) %><% if mic.starts_local_time %> · <%= mic.starts_local_time.strftime("%-l:%M %p") %><% end %></dd></div>
                <% end %>
                <% if mic.format.present? %>
                  <div><dt class="text-[10px] uppercase tracking-wider text-gray-500 font-bold">Format</dt><dd><%= mics_format_label(mic.format) %></dd></div>
                <% end %>
                <% if mic.signup_method.present? %>
                  <div><dt class="text-[10px] uppercase tracking-wider text-gray-500 font-bold">Sign-up</dt><dd><%= mics_signup_method_label(mic.signup_method) %><%= " · Bucket draw" if mic.bucket_draw %></dd></div>
                <% end %>
                <% if mic.signup_opens_at_text.present? %>
                  <div><dt class="text-[10px] uppercase tracking-wider text-gray-500 font-bold">Opens</dt><dd><%= mic.signup_opens_at_text %></dd></div>
                <% end %>
              </dl>
              <% if mic.blurb.present? %>
                <p class="text-sm text-gray-700 whitespace-pre-line mb-3"><%= mic.blurb %></p>
              <% end %>
              <div class="flex items-center gap-2 flex-wrap pt-2 border-t border-gray-100">
                <%# Pending submissions aren't public yet — go to the
                    edit/preview page, never the public URL. %>
                <%= link_to "Edit / preview", mics_owner_mic_path(mic.slug),
                      class: "text-xs text-pink-600 font-bold hover:underline" %>
                <%= button_to "Approve", mics_hub_approve_submission_path(@hub.slug, id: mic.id), method: :post,
                      class: "ml-auto cursor-pointer px-3 py-1.5 bg-emerald-500 hover:bg-emerald-600 text-white text-xs font-bold rounded" %>
                <%= button_to "Reject", mics_hub_reject_submission_path(@hub.slug, id: mic.id), method: :post,
                      data: { turbo_confirm: "Reject this submission?" },
                      class: "cursor-pointer px-3 py-1.5 bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-xs font-bold rounded" %>
              </div>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <%# ── Pending claims ── %>
    <% if @pending_claims.any? %>
      <section id="claims" class="mb-8">
        <h2 class="text-sm uppercase tracking-wider text-gray-700 font-bold mb-3">
          Pending claims <span class="ml-2 text-xs text-gray-500"><%= @pending_claim_ct %></span>
        </h2>
        <ul class="space-y-3">
          <% @pending_claims.each do |claim| %>
            <li class="bg-white border border-gray-200 rounded p-4">
              <div class="flex items-baseline justify-between gap-3 flex-wrap mb-2">
                <div class="min-w-0">
                  <div class="font-bold text-gray-900"><%= claim.mic.name %></div>
                  <div class="text-xs text-gray-500"><%= claim.mic.venue&.name %> · <%= claim.mic.venue&.neighborhood_city %></div>
                </div>
                <div class="text-xs text-gray-500 tabular-nums shrink-0">Filed <%= claim.created_at.strftime("%b %-d, %-l:%M%p") %></div>
              </div>
              <dl class="grid grid-cols-1 sm:grid-cols-3 gap-3 text-xs text-gray-700 my-3">
                <div><dt class="text-[10px] uppercase tracking-wider text-gray-500 font-bold">Claimant</dt><dd><%= claim.claimant.email_address %></dd></div>
                <div><dt class="text-[10px] uppercase tracking-wider text-gray-500 font-bold">Requested role</dt><dd class="font-bold"><%= claim.role.humanize %></dd></div>
                <% if claim.proof["evidence_url"].present? %>
                  <div><dt class="text-[10px] uppercase tracking-wider text-gray-500 font-bold">Evidence</dt><dd><a href="<%= claim.proof["evidence_url"] %>" target="_blank" rel="noopener" class="text-pink-600 hover:underline">View →</a></dd></div>
                <% end %>
              </dl>
              <% if claim.proof["note"].present? %>
                <p class="text-sm text-gray-800 whitespace-pre-line bg-gray-50 border border-gray-200 px-3 py-2 rounded mb-3"><%= claim.proof["note"] %></p>
              <% end %>
              <div class="flex items-center gap-2 flex-wrap pt-2 border-t border-gray-100">
                <%= link_to "Open mic", mics_detail_path(claim.mic.slug), target: "_blank", class: "text-xs text-pink-600 font-bold hover:underline" %>
                <%= button_to "Approve claim", mics_hub_approve_claim_path(@hub.slug, id: claim.id), method: :post,
                      class: "ml-auto cursor-pointer px-3 py-1.5 bg-emerald-500 hover:bg-emerald-600 text-white text-xs font-bold rounded" %>
                <%= button_to "Reject", mics_hub_reject_claim_path(@hub.slug, id: claim.id), method: :post,
                      data: { turbo_confirm: "Reject this claim?" },
                      class: "cursor-pointer px-3 py-1.5 bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-xs font-bold rounded" %>
              </div>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <%# ── Pending challenges ── %>
    <% if @pending_challenges.any? %>
      <section id="challenges" class="mb-8">
        <h2 class="text-sm uppercase tracking-wider text-gray-700 font-bold mb-3">
          Pending challenges <span class="ml-2 text-xs text-gray-500"><%= @pending_challenge_ct %></span>
        </h2>
        <ul class="space-y-3">
          <% @pending_challenges.each do |ch| %>
            <li class="bg-white border border-gray-200 rounded p-4">
              <div class="flex items-baseline justify-between gap-3 flex-wrap mb-2">
                <div class="min-w-0">
                  <div class="font-bold text-gray-900"><%= ch.mic.name %></div>
                  <div class="text-xs text-gray-500"><%= ch.mic.venue&.name %> · <%= ch.mic.venue&.neighborhood_city %></div>
                </div>
                <div class="text-xs text-gray-500 tabular-nums shrink-0">Filed <%= ch.created_at.strftime("%b %-d, %-l:%M%p") %></div>
              </div>
              <dl class="grid grid-cols-1 sm:grid-cols-2 gap-3 text-xs text-gray-700 my-3">
                <div><dt class="text-[10px] uppercase tracking-wider text-gray-500 font-bold">Challenger</dt><dd><%= ch.challenger.email_address %></dd></div>
                <div><dt class="text-[10px] uppercase tracking-wider text-gray-500 font-bold">Current lead</dt><dd><%= ch.target&.email_address || "(none — mic was unclaimed)" %></dd></div>
              </dl>
              <% if ch.reason.present? %>
                <p class="text-sm text-gray-800 whitespace-pre-line bg-gray-50 border border-gray-200 px-3 py-2 rounded mb-3"><%= ch.reason %></p>
              <% end %>
              <div class="flex items-center gap-2 flex-wrap pt-2 border-t border-gray-100">
                <%= link_to "Open mic", mics_detail_path(ch.mic.slug), target: "_blank", class: "text-xs text-pink-600 font-bold hover:underline" %>
                <span class="ml-auto flex items-center gap-1 flex-wrap">
                  <%= button_to "Replace lead", mics_hub_resolve_challenge_path(@hub.slug, id: ch.id, outcome: "replaced"), method: :post,
                        data: { turbo_confirm: "Make #{ch.challenger.email_address} the new lead?" },
                        class: "cursor-pointer px-3 py-1.5 bg-emerald-500 hover:bg-emerald-600 text-white text-xs font-bold rounded" %>
                  <%= button_to "Add as co-owner", mics_hub_resolve_challenge_path(@hub.slug, id: ch.id, outcome: "co_produce"), method: :post,
                        class: "cursor-pointer px-3 py-1.5 bg-gray-900 hover:bg-black text-white text-xs font-bold rounded" %>
                  <%= button_to "Reject", mics_hub_resolve_challenge_path(@hub.slug, id: ch.id, outcome: "rejected"), method: :post,
                        class: "cursor-pointer px-3 py-1.5 bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-xs font-bold rounded" %>
                </span>
              </div>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <%# ── Pending suggestions ── %>
    <% if @pending_suggestions.any? %>
      <section id="suggestions" class="mb-10">
        <h2 class="text-sm uppercase tracking-wider text-gray-700 font-bold mb-3">
          Pending suggestions <span class="ml-2 text-xs text-gray-500"><%= @pending_suggestion_ct %></span>
        </h2>
        <ul class="space-y-3">
          <% @pending_suggestions.each do |s| %>
            <li class="bg-white border border-gray-200 rounded p-4">
              <div class="flex items-baseline justify-between gap-3 flex-wrap mb-2">
                <div class="min-w-0">
                  <div class="font-bold text-gray-900"><%= s.mic.name %></div>
                  <div class="text-xs text-gray-500"><%= s.mic.venue&.name %> · <%= s.mic.venue&.neighborhood_city %> · from <%= s.submitter&.email_address || s.submitter_email %></div>
                </div>
                <div class="text-xs text-gray-500 tabular-nums shrink-0"><%= s.created_at.strftime("%b %-d, %-l:%M%p") %></div>
              </div>
              <% if s.note.present? %>
                <p class="text-sm text-gray-800 whitespace-pre-line bg-gray-50 border border-gray-200 px-3 py-2 rounded my-3"><%= s.note %></p>
              <% end %>
              <div class="flex items-center gap-2 flex-wrap pt-2 border-t border-gray-100">
                <%= link_to "Open mic", mics_detail_path(s.mic.slug), target: "_blank", class: "text-xs text-pink-600 font-bold hover:underline" %>
                <%= link_to "Edit", mics_owner_mic_path(s.mic.slug), class: "text-xs text-gray-700 hover:text-pink-600 underline" %>
                <%= button_to "Approve", mics_hub_approve_suggestion_path(@hub.slug, id: s.id), method: :post,
                      class: "ml-auto cursor-pointer px-3 py-1.5 bg-emerald-500 hover:bg-emerald-600 text-white text-xs font-bold rounded" %>
                <%= button_to "Reject", mics_hub_reject_suggestion_path(@hub.slug, id: s.id), method: :post,
                      class: "cursor-pointer px-3 py-1.5 bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-xs font-bold rounded" %>
              </div>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <%# ── Search bar ── %>
    <h2 class="text-sm uppercase tracking-wider text-gray-700 font-bold mb-3">All mics in <%= @hub.name %></h2>
    <section class="bg-white border border-gray-200 mb-4 rounded">
      <%= form_with url: mics_captain_hub_path(@hub.slug), method: :get, local: true, class: "px-4 sm:px-5 py-4" do %>
        <div class="grid grid-cols-1 sm:grid-cols-12 gap-3 items-end">
          <label class="block text-sm sm:col-span-9">
            <span class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-1">Search</span>
            <input type="search" name="q" value="<%= params[:q] %>"
                   placeholder="Mic name, venue, city, or slug"
                   class="w-full px-3 py-2 text-sm border border-gray-300 focus:border-pink-500 outline-none rounded">
          </label>
          <div class="sm:col-span-3 flex gap-2">
            <button type="submit" class="cursor-pointer flex-1 px-4 py-2 bg-pink-500 hover:bg-pink-600 text-white text-sm font-bold rounded">Search</button>
            <% if params[:q].present? %>
              <%= link_to "Clear", mics_captain_hub_path(@hub.slug), class: "px-3 py-2 text-xs text-gray-500 hover:text-pink-600 underline self-center" %>
            <% end %>
          </div>
        </div>
        <div class="mt-3 flex items-center gap-3 flex-wrap">
          <span class="text-xs text-gray-500">Sort:</span>
          <%= link_to "Name", mics_captain_hub_path(@hub.slug, request.query_parameters.merge(sort: "name")),
                class: "text-xs font-bold #{@sort == "name" ? "text-pink-600 underline" : "text-gray-500 hover:text-pink-600"}" %>
          <%= link_to "Newest first", mics_captain_hub_path(@hub.slug, request.query_parameters.merge(sort: "created_desc")),
                class: "text-xs font-bold #{@sort == "created_desc" ? "text-pink-600 underline" : "text-gray-500 hover:text-pink-600"}" %>
          <span class="ml-auto text-xs text-gray-500"><%= pluralize(@mics_total, "mic") %><% if @mics_total != @mics_all.size %> · showing top <%= @mics_all.size %><% end %></span>
        </div>
      <% end %>
    </section>

    <%# ── Unclaimed / Claimed split (no search) OR plain search results ── %>
    <% if params[:q].blank? %>
      <%# Unclaimed mics — the captain's main job. %>
      <% if @unclaimed_mics.any? %>
        <section class="mb-8">
          <div class="flex items-baseline justify-between gap-3 flex-wrap mb-3">
            <div>
              <h2 class="text-sm uppercase tracking-wider text-gray-700 font-bold">Unclaimed mics</h2>
              <p class="text-xs text-gray-500 mt-1">Live listings with no owner attached. You own these by default.</p>
            </div>
            <span class="text-xs uppercase tracking-wider text-gray-500 font-bold"><%= pluralize(@unclaimed_mics.size, "mic") %></span>
          </div>
          <ul class="divide-y divide-gray-100 border border-gray-200 rounded overflow-hidden bg-white">
            <% @unclaimed_mics.each do |mic| %>
              <li class="px-4 sm:px-6 py-3 flex items-baseline gap-3 flex-wrap hover:bg-pink-50">
                <span class="tabular-nums w-24 shrink-0 text-xs text-gray-500">
                  <%= mic.day_of_week ? mics_day_short(mic.day_of_week) : "—" %>
                  <%= mic.starts_local_time&.strftime("%-l:%M%p")&.downcase %>
                </span>
                <span class="flex-1 min-w-0">
                  <%= link_to mic.name, mics_detail_path(mic.slug), class: "font-bold text-gray-900 hover:underline" %>
                  <span class="block text-xs text-gray-500 truncate"><%= mic.venue.name %> · <%= mic.venue.neighborhood_city %></span>
                </span>
                <%= link_to "Manage →", mics_owner_mic_path(mic.slug),
                      class: "text-xs text-pink-600 font-bold hover:underline shrink-0" %>
              </li>
            <% end %>
          </ul>
        </section>
      <% end %>

      <% if @claimed_mics.any? %>
        <section class="mb-8">
          <div class="flex items-baseline justify-between gap-3 flex-wrap mb-3">
            <div>
              <h2 class="text-sm uppercase tracking-wider text-gray-700 font-bold">Claimed mics</h2>
              <p class="text-xs text-gray-500 mt-1">Owners manage these. You can still edit if needed.</p>
            </div>
            <span class="text-xs uppercase tracking-wider text-gray-500 font-bold"><%= pluralize(@claimed_mics.size, "mic") %></span>
          </div>
          <ul class="divide-y divide-gray-100 border border-gray-200 rounded overflow-hidden bg-white">
            <% @claimed_mics.each do |mic| %>
              <li class="px-4 sm:px-6 py-3 flex items-baseline gap-3 hover:bg-pink-50">
                <span class="flex-1 min-w-0">
                  <%= link_to mic.name, mics_detail_path(mic.slug), class: "font-bold text-gray-900 hover:underline" %>
                  <span class="block text-xs text-gray-500 truncate"><%= mic.venue.name %> · <%= pluralize(mic.mic_producers.size, "producer") %></span>
                </span>
                <%= link_to "Manage →", mics_owner_mic_path(mic.slug),
                      class: "text-xs text-pink-600 font-bold hover:underline shrink-0" %>
              </li>
            <% end %>
          </ul>
        </section>
      <% end %>
    <% else %>
      <%# Search results — flat list. %>
      <section class="mb-8 bg-white border border-gray-200 rounded overflow-hidden">
        <% if @mics_all.any? %>
          <ul class="divide-y divide-gray-100">
            <% @mics_all.each do |mic| %>
              <% claimed = mic.mic_producers.any? %>
              <li class="px-4 sm:px-6 py-3 flex items-baseline gap-3 flex-wrap hover:bg-pink-50">
                <span class="flex-1 min-w-0">
                  <%= link_to mic.name, mics_detail_path(mic.slug), class: "font-bold text-gray-900 hover:underline" %>
                  <span class="block text-xs text-gray-500 truncate"><%= mic.venue.name %> · <%= mic.venue.neighborhood_city %></span>
                </span>
                <span class="inline-flex items-center text-[10px] uppercase tracking-wider px-2 py-0.5 font-bold rounded shrink-0
                    <%= mic.pending ? "bg-amber-100 text-amber-700" :
                          (mic.ended? ? "bg-gray-100 text-gray-500" :
                            (mic.paused? ? "bg-amber-50 text-amber-700" :
                              (claimed ? "bg-emerald-100 text-emerald-700" : "bg-pink-100 text-pink-700"))) %>">
                  <%= mic.pending ? "Pending" : (mic.ended? ? "Ended" : (mic.paused? ? "Paused" : (claimed ? "Claimed" : "Unclaimed"))) %>
                </span>
                <%= link_to "Edit →", mics_owner_mic_path(mic.slug),
                      class: "text-xs text-pink-600 font-bold hover:underline shrink-0" %>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="px-4 py-10 text-center text-sm text-gray-500">
            No mics in <%= @hub.name %> match "<%= params[:q] %>".
            <%= link_to "Clear search", mics_captain_hub_path(@hub.slug), class: "text-pink-600 underline" %>.
          </p>
        <% end %>
      </section>
    <% end %>

    <%# ── Recent activity (last 15 edits in the hub) ── %>
    <% if @recent_edits.any? %>
      <section class="mb-8">
        <h2 class="text-sm uppercase tracking-wider text-gray-700 font-bold mb-3">Recent activity</h2>
        <ul class="text-xs text-gray-600 space-y-0.5 bg-white border border-gray-200 rounded p-3 max-w-3xl">
          <% @recent_edits.each do |e| %>
            <li class="tabular-nums">
              <%= e.created_at.strftime("%Y-%m-%d %H:%M") %> ·
              <%= link_to e.mic.name, mics_detail_path(e.mic.slug), class: "text-pink-600 hover:underline" %> ·
              <%= e.source %> · <%= e.field %><% if e.new_value.present? %> → <%= e.new_value.truncate(60) %><% end %>
            </li>
          <% end %>
        </ul>
      </section>
    <% end %>
  </div>
</main>

<%= render "mics/site_footer" %>
