<%#
  One row in the unified "who has access" list. Works for all audience kinds.
  locals: kind ("team" | "talent_pool" | "person"), id, name, subtitle,
          initials, permission, share_key
%>
<div class="flex items-center justify-between gap-3 py-2" data-share-key="<%= share_key %>">
  <div class="flex items-center gap-3 min-w-0">
    <% if kind == "person" %>
      <span class="w-8 h-8 rounded-full bg-gray-100 text-gray-600 flex items-center justify-center text-xs font-bold flex-shrink-0"><%= initials %></span>
    <% else %>
      <span class="w-8 h-8 rounded-full bg-pink-50 text-pink-600 flex items-center justify-center flex-shrink-0">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/></svg>
      </span>
    <% end %>
    <div class="min-w-0">
      <div class="text-sm font-medium text-gray-900 truncate"><%= name %></div>
      <% if subtitle.present? %><div class="text-xs text-gray-500 truncate"><%= subtitle %></div><% end %>
    </div>
  </div>

  <div class="flex items-center gap-1.5 flex-shrink-0">
    <% select_class = "text-xs border-gray-300 rounded py-1 focus:ring-pink-500 focus:border-pink-500" %>
    <% case kind
       when "team" %>
      <input type="hidden" name="team_enabled" value="1">
      <select name="team_permission" class="<%= select_class %>">
        <option value="write" <%= "selected" if permission != "read" %>>Can edit</option>
        <option value="read"  <%= "selected" if permission == "read" %>>Can view</option>
      </select>
    <% when "talent_pool" %>
      <input type="hidden" name="talent_pools[<%= id %>][enabled]" value="1">
      <select name="talent_pools[<%= id %>][permission]" class="<%= select_class %>">
        <option value="read"  <%= "selected" if permission != "write" %>>Can view</option>
        <option value="write" <%= "selected" if permission == "write" %>>Can edit</option>
      </select>
    <% when "person" %>
      <select name="people[<%= id %>]" class="<%= select_class %>">
        <option value="read"  <%= "selected" if permission != "write" %>>Can view</option>
        <option value="write" <%= "selected" if permission == "write" %>>Can edit</option>
      </select>
    <% end %>
    <button type="button" data-action="document-audience#remove" title="Remove access"
            class="w-6 h-6 inline-flex items-center justify-center rounded-full text-gray-400 hover:bg-gray-100 hover:text-gray-700 cursor-pointer">&times;</button>
  </div>
</div>
