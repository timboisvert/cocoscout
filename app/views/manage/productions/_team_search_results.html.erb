<%# Search results for production team member search - shows already on production, org users, global users, and invite option %>

<% if query.blank? || query.length < 2 %>
  <p class="text-gray-500 text-sm p-4">Type at least 2 characters to search...</p>
<% elsif already_on_production.empty? && org_users.empty? && global_users.empty? && !show_invite %>
  <div class="p-4 text-center">
    <div class="text-gray-500 text-sm mb-3">No results found for "<%= query %>"</div>
    <% if query.include?("@") %>
      <p class="text-xs text-gray-400 mb-3">Want to invite this person?</p>
      <button type="button"
              class="text-pink-600 hover:text-pink-700 text-sm font-medium cursor-pointer"
              data-action="production-team-search#showInviteForm"
              data-email="<%= query %>">
        Invite <%= query %>
      </button>
    <% else %>
      <p class="text-xs text-gray-400">Try searching by email to invite someone new</p>
    <% end %>
  </div>
<% else %>

  <%# Already on this production %>
  <% if already_on_production.any? %>
    <div class="mb-3">
      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide px-1 mb-2">
        Already on this production
      </div>
      <div class="space-y-1">
        <% already_on_production.each do |user| %>
          <div class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg bg-gray-50">
            <% person = user.person %>
            <% headshot_variant = person&.safe_headshot_variant(:thumb) %>
            <% if headshot_variant %>
              <%= image_tag headshot_variant, alt: person.name, class: "w-8 h-8 rounded-lg object-cover flex-shrink-0" %>
            <% else %>
              <div class="w-8 h-8 rounded-lg bg-gray-200 flex items-center justify-center text-gray-600 font-bold text-xs flex-shrink-0">
                <%= (person&.initials || user.email_address.first.upcase) %>
              </div>
            <% end %>
            <div class="flex-grow min-w-0">
              <span class="font-medium text-sm block truncate"><%= person&.name || user.email_address %></span>
              <span class="text-xs text-gray-500 block truncate"><%= user.email_address %></span>
            </div>
            <span class="text-xs text-gray-400 flex-shrink-0">Already added</span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Organization members - can add instantly %>
  <% if org_users.any? %>
    <div class="mb-3">
      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide px-1 mb-2">
        In Your Organization
      </div>
      <div class="space-y-1">
        <% org_users.each do |user| %>
          <% person = user.person %>
          <div class="flex items-center gap-3 p-3 border border-gray-200 rounded-lg hover:border-pink-300 hover:bg-pink-50 transition-all">
            <% headshot_variant = person&.safe_headshot_variant(:thumb) %>
            <% if headshot_variant %>
              <%= image_tag headshot_variant, alt: person&.name, class: "w-8 h-8 rounded-lg object-cover flex-shrink-0" %>
            <% else %>
              <div class="w-8 h-8 rounded-lg bg-gray-200 flex items-center justify-center text-gray-600 font-bold text-xs flex-shrink-0">
                <%= (person&.initials || user.email_address.first.upcase) %>
              </div>
            <% end %>
            <div class="flex-grow min-w-0">
              <span class="font-medium text-sm block truncate"><%= person&.name || user.email_address %></span>
              <span class="text-xs text-gray-500 block truncate"><%= user.email_address %></span>
            </div>
            <button type="button"
              class="px-3 py-1.5 text-pink-600 bg-white rounded-md text-xs font-bold shadow hover:bg-pink-100 transition-all border border-pink-300 cursor-pointer flex-shrink-0"
              data-action="production-team-search#selectUser"
              data-user-id="<%= user.id %>"
              data-user-name="<%= person&.name || user.email_address %>"
              data-user-email="<%= user.email_address %>">
              Add
            </button>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Global CocoScout users - can add instantly %>
  <% if global_users.any? %>
    <div class="mb-3">
      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide px-1 mb-2">
        On CocoScout
      </div>
      <div class="space-y-1">
        <% global_users.each do |user| %>
          <% person = user.person %>
          <div class="flex items-center gap-3 p-3 border border-pink-200 bg-pink-50 rounded-lg hover:border-pink-400 transition-all">
            <% headshot_variant = person&.safe_headshot_variant(:thumb) %>
            <% if headshot_variant %>
              <%= image_tag headshot_variant, alt: person&.name, class: "w-8 h-8 rounded-lg object-cover flex-shrink-0" %>
            <% else %>
              <div class="w-8 h-8 rounded-lg bg-pink-200 flex items-center justify-center text-pink-700 font-bold text-xs flex-shrink-0">
                <%= (person&.initials || user.email_address.first.upcase) %>
              </div>
            <% end %>
            <div class="flex-grow min-w-0">
              <span class="font-medium text-sm block truncate"><%= person&.name || user.email_address %></span>
              <span class="text-xs text-gray-500 block truncate"><%= user.email_address %></span>
            </div>
            <button type="button"
              class="px-3 py-1.5 text-pink-600 bg-white rounded-md text-xs font-bold shadow hover:bg-pink-100 transition-all border border-pink-300 cursor-pointer flex-shrink-0"
              data-action="production-team-search#selectUser"
              data-user-id="<%= user.id %>"
              data-user-name="<%= person&.name || user.email_address %>"
              data-user-email="<%= user.email_address %>">
              Add
            </button>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Invite option for non-existing email %>
  <% if show_invite %>
    <div class="border-t border-gray-200 pt-3 mt-2">
      <div class="text-xs font-semibold text-gray-500 uppercase tracking-wide px-1 mb-2">
        Invite New Person
      </div>
      <div class="p-3 border-2 border-dashed border-gray-300 rounded-lg bg-gray-50">
        <p class="text-sm text-gray-600 mb-2">
          No CocoScout account found for this email.
        </p>
        <button type="button"
                class="w-full px-4 py-2 text-pink-600 bg-white rounded-lg text-sm font-medium shadow hover:bg-pink-50 transition-all border border-pink-300 cursor-pointer"
                data-action="production-team-search#showInviteForm"
                data-email="<%= query %>">
          Invite <%= query %>
        </button>
      </div>
    </div>
  <% end %>

<% end %>
