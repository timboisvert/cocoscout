<% content_for :title, "Find a Course" %>

<div class="w-full">

  <%= render partial: "shared/notice", locals: { notice: notice } %>

  <%= render partial: "shared/top_menu_tabs", locals: {
    tabs: [
      { name: "My Courses", path: my_courses_path, active: false },
      { name: "Find a Course", path: my_courses_directory_path, active: true }
    ]
  } %>

  <% if @offerings_data.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      <% @offerings_data.each do |data| %>
        <% offering = data[:offering] %>
        <% instructor = data[:instructor] %>
        <% first_session = data[:first_session] %>
        <% last_session = data[:last_session] %>
        <% location = data[:location] %>
        <%
          date_range = if first_session.date_and_time.to_date == last_session.date_and_time.to_date
                         first_session.date_and_time.strftime("%B %-d, %Y")
                       elsif first_session.date_and_time.year == last_session.date_and_time.year
                         "#{first_session.date_and_time.strftime("%b %-d")} – #{last_session.date_and_time.strftime("%b %-d, %Y")}"
                       else
                         "#{first_session.date_and_time.strftime("%b %-d, %Y")} – #{last_session.date_and_time.strftime("%b %-d, %Y")}"
                       end
        %>

        <%= link_to my_course_show_path(code: offering.short_code), class: "block group" do %>
          <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden hover:shadow-md hover:border-gray-300 transition-all h-full flex flex-col">

            <%# Header with org name %>
            <div class="px-5 pt-5 pb-3">
              <p class="text-xs font-medium text-pink-600 uppercase tracking-wide mb-1.5"><%= offering.organization.name %></p>
              <h3 class="text-lg font-bold text-gray-900 group-hover:text-pink-600 transition-colors leading-snug"><%= offering.title %></h3>
              <% if offering.subtitle.present? %>
                <p class="text-sm text-gray-600 mt-1 line-clamp-2"><%= offering.subtitle %></p>
              <% end %>
            </div>

            <%# Details section %>
            <div class="px-5 pb-4 flex-1 space-y-3">

              <%# Instructor(s) %>
              <% cois = offering.course_offering_instructors.includes(:person) %>
              <% if cois.any? %>
                <% cois.each do |coi| %>
                  <% instr = coi.person %>
                  <div class="flex items-center gap-2.5">
                    <% if coi.headshot.attached? %>
                      <%= image_tag coi.headshot.variant(resize_to_fill: [64, 64]), alt: instr.name, class: "w-8 h-8 rounded-lg object-cover flex-shrink-0" %>
                    <% else %>
                      <% headshot_variant = instr.safe_headshot_variant(:thumb) %>
                      <% if headshot_variant %>
                        <%= image_tag headshot_variant, alt: instr.name, class: "w-8 h-8 rounded-lg object-cover flex-shrink-0" %>
                      <% else %>
                        <div class="w-8 h-8 rounded-lg bg-pink-100 flex items-center justify-center text-pink-700 font-bold text-xs flex-shrink-0">
                          <%= instr.initials %>
                        </div>
                      <% end %>
                    <% end %>
                    <span class="text-sm text-gray-700"><%= instr.name %></span>
                  </div>
                <% end %>
              <% end %>

              <%# Schedule info %>
              <div class="space-y-1.5">
                <div class="flex items-center gap-2 text-sm text-gray-600">
                  <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <span><%= date_range %></span>
                </div>

                <% if data[:schedule_pattern] %>
                  <div class="flex items-center gap-2 text-sm text-gray-600">
                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span><%= data[:schedule_pattern] %> &middot; <%= data[:total_sessions] %> sessions</span>
                  </div>
                <% else %>
                  <div class="flex items-center gap-2 text-sm text-gray-600">
                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span><%= data[:total_sessions] %> session<%= data[:total_sessions] == 1 ? '' : 's' %></span>
                  </div>
                <% end %>

                <% if location %>
                  <div class="flex items-center gap-2 text-sm text-gray-600">
                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <span><%= location.name %></span>
                  </div>
                <% elsif offering.production.shows.any?(&:is_online?) %>
                  <div class="flex items-center gap-2 text-sm text-gray-600">
                    <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                    </svg>
                    <span>Online</span>
                  </div>
                <% end %>
              </div>
            </div>

            <%# Footer with price %>
            <div class="px-5 py-3 bg-gray-50 border-t border-gray-100 flex items-center justify-between">
              <div>
                <% if offering.early_bird_active? %>
                  <span class="text-lg font-bold text-pink-600"><%= offering.formatted_early_bird_price %></span>
                  <span class="text-sm text-gray-400 line-through ml-1"><%= offering.formatted_price %></span>
                <% else %>
                  <span class="text-lg font-bold text-gray-900"><%= offering.formatted_price %></span>
                <% end %>
              </div>
              <span class="text-xs font-medium text-pink-600 group-hover:text-pink-700">View Details →</span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16">
      <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
        </svg>
      </div>
      <h3 class="text-lg font-medium text-gray-900 mb-1">No courses available</h3>
      <p class="text-sm text-gray-500">There are no open courses listed in the directory right now. Check back soon!</p>
    </div>
  <% end %>

  <%# Promotional box %>
  <div class="mt-10 mb-4">
    <div class="bg-gradient-to-r from-pink-50 to-purple-50 border border-pink-200 rounded-lg px-6 py-5 flex flex-col sm:flex-row items-center gap-4 sm:gap-6">
      <div class="flex-shrink-0">
        <div class="w-10 h-10 bg-pink-100 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
          </svg>
        </div>
      </div>
      <div class="flex-1 text-center sm:text-left">
        <p class="text-sm font-semibold text-gray-900">Got a course? Manage it with CocoScout.</p>
        <p class="text-xs text-gray-500 mt-0.5">Set up registration, collect payments, and list your course in this directory — all in one place.</p>
      </div>
      <%= link_to manage_course_wizard_basics_path, class: "flex-shrink-0" do %>
        <%= render "shared/button", text: "Create a Course", variant: "primary", size: "small" %>
      <% end %>
    </div>
  </div>

</div>
