<% content_for :title, "Preview - #{@questionnaire.title}" %>

<div class="w-full mb-10">
  <%= render partial: "shared/notice", locals: { notice: notice } %>
  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      ["Contacts", manage_contacts_path],
      ["Questionnaires", manage_contacts_questionnaires_path],
      [@questionnaire.title, manage_contacts_questionnaire_path(@questionnaire)]
    ],
    text: "Preview Questionnaire",
    links: [
      {text: "Edit Questionnaire", path: manage_form_contacts_questionnaire_path(@questionnaire)}
    ]
  } %>

  <!-- Shareable Link -->
  <div class="mb-4">
      <%= render "shared/copy_url",
        url: @questionnaire.respond_url,
        label: "Shareable Link",
        help_text: "Share this link with people to collect their responses" %>
  </div>
  <div class="bg-white border border-gray-200 rounded-lg shadow-sm p-6 pt-12">
    <div class="max-w-6xl mx-auto">

    <!-- Full-Width Header -->
    <div class="mb-8 sm:mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-3 coustard-regular"><%= @questionnaire.title %></h1>
    </div>

    <!-- Two Column Layout: Instruction Text & Form -->
    <div class="grid lg:grid-cols-2 gap-8 lg:gap-12">

      <!-- Left Column: Instruction Text -->
      <div class="space-y-6">
        <% if @questionnaire.instruction_text.present? %>
          <div class="bg-gradient-to-br from-slate-50 to-white border border-slate-200 rounded-lg p-6 sm:p-8 shadow-sm">
            <div class="prose prose-slate max-w-none text-slate-700">
              <%= @questionnaire.instruction_text %>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Right Column: Form -->
      <div>
        <%= form_with url: "#", method: :get, data: { turbo: false }, class: "space-y-4", onsubmit: "event.preventDefault(); alert('This is a preview - form submission is disabled'); return false;" do |form| %>

          <!-- Questions Section -->
          <% if @questions.any? %>
            <div class="bg-white border border-slate-200 rounded-lg shadow-sm p-5 space-y-5">
              <% @questions.each do |question| %>
                <div class="">
                  <label>
                    <%= question.text %>
                    <% if question.required %>
                      <span class="text-pink-500 text-sm">(required)</span>
                    <% end %>
                  </label>

                  <div class="mt-2">
                    <% type_class = question.question_type_class %>
                    <% if type_class %>
                      <% case type_class.key %>
                      <% when "text", "email", "phone" %>
                        <input type="text" class="block shadow-sm rounded-lg border px-3 py-2 w-full border-gray-300" placeholder="Answer...">
                      <% when "url" %>
                        <input type="url" class="block shadow-sm rounded-lg border px-3 py-2 w-full border-gray-300" placeholder="https://...">
                        <p class="mt-1 text-xs text-gray-400">YouTube, Spotify, or any web link.</p>
                      <% when "file_upload" %>
                        <input type="file" class="block mt-1 w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-pink-50 file:text-pink-700" disabled>
                        <p class="mt-1 text-xs text-gray-400">Images (JPEG, PNG, GIF, WebP) or audio files (MP3, WAV, AAC, OGG, MP4). Max 25MB.</p>
                      <% when "textarea" %>
                        <textarea class="block shadow-sm rounded-lg border px-3 py-2 w-full border-gray-300" rows="4" placeholder="Answer..."></textarea>
                      <% when "yesno" %>
                        <div class="space-y-2">
                          <div class="flex items-center">
                            <input type="radio" name="question_<%= question.id %>" class="border-gray-300 text-pink-600">
                            <label class="ml-2 text-sm text-gray-700">Yes</label>
                          </div>
                          <div class="flex items-center">
                            <input type="radio" name="question_<%= question.id %>" class="border-gray-300 text-pink-600">
                            <label class="ml-2 text-sm text-gray-700">No</label>
                          </div>
                        </div>
                      <% when "multiple-single" %>
                        <div class="space-y-2">
                          <% question.question_options.each do |option| %>
                            <div class="flex items-center">
                              <input type="radio" name="question_<%= question.id %>" class="border-gray-300 text-pink-600">
                              <label class="ml-2 text-sm text-gray-700"><%= option.text %></label>
                            </div>
                          <% end %>
                        </div>
                      <% when "multiple-multiple" %>
                        <div class="space-y-2">
                          <% question.question_options.each do |option| %>
                            <div class="flex items-center">
                              <input type="checkbox" class="rounded border-gray-300 text-pink-600">
                              <label class="ml-2 text-sm text-gray-700"><%= option.text %></label>
                            </div>
                          <% end %>
                        </div>
                      <% when "ranking" %>
                        <div class="text-sm text-gray-500 mb-2">
                          <span class="hidden sm:inline">Drag to reorder</span>
                          <span class="sm:hidden">Use arrows to reorder options</span>
                        </div>
                        <div class="mt-2" data-controller="ranking" data-ranking-question-id-value="<%= question.id %>">
                          <div class="space-y-2" data-ranking-target="list" data-action="dragover->ranking#dragOver drop->ranking#drop">
                            <% question.question_options.each_with_index do |option, index| %>
                              <div class="flex items-center gap-2 p-3 bg-white border border-gray-300 rounded-lg cursor-move hover:bg-gray-50 transition"
                                   draggable="true"
                                   data-ranking-target="item"
                                   data-option-text="<%= option.text %>"
                                   data-action="dragstart->ranking#dragStart dragend->ranking#dragEnd dragover->ranking#dragOver drop->ranking#drop touchstart->ranking#touchStart touchmove->ranking#touchMove touchend->ranking#touchEnd">

                                <!-- Rank number -->
                                <div class="flex-shrink-0 w-8 h-8 flex items-center justify-center bg-pink-500 text-white font-semibold rounded-full text-sm"
                                     data-ranking-target="rank">
                                  <%= index + 1 %>
                                </div>

                                <!-- Option text -->
                                <div class="flex-1 font-medium text-gray-900">
                                  <%= option.text %>
                                </div>

                                <!-- Mobile controls (arrows) -->
                                <div class="flex gap-1 sm:hidden">
                                  <button type="button"
                                          class="p-2 text-gray-400 hover:text-gray-600 disabled:opacity-30 disabled:cursor-not-allowed"
                                          data-action="click->ranking#moveUp"
                                          <%= 'disabled' if index == 0 %>>
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
                                    </svg>
                                  </button>
                                  <button type="button"
                                          class="p-2 text-gray-400 hover:text-gray-600 disabled:opacity-30 disabled:cursor-not-allowed"
                                          data-action="click->ranking#moveDown"
                                          <%= 'disabled' if index == question.question_options.length - 1 %>>
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                                    </svg>
                                  </button>
                                </div>

                                <!-- Desktop drag handle -->
                                <div class="hidden sm:block text-gray-400">
                                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/>
                                  </svg>
                                </div>
                              </div>
                            <% end %>
                          </div>
                        </div>
                      <% end %>
                    <% end %>
                  </div>
                </div>
            <% end %>
          </div>
        <% end %>

        <!-- Submit Button -->
        <%= render "shared/button", text: "Submit", variant: "primary", size: "jumbo", type: :submit %>
      <% end %>
    </div>    </div>
    </div>
  </div>
</div>
