<%#
  Sharing/permissions modal for one document — a single unified access list
  (Google-Docs style). Add the production team, a talent pool, or specific
  people from one search box; each entry gets a Can view / Can edit control.
  Locals: document, production, talent_pool_options, candidate_people
    talent_pool_options: [{ id:, pool:, name:, subtitle: }] (already named for
    the production / organization / shared-pool case by the controller)
  This is purely about VISIBILITY (who can see/edit). Which productions the
  document belongs to is managed separately in the Productions modal.
  Trigger with: data-controller="modal" data-action="click->modal#open"
                data-modal-id="sharing-modal-<document.id>"
%>
<%
  pool_options        = talent_pool_options || []
  pool_options_by_id  = pool_options.index_by { |o| o[:id] }
  selected_pool_ids   = document.talent_pool_share_ids
  selected_person_ids = document.person_share_ids
  selected_people     = Person.where(id: selected_person_ids).index_by(&:id)

  # Fallback naming for a pool already shared with but no longer an offered
  # option (e.g. the org switched talent-pool modes since it was shared).
  pool_label = ->(pid) do
    opt = pool_options_by_id[pid]
    name = opt ? opt[:name] : (TalentPool.find_by(id: pid)&.name || "Talent pool")
    [ name, (opt ? opt[:subtitle] : "Talent pool") ]
  end

  # Candidate pool for the "Add" search: everything not already on the list.
  candidates = []
  unless document.shared_with_team?
    candidates << { key: "team", kind: "team", id: "", name: "Everyone on the production team",
                    subtitle: "Production team", initials: "" }
  end
  pool_options.reject { |o| selected_pool_ids.include?(o[:id]) }.each do |opt|
    candidates << { key: "pool-#{opt[:id]}", kind: "talent_pool", id: opt[:id], name: opt[:name],
                    subtitle: opt[:subtitle], initials: "" }
  end
  (candidate_people || []).reject { |p| selected_person_ids.include?(p.id) }.each do |person|
    candidates << { key: "person-#{person.id}", kind: "person", id: person.id, name: person.name,
                    subtitle: "", initials: person.initials }
  end
%>
<div id="sharing-modal-<%= document.id %>"
     class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-[100] flex items-center justify-center p-4"
     data-controller="modal"
     data-action="click->modal#closeOnBackdrop keydown.escape->modal#close">
  <div class="bg-white rounded-xl shadow-2xl w-full max-w-lg max-h-[88vh] overflow-y-auto"
       data-action="click->modal#stopPropagation">
    <div class="flex items-start justify-between px-5 py-4 border-b border-gray-200">
      <div>
        <h3 class="text-base font-semibold text-gray-900">Share &ldquo;<%= document.title %>&rdquo;</h3>
        <p class="text-xs text-gray-500 mt-0.5">Add the production team, a talent pool, or specific people.</p>
      </div>
      <button type="button" data-action="click->modal#close" class="text-gray-400 hover:text-gray-600 cursor-pointer">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <%= form_with url: share_manage_production_document_path(production, document), method: :patch, local: true do %>
      <div class="px-5 py-4"
           data-controller="document-audience"
           data-document-audience-candidates-value="<%= candidates.to_json %>">

        <%# Row templates the controller clones when something is added. %>
        <template data-document-audience-target="teamTemplate"><%= render "manage/documents/share_row", kind: "team", id: "", name: "Everyone on the production team", subtitle: "Production team", initials: "", permission: "write", share_key: "team" %></template>
        <template data-document-audience-target="poolTemplate"><%= render "manage/documents/share_row", kind: "talent_pool", id: "__ID__", name: "__NAME__", subtitle: "Talent pool", initials: "", permission: "read", share_key: "pool-__ID__" %></template>
        <template data-document-audience-target="personTemplate"><%= render "manage/documents/share_row", kind: "person", id: "__ID__", name: "__NAME__", subtitle: "", initials: "__INIT__", permission: "read", share_key: "person-__ID__" %></template>

        <%# Add box %>
        <div class="relative mb-3">
          <input type="text" data-document-audience-target="search"
                 data-action="input->document-audience#search focus->document-audience#search"
                 placeholder="Add people, a talent pool, or the whole team…" autocomplete="off"
                 class="block w-full text-sm rounded-lg border border-gray-300 px-3 py-2.5 focus:ring-pink-500 focus:border-pink-500">
          <div data-document-audience-target="results"
               class="hidden absolute z-20 mt-1 w-full max-h-60 overflow-y-auto bg-white border border-gray-200 rounded-lg shadow-lg"></div>
        </div>

        <%# Unified access list %>
        <div class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Who has access</div>
        <div data-document-audience-target="rows" class="divide-y divide-gray-100">
          <% if document.shared_with_team? %>
            <%= render "manage/documents/share_row", kind: "team", id: "", name: "Everyone on the production team",
                  subtitle: "Production team", initials: "", permission: (document.team_permission || "write"), share_key: "team" %>
          <% end %>
          <% selected_pool_ids.each do |pid| %>
            <% pool_name, pool_subtitle = pool_label.call(pid) %>
            <%= render "manage/documents/share_row", kind: "talent_pool", id: pid, name: pool_name,
                  subtitle: pool_subtitle, initials: "", permission: (document.pool_permission(pid) || "read"), share_key: "pool-#{pid}" %>
          <% end %>
          <% selected_person_ids.each do |person_id| %>
            <% person = selected_people[person_id] %>
            <%= render "manage/documents/share_row", kind: "person", id: person_id, name: (person&.name || "Someone"),
                  subtitle: "", initials: (person&.initials || "?"), permission: (document.person_permission(person_id) || "read"), share_key: "person-#{person_id}" %>
          <% end %>
        </div>
        <p data-document-audience-target="empty" class="text-sm text-gray-400 py-3 <%= "hidden" if document.shares.any? %>">
          No one has access yet. Add someone above.
        </p>
      </div>

      <div class="flex items-center justify-end gap-2 px-5 py-3 border-t border-gray-200">
        <button type="button" data-action="click->modal#close" class="px-4 py-2 text-sm text-gray-700 hover:text-gray-900 cursor-pointer">Cancel</button>
        <%= render "shared/button", text: "Save sharing", variant: "primary", size: "small", type: :submit %>
      </div>
    <% end %>
  </div>
</div>
