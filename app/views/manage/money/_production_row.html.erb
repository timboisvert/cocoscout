<%#
  Money Production Row — delegates chrome to shared/_production_row.
  Required: summary (Hash with production financial data)
  Optional: link_path — defaults to this production's financials

  In-house panels:     Gross Revenue, Direct Costs, Gross Profit
  Third-party panels:  Contract Revenue, Revenue/Pending, Status/Your Share
%>
<%
  production = summary[:production]
  is_third_party = summary[:is_third_party]
  gross_revenue = summary[:gross_revenue] || 0

  if is_third_party
    is_revenue_share = summary[:is_revenue_share]
    is_ticket_revenue_minus_fee = summary[:is_ticket_revenue_minus_fee]
    is_share_based = is_revenue_share || is_ticket_revenue_minus_fee
    our_share = summary[:our_share]
    their_share = summary[:their_share]
    flat_fee_amount = summary[:flat_fee_amount]
    confirmed_count = summary[:confirmed_show_count] || 0
    pending_show_count = summary[:pending_show_count] || 0

    # Panel 1: contract revenue terms
    revenue_panel =
      if is_revenue_share
        { label: "Revenue Share", value: "#{our_share}/#{their_share} Split", sub: "You keep #{our_share}%", sub_class: "text-[10px] text-gray-500" }
      elsif is_ticket_revenue_minus_fee
        { label: "Flat Fee", value: number_to_currency(flat_fee_amount), sub: "You keep from ticket revenue", sub_class: "text-[10px] text-gray-500" }
      else
        { label: "Contract Revenue", value: number_to_currency(gross_revenue) }
      end

    # Panel 2: ticket revenue (share-based) or pending payments (flat)
    if is_share_based
      ticket_panel = { label: "Ticket Revenue" }
      if gross_revenue > 0
        ticket_panel[:value] = number_to_currency(gross_revenue)
        sub = "#{confirmed_count} #{'show'.pluralize(confirmed_count)} confirmed"
        sub += " &middot; #{pending_show_count} pending" if pending_show_count > 0
        ticket_panel[:sub] = sub.html_safe
        ticket_panel[:sub_class] = "text-[10px] text-gray-500"
      elsif confirmed_count > 0
        ticket_panel[:value] = number_to_currency(0)
        ticket_panel[:value_class] = "text-sm text-gray-900"
        ticket_panel[:sub] = "#{confirmed_count} shows, no revenue"
        ticket_panel[:sub_class] = "text-[10px] text-gray-500"
      elsif pending_show_count > 0
        ticket_panel[:value] = "Awaiting data"
        ticket_panel[:value_class] = "text-sm text-gray-400"
        ticket_panel[:sub] = "#{pending_show_count} #{'show'.pluralize(pending_show_count)} pending"
        ticket_panel[:sub_class] = "text-[10px] text-gray-500"
      else
        ticket_panel[:value] = "No shows yet"
        ticket_panel[:value_class] = "text-sm text-gray-400"
      end
      revenue2_panel = ticket_panel
    else
      pending_amount = summary[:pending_amount] || 0
      revenue2_panel =
        if pending_amount > 0
          { label: "Pending", value: number_to_currency(pending_amount), value_class: "text-sm font-medium text-amber-600" }
        else
          { label: "Pending", value: "$0.00", value_class: "text-sm text-gray-400" }
        end
    end

    # Panel 3: your share (share-based with revenue) or status
    if is_share_based && gross_revenue > 0
      status_panel = { label: "You Keep", value: number_to_currency(summary[:net_income]), value_class: "text-sm font-medium text-green-600" }
    else
      overdue_count = summary[:overdue_count] || 0
      pending_count = summary[:pending_count] || 0
      status_panel =
        if overdue_count > 0
          { label: "Status", value: "#{overdue_count} overdue", value_class: "text-sm font-medium text-red-600" }
        elsif pending_count > 0
          { label: "Status", value: "#{pending_count} pending", value_class: "text-sm font-medium text-amber-600" }
        else
          { label: "Status", value: "All received", value_class: "text-sm font-medium text-green-600" }
        end
    end

    panels = [ revenue_panel, revenue2_panel, status_panel ]
    badge = { text: "Contract", color: "pink" }
    subtitle = "#{summary[:total_shows]} #{'event'.pluralize(summary[:total_shows])}"
  else
    production_expenses = summary[:production_expenses] || 0
    cost_of_shows = (summary[:show_expenses] || 0) + production_expenses + (summary[:total_payouts] || 0)
    gross_profit = gross_revenue - cost_of_shows

    panels = [
      { label: "Gross Revenue", value: number_to_currency(gross_revenue) },
      if cost_of_shows > 0
        { label: "Direct Costs", value: number_to_currency(cost_of_shows), value_class: "text-sm font-medium text-red-600" }
      else
        { label: "Direct Costs", value: "$0.00", value_class: "text-sm text-gray-400" }
      end,
      { label: "Gross Profit", value: number_to_currency(gross_profit), value_class: "text-sm font-medium #{gross_profit >= 0 ? 'text-green-600' : 'text-red-600'}" }
    ]
    badge = nil
    subtitle = "#{summary[:revenue_shows]} revenue #{'event'.pluralize(summary[:revenue_shows])}"
  end
%>

<%= render "shared/production_row",
  production: production,
  link_path: local_assigns[:link_path] || manage_money_production_financials_path(production),
  badge: badge,
  subtitle: subtitle,
  panels: panels %>
