<% content_for :title, "Courses" %>

<%= render partial: "shared/top_menu", locals: {
  breadcrumbs: [],
  text: "Courses",
  links: [
    { text: "New Course", path: manage_course_wizard_basics_path }
  ]
} %>

<%= render partial: "shared/notice", locals: { notice: notice, alert: alert } %>

<% if @course_offerings.any? %>
  <div class="space-y-2">
    <% @course_offerings.each do |offering| %>
      <div class="bg-white rounded-lg border border-gray-200 hover:border-gray-300 transition-all">
        <%= link_to manage_course_offering_path(offering), class: "block" do %>
          <div class="flex flex-col lg:flex-row lg:items-stretch">

            <%# Panel 1: Course Info %>
            <div class="flex-1 flex items-center gap-4 px-4 py-3 rounded-t-lg lg:rounded-l-lg lg:rounded-tr-none">
              <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-pink-100 flex items-center justify-center">
                <svg class="w-5 h-5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <span class="font-medium text-gray-900 truncate"><%= offering.title %></span>
                  <% case offering.status %>
                  <% when "draft" %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-700">Draft</span>
                  <% when "open" %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">Open</span>
                  <% when "closed" %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-700">Closed</span>
                  <% when "archived" %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-500">Archived</span>
                  <% end %>
                </div>
                <div class="text-sm text-gray-600">
                  <%= offering.production.name %>
                  <% if offering.instructor_name.present? %>
                    &middot; <%= offering.instructor_name %>
                  <% end %>
                </div>
              </div>
            </div>

            <%# Panel 2: Price %>
            <div class="w-full lg:w-1/5 px-4 py-3 border-t lg:border-t-0 lg:border-l border-gray-200 flex flex-col justify-center">
              <div class="text-[10px] text-gray-400 uppercase tracking-wide mb-0.5">Price</div>
              <div class="text-sm font-medium text-gray-900"><%= offering.formatted_price %></div>
              <% if offering.early_bird_price_cents.present? %>
                <div class="text-[10px] text-green-600">Early bird: <%= offering.formatted_early_bird_price %></div>
              <% end %>
            </div>

            <%# Panel 3: Registrations %>
            <div class="w-full lg:w-1/6 px-4 py-3 border-t lg:border-t-0 lg:border-l border-gray-200 flex flex-col justify-center">
              <div class="text-[10px] text-gray-400 uppercase tracking-wide mb-0.5">Registrations</div>
              <div class="text-sm font-medium text-gray-900"><%= offering.confirmed_registrations_count %></div>
            </div>

            <%# Panel 4: Capacity %>
            <div class="w-full lg:w-1/6 px-4 py-3 border-t lg:border-t-0 lg:border-l border-gray-200 rounded-b-lg lg:rounded-r-lg lg:rounded-bl-none flex flex-col justify-center">
              <div class="text-[10px] text-gray-400 uppercase tracking-wide mb-0.5">Spots Left</div>
              <% if offering.capacity.present? %>
                <div class="text-sm font-medium <%= offering.spots_remaining > 0 ? 'text-gray-900' : 'text-red-600' %>"><%= offering.spots_remaining %></div>
              <% else %>
                <div class="text-sm text-gray-400">&infin;</div>
              <% end %>
            </div>

          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="bg-white border border-gray-200 rounded-lg p-12 text-center">
    <div class="flex items-center justify-center mb-4">
      <div class="h-12 w-12 rounded-full bg-pink-100 flex items-center justify-center">
        <svg class="h-6 w-6 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
      </div>
    </div>
    <h3 class="text-lg font-semibold text-gray-900 mb-2">No Courses Yet</h3>
    <p class="text-gray-600 text-sm mb-6">
      Create a course to start selling registrations online.
    </p>
    <%= link_to manage_course_wizard_basics_path do %>
      <%= render "shared/button", text: "Create Course", variant: "primary", size: "medium" %>
    <% end %>
  </div>
<% end %>
