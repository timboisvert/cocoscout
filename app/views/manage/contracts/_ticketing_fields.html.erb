<%#
  Ticketing fields: ticket tiers (name + price) and an optional discount code.
  Wrapped in the `contract-ticketing` Stimulus controller with a hidden JSON input
  named "ticketing". The caller supplies the surrounding <form> and nav buttons.
  Local: ticketing (Hash, e.g. @contract.draft_ticketing or staged amend data).
%>
<%
  ticketing ||= {}
  discount = ticketing["discount"] || {}
  applies_to = discount["applies_to"] || "all"
  input_class = "w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-pink-500 focus:border-pink-500"
%>

<div data-controller="contract-ticketing" data-contract-ticketing-existing-value="<%= ticketing.to_json %>">
  <%# Ticket tiers %>
  <div class="mb-6">
    <h3 class="text-sm font-medium text-gray-900 mb-3">Ticket Tiers</h3>

    <div class="bg-gray-50 rounded-xl p-4 mb-3 border border-gray-200">
      <div class="flex gap-2">
        <input type="text" data-contract-ticketing-target="tierName" placeholder="Tier name (e.g. General)"
               class="flex-1 px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-pink-500 focus:border-pink-500">
        <div class="relative w-32">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 font-medium">$</span>
          <input type="number" step="0.01" min="0" data-contract-ticketing-target="tierPrice" placeholder="0.00"
                 class="w-full pl-8 pr-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-pink-500 focus:border-pink-500">
        </div>
        <%= render "shared/button", text: "Add", variant: "secondary", size: "small", type: :button, data: { action: "click->contract-ticketing#addTier" } %>
      </div>
    </div>

    <div data-contract-ticketing-target="list"></div>
  </div>

  <%# Discount code %>
  <div class="bg-gray-50 rounded-xl p-5 mb-6 border border-gray-200">
    <h3 class="text-sm font-medium text-gray-900 mb-3">Discount Code (optional)</h3>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-3">
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Code</label>
        <input type="text" data-contract-ticketing-target="discountCode"
               data-action="input->contract-ticketing#serialize"
               value="<%= discount["code"] %>" placeholder="e.g. FRIENDS"
               class="<%= input_class %>">
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Amount off</label>
        <input type="number" step="0.01" min="0" data-contract-ticketing-target="discountAmount"
               data-action="input->contract-ticketing#serialize"
               value="<%= discount["amount"] %>" placeholder="0"
               class="<%= input_class %>">
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Type</label>
        <select data-contract-ticketing-target="discountType"
                data-action="change->contract-ticketing#serialize"
                class="w-full pl-3 pr-8 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-pink-500 focus:border-pink-500">
          <option value="fixed" <%= "selected" if discount["amount_type"] == "fixed" %>>$ off</option>
          <option value="percent" <%= "selected" if discount["amount_type"] == "percent" %>>% off</option>
        </select>
      </div>
    </div>

    <div class="mb-2">
      <label class="block text-xs font-medium text-gray-700 mb-1">Applies to</label>
      <div class="flex gap-4">
        <label class="flex items-center gap-2">
          <input type="radio" name="discount_applies_to" value="all" <%= "checked" if applies_to != "specific" %>
                 data-action="change->contract-ticketing#toggleAppliesTo"
                 class="h-4 w-4 text-pink-600 border-gray-300 focus:ring-pink-500 accent-pink-500">
          <span class="text-sm text-gray-900">All tickets</span>
        </label>
        <label class="flex items-center gap-2">
          <input type="radio" name="discount_applies_to" value="specific" <%= "checked" if applies_to == "specific" %>
                 data-action="change->contract-ticketing#toggleAppliesTo"
                 class="h-4 w-4 text-pink-600 border-gray-300 focus:ring-pink-500 accent-pink-500">
          <span class="text-sm text-gray-900">Certain tiers only</span>
        </label>
      </div>
    </div>

    <div data-contract-ticketing-target="specificTiersWrapper" class="hidden mt-2 pl-1">
      <label class="block text-xs font-medium text-gray-700 mb-1">Which tiers?</label>
      <div data-contract-ticketing-target="specificTiers"></div>
    </div>
  </div>

  <input type="hidden" name="ticketing" data-contract-ticketing-target="ticketingJson" value="<%= ticketing.to_json %>">
</div>
