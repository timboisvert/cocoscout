<% content_for :title, "Money" %>

<%
  money_description = <<~HTML
    <p>
      This is your organization's financial hub — the central place to track revenue, manage payouts,
      and understand your show economics across all productions.
    </p>
  HTML

  money_actions = [
    { icon: "chart-bar", text: "Financials", description: "Track revenue and costs", path: manage_money_financials_path },
    { icon: "dollar-sign", text: "Payouts", description: "Calculate and distribute payments", path: manage_money_payouts_path },
    { icon: "file-text", text: "Contracts", description: "Third-party rentals and bookings", path: manage_contracts_path }
  ]
%>

<div class="w-full mb-10">
  <%= render partial: "shared/notice", locals: { notice: notice, alert: alert } %>

  <%= render "shared/module_header",
    title: "Money",
    description: money_description,
    actions: money_actions
  %>

  <div class="border-t border-gray-200 pt-4 mt-2">
    <%# Financial Overview with Period Selector %>
    <%= render partial: "manage/payouts/profitability_summary", locals: {
      summary: @org_summary,
      selected_period: @selected_period,
      production: nil,
      period_path: manage_money_index_path(production_filter: @production_filter),
      refresh_url: manage_refresh_money_path(period: @selected_period, production_filter: @production_filter),
      cached_at: @cached_at
    } %>
  </div>

  <%# Production Type Filter %>
  <div class="flex items-center justify-between gap-4 mb-3">
    <div class="flex-1">
      <%= render "shared/filters/filter_bar",
        toggle_label: "Production Type",
        bare: true,
        filter_groups: [
          {
            label: "Productions",
            filters: [
              { text: "All", path: manage_money_index_path(period: @selected_period, production_filter: "all", show_all: @show_all || nil), active: @production_filter == "all" },
              { text: "In-house", path: manage_money_index_path(period: @selected_period, production_filter: "first_party", show_all: @show_all || nil), active: @production_filter == "first_party" },
              { text: "Third-party", path: manage_money_index_path(period: @selected_period, production_filter: "third_party", show_all: @show_all || nil), active: @production_filter == "third_party" }
            ]
          }
        ]
      %>
    </div>
  </div>

  <%# Productions List %>
  <div class="">

    <% if @production_summaries.any? %>
      <div class="space-y-2">
        <% @production_summaries.each do |summary| %>
          <%= render "manage/money/production_row", summary: summary %>
        <% end %>
      </div>
    <% else %>
      <div class="bg-gray-50 rounded-lg border border-dashed border-gray-300 p-8 text-center">
        <% if @production_filter == "first_party" %>
          <p class="text-gray-600">No in-house productions found.</p>
        <% elsif @production_filter == "third_party" %>
          <p class="text-gray-600">No third-party productions found.</p>
        <% else %>
          <p class="text-gray-600">No productions yet. Create a production to start tracking finances.</p>
        <% end %>
      </div>
    <% end %>

    <%# Show All / Hidden Productions Toggle %>
    <% if !@show_all && @hidden_count && @hidden_count > 0 %>
      <div class="mt-4 text-center">
        <%= link_to manage_money_index_path(period: @selected_period, production_filter: @production_filter, show_all: "true"),
            class: "text-sm text-gray-500 hover:text-pink-600 transition-colors" do %>
          <%= @hidden_count %> older <%= "production".pluralize(@hidden_count) %> hidden &middot; Show all
        <% end %>
      </div>
    <% elsif @show_all %>
      <div class="mt-4 text-center">
        <%= link_to manage_money_index_path(period: @selected_period, production_filter: @production_filter),
            class: "text-sm text-gray-500 hover:text-pink-600 transition-colors" do %>
          Show only recent productions
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Courses Section (collapsed) %>
  <% if @course_summaries.any? %>
    <details class="mt-8 border-t border-gray-200 pt-4">
      <summary class="cursor-pointer text-sm font-semibold text-gray-700 uppercase tracking-wide hover:text-pink-600 transition-colors">
        Courses (<%= @course_summaries.count %>)
      </summary>
      <div class="mt-3 space-y-2">
        <% @course_summaries.each do |summary| %>
          <% offering = summary[:course_offering] %>
          <% if offering %>
            <div class="bg-white rounded-lg border border-gray-200 hover:border-gray-300 transition-all">
              <%= link_to manage_money_production_financials_path(summary[:production]), class: "block" do %>
                <div class="flex flex-col lg:flex-row lg:items-stretch">
                  <%# Panel 1: Course Info %>
                  <div class="flex-1 flex items-center gap-4 px-4 py-3">
                    <div class="flex-shrink-0 w-14 h-8 rounded-lg bg-pink-100 flex items-center justify-center">
                      <span class="text-sm font-bold text-pink-600"><%= summary[:production].initials %></span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2">
                        <span class="font-medium text-gray-900"><%= offering.title %></span>
                        <span class="inline-flex items-center rounded-full bg-pink-100 px-2 py-0.5 text-xs font-medium text-pink-700">Course</span>
                        <% if offering.contract.present? %>
                          <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600">Contract</span>
                        <% end %>
                      </div>
                      <div class="text-sm text-gray-600">
                        <%= offering.course_registrations.confirmed.count %> registrations
                      </div>
                    </div>
                  </div>

                  <%# Panel 2: Revenue %>
                  <div class="flex-shrink-0 w-40 flex flex-col items-end justify-center px-4 py-3 border-t lg:border-t-0 lg:border-l border-gray-100">
                    <span class="text-xs text-gray-500 uppercase tracking-wide">Revenue</span>
                    <span class="text-lg font-semibold text-gray-900"><%= number_to_currency((summary[:course_confirmed_revenue_cents] || 0) / 100.0) %></span>
                  </div>

                  <%# Panel 3: Payout Status %>
                  <div class="flex-shrink-0 w-40 flex flex-col items-end justify-center px-4 py-3 border-t lg:border-t-0 lg:border-l border-gray-100">
                    <span class="text-xs text-gray-500 uppercase tracking-wide">Payouts</span>
                    <% case summary[:course_payout_status] %>
                    <% when "paid" %>
                      <span class="inline-flex items-center gap-1 text-sm font-medium text-green-600">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                        Paid
                      </span>
                    <% when "calculated" %>
                      <span class="text-sm font-medium text-pink-600"><%= number_to_currency((summary[:course_payout_total_cents] || 0) / 100.0) %></span>
                      <span class="text-xs text-pink-500">Awaiting payment</span>
                    <% else %>
                      <span class="text-sm text-gray-400">—</span>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <%= render "manage/money/production_row", summary: summary %>
          <% end %>
        <% end %>
      </div>
    </details>
  <% end %>
</div>
