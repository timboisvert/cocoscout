<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "CocoScout" %></title>
    <%# viewport-fit=cover exposes safe area insets for iPhone notch + home indicator %>
    <meta name="viewport" content="width=device-width,initial-scale=1,minimum-scale=1,maximum-scale=5">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "actiontext", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= Sentry.get_trace_propagation_meta.html_safe %>
  </head>

  <body class="inter-regular text-slate-700 bg-[#f9f9f7]"
        data-turbo-native="true"
        <% if Current.user.present? %>
          data-controller="user-notifications"
          data-user-notifications-user-id-value="<%= Current.user.id %>"
        <% end %>>

    <%# Cat logo loading overlay — shown during Turbo navigations %>
    <div id="native-loader"
         style="display:none; position:fixed; inset:0; z-index:9999; background:#f9f9f7;
                align-items:center; justify-content:center; flex-direction:column; gap:12px;">
      <img src="/icon.png" alt="" width="72" height="72"
           style="animation: coco-pulse 1.1s ease-in-out infinite;">
    </div>

    <style>
      @keyframes coco-pulse {
        0%, 100% { transform: scale(1);   opacity: 1; }
        50%       { transform: scale(0.88); opacity: 0.7; }
      }
    </style>

    <script>
      (function () {
        var loader = null;
        var hideTimer = null;

        function show() {
          if (!loader) loader = document.getElementById("native-loader");
          if (!loader) return;
          clearTimeout(hideTimer);
          loader.style.display = "flex";
        }

        function hide() {
          if (!loader) loader = document.getElementById("native-loader");
          if (!loader) return;
          // Small delay so the new page has painted before we reveal it
          hideTimer = setTimeout(function () {
            loader.style.display = "none";
          }, 80);
        }

        // Full page navigations
        document.addEventListener("turbo:visit",  show);
        document.addEventListener("turbo:load",   hide);
        // Turbo frame loads (filters, partials)
        document.addEventListener("turbo:before-fetch-request", show);
        document.addEventListener("turbo:before-fetch-response", hide);
        // Fallback in case load never fires
        document.addEventListener("turbo:render",  hide);
      })();
    </script>

    <main class="px-4 pt-4 pb-8 overflow-x-hidden" data-controller="bridge--form">
      <div id="flash-messages"></div>
      <%= yield %>
    </main>

    <%# Global modal turbo frames %>
    <%= turbo_frame_tag "contact_modal" %>
    <%= yield :modals %>
  </body>
</html>
