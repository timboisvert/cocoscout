<%#
  Renders a production's "image" with consistent priority and aspect rules,
  for use in lists, rows, and tiles. One source of truth for this decision.

  Priority:
    1. Logo (if attached) → square (1:1)
    2. Primary poster (if logo isn't attached) → 3:4 (Instagram portrait)
    3. Initials fallback → square (1:1)

  Locals:
    production     - the Production
    width:         - Tailwind width class for the container (default "w-12")
    classes:       - optional extra classes for the outer container
    initials_class: - text size class for the initials fallback (default "text-base")
%>
<%
  width = local_assigns.fetch(:width, "w-12")
  extra = local_assigns.fetch(:classes, "")
  initials_class = local_assigns.fetch(:initials_class, "text-base")
  logo_variant = production.safe_logo_variant(:small)
  primary_poster_variant = logo_variant ? nil : production.primary_poster&.safe_image_variant(:small)
%>
<% if logo_variant %>
  <div class="<%= width %> aspect-square rounded overflow-hidden border border-gray-200 bg-white <%= extra %>">
    <%= image_tag logo_variant, alt: production.name, class: "w-full h-full object-cover" %>
  </div>
<% elsif primary_poster_variant %>
  <div class="<%= width %> aspect-[3/4] rounded overflow-hidden border border-gray-200 bg-white <%= extra %>">
    <%= image_tag primary_poster_variant, alt: production.name, class: "w-full h-full object-cover" %>
  </div>
<% else %>
  <div class="<%= width %> aspect-square rounded bg-pink-100 flex items-center justify-center <%= extra %>">
    <span class="<%= initials_class %> font-bold text-pink-600"><%= production.initials %></span>
  </div>
<% end %>
