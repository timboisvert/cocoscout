<%# Public marketing-site header. Full nav on desktop; hamburger drawer on
    mobile (reuses the shared `mobile-nav` Stimulus controller — toggle() shows
    panelTarget, Escape closes it). Rendered on every public marketing page. %>
<header class="w-full bg-white/90 backdrop-blur-sm border-b border-pink-100 sticky top-0 z-30"
        data-controller="mobile-nav">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <%= link_to root_path, class: "flex items-center gap-2 shrink-0" do %>
        <%= image_tag "/icon.png", alt: "CocoScout", class: "h-9 w-9" %>
        <span class="text-xl coustard-regular text-pink-500">CocoScout</span>
      <% end %>

      <%# Desktop nav %>
      <nav class="hidden md:flex items-center gap-1 lg:gap-2">
        <%= link_to "For Producers", producers_path, class: "px-3 py-2 text-sm text-slate-600 hover:text-pink-500 transition" %>
        <%= link_to "For Performers", performers_path, class: "px-3 py-2 text-sm text-slate-600 hover:text-pink-500 transition" %>
        <%= link_to "Find a Mic", mics_home_path, class: "px-3 py-2 text-sm text-slate-600 hover:text-pink-500 transition" %>
        <span class="w-px h-5 bg-slate-200 mx-1"></span>
        <%= link_to "Sign Up Free", signup_path, class: "px-3 py-2 text-sm font-medium text-slate-600 hover:text-pink-500 transition" %>
        <%= render "shared/button", text: "Sign In", path: signin_path, variant: "primary", size: "small" %>
      </nav>

      <%# Mobile hamburger %>
      <button type="button" data-action="click->mobile-nav#toggle"
              class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-lg text-slate-700 hover:bg-pink-50 cursor-pointer"
              aria-label="Open menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg>
      </button>
    </div>
  </div>

  <%# Mobile drawer panel — the "new top section on mobile" %>
  <div data-mobile-nav-target="panel" class="hidden md:hidden border-t border-pink-100 bg-white shadow-lg">
    <nav class="px-4 py-3 flex flex-col gap-1">
      <%= link_to "For Producers", producers_path, class: "px-3 py-3 rounded-lg text-base font-medium text-slate-700 hover:bg-pink-50 hover:text-pink-600 transition" %>
      <%= link_to "For Performers", performers_path, class: "px-3 py-3 rounded-lg text-base font-medium text-slate-700 hover:bg-pink-50 hover:text-pink-600 transition" %>
      <%= link_to mics_home_path, class: "px-3 py-3 rounded-lg text-base font-medium text-slate-700 hover:bg-pink-50 hover:text-pink-600 transition flex items-center justify-between gap-2" do %>
        <span>Find a Mic</span>
        <span class="text-[10px] uppercase tracking-wider px-1.5 py-0.5 rounded bg-pink-100 text-pink-700 font-bold">findamic.com</span>
      <% end %>
      <div class="h-px bg-slate-100 my-2"></div>
      <%= link_to "Sign Up Free", signup_path, class: "px-3 py-3 rounded-lg text-base font-medium text-slate-700 hover:bg-pink-50 transition text-center" %>
      <%= render "shared/button", text: "Sign In", path: signin_path, variant: "primary", size: "jumbo" %>
    </nav>
  </div>
</header>
