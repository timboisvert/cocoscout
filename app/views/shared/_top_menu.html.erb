<%# Default links to empty array if not provided %>
<% links = local_assigns.fetch(:links, []) %>
<% extra_buttons = local_assigns[:extra_buttons] %>

<% if turbo_native_app? %>
  <%# Native: title + breadcrumbs are shown by the native nav bar.
      Only render action buttons, and only when there are some. %>
  <% if links.count > 0 || extra_buttons.present? %>
    <div class="flex gap-2 flex-wrap mb-4">
      <%= extra_buttons %>
      <% links.each do |link| %>
        <%
          if controller.class.ancestors.include?(Manage::ManageController)
            requires_global_manager = link[:global_manager_required] || false
            can_show_link = requires_global_manager ? current_user_is_global_manager? : current_user_can_manage?
          else
            can_show_link = true
          end
        %>
        <% if can_show_link %>
          <%
            button_data = link[:data] || {}
            button_data[:action] = link[:data_action] if link[:data_action].present?
            button_variant = if link[:variant].present?
              link[:variant]
            elsif link[:color] == "white"
              "outline"
            else
              "primary"
            end
          %>
          <%= render partial: "shared/button", locals: {
            text: link[:text],
            path: link[:path],
            icon: link[:icon],
            variant: button_variant,
            data: button_data,
            size: "small",
            method: link[:method],
            type: link[:type] || :submit,
            disabled: link[:disabled] || false
          } %>
        <% end %>
      <% end %>
    </div>
  <% end %>

<% else %>
  <%# Web: full breadcrumb + title + action buttons %>
  <div class="flex flex-col sm:flex-row sm:items-top sm:justify-between gap-2 sm:gap-4 mb-4 border-b-1 border-gray-200 pb-2">

    <div class="pt-1 coustard-regular min-w-0">
      <%# Mobile: just a back arrow to the immediate parent + current title %>
      <% parent = breadcrumbs.last %>
      <div class="sm:hidden flex items-center gap-2 min-w-0">
        <% if parent && parent[1] %>
          <%= link_to parent[1], class: "flex items-center text-pink-500 hover:text-pink-600 flex-shrink-0", title: "Back to #{parent[0]}" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          <% end %>
        <% end %>
        <span class="text-md font-medium text-gray-900 truncate"><%= text.length > 40 ? "#{text[0..37]}..." : text %></span>
      </div>

      <%# Desktop: full breadcrumb chain %>
      <div class="hidden sm:block">
        <% breadcrumbs.each do |name, path| %>
          <% display_name = name.length > 40 ? "#{name[0..37]}..." : name %>
          <% if path %>
            <%= link_to display_name, path, class:"text-xl mb-1 mr-2 text-pink-500 hover:text-pink-600 underline" %>
            <span class="text-xl font-medium text-gray-500 mr-2"> /</span>
          <% else %>
            <span class="text-xl mb-1 mr-2"><%= display_name %></span>
            <span class="text-xl mb-1 mr-2">/</span>
          <% end %>
        <% end %>
        <% display_text = text.length > 40 ? "#{text[0..37]}..." : text %>
        <span class="text-xl mb-1 mr-2"><%= display_text %></span>
      </div>
    </div>

    <% if links.count > 0 || extra_buttons.present? %>
      <div class="flex gap-2 flex-wrap flex-shrink-0">
        <%= extra_buttons %>
        <% links.each do |link| %>
          <%
            if controller.class.ancestors.include?(Manage::ManageController)
              requires_global_manager = link[:global_manager_required] || false
              can_show_link = requires_global_manager ? current_user_is_global_manager? : current_user_can_manage?
            else
              can_show_link = true
            end
          %>
          <% if can_show_link %>
            <%
              button_data = link[:data] || {}
              button_data[:action] = link[:data_action] if link[:data_action].present?
              button_variant = if link[:variant].present?
                link[:variant]
              elsif link[:color] == "white"
                "outline"
              else
                "primary"
              end
            %>
            <%= render partial: "shared/button", locals: {
              text: link[:text],
              path: link[:path],
              icon: link[:icon],
              variant: button_variant,
              data: button_data,
              size: "small",
              method: link[:method],
              type: link[:type] || :submit,
              disabled: link[:disabled] || false
            } %>
          <% end %>
        <% end %>
      </div>
    <% end %>

  </div>
<% end %>