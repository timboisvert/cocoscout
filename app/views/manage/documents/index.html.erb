<% content_for :title, "Documents" %>

<div class="w-full mb-10">
  <%= render partial: "shared/notice", locals: { notice: notice, alert: alert } %>
  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      [@production.name, edit_manage_production_path(@production)]
    ],
    text: "Documents",
    links: [
      { text: "New document", icon: "plus", path: new_manage_production_document_path(@production) }
    ]
  } %>

  <% if @documents.any? %>
    <div class="space-y-2">
      <% @documents.each do |doc| %>
        <div class="group bg-white border border-gray-200 rounded-lg px-4 py-3 flex items-center gap-4 hover:border-gray-300 transition-colors">
          <div class="w-9 h-9 rounded-lg bg-pink-50 flex items-center justify-center text-pink-600 flex-shrink-0">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
          </div>
          <div class="flex-1 min-w-0">
            <%= link_to doc.title, manage_production_document_path(@production, doc),
                  class: "font-medium text-gray-900 hover:text-pink-600 truncate block" %>
            <div class="text-xs text-gray-500 mt-0.5">
              Shared with: <%= doc.audience_summary %> · Updated <%= doc.updated_at.strftime("%b %-d, %Y") %>
            </div>
          </div>
          <div class="flex items-center gap-2 flex-shrink-0 opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity">
            <button type="button" data-controller="modal" data-action="click->modal#open"
                    data-modal-id="sharing-modal-<%= doc.id %>"
                    class="px-3 py-1.5 text-sm rounded border border-gray-300 bg-white hover:border-gray-400 cursor-pointer">Share</button>
            <%= render "shared/button", text: "Edit", variant: "outline", size: "small",
                  path: edit_manage_production_document_path(@production, doc) %>
            <%= render "shared/button", text: "Delete", variant: "danger", size: "small",
                  path: manage_production_document_path(@production, doc), method: :delete,
                  data: { turbo_confirm: "Delete \"#{doc.title}\"? This can't be undone." } %>
          </div>
        </div>
      <% end %>
    </div>

    <% @documents.each do |doc| %>
      <%= render "sharing_modal", document: doc, production: @production,
            talent_pools: @talent_pools, candidate_people: @candidate_people %>
    <% end %>
  <% else %>
    <div class="bg-gray-50 border border-dashed border-gray-300 rounded-lg p-8 text-center">
      <p class="text-sm text-gray-600 mb-3">No documents yet. Create a performer handbook or any document your team needs.</p>
      <%= link_to new_manage_production_document_path(@production) do %>
        <%= render "shared/button", text: "Create your first document", variant: "primary", size: "medium" %>
      <% end %>
    </div>
  <% end %>
</div>
