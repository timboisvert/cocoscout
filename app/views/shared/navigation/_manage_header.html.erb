<header class="hidden lg:flex fixed top-0 left-56 right-0 h-16 bg-white border-b border-gray-200 items-stretch justify-between z-50">
  <div class="flex items-stretch">

    <% if Current.organization.present? %>
      <%# Organization context dropdown %>
      <div class="relative flex items-center border-r border-slate-200 pt-1" data-controller="dropdown">
        <button data-action="click->dropdown#toggle click@window->dropdown#hide" class="flex items-center gap-2 hover:bg-slate-50 px-4 py-2 transition cursor-pointer">
          <% if Current.organization.logo.attached? %>
            <%= image_tag Current.organization.logo, class: "w-5 h-5 rounded object-cover" %>
          <% else %>
            <div class="w-5 h-5 rounded bg-pink-100 text-pink-600 flex items-center justify-center font-bold text-[10px]">
              <%= Current.organization.name[0..1].upcase %>
            </div>
          <% end %>
          <div class="flex flex-col items-start leading-none">
            <span class="text-[10px] text-slate-400 font-semibold uppercase tracking-wider">Organization</span>
            <span class="text-sm font-medium text-slate-700 max-w-[180px] truncate"><%= Current.organization.name %></span>
          </div>
          <svg class="w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <div data-dropdown-target="menu" class="hidden absolute left-0 top-full mt-0 min-w-[240px] py-1 bg-pink-500 rounded-lg shadow-lg z-50">
          <div class="flex flex-col">
            <%# Organization section %>
            <div class="px-3 py-2 border-b border-pink-400">
              <div class="text-[10px] text-pink-200 font-semibold uppercase tracking-wider mb-1">Organization</div>
              <div class="text-sm text-white font-medium"><%= Current.organization.name %></div>
              <div class="flex flex-col gap-0.5 mt-1">
                <% if current_user_is_global_manager? %>
                  <%= link_to "Manage this Organization", manage_organization_path(Current.organization), class: "text-xs text-pink-100 hover:text-white hover:underline" %>
                <% end %>
                <%= link_to "All My Organizations", manage_organizations_path, class: "text-xs text-pink-100 hover:text-white hover:underline" %>
              </div>
            </div>
            <%# Productions section %>
            <div class="px-3 py-2">
              <div class="text-[10px] text-pink-200 font-semibold uppercase tracking-wider mb-1">Productions</div>
              <div class="flex flex-col gap-0.5">
                <%= link_to "Manage Productions", manage_productions_path, class: "text-xs text-pink-100 hover:text-white hover:underline" %>
                <% if current_user_is_global_manager? %>
                  <%= link_to "Add a Production", manage_productions_wizard_path, class: "text-xs text-pink-100 hover:text-white hover:underline" %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <%= render "shared/navigation/user_dropdown" %>
</header>
