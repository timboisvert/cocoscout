<% content_for :title, "My Calendar" %>

<div class="w-full">

  <%= render partial: "shared/notice", locals: { notice: notice } %>

  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [],
    text: "My Calendar",
    links: []
  } %>

  <!-- Onboarding Checklist (show only for primary person to avoid duplicates) -->
  <% if (primary = @people.first) %>
    <%= render "my/dashboard/onboarding_checklist", person: primary %>
  <% end %>

  <!-- Pending Vacancy Invitations -->
  <% if @pending_vacancy_invitations.any? %>
    <div class="border border-pink-200 rounded-lg overflow-hidden mb-6 bg-pink-50">
      <div class="bg-pink-100 px-4 py-3 border-b border-pink-200 flex items-center gap-2">
        <svg class="w-5 h-5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
        </svg>
        <h3 class="text-md font-semibold text-pink-900 coustard-regular">You're Invited to Fill a Role!</h3>
      </div>
      <div class="p-4">
        <div class="space-y-3">
          <% @pending_vacancy_invitations.each do |invitation| %>
            <% vacancy = invitation.role_vacancy %>
            <% show = vacancy.show %>
            <% production = show.production %>
            <div class="p-3 bg-white border border-pink-200 rounded-lg">
              <div class="flex items-center gap-4">
                <div class="flex-shrink-0 w-14 text-center">
                  <div class="text-xs font-semibold text-pink-600 uppercase"><%= show.date_and_time.strftime("%b") %></div>
                  <div class="text-2xl font-bold text-gray-900"><%= show.date_and_time.strftime("%-d") %></div>
                  <div class="text-xs text-gray-500"><%= show.date_and_time.strftime("%a") %></div>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="font-medium text-gray-900 truncate"><%= production.name %></div>
                  <div class="text-sm text-gray-600">
                    <strong class="text-pink-600"><%= vacancy.role.name %></strong>
                    · <%= show.date_and_time.strftime("%l:%M %p").strip %>
                  </div>
                </div>
              </div>
              <% if invitation.can_claim? %>
                <div class="mt-3 pt-3 border-t border-pink-200 flex flex-col sm:flex-row sm:items-center gap-2">
                  <div class="flex items-center gap-2">
                    <%= render "shared/button", text: "Claim Role", path: claim_vacancy_path(invitation.token), variant: invitation.declined? ? "outline" : "primary", size: "small" %>
                    <% unless invitation.declined? %>
                      <%= render "shared/button", text: "Decline", path: decline_claim_vacancy_path(invitation.token), method: :post, variant: "outline", size: "small" %>
                    <% end %>
                  </div>
                  <% if invitation.declined? %>
                    <span class="text-xs text-gray-500">You declined, but you can still claim if available</span>
                  <% end %>
                </div>
              <% else %>
                <div class="mt-3 pt-3 border-t border-pink-200">
                  <span class="text-sm text-gray-500">No longer available</span>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Pending Agreement Signatures -->
  <% if @pending_agreements.any? %>
    <div class="border border-pink-200 rounded-lg overflow-hidden mb-6 bg-pink-50">
      <div class="bg-pink-100 px-4 py-3 border-b border-pink-200 flex items-center gap-2">
        <svg class="w-5 h-5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <h3 class="text-md font-semibold text-pink-900 coustard-regular">Agreement Signature Required</h3>
      </div>
      <div class="p-4">
        <div class="space-y-3">
          <% @pending_agreements.each do |production| %>
            <div class="p-3 bg-white border border-pink-200 rounded-lg flex items-center justify-between">
              <div class="flex items-center gap-3">
                <% if production.logo.attached? %>
                  <%= image_tag production.logo.variant(:small), class: "w-10 h-10 rounded object-cover" %>
                <% else %>
                  <div class="w-10 h-10 rounded bg-pink-200 flex items-center justify-center">
                    <span class="text-pink-700 font-semibold text-sm"><%= production.name.first(2).upcase %></span>
                  </div>
                <% end %>
                <div>
                  <div class="font-medium text-gray-900"><%= production.name %></div>
                  <div class="text-sm text-gray-600">Please review and sign the performer agreement</div>
                </div>
              </div>
              <%= render "shared/button", text: "Review & Sign", path: my_production_agreement_path(production), variant: "primary", size: "small" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Unified Calendar -->
  <%
    desktop_month = @current_month
    month_start_date = desktop_month.to_date.beginning_of_month
    month_end_date = month_start_date.end_of_month
  %>

  <!-- Filters -->
  <%
    calendar_types = {
      "show" => { label: "Shows", color_class: "bg-pink-200 border-pink-300" },
      "rehearsal" => { label: "Rehearsals", color_class: "bg-blue-200 border-blue-300" },
      "meeting" => { label: "Meetings", color_class: "bg-green-200 border-green-300" },
      "course" => { label: "Courses", color_class: "bg-purple-200 border-purple-300" },
      "audition" => { label: "Auditions", color_class: "bg-amber-200 border-amber-300" }
    }
    all_calendar_types = calendar_types.keys
  %>
  <%= render "shared/filters/filter_bar",
      toggle_label: "Filters",
      filter_groups: [
        {
          label: "View",
          filters: [
            {
              text: "My Assignments",
              path: my_dashboard_path(month: params[:month], scope: "my_assignments", event_type: @event_type_filter.join(","), entity: @entity_filter.join(",")),
              active: @calendar_scope == "my_assignments"
            },
            {
              text: "All Shows & Events",
              path: my_dashboard_path(month: params[:month], scope: "all_shows", event_type: @event_type_filter.join(","), entity: @entity_filter.join(",")),
              active: @calendar_scope == "all_shows"
            }
          ]
        },
        { separator: true },
        {
          label: "Show",
          filters: calendar_types.map { |type, config|
            current_types = @event_type_filter.dup
            toggled = current_types.include?(type) ? current_types - [type] : current_types + [type]
            toggled = [type] if toggled.empty?
            {
              text: config[:label],
              path: my_dashboard_path(month: params[:month], scope: @calendar_scope, event_type: toggled.join(","), entity: @entity_filter.join(",")),
              active: @event_type_filter.include?(type)
            }
          }
        },
        (@people.count > 1 || @groups.any?) ? { separator: true } : nil,
        (@people.count > 1 || @groups.any?) ? {
          partial: "shared/filters/entity_filter",
          locals: {
            path_helper: method(:my_dashboard_path),
            people: @people,
            groups: @groups,
            entity_filter: @entity_filter,
            label: "Include",
            event_type: @event_type_filter.join(","),
            month: params[:month],
            scope: @calendar_scope
          }
        } : nil
      ].compact
  %>

  <% if @calendar_scope == "all_shows" %>
    <div class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-2.5 mb-4 text-sm text-gray-600">
      Showing all events associated with your productions. Your assignments are highlighted.
    </div>
  <% end %>

  <!-- Month Navigation -->
  <div class="flex items-center justify-between mb-4">
    <div>
      <% if @can_go_prev %>
        <%= render "shared/button",
            text: @prev_month.strftime("%B"),
            path: my_dashboard_path(month: @prev_month.strftime("%Y-%m-01"), scope: @calendar_scope, event_type: @event_type_filter.join(","), entity: @entity_filter.join(",")),
            variant: "secondary",
            size: "small",
            icon: "chevron-left",
            data: { turbo_prefetch: false } %>
      <% end %>
    </div>

    <div class="flex items-center gap-3">
      <h2 class="text-2xl font-bold text-gray-900"><%= desktop_month.strftime("%B %Y") %></h2>
      <% if desktop_month != Time.current.beginning_of_month %>
        <%= render "shared/button",
            text: "Today",
            path: my_dashboard_path(scope: @calendar_scope, event_type: @event_type_filter.join(","), entity: @entity_filter.join(",")),
            variant: "outline-pink",
            size: "small",
            data: { turbo_prefetch: false } %>
      <% end %>
    </div>

    <div>
      <% if @can_go_next %>
        <%= render "shared/button",
            text: @next_month.strftime("%B"),
            path: my_dashboard_path(month: @next_month.strftime("%Y-%m-01"), scope: @calendar_scope, event_type: @event_type_filter.join(","), entity: @entity_filter.join(",")),
            variant: "secondary",
            size: "small",
            icon: "chevron-right",
            data: { turbo_prefetch: false } %>
      <% end %>
    </div>
  </div>

  <!-- Desktop: Calendar Grid -->
  <div class="hidden md:block border border-gray-200 rounded-lg p-4 mb-8">
    <div class="grid grid-cols-7 gap-1">
      <!-- Day headers -->
      <% %w[Sun Mon Tue Wed Thu Fri Sat].each do |day| %>
        <div class="text-center text-xs font-semibold text-gray-600 p-2"><%= day %></div>
      <% end %>

      <!-- Empty cells before month starts -->
      <% (month_start_date.wday).times do %>
        <div class="border border-gray-100 bg-gray-50 min-h-[80px] p-1"></div>
      <% end %>

      <!-- Calendar days -->
      <% current_date = month_start_date %>
      <% while current_date <= month_end_date %>
        <% day_events = (@events_by_date[current_date] || []).sort_by { |e| e[:time] } %>
        <% is_past = current_date < Date.current %>
        <% is_today = current_date == Date.current %>
        <div class="border border-gray-200 min-h-[80px] p-1 <%= 'bg-blue-50' if is_today %> <%= 'opacity-50 bg-gray-50' if is_past %>">
          <div class="text-xs font-semibold mb-1 <%= is_past ? 'text-gray-400' : 'text-gray-700' %>">
            <%= current_date.day %>
          </div>

          <% day_events.first(4).each do |event| %>
            <%
              if event[:color] == "gray"
                color_classes = "bg-white text-gray-700 border-gray-300 hover:bg-gray-50"
              elsif event[:color] == "canceled"
                color_classes = "bg-gray-100 text-gray-400 border-gray-300 line-through opacity-60"
              else
                color_classes = case event[:color]
                  when "pink" then "bg-pink-100 text-pink-800 border-pink-300 hover:bg-pink-200"
                  when "blue" then "bg-blue-100 text-blue-800 border-blue-300 hover:bg-blue-200"
                  when "green" then "bg-green-100 text-green-800 border-green-300 hover:bg-green-200"
                  when "purple" then "bg-purple-100 text-purple-800 border-purple-300 hover:bg-purple-200"
                  when "amber" then "bg-amber-100 text-amber-800 border-amber-300 hover:bg-amber-200"
                  else "bg-gray-100 text-gray-800 border-gray-300 hover:bg-gray-200"
                end
              end
              color_classes = "bg-gray-100 text-gray-600 border-gray-300 hover:bg-gray-200" if is_past
            %>
            <%= link_to event[:path], class: "block mb-1" do %>
              <div class="text-xs p-1.5 rounded border <%= color_classes %> transition-colors truncate">
                <div class="font-semibold truncate"><%= event[:time].strftime("%-I:%M%p").downcase %></div>
                <div class="truncate text-[10px]"><%= event[:title] %></div>
                <% unless event[:color] == "gray" %>
                  <div class="truncate text-[10px] font-semibold <%= is_past ? 'text-gray-500' : '' %>"><%= event[:subtitle] %></div>
                <% end %>
              </div>
            <% end %>
          <% end %>
          <% if day_events.size > 4 %>
            <div class="text-[10px] text-gray-500 text-center mt-0.5">+<%= day_events.size - 4 %> more</div>
          <% end %>
        </div>
        <% current_date = current_date + 1.day %>
      <% end %>

      <!-- Empty cells to complete the week -->
      <% remaining_cells = (7 - (month_end_date + 1.day).wday) % 7 %>
      <% remaining_cells.times do %>
        <div class="border border-gray-100 bg-gray-50 min-h-[80px] p-1"></div>
      <% end %>
    </div>
  </div>

  <!-- Mobile: List View -->
  <div class="md:hidden space-y-1 mb-8">
    <% current_date = month_start_date %>
    <% current_week_start = Date.current.beginning_of_week(:sunday) %>
    <% mobile_showed_anything = false %>
    <% while current_date <= month_end_date %>
      <%# Skip days from past completed weeks %>
      <% if current_date < current_week_start %>
        <% current_date = current_date + 1.day %>
        <% next %>
      <% end %>
      <% day_events = (@events_by_date[current_date] || []).sort_by { |e| e[:time] } %>
      <% if day_events.any? %>
        <% mobile_showed_anything = true %>
        <% is_past = current_date < Date.current %>
        <% is_today = current_date == Date.current %>
        <div class="<%= 'opacity-50' if is_past %>">
          <div class="text-xs font-semibold px-1 py-1 <%= is_today ? 'text-pink-600' : (is_past ? 'text-gray-400' : 'text-gray-500') %>">
            <%= current_date.strftime("%a, %b %-d") %>
          </div>
          <% day_events.each do |event| %>
            <%
              is_canceled = event[:canceled]
              is_assigned = event[:color] != "gray" && !is_canceled
              if is_canceled
                row_bg = "bg-gray-50 border border-gray-200 opacity-60 line-through"
                dot_color = "bg-gray-300"
              elsif is_assigned
                row_bg = case event[:color]
                  when "pink" then "bg-pink-50 border border-pink-200"
                  when "blue" then "bg-blue-50 border border-blue-200"
                  when "green" then "bg-green-50 border border-green-200"
                  when "purple" then "bg-purple-50 border border-purple-200"
                  when "amber" then "bg-amber-50 border border-amber-200"
                  else ""
                end
                dot_color = case event[:color]
                  when "pink" then "bg-pink-400"
                  when "blue" then "bg-blue-400"
                  when "green" then "bg-green-400"
                  when "purple" then "bg-purple-400"
                  when "amber" then "bg-amber-400"
                  else "bg-gray-400"
                end
              else
                row_bg = ""
                dot_color = "bg-gray-400"
              end
              if is_past
                row_bg = ""
                dot_color = "bg-gray-300"
              end
            %>
            <%= link_to event[:path], class: "flex items-center gap-2 px-2 py-1.5 rounded hover:bg-gray-50 transition-colors #{row_bg}" do %>
              <div class="w-1.5 h-1.5 rounded-full flex-shrink-0 <%= dot_color %>"></div>
              <span class="text-xs text-gray-500 w-14 flex-shrink-0"><%= event[:time].strftime("%-I:%M%p").downcase %></span>
              <span class="text-sm truncate flex-1 <%= is_past ? 'text-gray-400' : 'text-gray-900' %>"><%= event[:title] %></span>
              <% unless event[:color] == "gray" %>
                <span class="text-xs text-gray-400 truncate max-w-[100px]"><%= event[:subtitle] %></span>
              <% end %>
            <% end %>
          <% end %>
        </div>
      <% end %>
      <% current_date = current_date + 1.day %>
    <% end %>
    <% unless mobile_showed_anything %>
      <div class="text-center text-sm text-gray-500 py-8">
        <% if @calendar_scope == "my_assignments" %>
          You don't have any assignments this month.
        <% else %>
          You don't have any shows or events this month.
        <% end %>
      </div>
    <% end %>
  </div>

</div>