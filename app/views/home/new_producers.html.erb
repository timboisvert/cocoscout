    <!-- Carousel JavaScript -->
    <script>
      function initCarousels() {
        document.querySelectorAll('[data-carousel]').forEach(function(carousel) {
          // Skip if already initialized
          if (carousel.dataset.carouselInitialized) return;
          carousel.dataset.carouselInitialized = 'true';

          const slides = carousel.querySelectorAll('.carousel-slide');
          const dots = carousel.querySelectorAll('.carousel-dot');
          const prevBtn = carousel.querySelector('.carousel-prev');
          const nextBtn = carousel.querySelector('.carousel-next');
          let currentIndex = 0;

          function showSlide(index) {
            slides.forEach((slide, i) => {
              if (i === index) {
                // Active slide: remove hidden, make it relative (establishes height)
                slide.classList.remove('hidden', 'absolute', 'inset-0');
              } else {
                // Inactive slides: hide and make absolute
                slide.classList.add('hidden', 'absolute', 'inset-0');
              }
            });
            dots.forEach((dot, i) => {
              dot.classList.toggle('bg-pink-500', i === index);
              dot.classList.toggle('bg-slate-300', i !== index);
            });
            currentIndex = index;
          }

          if (prevBtn) {
            prevBtn.addEventListener('click', function(e) {
              e.preventDefault();
              const newIndex = currentIndex === 0 ? slides.length - 1 : currentIndex - 1;
              showSlide(newIndex);
            });
          }

          if (nextBtn) {
            nextBtn.addEventListener('click', function(e) {
              e.preventDefault();
              const newIndex = currentIndex === slides.length - 1 ? 0 : currentIndex + 1;
              showSlide(newIndex);
            });
          }

          dots.forEach(function(dot, index) {
            dot.addEventListener('click', function(e) {
              e.preventDefault();
              showSlide(index);
            });
          });
        });
      }

      // Support both regular page load and Turbo navigation
      document.addEventListener('DOMContentLoaded', initCarousels);
      document.addEventListener('turbo:load', initCarousels);
    </script>

