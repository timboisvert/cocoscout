<%#
  Tech fields: who provides the tech, and (when we do) the hourly rate, hours, and
  how it's paid. Wrapped in the `contract-tech` Stimulus controller which shows/hides
  the charge block. Plain named inputs (tech_provider, tech_hourly_rate, tech_hours,
  tech_payment_method) — the caller supplies the surrounding <form> and nav buttons.
  Local: tech (Hash, e.g. @contract.draft_tech or staged amend data).
%>
<%
  tech ||= {}
  provider = tech["provider"] || "them"
  payment_method = tech["payment_method"] || "cash"
%>

<div data-controller="contract-tech">
  <%# Provider choice %>
  <div class="space-y-3 mb-6">
    <label class="flex items-start p-3 bg-gray-50 rounded-xl border border-gray-200 cursor-pointer hover:border-pink-400 transition-colors">
      <input type="radio" name="tech_provider" value="them" <%= "checked" if provider != "us" %>
             data-action="change->contract-tech#toggle"
             class="mt-0.5 h-4 w-4 text-pink-600 border-gray-300 focus:ring-pink-500 accent-pink-500">
      <div class="ml-3">
        <div class="text-sm font-medium text-gray-900">They provide their own tech</div>
        <div class="text-xs text-gray-500">The contractor brings their own technician.</div>
      </div>
    </label>

    <label class="flex items-start p-3 bg-gray-50 rounded-xl border border-gray-200 cursor-pointer hover:border-pink-400 transition-colors">
      <input type="radio" name="tech_provider" value="us" <%= "checked" if provider == "us" %>
             data-action="change->contract-tech#toggle"
             class="mt-0.5 h-4 w-4 text-pink-600 border-gray-300 focus:ring-pink-500 accent-pink-500">
      <div class="ml-3">
        <div class="text-sm font-medium text-gray-900">We provide the tech</div>
        <div class="text-xs text-gray-500">We supply a technician and charge for it.</div>
      </div>
    </label>
  </div>

  <%# Charge details (only when we provide) %>
  <div data-contract-tech-target="charges" class="bg-gray-50 rounded-xl p-5 mb-6 border border-gray-200 <%= "hidden" if provider != "us" %>">
    <h3 class="text-sm font-medium text-gray-900 mb-3">Charge Details</h3>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Hourly rate</label>
        <div class="relative">
          <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 font-medium">$</span>
          <input type="number" step="0.01" min="0" name="tech_hourly_rate"
                 value="<%= tech["hourly_rate"] %>" placeholder="0.00"
                 class="w-full pl-8 pr-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-pink-500 focus:border-pink-500">
        </div>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-700 mb-1">Hours</label>
        <input type="number" step="0.25" min="0" name="tech_hours"
               value="<%= tech["hours"] %>" placeholder="0"
               class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-pink-500 focus:border-pink-500">
      </div>
    </div>

    <div>
      <label class="block text-xs font-medium text-gray-700 mb-1">How is this paid?</label>
      <div class="flex gap-4">
        <label class="flex items-center gap-2">
          <input type="radio" name="tech_payment_method" value="cash" <%= "checked" if payment_method != "from_cut" %>
                 class="h-4 w-4 text-pink-600 border-gray-300 focus:ring-pink-500 accent-pink-500">
          <span class="text-sm text-gray-900">Paid in cash</span>
        </label>
        <label class="flex items-center gap-2">
          <input type="radio" name="tech_payment_method" value="from_cut" <%= "checked" if payment_method == "from_cut" %>
                 class="h-4 w-4 text-pink-600 border-gray-300 focus:ring-pink-500 accent-pink-500">
          <span class="text-sm text-gray-900">Taken out of their cut</span>
        </label>
      </div>
    </div>
  </div>
</div>
