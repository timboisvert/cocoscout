<% content_for :title, @course_offering.title %>

<div class="w-full" data-controller="contact-production">

  <%= render partial: "shared/notice", locals: { notice: notice } %>

  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      ["My Courses", my_courses_path]
    ],
    text: @course_offering.title,
    links: []
  } %>

  <!-- Course Information Card -->
  <div class="border border-gray-200 rounded-lg overflow-hidden bg-white mb-6">
    <div class="flex flex-col lg:flex-row lg:items-stretch">
      <!-- Left: Course Details -->
      <div class="flex-1 p-6">
        <div class="space-y-4">
          <!-- Title and Subtitle -->
          <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-1"><%= @course_offering.title %></h2>
            <% if @course_offering.subtitle.present? %>
              <p class="text-gray-600"><%= @course_offering.subtitle %></p>
            <% end %>
            <% if @registration&.status == "refunded" %>
              <div class="mt-2">
                <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium bg-red-50 text-red-700 ring-1 ring-inset ring-red-600/10">Refunded</span>
              </div>
            <% end %>
            <% if @is_instructor %>
              <div class="mt-2">
                <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium bg-purple-50 text-purple-700 ring-1 ring-inset ring-purple-600/10">Instructor</span>
              </div>
            <% end %>
          </div>

          <!-- Course Details -->
          <div class="space-y-2 text-sm">
            <% first_session = @all_sessions.first %>
            <% last_session = @all_sessions.last %>
            <% if first_session && last_session %>
              <div class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-gray-400 flex-shrink-0 mt-0.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                </svg>
                <span class="text-gray-900 font-medium">
                  <% if first_session.date_and_time.to_date == last_session.date_and_time.to_date %>
                    <%= first_session.date_and_time.strftime("%B %-d, %Y") %>
                  <% elsif first_session.date_and_time.year == last_session.date_and_time.year %>
                    <%= first_session.date_and_time.strftime("%b %-d") %> – <%= last_session.date_and_time.strftime("%b %-d, %Y") %>
                  <% else %>
                    <%= first_session.date_and_time.strftime("%b %-d, %Y") %> – <%= last_session.date_and_time.strftime("%b %-d, %Y") %>
                  <% end %>
                  · <%= @all_sessions.size %> session<%= @all_sessions.size == 1 ? '' : 's' %>
                </span>
              </div>
            <% end %>

            <% if @course_offering.instructor_name.present? %>
              <div class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-gray-400 flex-shrink-0 mt-0.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                </svg>
                <span class="text-gray-900 font-medium">Instructor: <%= @course_offering.instructor_name %></span>
              </div>
            <% end %>

            <% if @location %>
              <div class="flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-gray-400 flex-shrink-0 mt-0.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
                <span class="text-gray-900 font-medium"><%= @location.name %></span>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Right: Registration Details -->
      <% if @registration %>
      <div class="w-full lg:w-1/4 border-t lg:border-t-0 lg:border-l border-gray-200 flex flex-col justify-center px-5 py-4 bg-gray-50/50">
        <div class="space-y-3">
          <div class="flex items-center gap-2 mb-1">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-pink-600">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 6v.75m0 3v.75m0 3v.75m0 3V18m-9-5.25h5.25M7.5 15h3M3.375 5.25c-.621 0-1.125.504-1.125 1.125v3.026a2.999 2.999 0 0 1 0 5.198v3.026c0 .621.504 1.125 1.125 1.125h17.25c.621 0 1.125-.504 1.125-1.125v-3.026a2.999 2.999 0 0 1 0-5.198V6.375c0-.621-.504-1.125-1.125-1.125H3.375Z" />
            </svg>
            <span class="text-xs font-semibold text-pink-700 uppercase tracking-wide">Registration</span>
          </div>
          <div>
            <div class="text-[10px] text-gray-400 uppercase tracking-wide mb-0.5">
              <% if @registration.status == "confirmed" %>
                Paid
              <% elsif @registration.status == "refunded" %>
                Refunded
              <% end %>
            </div>
            <div class="text-lg font-bold text-gray-900"><%= @registration.formatted_amount %></div>
          </div>
          <% if @all_sessions.any? %>
            <div>
              <div class="text-[10px] text-gray-400 uppercase tracking-wide mb-0.5">Progress</div>
              <div class="text-sm font-medium text-gray-900"><%= @completed_sessions %>/<%= @all_sessions.size %> sessions</div>
              <div class="w-full mt-1">
                <div class="w-full bg-gray-200 rounded-full h-1.5">
                  <div class="bg-pink-500 h-1.5 rounded-full" style="width: <%= @all_sessions.size > 0 ? (@completed_sessions.to_f / @all_sessions.size * 100).round : 0 %>%"></div>
                </div>
              </div>
            </div>
          <% end %>
          <div class="pt-1">
            <%= link_to my_course_show_path(@course_offering.short_code), class: "inline-flex items-center gap-1 text-xs font-medium text-pink-600 hover:text-pink-700 transition-colors" do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
              View Registration
            <% end %>
          </div>
        </div>
      </div>
      <% end %>
    </div>
  </div>

<%# Contact Instructor Card — only for students, not when viewing as instructor %>
  <% if @instructors.present? && !@is_instructor %>
    <div class="mb-6">
      <div class="bg-gradient-to-br from-pink-50 to-pink-100/50 rounded-xl border border-pink-200 p-5 shadow-sm">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0">
            <% lead_instructor = @instructors.first %>
            <% if @lead_coi&.headshot&.attached? %>
              <%= image_tag @lead_coi.headshot.variant(resize_to_fill: [96, 96]), alt: lead_instructor.name, class: "w-12 h-12 rounded-lg object-cover shadow-lg" %>
            <% else %>
              <% headshot_variant = lead_instructor.safe_headshot_variant(:thumb) %>
              <% if headshot_variant %>
                <%= image_tag headshot_variant, alt: lead_instructor.name, class: "w-12 h-12 rounded-lg object-cover shadow-lg" %>
              <% else %>
                <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-gradient-to-br from-pink-500 to-pink-600 shadow-lg shadow-pink-500/30 text-white font-bold text-sm">
                  <%= lead_instructor.initials %>
                </div>
              <% end %>
            <% end %>
          </div>
          <div class="flex-1 min-w-0">
            <h3 class="text-base font-semibold text-gray-900">
              Have a question for your <%= @instructors.size == 1 ? 'instructor' : 'instructors' %>?
            </h3>
            <p class="mt-1 text-sm text-gray-600">
              Send a private message to <span class="font-medium text-pink-600"><%= @instructors.map(&:name).join(", ") %></span>.
            </p>
            <div class="mt-3">
              <%= render "shared/button",
                  text: "Contact Instructor",
                  variant: "secondary",
                  type: :button,
                  data: {
                    action: "click->contact-production#open",
                    "production-name": @instructors.map(&:name).join(", "),
                    "action-url": my_direct_messages_path,
                    "person-id": @instructors.map(&:id).join(",")
                  } %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%# Instructor Panel: Registered Course Members %>
  <% if @is_instructor && @registered_students.present? %>
    <div class="border border-gray-200 rounded-lg overflow-hidden bg-white mb-6">
      <%= render "shared/card_header", title: "Course Members (#{@registered_students.size})" do %>
        <%= render "shared/button",
            text: "Contact All Members",
            variant: "secondary",
            size: "small",
            type: :button,
            data: {
              action: "click->contact-production#open",
              "production-name": "All Course Members",
              "action-url": my_direct_messages_path,
              "person-id": @registered_students.map(&:id).join(",")
            } %>
      <% end %>
      <div class="p-4">
        <%# Student list %>
        <div class="space-y-1">
          <% @registered_students.each do |student| %>
            <div class="flex items-center justify-between px-3 py-2 rounded-lg hover:bg-gray-50 group">
              <div class="flex items-center gap-3 min-w-0">
                <% headshot_variant = student.safe_headshot_variant(:thumb) %>
                <% if headshot_variant %>
                  <%= image_tag headshot_variant, alt: student.name, class: "w-8 h-8 rounded-lg object-cover" %>
                <% else %>
                  <div class="w-8 h-8 rounded-lg bg-gray-200 flex items-center justify-center text-gray-600 font-bold text-xs">
                    <%= student.initials %>
                  </div>
                <% end %>
                <span class="text-sm font-medium text-gray-900 truncate"><%= student.name %></span>
              </div>
              <div class="flex-shrink-0 opacity-0 group-hover:opacity-100 transition-opacity">
                <%= render "shared/button",
                    text: "Message",
                    variant: "secondary",
                    size: "small",
                    type: :button,
                    data: {
                      action: "click->contact-production#open",
                      "production-name": student.name,
                      "action-url": my_direct_messages_path,
                      "person-id": student.id
                    } %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <div class="space-y-4">

    <!-- Class Schedule -->
    <div class="border border-gray-200 rounded-lg overflow-hidden">
      <%= render "shared/card_header", title: "Class Schedule" %>
      <div class="p-2">
        <% if @all_sessions.any? %>
          <div class="space-y-1">
            <% @all_sessions.each_with_index do |session, idx| %>
              <% is_past = session.date_and_time < Time.current %>
              <% is_next = session == @next_session %>
              <div class="flex items-center gap-3 px-3 py-2 rounded-lg <%= is_next ? 'bg-pink-50 border border-pink-200' : (is_past ? 'opacity-60' : '') %>">
                <div class="flex-shrink-0 w-10 text-center">
                  <div class="text-[10px] font-semibold text-pink-600 uppercase leading-tight"><%= session.date_and_time.strftime("%b") %></div>
                  <div class="text-lg font-bold text-gray-900 leading-tight"><%= session.date_and_time.strftime("%-d") %></div>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="text-sm font-medium text-gray-900"><%= session.date_and_time.strftime("%A") %></div>
                  <div class="text-xs text-gray-500"><%= session.date_and_time.strftime("%-I:%M %p") %></div>
                </div>
                <div class="flex-shrink-0">
                  <% if is_past %>
                    <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                  <% elsif is_next %>
                    <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-pink-100 text-pink-700">Next</span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="p-4 text-center text-sm text-gray-500">No sessions scheduled.</div>
        <% end %>
      </div>
    </div>

    <!-- Location -->
    <% if @location %>
      <div class="border border-gray-200 rounded-lg overflow-hidden">
        <%= render "shared/card_header", title: @location.name, icon: '<svg class="w-5 h-5 text-gray-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>' %>
        <div class="p-4 flex flex-col lg:flex-row gap-4">
          <% address = [@location.address1, @location.address2, @location.city, @location.state, @location.postal_code].compact.reject(&:blank?).join(', ') %>

          <!-- Left: Location Info -->
          <div class="lg:w-1/3 space-y-3">
            <div>
              <% if @location.address1.present? %>
                <div class="text-sm text-gray-900"><%= @location.address1 %></div>
              <% end %>
              <% if @location.address2.present? %>
                <div class="text-sm text-gray-900"><%= @location.address2 %></div>
              <% end %>
              <% if @location.city.present? || @location.state.present? || @location.postal_code.present? %>
                <div class="text-sm text-gray-900">
                  <%= @location.city %><% if @location.city.present? && @location.state.present? %>,<% end %> <%= @location.state %> <%= @location.postal_code %>
                </div>
              <% end %>
            </div>

            <% if @location.respond_to?(:notes) && @location.notes.present? %>
              <div class="pt-2 border-t border-gray-200">
                <div class="text-xs font-semibold text-gray-700 mb-1">Notes</div>
                <div class="text-sm text-gray-600"><%= simple_format(@location.notes, class: "whitespace-pre-wrap") %></div>
              </div>
            <% end %>

            <div class="flex gap-2 pt-2">
              <a href="http://maps.apple.com/?address=<%= URI.encode_www_form_component(address) %>" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-gray-700 bg-gray-100 rounded-md hover:bg-gray-200 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3 h-3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
                Open in Maps
              </a>
              <a href="https://www.google.com/maps/search/?api=1&query=<%= URI.encode_www_form_component(address) %>" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-gray-700 bg-gray-100 rounded-md hover:bg-gray-200 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3 h-3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
                Google Maps
              </a>
            </div>
          </div>

          <!-- Right: Map -->
          <div class="lg:w-2/3">
            <div class="w-full h-[400px] lg:h-full min-h-[300px]">
              <iframe
                width="100%"
                height="100%"
                style="border:0; border-radius: 0.5rem;"
                loading="lazy"
                allowfullscreen
                referrerpolicy="no-referrer-when-downgrade"
                src="https://www.google.com/maps?q=<%= URI.encode_www_form_component(address) %>&output=embed">
              </iframe>
            </div>
          </div>
        </div>
      </div>
    <% end %>

  </div>

  <%# Contact Production Modal %>
  <%= render "shared/contact_production_modal" %>
</div>
