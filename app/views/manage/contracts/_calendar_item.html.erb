<%#
  A single pill in the contracts calendar.
  Local: item — hash with :type (:payment | :rental), :record, :contract, etc.
%>
<%
  record   = item[:record]
  contract = item[:contract]
%>
<% case item[:type] %>
<% when :payment %>
  <%
    late = item[:late]
    incoming = item[:incoming]
    label = (contract&.production_name.presence || contract&.contractor_name).to_s
    amount = if record.amount_tbd? && record.amount.to_f == 0
      "TBD"
    else
      number_to_currency(record.amount, precision: 0)
    end
    classes = if late
      "bg-red-500 text-white border-red-600 hover:bg-red-600"
    elsif incoming
      "bg-green-100 text-green-800 border-green-300 hover:bg-green-200"
    else
      "bg-red-100 text-red-800 border-red-300 hover:bg-red-200"
    end
  %>
  <%= link_to (contract ? manage_contract_path(contract) : "#"), class: "block mb-1" do %>
    <div class="text-xs px-1.5 py-1 rounded border <%= classes %> transition-colors">
      <div class="flex items-center justify-between gap-1">
        <span class="font-semibold"><%= incoming ? "+" : "−" %><%= amount %></span>
        <% if late %><span class="text-[9px] font-bold uppercase">Late</span><% end %>
      </div>
      <div class="truncate text-[10px]"><%= label.presence || "Payment" %></div>
    </div>
  <% end %>

<% when :rental %>
  <%
    space = record.respond_to?(:space_name) ? record.space_name.presence : nil
    location = [ record.location&.name, space ].compact.join(" · ").presence || "Space rental"
    renter = (contract&.production_name.presence || contract&.contractor_name).to_s
    path = contract ? manage_contract_path(contract) : "#"
    rental_payments = item[:payments] || []
    has_late = rental_payments.any?(&:overdue?)
  %>
  <%= link_to path, class: "block mb-1" do %>
    <div class="text-xs px-1.5 py-1 rounded border transition-colors <%= has_late ? 'bg-blue-100 text-blue-800 border-red-400 hover:bg-blue-200' : 'bg-blue-100 text-blue-800 border-blue-300 hover:bg-blue-200' %>">
      <div class="font-semibold"><%= item[:at].strftime("%-l:%M%p").downcase %><% if renter.present? %> · <%= renter %><% end %></div>
      <div class="truncate text-[10px]"><%= location %></div>
      <% rental_payments.each do |payment| %>
        <%
          incoming = payment.direction_incoming?
          late = payment.overdue?
          amount = payment.amount_tbd? && payment.amount.to_f == 0 ? "TBD" : number_to_currency(payment.amount, precision: 0)
        %>
        <div class="flex items-center justify-between gap-1 mt-0.5 font-semibold <%= late ? 'text-red-600' : (incoming ? 'text-green-700' : 'text-red-700') %>">
          <span><%= incoming ? "+" : "−" %><%= amount %></span>
          <% if late %><span class="text-[9px] font-bold uppercase">Late</span><% end %>
        </div>
      <% end %>
    </div>
  <% end %>
<% end %>
