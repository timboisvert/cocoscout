<% content_for :title, "Find an Audition" %>

<div class="w-full">

  <%= render partial: "shared/notice", locals: { notice: notice } %>

  <%= render partial: "shared/top_menu_tabs", locals: {
    tabs: [
      { name: "My Auditions", path: my_auditions_path, active: false },
      { name: "Find an Audition", path: my_auditions_directory_path, active: true }
    ]
  } %>

  <% if @cycles_data.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      <% @cycles_data.each do |data| %>
        <% cycle = data[:cycle] %>
        <% production = data[:production] %>
        <% organization = data[:organization] %>
        <% next_session = data[:next_session] %>
        <% location = data[:location] %>

        <%= link_to submit_audition_request_path(token: cycle.token), class: "block group" do %>
          <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden hover:shadow-md hover:border-gray-300 transition-all h-full flex flex-col">

            <%# Header with org name %>
            <div class="px-5 pt-5 pb-3">
              <p class="text-xs font-medium text-pink-600 uppercase tracking-wide mb-1.5"><%= organization.name %></p>
              <h3 class="text-lg font-bold text-gray-900 group-hover:text-pink-600 transition-colors leading-snug"><%= production.name %></h3>
              <% if cycle.header_text.present? %>
                <p class="text-sm text-gray-600 mt-1 line-clamp-2"><%= strip_tags(cycle.header_text) %></p>
              <% end %>
            </div>

            <%# Details section %>
            <div class="px-5 pb-4 flex-1 space-y-3">

              <%# Format badges %>
              <div class="flex flex-wrap gap-1.5">
                <% data[:formats].each do |fmt| %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= fmt == 'In-Person' ? 'bg-blue-100 text-blue-700' : 'bg-purple-100 text-purple-700' %>">
                    <% if fmt == "In-Person" %>
                      <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                    <% else %>
                      <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
                    <% end %>
                    <%= fmt %>
                  </span>
                <% end %>
              </div>

              <%# Next session date %>
              <% if next_session %>
                <div class="flex items-center gap-2 text-sm text-gray-600">
                  <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <span>Next: <%= next_session.start_at.strftime("%B %-d, %Y at %-I:%M %p") %></span>
                </div>
              <% end %>

              <% if data[:upcoming_sessions_count] > 0 %>
                <div class="flex items-center gap-2 text-sm text-gray-600">
                  <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span><%= data[:upcoming_sessions_count] %> upcoming session<%= data[:upcoming_sessions_count] == 1 ? '' : 's' %></span>
                </div>
              <% end %>

              <%# Location %>
              <% if location %>
                <div class="flex items-center gap-2 text-sm text-gray-600">
                  <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  <span><%= location.name %></span>
                </div>
              <% end %>

              <%# Deadline %>
              <% if cycle.closes_at.present? %>
                <div class="flex items-center gap-2 text-sm text-gray-600">
                  <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                  </svg>
                  <span>Closes <%= cycle.closes_at.strftime("%B %-d, %Y") %></span>
                </div>
              <% end %>
            </div>

            <%# Footer %>
            <div class="px-5 py-3 bg-gray-50 border-t border-gray-100 flex items-center justify-between">
              <% if cycle.closes_at.present? %>
                <span class="text-sm text-gray-500">Deadline: <%= cycle.closes_at.strftime("%b %-d, %Y") %></span>
              <% else %>
                <span class="text-sm text-gray-500">Open-ended</span>
              <% end %>
              <span class="text-xs font-medium text-pink-600 group-hover:text-pink-700">Apply Now →</span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16">
      <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
      </div>
      <h3 class="text-lg font-medium text-gray-900 mb-1">No auditions available</h3>
      <p class="text-sm text-gray-500">There are no open auditions listed in the directory right now. Check back soon!</p>
    </div>
  <% end %>

</div>
