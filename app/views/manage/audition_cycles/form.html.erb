<% content_for :title, "Audition Form" %>

<div class="w-full pb-8" data-controller="question-modal availability-wizard"
     data-create-path="<%= manage_create_question_signups_auditions_cycle_path(@production, @audition_cycle) %>"
     data-new-description="Custom Questions are shown at the bottom of the audition form."
     data-has-errors="<%= @question.errors.any? %>">
  <%= render partial: "shared/notice", locals: { notice: notice } %>
  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      ["Sign-ups", manage_signups_path],
      [@production.name, manage_signups_production_path(@production)],
      ["Auditions", manage_signups_auditions_path(@production)]
    ],
    text: "Form",
    links: []
  } %>

  <%= render partial: "manage/auditions/cycle_status_panel" %>
  <%= render partial: "manage/auditions/topical_nav", locals: { current_topic: :form } %>

  <% if flash[:notice]&.include?("Audition cycle created") %>
    <div class="mb-6 p-5 bg-gradient-to-r from-pink-50 to-rose-50 border border-pink-200 rounded-lg">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 w-10 h-10 bg-pink-100 rounded-full flex items-center justify-center">
          <svg class="w-5 h-5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <h3 class="font-semibold text-pink-900 mb-1">Your audition cycle is set up!</h3>
          <p class="text-sm text-pink-700">Now customize what information you collect on the audition form. Add custom questions, configure availability options, and preview how it will look to auditionees.</p>
        </div>
      </div>
    </div>
  <% end %>

  <div class="space-y-6">

    <%# ===== Introduction Instructions ===== %>
    <%= render "manage/audition_cycles/form_text_section",
          field: :instruction_text,
          title: "Introduction Instructions",
          help: "Shown at the top of the audition form, before any questions." %>

    <%# ===== Video Upload Instructions ===== %>
    <% if @audition_cycle.accepts_video_submissions? %>
      <%= render "manage/audition_cycles/form_text_section",
            field: :video_field_text,
            title: "Video Upload Instructions",
            help: "Shown above the video upload section." %>
    <% end %>

    <%# ===== Success Message ===== %>
    <%= render "manage/audition_cycles/form_text_section",
          field: :success_text,
          title: "Success Message",
          help: "Shown after someone successfully submits the audition form." %>

    <%# ===== Availability ===== %>
    <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden" data-controller="edit-modal">
      <%= render "shared/card_header", title: "Availability Questions" do %>
        <button type="button" data-action="click->edit-modal#open" class="text-sm text-pink-500 hover:text-pink-600 font-medium cursor-pointer">Edit</button>
      <% end %>
      <div class="p-5 space-y-3">
        <%# Show & Event Availability summary %>
        <div class="flex items-center justify-between">
          <div>
            <div class="text-sm font-medium text-gray-900">Show & Event Availability</div>
            <div class="text-sm text-gray-500">
              <% if @audition_cycle.include_availability_section %>
                <% selected_count = (@audition_cycle.availability_show_ids || []).size %>
                Asking about <%= selected_count.zero? ? "all upcoming shows" : pluralize(selected_count, "show") %><%= " (required)" if @audition_cycle.require_all_availability %>
              <% else %>
                Off
              <% end %>
            </div>
          </div>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold <%= @audition_cycle.include_availability_section ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600' %>">
            <%= @audition_cycle.include_availability_section ? "On" : "Off" %>
          </span>
        </div>

        <% if @audition_cycle.accepts_in_person_auditions? %>
          <div class="flex items-center justify-between border-t border-gray-100 pt-3">
            <div>
              <div class="text-sm font-medium text-gray-900">Audition Session Availability</div>
              <div class="text-sm text-gray-500">
                <% if @audition_cycle.include_audition_availability_section %>
                  Asking which audition times work for them<%= " (required)" if @audition_cycle.require_all_audition_availability %>
                <% else %>
                  Off
                <% end %>
              </div>
            </div>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold <%= @audition_cycle.include_audition_availability_section ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600' %>">
              <%= @audition_cycle.include_audition_availability_section ? "On" : "Off" %>
            </span>
          </div>
        <% end %>
      </div>

      <%# Availability Edit Modal %>
      <div data-edit-modal-target="modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4" data-action="click->edit-modal#closeOnBackdrop keydown.esc@window->edit-modal#close">
        <div class="bg-white rounded-lg shadow-xl w-full max-w-2xl max-h-[90vh] overflow-y-auto" data-action="click->edit-modal#stopPropagation">
          <div class="sticky top-0 bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between z-10">
            <h2 class="text-xl font-semibold text-gray-900 coustard-regular">Edit Availability</h2>
            <button type="button" data-action="click->edit-modal#close" class="text-gray-500 hover:text-gray-700 cursor-pointer">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>
          <div class="px-6 py-6">
            <%= form_with model: [:manage, @production, @audition_cycle], url: manage_signups_auditions_cycle_path(@production, @audition_cycle), method: :patch, local: true do |form| %>
              <%= hidden_field_tag :redirect_to, "form" %>

              <div class="space-y-4">
                <%# Show & Event Availability %>
                <div class="p-4 bg-gray-50 rounded-lg border border-gray-200">
                  <div class="flex items-center justify-between">
                    <div class="flex-1 mr-4">
                      <p class="font-medium text-gray-900">Show & Event Availability</p>
                      <p class="text-sm text-gray-500 mt-1">Ask if they're available for upcoming shows and events</p>
                    </div>
                    <label class="relative inline-flex items-center cursor-pointer">
                      <input type="hidden" name="audition_cycle[include_availability_section]" value="0">
                      <input type="checkbox" name="audition_cycle[include_availability_section]" value="1"
                             <%= "checked" if @audition_cycle.include_availability_section %>
                             class="sr-only peer"
                             data-action="change->availability-wizard#toggleSection"
                             data-availability-wizard-target="showAvailabilityToggle">
                      <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-pink-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-pink-500"></div>
                    </label>
                  </div>

                  <div data-availability-wizard-target="showAvailabilitySection" class="<%= 'hidden' unless @audition_cycle.include_availability_section %> mt-4 pt-4 border-t border-gray-200">
                    <p class="text-sm font-medium text-gray-700 mb-2">Select shows & events to ask about:</p>
                    <% if @shows.any? %>
                      <%
                        selected_show_ids = (@audition_cycle.availability_show_ids || []).map { |id| id.to_i }
                        all_selected = selected_show_ids.empty?
                      %>
                      <div class="bg-white border border-gray-200 rounded-lg p-3 max-h-48 overflow-y-auto" data-availability-wizard-target="showList">
                        <%= hidden_field_tag "audition_cycle[availability_show_ids][]", "" %>
                        <div class="space-y-2">
                          <% @shows.each do |show| %>
                            <label class="flex items-center cursor-pointer hover:bg-gray-50 p-2 rounded -m-2">
                              <%= check_box_tag "audition_cycle[availability_show_ids][]", show.id,
                                                all_selected || selected_show_ids.include?(show.id),
                                                id: "modal_availability_show_#{show.id}",
                                                class: "w-4 h-4 rounded border-gray-300 text-pink-600 focus:ring-pink-500 accent-pink-500",
                                                data: { "availability-wizard-target": "showCheckbox" } %>
                              <span class="ml-3 text-sm text-gray-700">
                                <span class="font-medium"><%= show.event_type.titleize %></span>
                                <span class="text-gray-500"> · <%= show.date_and_time.strftime("%b %-d at %-l:%M %p") %></span>
                              </span>
                            </label>
                          <% end %>
                        </div>
                      </div>
                    <% else %>
                      <p class="text-sm text-gray-500">No upcoming shows yet.</p>
                    <% end %>

                    <div class="mt-3 pt-3 border-t border-gray-200">
                      <div class="flex items-center justify-between">
                        <span class="text-sm text-gray-700">Require show & event availability when signing up</span>
                        <label class="relative inline-flex items-center cursor-pointer">
                          <input type="hidden" name="audition_cycle[require_all_availability]" value="0">
                          <input type="checkbox" name="audition_cycle[require_all_availability]" value="1"
                                 <%= "checked" if @audition_cycle.require_all_availability %>
                                 class="sr-only peer">
                          <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-pink-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-pink-500"></div>
                        </label>
                      </div>
                    </div>
                  </div>
                </div>

                <% if @audition_cycle.accepts_in_person_auditions? %>
                  <div class="p-4 bg-gray-50 rounded-lg border border-gray-200">
                    <div class="flex items-center justify-between">
                      <div class="flex-1 mr-4">
                        <p class="font-medium text-gray-900">Audition Session Availability</p>
                        <p class="text-sm text-gray-500 mt-1">Ask which audition times work for them</p>
                      </div>
                      <label class="relative inline-flex items-center cursor-pointer">
                        <input type="hidden" name="audition_cycle[include_audition_availability_section]" value="0">
                        <input type="checkbox" name="audition_cycle[include_audition_availability_section]" value="1"
                               <%= "checked" if @audition_cycle.include_audition_availability_section %>
                               class="sr-only peer"
                               data-action="change->availability-wizard#toggleAuditionSection"
                               data-availability-wizard-target="auditionAvailabilityToggle">
                        <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-pink-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-pink-500"></div>
                      </label>
                    </div>

                    <div data-availability-wizard-target="auditionAvailabilitySection" class="<%= 'hidden' unless @audition_cycle.include_audition_availability_section %> mt-4 pt-4 border-t border-gray-200">
                      <div class="flex items-center justify-between">
                        <span class="text-sm text-gray-700">Require audition session availability when signing up</span>
                        <label class="relative inline-flex items-center cursor-pointer">
                          <input type="hidden" name="audition_cycle[require_all_audition_availability]" value="0">
                          <input type="checkbox" name="audition_cycle[require_all_audition_availability]" value="1"
                                 <%= "checked" if @audition_cycle.require_all_audition_availability %>
                                 class="sr-only peer">
                          <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-pink-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-pink-500"></div>
                        </label>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>

              <div class="mt-6 flex gap-2">
                <%= render "shared/button", text: "Save", variant: "primary", size: "medium", type: :submit %>
                <button type="button" data-action="click->edit-modal#close" class="px-4 py-2 text-sm text-gray-600 hover:text-gray-800 cursor-pointer">Cancel</button>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <%# ===== Custom Questions ===== %>
    <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
      <%= render "shared/card_header", title: "Custom Questions" %>
      <div class="p-5">
        <p class="text-sm text-gray-500 mb-4">Additional questions auditionees answer during sign-up. Drag to reorder.</p>
        <%= render partial: "questions" %>
      </div>
    </div>

    <%# ===== Form Review Status (naturally flowing) ===== %>
    <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
      <%= render "shared/card_header", title: "Review Audition Form" %>
      <div class="p-5">
        <% if @audition_cycle.form_reviewed %>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="flex-1">
              <div class="text-sm font-medium text-green-700">Form reviewed & ready to share</div>
              <div class="text-xs text-gray-500 mt-0.5">Auditionees can fill out the form when the cycle is open.</div>
            </div>
            <div class="flex items-center gap-2 flex-shrink-0">
              <%= link_to "Preview", manage_preview_signups_auditions_cycle_path(@production, @audition_cycle),
                    target: "_blank", rel: "noopener",
                    class: "bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 inline-flex items-center justify-center font-medium rounded transition-colors cursor-pointer px-3 py-1.5 text-sm" %>
              <%= form_with model: [:manage, @production, @audition_cycle],
                            url: manage_signups_auditions_cycle_path(@production, @audition_cycle),
                            method: :patch,
                            local: true do |form| %>
                <%= hidden_field_tag :redirect_to, "form" %>
                <%= form.hidden_field :form_reviewed, value: "0" %>
                <%= render partial: "shared/button", locals: { text: "Mark as Not Ready", variant: "ghost", size: "small", type: "submit" } %>
              <% end %>
            </div>
          </div>
        <% else %>
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-amber-100 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-amber-600" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
              </svg>
            </div>
            <div class="flex-1">
              <div class="text-sm font-medium text-gray-900">Preview the form, then mark it ready</div>
              <div class="text-xs text-gray-500 mt-0.5">The form won't be visible to auditionees until you mark it ready.</div>
            </div>
            <div class="flex items-center gap-2 flex-shrink-0">
              <%= link_to "Preview", manage_preview_signups_auditions_cycle_path(@production, @audition_cycle),
                    target: "_blank", rel: "noopener",
                    class: "bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 inline-flex items-center justify-center font-medium rounded transition-colors cursor-pointer px-3 py-1.5 text-sm" %>
              <%= form_with model: [:manage, @production, @audition_cycle],
                            url: manage_signups_auditions_cycle_path(@production, @audition_cycle),
                            method: :patch,
                            local: true do |form| %>
                <%= hidden_field_tag :redirect_to, "form" %>
                <%= form.hidden_field :form_reviewed, value: "1" %>
                <%= render partial: "shared/button", locals: { text: "Mark Ready", variant: "primary", size: "small", type: "submit" } %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Question Modal -->
  <%= render "shared/question_modal" %>
</div>

<%# Show-more toggles for any .show-more sections on the page %>
<script>
  (function() {
    function init() {
      document.querySelectorAll('.show-more').forEach((wrapper) => {
        if (wrapper.dataset.showMoreInit === '1') return;
        wrapper.dataset.showMoreInit = '1';
        const content = wrapper.querySelector('.show-more-content');
        const btn = wrapper.querySelector('.show-more-btn');
        if (!content || !btn) return;
        // Show the button only if content overflows
        if (content.scrollHeight > content.clientHeight + 1) {
          btn.classList.remove('hidden');
        }
        btn.addEventListener('click', () => {
          const collapsed = content.classList.toggle('line-clamp-4');
          content.classList.toggle('overflow-hidden', collapsed);
          btn.textContent = collapsed ? 'Show more' : 'Show less';
        });
      });
    }
    document.addEventListener('turbo:load', init);
    init();
  })();
</script>
