<%= form_with model: @document,
      url: (@document.persisted? ? manage_production_document_path(@production, @document) : manage_production_documents_path(@production)),
      method: (@document.persisted? ? :patch : :post) do |f| %>
  <% if @document.errors.any? %>
    <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
      <%= @document.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <%# Full-page document editor. A fixed-height card whose title, toolbar and
      footer stay put; only the body (contents rail + editor) scrolls. %>
  <div class="document-editor bg-white border border-gray-200 rounded-lg shadow-sm flex flex-col h-[calc(100vh-11rem)] min-h-[28rem] overflow-hidden"
       data-controller="document-editor">

    <%# Title + sharing (fixed) %>
    <div class="flex-shrink-0 flex items-start gap-3 px-6 sm:px-10 pt-5 pb-3">
      <%= f.text_field :title, required: true, placeholder: "Untitled document",
            class: "flex-1 min-w-0 text-3xl coustard-regular text-gray-900 border-0 px-0 py-1 focus:ring-0 placeholder:text-gray-300" %>
      <% if @document.persisted? %>
        <button type="button"
                data-controller="modal" data-action="click->modal#open"
                data-modal-id="sharing-modal-<%= @document.id %>"
                class="mt-1.5 flex-shrink-0 inline-flex items-center gap-2 px-3 py-1.5 text-sm rounded-lg border border-gray-300 bg-white hover:border-gray-400 cursor-pointer">
          <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 1 0 0 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186 9.566-5.314m-9.566 7.5 9.566 5.314m0 0a2.25 2.25 0 1 0 3.935 2.186 2.25 2.25 0 0 0-3.935-2.186Zm0-12.814a2.25 2.25 0 1 0 3.933-2.185 2.25 2.25 0 0 0-3.933 2.185Z"/></svg>
          <span class="text-gray-700">Sharing</span>
          <span class="text-gray-400 hidden sm:inline">· <%= @document.audience_summary %></span>
        </button>
      <% end %>
    </div>

    <%# Toolbar (relocated here by the controller — stays pinned under the title) %>
    <div data-document-editor-target="toolbarSlot"
         class="flex-shrink-0 px-4 sm:px-8 py-1 border-y border-gray-100 bg-white min-h-[2.75rem]"></div>

    <%# Body: contents rail (pinned) + the editor (scrolls) %>
    <div class="flex-1 flex min-h-0">
      <aside class="hidden lg:block w-60 flex-shrink-0 border-r border-gray-100 px-4 py-5 overflow-y-auto">
        <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-2">Contents</div>
        <nav data-document-editor-target="toc" class="space-y-0.5 text-sm"></nav>
        <p data-document-editor-target="tocEmpty" class="text-xs text-gray-400 leading-relaxed">
          Add headings (H1–H3) to build a table of contents.
        </p>
      </aside>

      <div class="flex-1 min-w-0 overflow-y-auto px-6 sm:px-10 pt-5 pb-24">
        <%= f.rich_text_area :body, data: { document_editor_target: "editor" } %>
      </div>
    </div>

    <%# Footer (fixed — always reachable, no scrolling to save) %>
    <div class="flex-shrink-0 flex items-center justify-end gap-3 px-6 sm:px-10 py-3 border-t border-gray-100 bg-gray-50/70 rounded-b-lg">
      <%= link_to "Cancel", manage_production_documents_path(@production),
            class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
      <%= render "shared/button", text: "Save document", variant: "primary", size: "medium", type: :submit %>
    </div>
  </div>
<% end %>
