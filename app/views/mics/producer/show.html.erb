<%
  mics_seo title: "Manage #{@mic.name} — Find a Mic",
            description: "Producer dashboard for #{@mic.name}."
%>
<%= render "mics/header" %>

<main class="w-full bg-white">
  <%# Slim masthead. Just identity + a quick link to the public listing. %>
  <section class="bg-pink-500 text-white border-b border-pink-600">
    <div class="w-full px-4 sm:px-8 py-5 sm:py-7 flex items-baseline justify-between gap-3 flex-wrap">
      <div>
        <h1 class="coustard-regular text-3xl sm:text-4xl"><%= @mic.name %></h1>
        <p class="mt-1 text-sm text-pink-100"><%= @mic.venue.name %> · <%= @mic.venue.neighborhood_city %></p>
      </div>
      <a href="<%= mics_detail_path(@mic.slug) %>"
         class="cursor-pointer px-3 py-1.5 bg-white text-pink-700 font-bold hover:bg-pink-50 active:bg-pink-200 transition-colors duration-100">
        View public listing →
      </a>
    </div>
  </section>

  <% if flash[:notice] %>
    <div class="w-full px-4 sm:px-8 py-3 bg-emerald-50 border-b border-emerald-200 text-emerald-700 text-sm">
      <%= flash[:notice] %>
    </div>
  <% end %>
  <% if flash[:alert] %>
    <div class="w-full px-4 sm:px-8 py-3 bg-red-50 border-b border-red-200 text-red-700 text-sm">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%# Big action row. Each tile opens a modal. %>
  <section class="w-full px-4 sm:px-8 py-6 border-b border-gray-100">
    <div class="text-xs uppercase tracking-wider text-gray-500 font-bold mb-3">Quick actions</div>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
      <% [
        [ "modal-verify",     "✓",  "Verify info",        "Confirm everything is still accurate." ],
        [ "modal-status",     "●",  "Set status",         "Online only, extra spots, running as planned." ],
        [ "modal-announce",   "📣", "Post announcement",  "News on the mic page (+ optional alert to subscribers)." ],
        [ "modal-cancel",     "✕",  "Cancel a date",      "Mark a specific date cancelled." ]
      ].each do |id, icon, title, blurb| %>
        <button type="button"
                data-controller="mics-modal"
                data-action="click->mics-modal#open"
                data-mics-modal-target-id-value="<%= id %>"
                class="cursor-pointer text-left px-4 py-4 bg-white border-2 border-gray-200 rounded hover:border-pink-400 hover:bg-pink-50 active:bg-pink-100 transition-colors duration-100 group">
          <div class="flex items-baseline gap-2">
            <span class="text-2xl text-pink-500"><%= icon %></span>
            <span class="coustard-regular text-lg text-gray-900 group-hover:text-pink-700"><%= title %></span>
          </div>
          <div class="mt-1 text-xs text-gray-500"><%= blurb %></div>
        </button>
      <% end %>
    </div>
  </section>

  <%# Sections — boxed style with pink header bar. %>
  <div class="w-full px-4 sm:px-8 py-6 bg-pink-50">
    <div class="w-full max-w-5xl space-y-6">

      <% if @pending_suggestions.any? %>
        <section class="bg-amber-50 border border-amber-300">
          <header class="px-5 sm:px-6 py-3 border-b border-amber-200 bg-amber-100">
            <h2 class="text-xs uppercase tracking-wider text-amber-800 font-bold">
              <%= pluralize(@pending_suggestions.size, "pending suggestion") %> from the community
            </h2>
          </header>
          <ul class="divide-y divide-amber-200">
            <% @pending_suggestions.each do |s| %>
              <li class="px-5 sm:px-6 py-3 flex items-baseline gap-3 flex-wrap">
                <div class="flex-1 min-w-0">
                  <div class="text-xs text-gray-500"><%= s.created_at.strftime("%b %-d, %-l:%M%p") %> · <%= s.submitter&.email_address || s.submitter_email %></div>
                  <div class="text-sm text-gray-800 mt-1 whitespace-pre-line"><%= s.note %></div>
                </div>
                <div class="flex gap-2 shrink-0">
                  <%= button_to "Approve", mics_producer_approve_suggestion_path(@mic.slug, suggestion_id: s.id), method: :post,
                        class: "cursor-pointer px-3 py-1.5 bg-emerald-500 hover:bg-emerald-600 text-white text-xs font-bold rounded" %>
                  <%= button_to "Reject", mics_producer_reject_suggestion_path(@mic.slug, suggestion_id: s.id), method: :post,
                        class: "cursor-pointer px-3 py-1.5 bg-white border border-gray-300 hover:bg-gray-50 text-gray-700 text-xs font-bold rounded" %>
                </div>
              </li>
            <% end %>
          </ul>
        </section>
      <% end %>

      <%# Basic info — Name, Format, Spot length, Cap, Blurb. %>
      <section class="bg-white border border-pink-100 rounded">
        <header class="px-5 sm:px-6 py-3 border-b border-pink-100 bg-pink-50">
          <h2 class="text-xs uppercase tracking-wider text-pink-700 font-bold">Basic info</h2>
        </header>
        <div class="px-5 sm:px-6 py-5">
          <%= form_with url: mics_producer_mic_path(@mic.slug), method: :patch do %>
            <%= render "mics/form_field", name: "mic[name]", label: "Name", value: @mic.name %>
            <%= render "mics/form_field", name: "mic[format]", label: "Format", type: "select", value: @mic.format,
                  options: Mic.formats.keys.map { |k| [ mics_format_label(k), k ] } %>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-4">
              <%= render "mics/form_field", name: "mic[spot_length_minutes]", label: "Spot length (minutes)", value: @mic.spot_length_minutes %>
              <%= render "mics/form_field", name: "mic[signup_cap]", label: "Cap", value: @mic.signup_cap,
                    placeholder: "e.g. 10, 10ish, 10-15",
                    help: "Free text — write whatever describes the cap. Producers often say things like \"10ish\" or \"up to 15\"." %>
            </div>
            <%= render "mics/form_field", name: "mic[blurb]", label: "Blurb", type: "textarea", rows: 4, value: @mic.blurb %>

            <%# Accessibility — drives the "Wheelchair accessible" filter on
                city pages and the ♿ badge on listings. Posted as a nested
                hash so the controller can merge into the jsonb column. %>
            <fieldset class="mb-4">
              <legend class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-2">Accessibility</legend>
              <label class="flex items-center gap-2 text-sm text-gray-800">
                <input type="hidden" name="mic[accessibility][wheelchair]" value="0">
                <input type="checkbox" name="mic[accessibility][wheelchair]" value="1"
                       <%= "checked" if (@mic.accessibility || {})["wheelchair"] %>
                       class="h-4 w-4 text-pink-600 border-gray-300 rounded focus:ring-pink-500 accent-pink-500">
                <span>♿ Wheelchair accessible</span>
              </label>
              <% if (@mic.venue.accessibility || {})["wheelchair"] %>
                <p class="mt-1 text-xs text-gray-500">The venue is already marked wheelchair accessible — leaving this off won't hide the badge.</p>
              <% else %>
                <p class="mt-1 text-xs text-gray-500">Performers filtering for wheelchair-accessible mics will only see this one if it's checked.</p>
              <% end %>
            </fieldset>

            <div class="flex justify-end pt-2 border-t border-gray-100">
              <%= render "shared/button", text: "Save basic info", variant: "primary", size: "medium", type: :submit %>
            </div>
          <% end %>
        </div>
      </section>

      <%# Location / Venue — editable for any user who can manage the mic.
          Two flows: (1) edit the current venue in place (affects every
          mic at that venue), (2) move this mic to a different venue. %>
      <section class="bg-white border border-pink-100 rounded">
        <header class="px-5 sm:px-6 py-3 border-b border-pink-100 bg-pink-50">
          <h2 class="text-xs uppercase tracking-wider text-pink-700 font-bold">Location</h2>
          <p class="text-xs text-gray-500 mt-1">
            Currently <strong><%= @mic.venue.name %></strong> · <%= @mic.venue.neighborhood_city %>.
            <% other_count = @mic.venue.mics.where.not(id: @mic.id).count %>
            <% if other_count.positive? %>
              ⚠️ This venue hosts <%= pluralize(other_count, "other mic") %> — edits affect all of them. Use "Move to a different venue" if just this one is relocating.
            <% end %>
          </p>
        </header>
        <div class="px-5 sm:px-6 py-5 space-y-6">
          <%# Edit current venue in place. %>
          <%= form_with url: mics_producer_update_venue_path(@mic.slug), method: :patch do %>
            <%= render "mics/form_field", name: "venue[name]", label: "Venue name", value: @mic.venue.name, required: true %>
            <%= render "mics/form_field", name: "venue[address1]", label: "Street address", value: @mic.venue.address1 %>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-4">
              <%= render "mics/form_field", name: "venue[neighborhood]", label: "Neighborhood", value: @mic.venue.neighborhood %>
              <%= render "mics/form_field", name: "venue[postal_code]", label: "ZIP", value: @mic.venue.postal_code %>
              <%= render "mics/form_field", name: "venue[city]", label: "City", value: @mic.venue.city, required: true %>
              <div class="mb-4">
                <%= render "shared/us_state_select",
                      name: "venue[state]", required: true, value: @mic.venue.state, label: "State" %>
              </div>
            </div>
            <div class="flex justify-end pt-2 border-t border-gray-100">
              <%= render "shared/button", text: "Save location", variant: "primary", size: "medium", type: :submit %>
            </div>
          <% end %>

          <%# Move to a different venue — re-points just this mic. %>
          <details class="border border-gray-200 bg-gray-50">
            <summary class="px-4 py-3 cursor-pointer text-sm font-bold text-gray-700 hover:bg-gray-100">
              Move to a different venue
            </summary>
            <div class="px-4 py-4 border-t border-gray-200 bg-white">
              <p class="text-xs text-gray-500 mb-3">
                Use this when the mic itself is relocating (e.g. the host moved venues). If the venue you're going to already exists in CocoScout, we'll reuse it; otherwise we'll create it.
              </p>
              <%= form_with url: mics_producer_move_venue_path(@mic.slug), method: :post,
                    data: { turbo_confirm: "Move this mic to a different venue? Existing schedule + producers stay the same." } do %>
                <%= render "mics/form_field", name: "venue_name", label: "New venue name", required: true,
                      placeholder: "e.g. Cole's Bar" %>
                <%= render "mics/form_field", name: "venue_address1", label: "Street address" %>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-4">
                  <%= render "mics/form_field", name: "venue_neighborhood", label: "Neighborhood" %>
                  <%= render "mics/form_field", name: "venue_postal_code", label: "ZIP" %>
                  <%= render "mics/form_field", name: "venue_city", label: "City", required: true %>
                  <div class="mb-4">
                    <%= render "shared/us_state_select",
                          name: "venue_state", required: true, value: @mic.venue.state, label: "State" %>
                  </div>
                </div>
                <div class="flex justify-end pt-2 border-t border-gray-100">
                  <%= render "shared/button", text: "Move this mic", variant: "secondary", size: "medium", type: :submit %>
                </div>
              <% end %>
            </div>
          </details>
        </div>
      </section>

      <%# Schedule — structured recurrence with Stimulus-driven UI. %>
      <section class="bg-white border border-pink-100 rounded">
        <header class="px-5 sm:px-6 py-3 border-b border-pink-100 bg-pink-50">
          <h2 class="text-xs uppercase tracking-wider text-pink-700 font-bold">Schedule</h2>
          <% if (preview = mics_schedule_label(@mic)).present? %>
            <p class="text-xs text-gray-500 mt-1">Current: <span class="font-bold text-gray-800"><%= preview %></span></p>
          <% end %>
        </header>
        <div class="px-5 sm:px-6 py-5">
          <%
            actual_pattern = (@mic.recurrence_pattern || "weekly")
            primary_choice = case actual_pattern
                             when "weekly"   then "weekly"
                             when "biweekly" then "biweekly"
                             else                  "monthly"
                             end
            monthly_kind   = actual_pattern.start_with?("monthly_") ? actual_pattern : "monthly_nth_weekday"
          %>
          <%= form_with url: mics_producer_mic_path(@mic.slug), method: :patch,
                data: { controller: "mics-schedule-form" } do %>

            <%# Hidden field that actually persists. JS writes the resolved enum value into it. %>
            <input type="hidden" name="mic[recurrence_pattern]" value="<%= actual_pattern %>"
                   data-mics-schedule-form-target="hiddenPattern">

            <%# Top-level: Weekly / Bi-weekly / Monthly %>
            <%= render "mics/form_field", name: "ui_primary_pattern", label: "How often?", type: "select",
                  value: primary_choice,
                  options: [
                    [ "Weekly",            "weekly" ],
                    [ "Every other week",  "biweekly" ],
                    [ "Monthly",           "monthly" ]
                  ],
                  data: { "mics-schedule-form-target": "primary",
                          action: "change->mics-schedule-form#refresh" } %>

            <%# Bi-weekly anchor — "starting on" so we know which weeks. %>
            <div data-mics-schedule-form-target="anchorBlock"
                 class="<%= primary_choice == "biweekly" ? "" : "hidden" %>">
              <%= render "mics/form_field", name: "mic[recurrence_anchor_date]",
                    label: "Starting on", type: "date",
                    value: @mic.recurrence_anchor_date&.iso8601,
                    help: "Pick any known mic date. We'll bracket the right alternating weeks from there." %>
            </div>

            <%# Sub-pattern shown only for Monthly. %>
            <div data-mics-schedule-form-target="monthlyKindBlock"
                 class="<%= primary_choice == "monthly" ? "" : "hidden" %>">
              <%= render "mics/form_field", name: "ui_monthly_kind", label: "Monthly on…", type: "select",
                    value: monthly_kind,
                    options: [
                      [ "A specific weekday (e.g. 2nd Tuesday)", "monthly_nth_weekday" ],
                      [ "Multiple weeks (e.g. 1st & 3rd Monday)", "monthly_nth_weekdays" ],
                      [ "A specific day of the month (e.g. the 15th)", "monthly_day_of_month" ]
                    ],
                    data: { "mics-schedule-form-target": "monthlyKind",
                            action: "change->mics-schedule-form#refresh" } %>
            </div>

            <%# Nth-week select — only for Monthly + nth_weekday %>
            <div data-mics-schedule-form-target="nthBlock"
                 class="<%= (primary_choice == "monthly" && monthly_kind == "monthly_nth_weekday") ? "" : "hidden" %>">
              <%= render "mics/form_field", name: "mic[recurrence_nth_week]", label: "Which one?", type: "select",
                    value: @mic.recurrence_nth_week || 1,
                    options: [
                      [ "1st", 1 ], [ "2nd", 2 ], [ "3rd", 3 ],
                      [ "4th", 4 ], [ "5th", 5 ], [ "Last", -1 ]
                    ] %>
            </div>

            <%# Multi-nth-week checkboxes — only for Monthly + nth_weekdays %>
            <div data-mics-schedule-form-target="nthMultiBlock"
                 class="mb-4 <%= (primary_choice == "monthly" && monthly_kind == "monthly_nth_weekdays") ? "" : "hidden" %>">
              <label class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-2">Which weeks?</label>
              <% selected_weeks = Array(@mic.recurrence_nth_weeks).map(&:to_i) %>
              <%# Hidden zero-value so an all-unchecked submit still posts the key. %>
              <input type="hidden" name="mic[recurrence_nth_weeks][]" value="">
              <div class="flex flex-wrap gap-2">
                <% [ [ 1, "1st" ], [ 2, "2nd" ], [ 3, "3rd" ], [ 4, "4th" ], [ 5, "5th" ], [ -1, "Last" ] ].each do |val, label| %>
                  <label class="inline-flex items-center gap-1.5 px-3 py-1.5 border rounded <%= selected_weeks.include?(val) ? "bg-pink-500 text-white border-pink-600 font-bold" : "bg-white border-gray-300 text-gray-700 hover:bg-pink-50" %>">
                    <input type="checkbox" name="mic[recurrence_nth_weeks][]" value="<%= val %>"
                           <%= "checked" if selected_weeks.include?(val) %>
                           class="h-4 w-4 accent-pink-500">
                    <span class="text-sm"><%= label %></span>
                  </label>
                <% end %>
              </div>
              <p class="mt-1 text-xs text-gray-500">Pick every week the mic runs. e.g. for "first and third Monday," check 1st and 3rd.</p>
            </div>

            <%# Day-of-month input — only for Monthly + day_of_month %>
            <div data-mics-schedule-form-target="domBlock"
                 class="<%= (primary_choice == "monthly" && monthly_kind == "monthly_day_of_month") ? "" : "hidden" %>">
              <%= render "mics/form_field", name: "mic[recurrence_day_of_month]", label: "Day of month (1–31)", type: "text",
                    value: @mic.recurrence_day_of_month,
                    help: "If a month doesn't have that day (e.g. Feb 30), it gets skipped." %>
            </div>

            <%# Day-of-week + start time — hidden only when day-of-month is the active monthly mode. %>
            <div data-mics-schedule-form-target="dowBlock"
                 class="<%= (primary_choice == "monthly" && monthly_kind == "monthly_day_of_month") ? "hidden" : "" %>">
              <%= render "mics/form_field", name: "mic[day_of_week]", label: "Which day of the week?", type: "select",
                    value: @mic.day_of_week,
                    options: (0..6).map { |i| [ mics_day_name(i), i ] } %>
            </div>

            <%= render "mics/form_field", name: "mic[starts_local_time]", label: "Start time", type: "time",
                  value: @mic.starts_local_time&.strftime("%H:%M") %>

            <%# Pause state lives in its own accordion — toggled on, the
                mic stops appearing on city listings and upcoming-week
                feeds, but stays searchable and on favoriters' lists.
                Optional resume date silently picks the schedule back up
                on that date. Optional note explains what's going on. %>
            <% currently_paused = @mic.paused? %>
            <details class="group border border-gray-200 bg-gray-50 mb-4" <%= "open" if currently_paused %>>
              <summary class="list-none px-4 py-3 cursor-pointer text-sm font-bold text-gray-700 hover:bg-gray-100 flex items-center gap-2">
                <span class="text-xs text-gray-500 transition-transform group-open:rotate-90 inline-block">▶</span>
                <span>Pause this mic</span>
                <% if currently_paused %>
                  <span class="ml-auto inline-flex items-center text-[10px] uppercase tracking-wider px-2 py-0.5 bg-amber-500 text-white font-bold rounded">
                    Paused<% if @mic.canceled_until.present? && @mic.canceled_until >= Date.current %> until <%= @mic.canceled_until.strftime("%b %-d") %><% end %>
                  </span>
                <% end %>
              </summary>
              <div class="px-4 py-4 border-t border-gray-200 bg-white space-y-4">
                <label class="flex items-center gap-2 text-sm text-gray-800">
                  <input type="hidden" name="mic[paused]" value="0">
                  <input type="checkbox" name="mic[paused]" value="1" <%= "checked" if currently_paused %>
                         class="h-4 w-4 text-pink-600 border-gray-300 rounded focus:ring-pink-500 accent-pink-500">
                  <span><strong>Pause this mic.</strong> Stays searchable and visible on favorites — just doesn't show up in city listings or upcoming-week views.</span>
                </label>

                <%= render "mics/form_field", name: "mic[canceled_until]", label: "Resume on (optional)", type: "date",
                      value: @mic.canceled_until&.iso8601,
                      help: "Leave empty for an open-ended hiatus. When set, the regular schedule silently picks back up on that date." %>

                <%= render "mics/form_field", name: "mic[pause_note]", label: "Pause message (shown on the public page)",
                      type: "textarea", rows: 3, value: @mic.pause_note,
                      placeholder: "e.g. On hiatus for the summer. See you in September!",
                      help: "Performers landing on the page will see this front-and-center while the mic is paused." %>
              </div>
            </details>

            <div class="flex justify-end pt-2 border-t border-gray-100">
              <%= render "shared/button", text: "Save schedule", variant: "primary", size: "medium", type: :submit %>
            </div>
          <% end %>
        </div>
      </section>

      <%# Sign-up info — channel (online / in-person / both) + bucket draw + URL (only for online). %>
      <section class="bg-white border border-pink-100 rounded">
        <header class="px-5 sm:px-6 py-3 border-b border-pink-100 bg-pink-50">
          <h2 class="text-xs uppercase tracking-wider text-pink-700 font-bold">Sign-up info</h2>
        </header>
        <div class="px-5 sm:px-6 py-5">
          <%= form_with url: mics_producer_mic_path(@mic.slug), method: :patch,
                data: { controller: "mics-signup-form" } do %>
            <%= render "mics/form_field", name: "mic[signup_method]", label: "Sign-up type", type: "select",
                  value: (@mic.signup_method.presence || "in_person"),
                  options: Mic.signup_methods.keys.map { |k| [ mics_signup_method_label(k), k ] },
                  data: { "mics-signup-form-target": "channel", action: "change->mics-signup-form#refresh" } %>

            <div data-mics-signup-form-target="urlBlock"
                 class="<%= @mic.online_signup? ? "" : "hidden" %>">
              <%= render "mics/form_field", name: "mic[signup_url]", label: "How to sign up online", value: @mic.signup_url,
                    placeholder: "https://… or e.g. \"Through Lia Berman's FB Google Sheet post\"",
                    help: "A URL becomes a \"Sign up\" button on the public page. Any other text gets shown as instructions — useful when sign-up happens via Facebook, a Google Sheet link in a post, etc." %>
            </div>

            <%= render "mics/form_field", name: "mic[signup_opens_at_text]", label: "When sign-up opens",
                  value: @mic.signup_opens_at_text,
                  placeholder: "e.g. 7:30 PM, or 2 weeks beforehand",
                  help: "Whatever describes it best — a time of day (\"7:30 PM\"), a lead time (\"2 weeks before\"), or however you'd say it." %>

            <label class="flex items-center gap-2 mb-4 text-sm text-gray-800">
              <%# Hidden so unchecked posts a falsy value, not "no key" — Rails sees `0` vs `1`. %>
              <input type="hidden" name="mic[bucket_draw]" value="0">
              <input type="checkbox" name="mic[bucket_draw]" value="1" <%= "checked" if @mic.bucket_draw %>
                     class="h-4 w-4 text-pink-600 border-gray-300 rounded focus:ring-pink-500 accent-pink-500">
              <span>Bucket draw / random draw</span>
            </label>

            <%= render "mics/form_field", name: "mic[signup_notes]", label: "Sign-up notes", type: "textarea", rows: 3,
                  value: @mic.signup_notes,
                  placeholder: "e.g. Spend $30 at the bar to get bumped in any time. Late drops handled at the door.",
                  help: "Anything that doesn't fit the structured fields — house rules, comp policies, bump-in offers, drink minimums. Shown publicly under sign-up info." %>

            <div class="flex justify-end pt-2 border-t border-gray-100">
              <%= render "shared/button", text: "Save sign-up info", variant: "primary", size: "medium", type: :submit %>
            </div>
          <% end %>
        </div>
      </section>

      <%# Socials — Instagram, X, TikTok, Website. %>
      <section class="bg-white border border-pink-100 rounded">
        <header class="px-5 sm:px-6 py-3 border-b border-pink-100 bg-pink-50">
          <h2 class="text-xs uppercase tracking-wider text-pink-700 font-bold">Socials</h2>
          <p class="text-xs text-gray-500 mt-1">Instagram, X, TikTok, or a website. Each becomes a button on the public mic page.</p>
        </header>
        <div class="px-5 sm:px-6 py-5">
          <% existing_socials = @mic.mic_links.where(link_type: MicLink.link_types.values).ordered.to_a %>
          <% if existing_socials.any? %>
            <ul class="text-sm text-gray-700 space-y-1 mb-4 border border-gray-200">
              <% existing_socials.each do |link| %>
                <li class="flex items-baseline justify-between gap-2 px-3 py-2 border-b border-gray-100 last:border-b-0">
                  <span class="min-w-0 flex-1">
                    <span class="text-xs uppercase tracking-wider text-gray-500 font-bold mr-2"><%= link.link_type.humanize %></span>
                    <% if link.label.present? %><span class="font-bold mr-2"><%= link.label %></span><% end %>
                    <a href="<%= link.url %>" target="_blank" rel="noopener" class="text-xs text-gray-500 hover:text-pink-600 truncate"><%= link.url %></a>
                  </span>
                  <%= button_to "Remove", mics_producer_remove_link_path(@mic.slug, link_id: link.id),
                        method: :delete,
                        class: "cursor-pointer text-xs text-gray-500 hover:text-red-600 underline shrink-0" %>
                </li>
              <% end %>
            </ul>
          <% end %>

          <%= form_with url: mics_producer_add_link_path(@mic.slug), method: :post do %>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-4">
              <%= render "mics/form_field", name: "link_type", label: "Type", type: "select",
                    options: [
                      [ "Instagram", "instagram" ],
                      [ "X / Twitter", "x_twitter" ],
                      [ "TikTok",    "tiktok" ],
                      [ "Website",   "website" ]
                    ] %>
              <%= render "mics/form_field", name: "url", label: "URL", type: "url", required: true,
                    placeholder: "https://..." %>
            </div>
            <%= render "mics/form_field", name: "label", label: "Display label (optional)",
                  placeholder: "e.g. @mymicig — defaults to the type if blank" %>
            <div class="flex justify-end pt-2 border-t border-gray-100">
              <%= render "shared/button", text: "Add social", variant: "primary", size: "medium", type: :submit %>
            </div>
          <% end %>
        </div>
      </section>

      <%# Mic runners / Producers. %>
      <section class="bg-white border border-pink-100 rounded">
        <header class="px-5 sm:px-6 py-3 border-b border-pink-100 bg-pink-50">
          <h2 class="text-xs uppercase tracking-wider text-pink-700 font-bold">Mic runners / Producers</h2>
          <p class="text-xs text-gray-500 mt-1">
            Everyone listed here has equal edit rights on the mic. The lead earns the "claimed" badge on the public page.
          </p>
        </header>
        <div class="px-5 sm:px-6 py-5">
          <% if @co_producers.any? %>
            <ul class="divide-y divide-gray-100 border border-gray-200 rounded overflow-hidden mb-5">
              <% @co_producers.each do |mp| %>
                <% is_lead = (@mic.lead_producer_user_id == mp.user_id) %>
                <% role_label = mp.role_producer? ? "Mic runner / Producer" : mp.role.humanize %>
                <li class="px-3 py-2 flex items-baseline gap-3 flex-wrap">
                  <span class="flex-1 min-w-0">
                    <span class="font-bold text-gray-900"><%= mp.user.person&.name.presence || mp.user.email_address %></span>
                    <% if mp.user.person&.name.present? %>
                      <span class="text-xs text-gray-500 ml-1">· <%= mp.user.email_address %></span>
                    <% end %>
                    <span class="text-xs text-gray-500 ml-1">· <%= role_label %></span>
                    <% if is_lead %>
                      <span class="ml-2 inline-flex items-center text-[10px] uppercase tracking-wider px-1.5 py-0.5 bg-pink-500 text-white font-bold rounded">Lead</span>
                    <% end %>
                  </span>
                  <div class="flex items-center gap-2 shrink-0">
                    <% if Current.user&.superadmin? %>
                      <%= button_to impersonate_user_path, method: :post, params: { email: mp.user.email_address },
                            class: "cursor-pointer px-2 py-1 text-xs bg-amber-500 hover:bg-amber-600 text-white font-bold rounded" do %>
                        Impersonate
                      <% end %>
                    <% end %>
                    <% unless is_lead %>
                      <%= button_to "Make lead", mics_producer_set_lead_producer_path(@mic.slug, producer_id: mp.id), method: :post,
                            class: "cursor-pointer px-2 py-1 text-xs bg-gray-900 hover:bg-black text-white font-bold rounded" %>
                    <% end %>
                    <% if mp.user_id == Current.user&.id %>
                      <%# Self-row gets "Leave this mic" framing instead of
                          "Remove" — the action is the same, but the
                          intent and confirm copy reads correctly. %>
                      <%= button_to "Leave this mic", mics_producer_remove_producer_path(@mic.slug, producer_id: mp.id), method: :delete,
                            data: { turbo_confirm: "Step down as a mic runner of #{@mic.name}? If you're the last runner, the mic becomes unclaimed and anyone can claim it." },
                            class: "cursor-pointer px-2 py-1 text-xs bg-white border border-gray-300 hover:border-red-400 hover:text-red-600 text-gray-700 font-bold" %>
                    <% else %>
                      <%= button_to "Remove", mics_producer_remove_producer_path(@mic.slug, producer_id: mp.id), method: :delete,
                            data: { turbo_confirm: "Remove #{mp.user.email_address} from #{@mic.name}?" },
                            class: "cursor-pointer text-xs text-gray-500 hover:text-red-600 underline" %>
                    <% end %>
                  </div>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="text-sm text-gray-500 mb-5">No mic runners yet. Add the first one below.</p>
          <% end %>

          <%# Add via modal. Search by email; if no match, fields for inviting appear. %>
          <div class="flex justify-end">
            <button type="button"
                    data-controller="mics-modal"
                    data-action="click->mics-modal#open"
                    data-mics-modal-target-id-value="modal-add-producer"
                    class="cursor-pointer px-4 py-2 bg-pink-500 hover:bg-pink-600 active:bg-pink-700 text-white text-sm font-bold transition-colors duration-100">
              + Add a mic runner / producer
            </button>
          </div>
        </div>
      </section>

    </div>
  </div>

  <%# Marketing — convert to CocoScout sign-ups. %>
  <% unless @mic.production_id %>
    <section class="w-full px-4 sm:px-8 py-6 border-b border-gray-100">
      <div class="max-w-5xl">
        <div class="border-2 border-pink-500 bg-pink-50 p-5 sm:p-7 flex flex-col md:flex-row md:items-center gap-5">
          <div class="flex-1">
            <div class="text-xs uppercase tracking-wider text-pink-700 font-bold">Powered by CocoScout</div>
            <h3 class="coustard-regular text-2xl sm:text-3xl text-gray-900 mt-1">Run sign-ups, alerts, and your roster on CocoScout.</h3>
            <p class="text-sm text-gray-700 mt-2 max-w-2xl">
              Migrate this mic in one click. You get an easy online sign-up form with dozens of customizations, real rosters,
              and alert delivery when sign-ups open. Performers see their slots on a performance calendar.
            </p>
          </div>
          <div class="shrink-0">
            <%= link_to mics_producer_migrate_path(@mic.slug),
                  class: "cursor-pointer block px-6 py-3 bg-pink-500 text-white font-bold text-center hover:bg-pink-600 active:bg-pink-700 transition-colors duration-100" do %>
              Migrate to CocoScout sign-ups →
            <% end %>
          </div>
        </div>
      </div>
    </section>
  <% end %>

  <%# Danger zone — only superadmins and city captains can delete the
      whole mic. Producers can leave their producer role above; that's
      a different action with different consequences. %>
  <% if deletable_by?(Current.user) %>
    <section class="w-full px-4 sm:px-8 py-6 border-t border-red-100 bg-red-50">
      <div class="w-full max-w-5xl">
        <div class="border border-red-300 bg-white px-5 py-4 flex items-baseline justify-between gap-3 flex-wrap rounded">
          <div class="flex-1 min-w-0">
            <div class="text-xs uppercase tracking-wider text-red-700 font-bold">Danger zone</div>
            <p class="text-sm text-gray-700 mt-1">
              Permanently delete <strong><%= @mic.name %></strong> and everything attached to it (suggestions, announcements, claims, producer links, edit history). Use this for spam or duplicate listings — not for one-off pauses (use "Pause until" on the schedule instead).
            </p>
          </div>
          <%= button_to "Delete this mic", mics_producer_destroy_mic_path(@mic.slug), method: :delete,
                data: { turbo_confirm: "Permanently delete \"#{@mic.name}\"? This can't be undone." },
                class: "cursor-pointer px-4 py-2 bg-red-600 hover:bg-red-700 active:bg-red-800 text-white font-bold text-sm transition-colors duration-100 shrink-0 rounded" %>
        </div>
      </div>
    </section>
  <% end %>

</main>

<%# Modals %>

<%= render "mics/producer/modal", id: "modal-verify", title: "Verify info" do %>
  <p class="text-sm text-gray-700">
    Confirm everything on this listing is still accurate. We'll stamp the "last verified" timestamp on the public page so performers know it's fresh.
  </p>
  <%= form_with url: mics_producer_verify_path(@mic.slug), method: :post, class: "mt-5 flex justify-end gap-2" do %>
    <button type="button" data-controller="mics-modal" data-action="click->mics-modal#close"
            class="cursor-pointer px-4 py-2 text-sm text-gray-600 hover:text-gray-900">
      Cancel
    </button>
    <%= render "shared/button", text: "Mark as verified now", variant: "primary", size: "medium", type: :submit %>
  <% end %>
<% end %>

<%= render "mics/producer/modal", id: "modal-status", title: "Set status for a date" do %>
  <%= form_with url: mics_producer_post_status_path(@mic.slug), method: :post, class: "space-y-4" do %>
    <%= render "mics/form_field", name: "date", label: "Date", type: "date", value: next_upcoming_date_for(@mic) %>
    <%= render "mics/form_field", name: "mic_status", label: "Status", type: "select",
          options: [
            [ "Running as planned", "running_as_planned" ],
            [ "Online only",        "online_only" ],
            [ "Extra spots",        "extra_spots" ],
            [ "Cancelled",          "cancelled" ]
          ] %>
    <%= render "mics/form_field", name: "note", label: "Note (shown publicly, optional)" %>
    <div class="flex justify-end gap-2 pt-3 border-t border-gray-100">
      <button type="button" data-controller="mics-modal" data-action="click->mics-modal#close"
              class="cursor-pointer px-4 py-2 text-sm text-gray-600 hover:text-gray-900">Cancel</button>
      <%= render "shared/button", text: "Post status", variant: "primary", size: "medium", type: :submit %>
    </div>
  <% end %>
<% end %>

<%= render "mics/producer/modal", id: "modal-announce", title: "Post an announcement" do %>
  <p class="text-sm text-gray-600 mb-3">A short news item that shows up at the top of your mic page.</p>
  <%= form_with url: mics_create_announcement_path(@mic.slug), method: :post, class: "space-y-4" do %>
    <%= render "mics/form_field", name: "title", label: "Title (optional)" %>
    <%= render "mics/form_field", name: "body", label: "Announcement", type: "textarea", rows: 5, required: true %>
    <label class="flex items-center gap-2 text-sm text-gray-700">
      <input type="checkbox" name="notify_subscribers" value="1"
             class="h-4 w-4 text-pink-600 border-gray-300 rounded focus:ring-pink-500 accent-pink-500">
      <span>Notify subscribers when this goes out <span class="text-xs text-gray-400">(emails coming soon — we'll save your preference)</span></span>
    </label>
    <div class="flex justify-end gap-2 pt-3 border-t border-gray-100">
      <button type="button" data-controller="mics-modal" data-action="click->mics-modal#close"
              class="cursor-pointer px-4 py-2 text-sm text-gray-600 hover:text-gray-900">Cancel</button>
      <%= render "shared/button", text: "Post announcement", variant: "primary", size: "medium", type: :submit %>
    </div>
  <% end %>

  <% if @mic.mic_announcements.any? %>
    <h3 class="text-xs uppercase tracking-wider text-gray-500 font-bold mt-6 mb-2">Recent</h3>
    <ul class="space-y-2 text-sm max-h-48 overflow-y-auto">
      <% @mic.mic_announcements.recent(5).each do |a| %>
        <li class="border-l-2 border-pink-200 pl-3">
          <div class="text-xs text-gray-500"><%= a.posted_at.strftime("%b %-d, %-l:%M%p") %><% if a.notify_subscribers %> · 🔔 flagged for subscriber alert<% end %></div>
          <% if a.title.present? %><div class="font-bold"><%= a.title %></div><% end %>
          <div class="text-gray-700 whitespace-pre-line"><%= a.body %></div>
        </li>
      <% end %>
    </ul>
  <% end %>
<% end %>

<%= render "mics/producer/modal", id: "modal-cancel", title: "Cancel a date" do %>
  <p class="text-sm text-gray-600 mb-3">Performers will see "Cancelled" on the public listing and on the calendar.</p>
  <%= form_with url: mics_producer_cancel_date_path(@mic.slug), method: :post, class: "space-y-4" do %>
    <%= render "mics/form_field", name: "date", label: "Date to cancel", type: "date", value: next_upcoming_date_for(@mic) %>
    <%= render "mics/form_field", name: "reason", label: "Reason (shown publicly)",
          placeholder: "e.g. Venue closed for a private event" %>
    <div class="flex justify-end gap-2 pt-3 border-t border-gray-100">
      <button type="button" data-controller="mics-modal" data-action="click->mics-modal#close"
              class="cursor-pointer px-4 py-2 text-sm text-gray-600 hover:text-gray-900">Cancel</button>
      <%= render "shared/button", text: "Cancel this date", variant: "danger", size: "medium", type: :submit %>
    </div>
  <% end %>
<% end %>

<%= render "mics/producer/modal", id: "modal-add-producer", title: "Add a mic runner / producer" do %>
  <p class="text-sm text-gray-600 mb-4">
    Start with their email. If they're already on CocoScout we'll just add them; otherwise we'll send them an invite.
  </p>
  <%= form_with url: mics_producer_add_producer_path(@mic.slug), method: :post,
        data: { controller: "user-invite-form",
                "user-invite-form-url-value": mics_producer_lookup_path(@mic.slug),
                "user-invite-form-scope-label-value": "this mic" },
        class: "space-y-4" do %>

    <div>
      <label class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-1">Email</label>
      <input type="email" name="email" required
             placeholder="person@example.com"
             data-user-invite-form-target="email"
             data-action="input->user-invite-form#search"
             class="w-full px-3 py-2 border border-gray-300 focus:border-pink-500 focus:ring-1 focus:ring-pink-500 outline-none text-sm">
      <div data-user-invite-form-target="status" class="mt-1 text-xs"></div>
    </div>

    <div data-user-invite-form-target="newFields" class="hidden">
      <label class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-1">Name</label>
      <input type="text" name="name"
             placeholder="Alex Comic"
             data-user-invite-form-target="name"
             class="w-full px-3 py-2 border border-gray-300 focus:border-pink-500 focus:ring-1 focus:ring-pink-500 outline-none text-sm">
      <p class="mt-1 text-xs text-gray-500">We'll create their account and email them an invite to set a password.</p>
    </div>

    <div>
      <label class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-1">Role</label>
      <select name="role"
              class="w-full px-3 py-2 border border-gray-300 focus:border-pink-500 focus:ring-1 focus:ring-pink-500 outline-none text-sm bg-white">
        <option value="producer">Mic runner / Producer</option>
        <option value="co_producer">Co-producer</option>
        <option value="host">Host</option>
      </select>
    </div>

    <div class="flex justify-end gap-2 pt-3 border-t border-gray-100">
      <button type="button" data-controller="mics-modal" data-action="click->mics-modal#close"
              class="cursor-pointer px-4 py-2 text-sm text-gray-600 hover:text-gray-900">Cancel</button>
      <button type="submit"
              data-user-invite-form-target="submit"
              class="cursor-pointer px-4 py-2 bg-pink-500 hover:bg-pink-600 active:bg-pink-700 text-white text-sm font-bold transition-colors duration-100 opacity-50 cursor-not-allowed"
              disabled>
        Add to mic
      </button>
    </div>
  <% end %>
<% end %>

<%= render "mics/site_footer" %>
