<%= render layout: "manage/course_offering_wizard/wizard_layout", locals: { step_name: "Pricing" } do %>
  <h2 class="text-lg font-bold text-gray-900 mb-1">Pricing</h2>
  <p class="text-sm text-gray-600 mb-6">Set the registration fee. You can optionally offer an early bird discount.</p>

  <%= form_with url: manage_course_wizard_pricing_path, method: :post, local: true do |form| %>
    <div class="space-y-5">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="price_dollars" class="block text-sm font-medium text-gray-900 mb-1.5">
            Price
            <span class="text-pink-500">*</span>
          </label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500">$</span>
            <input type="number" name="price_dollars" id="price_dollars" required
                   min="0.01" step="0.01"
                   value="<%= @wizard_state[:price_cents] ? (@wizard_state[:price_cents].to_f / 100).round(2) : '' %>"
                   placeholder="150.00"
                   class="block w-full pl-7 pr-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition">
          </div>
        </div>
        <div>
          <label for="currency" class="block text-sm font-medium text-gray-900 mb-1.5">
            Currency
          </label>
          <select name="currency" id="currency"
                  class="block w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition">
            <% [["USD", "usd"], ["CAD", "cad"], ["GBP", "gbp"], ["EUR", "eur"]].each do |label, val| %>
              <option value="<%= val %>" <%= 'selected' if (@wizard_state[:currency] || 'usd') == val %>><%= label %></option>
            <% end %>
          </select>
        </div>
      </div>

      <div class="border-t border-gray-200 pt-5">
        <div class="flex items-center justify-between mb-3">
          <span class="text-sm font-medium text-gray-900">Offer early bird pricing</span>
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" id="enable_early_bird"
                   <%= 'checked' if @wizard_state[:early_bird_price_cents].present? %>
                   class="sr-only peer"
                   onchange="document.getElementById('early-bird-fields').classList.toggle('hidden', !this.checked)">
            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-pink-100 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-pink-500"></div>
          </label>
        </div>
        <div id="early-bird-fields" class="<%= 'hidden' unless @wizard_state[:early_bird_price_cents].present? %>">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label for="early_bird_price_dollars" class="block text-sm font-medium text-gray-700 mb-1.5">
                Early Bird Price
              </label>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500">$</span>
                <input type="number" name="early_bird_price_dollars" id="early_bird_price_dollars"
                       min="0.01" step="0.01"
                       value="<%= @wizard_state[:early_bird_price_cents] ? (@wizard_state[:early_bird_price_cents].to_f / 100).round(2) : '' %>"
                       placeholder="120.00"
                       class="block w-full pl-7 pr-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition">
              </div>
            </div>
            <div>
              <label for="early_bird_deadline" class="block text-sm font-medium text-gray-700 mb-1.5">
                Early Bird Deadline
              </label>
              <input type="datetime-local" name="early_bird_deadline" id="early_bird_deadline"
                     value="<%= @wizard_state[:early_bird_deadline] %>"
                     class="block w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition">
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 flex items-center justify-between">
      <%= link_to manage_course_wizard_instructor_path, class: "text-sm text-gray-500 hover:text-gray-700 flex items-center gap-1" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Back
      <% end %>
      <%= render "shared/button", text: "Next: Details", variant: "primary", size: "medium", type: :submit %>
    </div>
  <% end %>
<% end %>
