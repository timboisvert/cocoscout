<%#
  Distance origin modal. Two paths:
    1. "Use my location" — JS calls navigator.geolocation, then POSTs
       the lat/lng to /mics/origin with a hidden form.
    2. "Use a specific address" — text input, server geocodes via
       Census + Nominatim and stores in session.

  Activated by the "from <X>" text under the distance slider.
%>
<dialog id="modal-distance-origin"
        data-controller="mics-origin"
        class="fixed inset-0 m-auto w-[min(36rem,92vw)] max-h-[85vh] p-0 rounded shadow-2xl backdrop:bg-gray-900/50 overflow-hidden">
  <div class="flex flex-col max-h-[85vh]">
    <div class="flex items-center justify-between gap-3 px-5 sm:px-6 py-3 border-b border-gray-100 bg-pink-500 text-white shrink-0">
      <h3 class="text-lg sm:text-xl font-bold">Distance from where?</h3>
      <button type="button"
              onclick="this.closest('dialog').close()"
              class="cursor-pointer px-2 py-1 text-white hover:bg-pink-600 active:bg-pink-700 text-sm leading-none">
        ✕
      </button>
    </div>
    <div class="px-5 sm:px-6 py-5 overflow-y-auto space-y-5">
      <p class="text-sm text-gray-600">
        By default we measure from the city center. Pick a different anchor so the distance filter matches where you actually are.
      </p>

      <%# Use my location — browser geolocation %>
      <div class="border border-gray-200 rounded p-4">
        <div class="text-sm font-bold text-gray-900 mb-1">Use my location</div>
        <p class="text-xs text-gray-500 mb-3">We'll ask your browser for your current spot. Nothing leaves your device until you confirm.</p>
        <button type="button"
                data-action="click->mics-origin#useGeolocation"
                data-mics-origin-target="useMeButton"
                class="cursor-pointer inline-flex items-center gap-2 px-4 py-2 bg-pink-500 hover:bg-pink-600 text-white text-sm font-bold rounded">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
          </svg>
          Use my current location
        </button>
        <div data-mics-origin-target="geoStatus" class="mt-2 text-xs"></div>
      </div>

      <%# Use a specific address — server-side geocoding %>
      <div class="border border-gray-200 rounded p-4">
        <div class="text-sm font-bold text-gray-900 mb-1">Use a specific address</div>
        <p class="text-xs text-gray-500 mb-3">Type any U.S. address, ZIP, or "Wrigley Field" etc.</p>
        <%= form_with url: mics_set_origin_path, method: :post, local: true,
              class: "flex flex-wrap gap-2" do %>
          <input type="hidden" name="back_to" value="<%= request.fullpath %>">
          <input type="hidden" name="kind" value="address">
          <input type="text" name="address" required
                 placeholder="e.g. 1060 W Addison St, Chicago, IL 60613"
                 class="flex-1 min-w-[200px] px-3 py-2 text-sm border border-gray-300 rounded focus:border-pink-500 outline-none">
          <button type="submit" class="cursor-pointer px-4 py-2 bg-pink-500 hover:bg-pink-600 text-white text-sm font-bold rounded">Use it</button>
        <% end %>
      </div>

      <%# Clear override — back to city center %>
      <% if session[:mics_origin].present? %>
        <%= form_with url: mics_clear_origin_path, method: :post, local: true do %>
          <input type="hidden" name="back_to" value="<%= request.fullpath %>">
          <button type="submit" class="text-xs text-gray-500 hover:text-pink-600 underline">
            Clear and use city center instead
          </button>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# Hidden form the geolocation path POSTs to once the browser
      hands us back lat/lng. %>
  <%= form_with url: mics_set_origin_path, method: :post, local: true,
        data: { mics_origin_target: "geoForm" } do %>
    <input type="hidden" name="back_to" value="<%= request.fullpath %>">
    <input type="hidden" name="kind"  value="me">
    <input type="hidden" name="label" value="My location">
    <input type="hidden" name="lat" data-mics-origin-target="latInput">
    <input type="hidden" name="lng" data-mics-origin-target="lngInput">
  <% end %>
</dialog>
