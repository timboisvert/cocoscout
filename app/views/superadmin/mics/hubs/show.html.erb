<main class="w-full max-w-6xl mx-auto px-4 sm:px-6 py-8 space-y-6">
  <nav class="text-xs text-gray-500 mb-2">
    <%= link_to "Mics admin", mics_index_path, class: "hover:underline" %>
    <span class="px-1">›</span>
    <%= link_to "City hubs", mics_hubs_path, class: "hover:underline" %>
    <span class="px-1">›</span>
    <span class="text-gray-700"><%= @hub.name %>, <%= @hub.state %></span>
  </nav>

  <div class="flex items-baseline justify-between gap-3 flex-wrap">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @hub.name %>, <%= @hub.state %></h1>
      <p class="text-xs text-gray-500 mt-1">slug <code class="bg-gray-100 px-1"><%= @hub.slug %></code></p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "View public hub →", mics_city_path(@hub.slug), target: "_blank",
            class: "text-sm text-pink-600 font-bold hover:underline" %>
      <%= link_to "Queue →", mics_hub_queue_path(@hub.slug), target: "_blank",
            class: "text-sm text-pink-600 font-bold hover:underline" %>
    </div>
  </div>

  <% if flash[:notice] %>
    <div class="px-3 py-2 border border-emerald-200 bg-emerald-50 text-emerald-700 text-sm"><%= flash[:notice] %></div>
  <% end %>
  <% if flash[:alert] %>
    <div class="px-3 py-2 border border-red-200 bg-red-50 text-red-700 text-sm"><%= flash[:alert] %></div>
  <% end %>

  <%# Stats %>
  <section class="grid grid-cols-2 sm:grid-cols-4 gap-3">
    <% [
      [ "Total mics",   @mic_count ],
      [ "Active",       @active_count ],
      [ "Unclaimed",    @unclaimed_count ],
      [ "Pending review", @pending_mic_count ]
    ].each do |label, n| %>
      <div class="bg-white border border-gray-200 px-4 py-3">
        <div class="text-[10px] uppercase tracking-wider text-gray-500 font-bold"><%= label %></div>
        <div class="text-2xl font-bold text-gray-900 tabular-nums mt-1"><%= n %></div>
      </div>
    <% end %>
  </section>

  <%# Edit basic info %>
  <section class="bg-white border border-gray-200">
    <header class="px-4 sm:px-5 py-3 border-b border-gray-100 bg-gray-50 flex items-baseline justify-between">
      <h2 class="text-xs uppercase tracking-wider text-gray-600 font-bold">Settings</h2>
      <span class="inline-flex items-center text-[10px] uppercase tracking-wider px-2 py-0.5 font-bold
          <%= { "active" => "bg-emerald-100 text-emerald-700", "draft" => "bg-amber-100 text-amber-700", "archived" => "bg-gray-200 text-gray-600" }[@hub.status] %>">
        <%= @hub.status %>
      </span>
    </header>
    <div class="px-4 sm:px-5 py-4">
      <%= form_with url: mics_hub_path(@hub.slug), method: :patch,
            data: { controller: "slug-generator" },
            class: "space-y-4" do %>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <label class="block text-sm">
            <span class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-1">Name</span>
            <input type="text" name="city_hub[name]" value="<%= @hub.name %>" required
                   data-slug-generator-target="source"
                   data-action="input->slug-generator#regenerate"
                   class="w-full px-3 py-2 text-sm border border-gray-300 focus:border-pink-500 outline-none">
          </label>
          <%= render "shared/us_state_select",
                name: "city_hub[state]", required: true, value: @hub.state,
                data: { "slug-generator-target": "source",
                        action: "change->slug-generator#regenerate" } %>
          <label class="block text-sm">
            <span class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-1">Slug</span>
            <input type="text" name="city_hub[slug]" value="<%= @hub.slug %>" required
                   data-slug-generator-target="slug"
                   data-action="input->slug-generator#markEdited"
                   class="w-full px-3 py-2 text-sm border border-gray-300 focus:border-pink-500 outline-none">
          </label>
        </div>
        <label class="block text-sm">
          <span class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-1">Status</span>
          <select name="city_hub[status]"
                  class="px-3 py-2 text-sm border border-gray-300 focus:border-pink-500 outline-none">
            <% CityHub.statuses.keys.each do |s| %>
              <option value="<%= s %>" <%= "selected" if @hub.status == s %>><%= s.titleize %></option>
            <% end %>
          </select>
        </label>
        <label class="block text-sm" data-controller="char-counter" data-char-counter-max-value="175">
          <div class="flex items-baseline justify-between gap-2 mb-1">
            <span class="text-xs uppercase tracking-wider text-gray-500 font-bold">Intro (plain text)</span>
            <span class="text-[10px] tabular-nums" data-char-counter-target="readout"></span>
          </div>
          <textarea name="city_hub[intro_markdown]" rows="3" maxlength="175"
                    data-char-counter-target="input"
                    class="w-full px-3 py-2 text-sm border border-gray-300 focus:border-pink-500 outline-none"><%= @hub.intro_markdown %></textarea>
        </label>
        <div class="flex justify-end pt-1">
          <button type="submit" class="cursor-pointer px-4 py-2 bg-pink-500 hover:bg-pink-600 text-white text-sm font-bold">Save settings</button>
        </div>
      <% end %>
    </div>
  </section>

  <%# Captains %>
  <section class="bg-white border border-gray-200">
    <header class="px-4 sm:px-5 py-3 border-b border-gray-100 bg-gray-50">
      <h2 class="text-xs uppercase tracking-wider text-gray-600 font-bold">Captains</h2>
      <p class="text-xs text-gray-500 mt-1">
        Captains can edit every mic in this hub, approve/reject suggestions, and run the queue. They have effectively superadmin powers scoped to this city.
      </p>
    </header>

    <% if @editors.any? %>
      <ul class="divide-y divide-gray-100">
        <% @editors.each do |m| %>
          <li class="px-4 sm:px-5 py-2.5 flex items-baseline justify-between gap-3">
            <span class="text-sm text-gray-800"><%= m.user.email_address %></span>
            <div class="flex items-center gap-3 shrink-0">
              <%= button_to impersonate_user_path, method: :post,
                    params: { email: m.user.email_address, return_to: mics_captain_hub_path(@hub.slug) },
                    class: "cursor-pointer px-2 py-1 text-xs bg-amber-500 hover:bg-amber-600 text-white font-bold" do %>
                Impersonate
              <% end %>
              <%= button_to "Remove", mics_hub_remove_editor_path(@hub.slug, user_id: m.user_id), method: :delete,
                    data: { turbo_confirm: "Remove #{m.user.email_address} as a captain of #{@hub.name}?" },
                    class: "cursor-pointer text-xs text-gray-500 hover:text-red-600 underline" %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="px-4 sm:px-5 py-3 text-sm text-gray-500">No captains yet.</p>
    <% end %>

    <div class="px-4 sm:px-5 py-4 border-t border-gray-100 bg-gray-50 flex justify-end">
      <button type="button"
              onclick="document.getElementById('modal-add-captain').showModal()"
              class="cursor-pointer px-4 py-2 bg-pink-500 hover:bg-pink-600 text-white text-sm font-bold">
        + Add a captain
      </button>
    </div>
  </section>

  <%# Roll-up — pick which cities in this state to absorb into the hub. %>
  <section class="bg-white border border-gray-200">
    <header class="px-4 sm:px-5 py-3 border-b border-gray-100 bg-gray-50">
      <h2 class="text-xs uppercase tracking-wider text-gray-600 font-bold">Roll up venues</h2>
      <p class="text-xs text-gray-500 mt-1">
        Pick the cities in <%= @hub.state %> whose venues belong to <%= @hub.name %>. Many metros bleed across city lines — e.g. Indianapolis includes Speedway, Carmel, Greenwood, Lawrence — so the headline city alone won't capture the real ecosystem.
      </p>
    </header>
    <div class="px-4 sm:px-5 py-4">
      <% if @rollup_candidate_cities.empty? %>
        <p class="text-sm text-gray-500">No unassigned venues in <%= @hub.state %> right now.</p>
      <% else %>
        <%= form_with url: mics_hub_rollup_venues_path(@hub.slug), method: :post,
              data: { turbo_confirm: "Roll the selected cities' venues into #{@hub.name}?" },
              class: "space-y-3" do %>
          <div class="text-xs text-gray-500">
            <%= pluralize(@rollup_candidate_cities.size, "city") %> in <%= @hub.state %> with unassigned venues
            (<strong class="tabular-nums"><%= @rollup_candidates %></strong> total).
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-4 gap-y-1 max-h-72 overflow-y-auto pr-2 border border-gray-100 p-3">
            <% @rollup_candidate_cities.each do |city, n| %>
              <% pre = (city.to_s.downcase == @hub.name.to_s.downcase) %>
              <label class="flex items-baseline gap-2 text-sm text-gray-800 hover:bg-pink-50 px-1 py-0.5">
                <input type="checkbox" name="cities[]" value="<%= city %>" <%= "checked" if pre %>
                       class="h-4 w-4 text-pink-600 border-gray-300 rounded focus:ring-pink-500 accent-pink-500">
                <span class="flex-1 min-w-0 truncate"><%= city %><% if pre %> <span class="text-[10px] uppercase text-pink-600 font-bold ml-1">headline</span><% end %></span>
                <span class="tabular-nums text-xs text-gray-500"><%= n %></span>
              </label>
            <% end %>
          </div>
          <div class="flex items-center justify-between gap-3 pt-2 border-t border-gray-100">
            <span class="text-xs text-gray-500">Check every neighborhood that should report to this hub. Venues already in another hub are skipped.</span>
            <button type="submit" class="cursor-pointer px-4 py-2 bg-gray-900 hover:bg-black text-white text-sm font-bold">
              Roll selected cities into <%= @hub.name %>
            </button>
          </div>
        <% end %>
      <% end %>
    </div>
  </section>
</main>

<dialog id="modal-add-captain"
        class="fixed inset-0 m-auto w-[min(36rem,92vw)] max-h-[85vh] p-0 rounded shadow-2xl backdrop:bg-gray-900/50 overflow-hidden">
  <div class="flex flex-col max-h-[85vh]">
    <div class="flex items-center justify-between gap-3 px-5 sm:px-6 py-3 border-b border-gray-100 bg-pink-500 text-white shrink-0">
      <h3 class="text-lg sm:text-xl font-bold">Add a captain</h3>
      <button type="button"
              onclick="this.closest('dialog').close()"
              class="cursor-pointer px-2 py-1 text-white hover:bg-pink-600 active:bg-pink-700 text-sm leading-none">
        ✕
      </button>
    </div>
    <div class="px-5 sm:px-6 py-5 overflow-y-auto">
      <p class="text-sm text-gray-600 mb-4">
        Captains can edit every mic in this hub. Start with their email — if they're already on CocoScout we'll just add them; otherwise we'll send them an invite.
      </p>
      <%= form_with url: mics_hub_add_editor_path(@hub.slug), method: :post,
            data: { controller: "user-invite-form",
                    "user-invite-form-url-value": mics_hub_editor_lookup_path(@hub.slug),
                    "user-invite-form-scope-label-value": "this hub" },
            class: "space-y-4" do %>

        <div>
          <label class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-1">Email</label>
          <input type="email" name="email" required
                 placeholder="captain@example.com"
                 data-user-invite-form-target="email"
                 data-action="input->user-invite-form#search"
                 class="w-full px-3 py-2 border border-gray-300 focus:border-pink-500 focus:ring-1 focus:ring-pink-500 outline-none text-sm">
          <div data-user-invite-form-target="status" class="mt-1 text-xs"></div>
        </div>

        <div data-user-invite-form-target="newFields" class="hidden">
          <label class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-1">Name</label>
          <input type="text" name="name"
                 placeholder="Alex Captain"
                 data-user-invite-form-target="name"
                 class="w-full px-3 py-2 border border-gray-300 focus:border-pink-500 focus:ring-1 focus:ring-pink-500 outline-none text-sm">
          <p class="mt-1 text-xs text-gray-500">We'll create their account and email them an invite to set a password.</p>
        </div>

        <div class="flex justify-end gap-2 pt-3 border-t border-gray-100">
          <button type="button"
                  onclick="this.closest('dialog').close()"
                  class="cursor-pointer px-4 py-2 text-sm text-gray-600 hover:text-gray-900">Cancel</button>
          <button type="submit"
                  data-user-invite-form-target="submit"
                  class="cursor-pointer px-4 py-2 bg-pink-500 hover:bg-pink-600 active:bg-pink-700 text-white text-sm font-bold transition-colors duration-100 opacity-50 cursor-not-allowed"
                  disabled>
            Add to hub
          </button>
        </div>
      <% end %>
    </div>
  </div>
</dialog>
