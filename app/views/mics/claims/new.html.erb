<%
  is_challenge = @mic.claimed?
  page_title   = "Claim #{@mic.name}"
  page_desc =
    if is_challenge
      lead = @mic.lead_owner&.person&.name.presence || @mic.lead_owner&.email_address || "another user"
      "#{lead} currently claims to run this mic. Filing your claim opens a 72-hour window for them to respond — a moderator decides if they don't."
    else
      "We'll verify your relationship to #{@mic.venue.name} before granting owner rights."
    end
  mics_seo title: "#{page_title} — Find a Mic",
            description: page_desc
%>

<%= render "mics/form_shell", title: page_title,
      description: page_desc do %>
  <%= form_with url: mics_create_claim_path(@mic.slug), method: :post do %>
    <%= render "mics/claims/claim_fields", mic: @mic, is_challenge: is_challenge %>

    <div class="flex items-center justify-between gap-3 pt-2 border-t border-gray-100">
      <a href="<%= mics_detail_path(@mic.slug) %>" class="text-sm text-gray-500 hover:text-gray-700 underline">Cancel</a>
      <%= render "shared/button", text: "Submit claim", variant: "primary", size: "medium", type: :submit %>
    </div>
  <% end %>
<% end %>
