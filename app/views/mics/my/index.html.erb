<%
  mics_seo title: "My Mics — Find a Mic",
            description: "The mics you run and the mics you favorite, in one place."
%>
<%= render "mics/header" %>

<main class="w-full bg-white">
  <section class="bg-pink-500 text-white border-b border-pink-600">
    <div class="w-full px-4 sm:px-8 py-6 sm:py-10">
      <h1 class="coustard-regular text-4xl sm:text-5xl">My Mics</h1>
      <p class="mt-2 text-pink-100 text-sm sm:text-base">
        <%
          parts = []
          parts << "the mics you run" if @managed_mics.any?
          parts << "your favorites"   if @favorite_mics.any?
        %>
        <% if parts.any? %>
          One place for <%= parts.to_sentence %>.
        <% else %>
          Run a mic? Manage it here. Performer? Favorite the mics you go to.
        <% end %>
      </p>
    </div>
  </section>

  <% if flash[:notice] %>
    <div class="w-full px-4 sm:px-8 py-3 bg-emerald-50 border-b border-emerald-200 text-emerald-700 text-sm">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <% if @managed_mics.any? %>
    <section class="border-b border-gray-100">
      <div class="w-full px-4 sm:px-8 py-6">
        <div class="text-xs uppercase tracking-wider text-gray-500 font-bold mb-3">Mics you run</div>
        <div class="divide-y divide-gray-100 border border-gray-200 rounded overflow-hidden">
          <% @managed_mics.each do |mic| %>
            <div class="px-4 sm:px-6 py-3 flex items-baseline gap-3 hover:bg-pink-50">
              <div class="flex-1 min-w-0">
                <%= link_to mic.name, mics_detail_path(mic.slug),
                      class: "coustard-regular text-lg text-gray-900 hover:underline" %>
                <div class="text-xs text-gray-500 truncate"><%= mic.venue.name %> · <%= mic.venue.neighborhood_city %></div>
              </div>
              <%= link_to "Manage →", mics_owner_mic_path(mic.slug),
                    class: "text-xs text-pink-600 font-bold hover:underline shrink-0" %>
            </div>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>

  <%# Upcoming events from your favorites — calendar OR list view. %>
  <section class="border-b border-gray-100">
    <div class="w-full px-4 sm:px-8 py-6">
      <div class="flex items-baseline justify-between gap-3 flex-wrap mb-3">
        <div class="text-xs uppercase tracking-wider text-gray-500 font-bold">Upcoming from your favorites</div>

        <% if @favorite_mics.any? %>
          <div class="inline-flex border border-gray-300 text-sm overflow-hidden bg-white rounded">
            <%= link_to "Calendar", mics_my_path(view: "calendar"),
                  class: "px-4 py-2 font-bold #{@favorites_view == "calendar" ? "bg-pink-500 text-white" : "text-gray-700 hover:bg-pink-50"}" %>
            <%= link_to "List", mics_my_path(view: "list"),
                  class: "px-4 py-2 font-bold border-l border-gray-300 #{@favorites_view == "list" ? "bg-pink-500 text-white" : "text-gray-700 hover:bg-pink-50"}" %>
          </div>
        <% end %>
      </div>

      <% if @favorite_mics.empty? %>
        <div class="border border-gray-200 px-4 sm:px-6 py-6 text-sm text-gray-600 rounded">
          Star a mic on any listing to see it here.
          <%= link_to "Browse Chicago →", mics_city_path("chicago-il"), class: "ml-2 text-pink-600 font-bold underline" %>
        </div>

      <% elsif @favorites_view == "calendar" %>
        <%= render "mics/my/favorites_calendar",
              favorite_mics: @favorite_mics,
              by_date: @fav_by_date %>

      <% else %>
        <% if @fav_occurrences.any? %>
          <ul class="divide-y divide-gray-100 border border-gray-200 bg-white rounded overflow-hidden">
            <% @fav_occurrences.first(20).each do |occ| %>
              <li class="px-4 sm:px-6 py-2.5 flex items-baseline gap-3 hover:bg-pink-50">
                <span class="tabular-nums w-28 sm:w-32 shrink-0 font-bold text-gray-900">
                  <%= occ[:starts_at].strftime("%a %b %-d") %>
                </span>
                <span class="tabular-nums w-20 shrink-0 text-gray-500">
                  <%= occ[:starts_at].strftime("%-l:%M%p").downcase %>
                </span>
                <span class="flex-1 min-w-0">
                  <%= link_to occ[:mic].name, mics_detail_path(occ[:mic].slug),
                        class: "font-bold text-gray-900 hover:underline truncate" %>
                  <span class="block text-xs text-gray-500 truncate"><%= occ[:mic].venue.name %> · <%= occ[:mic].venue.neighborhood_city %></span>
                </span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="border border-gray-200 px-4 sm:px-6 py-6 text-sm text-gray-600 rounded">
            No upcoming dates from your favorites in the next few weeks.
          </div>
        <% end %>
      <% end %>
    </div>
  </section>

  <%# Static favorites roster — visible regardless of calendar/list view. %>
  <% if @favorite_mics.any? %>
    <section class="border-b border-gray-100">
      <div class="w-full px-4 sm:px-8 py-6">
        <div class="text-xs uppercase tracking-wider text-gray-500 font-bold mb-3">Your favorite mics</div>
        <div class="divide-y divide-gray-100 border border-gray-200 rounded overflow-hidden">
          <% @favorite_mics.each do |mic| %>
            <div class="px-4 sm:px-6 py-3 flex items-baseline gap-3 flex-wrap hover:bg-pink-50">
              <div class="flex-1 min-w-0">
                <span class="inline-flex items-baseline gap-2 flex-wrap">
                  <%= link_to mic.name, mics_detail_path(mic.slug),
                        class: "coustard-regular text-lg text-gray-900 hover:underline" %>
                  <% if mic.paused? %>
                    <span class="inline-flex items-center text-[10px] uppercase tracking-wider px-1.5 py-0.5 bg-amber-500 text-white font-bold rounded">
                      ⏸ Paused<% if mic.canceled_until.present? && mic.canceled_until >= Date.current %> · back <%= mic.canceled_until.strftime("%b %-d") %><% end %>
                    </span>
                  <% end %>
                </span>
                <div class="text-xs text-gray-500 truncate"><%= mic.venue.name %> · <%= mic.venue.neighborhood_city %></div>
              </div>
              <%= button_to "Unfavorite", mics_favorite_path(mic.slug), method: :post,
                    class: "cursor-pointer px-2.5 py-1.5 text-xs text-gray-500 hover:text-red-600 underline shrink-0" %>
            </div>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>
</main>

<%= render "mics/site_footer" %>
