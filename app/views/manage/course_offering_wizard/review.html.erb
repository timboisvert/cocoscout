<%= render layout: "manage/course_offering_wizard/wizard_layout", locals: { step_name: "Review" } do %>
  <h2 class="text-lg font-bold text-gray-900 mb-1">Review Your Course</h2>
  <p class="text-sm text-gray-600 mb-6">Everything look good? You can go back to any step to make changes.</p>

  <div class="space-y-5">
    <!-- Basics -->
    <div class="border border-gray-200 rounded-lg p-4">
      <div class="flex items-center justify-between mb-2">
        <h3 class="text-sm font-semibold text-gray-900">Basics</h3>
        <%= link_to manage_course_wizard_basics_path, class: "text-xs text-pink-600 hover:text-pink-700 font-medium" do %>
          Edit
        <% end %>
      </div>
      <dl class="space-y-2 text-sm">
        <div>
          <dt class="text-gray-500">Title</dt>
          <dd class="font-medium text-gray-900"><%= @wizard_state[:title] %></dd>
        </div>
        <% if @wizard_state[:subtitle].present? %>
          <div>
            <dt class="text-gray-500">Subtitle</dt>
            <dd class="text-gray-700"><%= @wizard_state[:subtitle] %></dd>
          </div>
        <% end %>
        <% if @wizard_state[:description].present? %>
          <div>
            <dt class="text-gray-500">Description</dt>
            <dd class="text-gray-700 prose prose-sm max-w-none"><%= sanitize @wizard_state[:description] %></dd>
          </div>
        <% end %>
      </dl>
    </div>

    <!-- Instructors -->
    <div class="border border-gray-200 rounded-lg p-4">
      <div class="flex items-center justify-between mb-2">
        <h3 class="text-sm font-semibold text-gray-900">Instructors</h3>
        <%= link_to manage_course_wizard_instructor_path, class: "text-xs text-pink-600 hover:text-pink-700 font-medium" do %>
          Edit
        <% end %>
      </div>
      <% if @instructor_people.any? %>
        <% instructor_headshot_blob_ids = @wizard_state[:instructor_headshot_blob_ids] || {} %>
        <% if @wizard_state[:instructor_preface].present? && @instructor_people.size > 1 %>
          <p class="text-sm text-gray-600 mb-2 prose prose-sm max-w-none"><%= sanitize @wizard_state[:instructor_preface] %></p>
        <% end %>
        <div class="space-y-2 mb-2">
          <% @instructor_people.each do |person| %>
            <div class="flex items-center gap-3">
              <% override_blob_id = instructor_headshot_blob_ids[person.id.to_s] %>
              <% override_blob = override_blob_id.present? ? ActiveStorage::Blob.find_by(id: override_blob_id) : nil %>
              <% if override_blob %>
                <%= image_tag override_blob.url, alt: person.name, class: "w-10 h-10 rounded-lg object-cover flex-shrink-0" %>
              <% elsif (headshot_variant = person.safe_headshot_variant(:tile)) %>
                <%= image_tag headshot_variant, alt: person.name, class: "w-10 h-10 rounded-lg object-cover flex-shrink-0" %>
              <% else %>
                <div class="w-10 h-10 rounded-lg bg-pink-100 flex items-center justify-center text-pink-700 font-bold text-sm flex-shrink-0">
                  <%= person.initials %>
                </div>
              <% end %>
              <div>
                <div class="font-medium text-sm text-gray-900"><%= person.name %></div>
                <% if person.email.present? %>
                  <div class="text-xs text-gray-500"><%= person.email %></div>
                <% end %>
                <% bio = @wizard_state[:instructor_bios]&.dig(person.id.to_s) %>
                <% if bio.present? %>
                  <div class="text-xs text-gray-500 mt-0.5"><%= truncate(strip_tags(bio), length: 120) %></div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
        <% if @wizard_state[:instructor_on_team] %>
          <div class="text-sm mt-2">
            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              Added to production team
            </span>
          </div>
        <% end %>
      <% else %>
        <p class="text-sm text-gray-400 italic">No instructors specified</p>
      <% end %>
    </div>

    <!-- Schedule -->
    <div class="border border-gray-200 rounded-lg p-4">
      <div class="flex items-center justify-between mb-2">
        <h3 class="text-sm font-semibold text-gray-900">Schedule</h3>
        <%= link_to manage_course_wizard_schedule_path, class: "text-xs text-pink-600 hover:text-pink-700 font-medium" do %>
          Edit
        <% end %>
      </div>
      <% if @wizard_state[:schedule_mode] == "contract" && @contract.present? %>
        <dl class="space-y-2 text-sm">
          <div>
            <dt class="text-gray-500">Linked Contract</dt>
            <dd class="font-medium text-gray-900"><%= @contract.contractor_name %><% if @contract.production_name.present? %> — <%= @contract.production_name %><% end %></dd>
          </div>
          <div>
            <dt class="text-gray-500">Sessions</dt>
            <dd class="text-gray-700">
              <% if @selected_shows&.any? %>
                <span class="font-medium"><%= @selected_shows.count %> session<%= @selected_shows.count == 1 ? '' : 's' %></span>
                <ul class="mt-1 space-y-0.5 text-xs text-gray-500">
                  <% @selected_shows.first(5).each do |show| %>
                    <li><%= show.date_and_time.strftime("%a, %b %-d, %Y at %-I:%M %p") %> (<%= show.duration_minutes %> min)</li>
                  <% end %>
                  <% if @selected_shows.count > 5 %>
                    <li>...and <%= @selected_shows.count - 5 %> more</li>
                  <% end %>
                </ul>
              <% else %>
                <span class="text-gray-400">No sessions selected</span>
              <% end %>
            </dd>
          </div>
        </dl>
      <% elsif @wizard_state[:sessions].present? && @wizard_state[:sessions].any? { |s| (s[:datetime] || s["datetime"]).present? } %>
        <dl class="text-sm">
          <dt class="text-gray-500">Sessions</dt>
          <dd class="text-gray-700 mt-1">
            <% valid_sessions = @wizard_state[:sessions].select { |s| (s[:datetime] || s["datetime"]).present? } %>
            <span class="font-medium"><%= valid_sessions.count %> session<%= valid_sessions.count == 1 ? '' : 's' %></span>
            <ul class="mt-1 space-y-0.5 text-xs text-gray-500">
              <% valid_sessions.first(5).each do |session| %>
                <% dt = DateTime.parse(session[:datetime] || session["datetime"]) rescue nil %>
                <% dur = (session[:duration] || session["duration"])&.to_i || 60 %>
                <li><%= dt&.strftime("%a, %b %-d, %Y at %-I:%M %p") || "Invalid date" %> (<%= dur %> min)</li>
              <% end %>
              <% if valid_sessions.count > 5 %>
                <li>...and <%= valid_sessions.count - 5 %> more</li>
              <% end %>
            </ul>
          </dd>
        </dl>
      <% else %>
        <p class="text-sm text-gray-400 italic">No sessions scheduled — you can add them later</p>
      <% end %>
    </div>

    <!-- Pricing -->
    <div class="border border-gray-200 rounded-lg p-4">
      <div class="flex items-center justify-between mb-2">
        <h3 class="text-sm font-semibold text-gray-900">Pricing</h3>
        <%= link_to manage_course_wizard_pricing_path, class: "text-xs text-pink-600 hover:text-pink-700 font-medium" do %>
          Edit
        <% end %>
      </div>
      <dl class="space-y-2 text-sm">
        <div>
          <dt class="text-gray-500">Price</dt>
          <dd class="font-medium text-gray-900">
            $<%= "%.2f" % (@wizard_state[:price_cents].to_f / 100) %>
          </dd>
        </div>
        <% if @wizard_state[:early_bird_price_cents].present? %>
          <div>
            <dt class="text-gray-500">Early Bird Price</dt>
            <dd class="font-medium text-green-700">
              $<%= "%.2f" % (@wizard_state[:early_bird_price_cents].to_f / 100) %>
              <% if @wizard_state[:early_bird_deadline].present? %>
                <span class="text-gray-500 font-normal">until <%= DateTime.parse(@wizard_state[:early_bird_deadline]).strftime("%B %-d, %Y") rescue @wizard_state[:early_bird_deadline] %></span>
              <% end %>
            </dd>
          </div>
        <% end %>
      </dl>

      <%# Fee breakdown summary %>
      <% price_dollars = @wizard_state[:price_cents].to_f / 100 %>
      <% has_promo = @wizard_state[:promo_code].present? %>
      <% fee_percent = has_promo ? 0 : 5.0 %>
      <% cocoscout_fee = price_dollars * (fee_percent / 100) %>
      <% producer_net = price_dollars - cocoscout_fee %>
      <% if price_dollars > 0 %>
        <div class="mt-3 pt-3 border-t border-gray-100 space-y-1">
          <div class="flex justify-between text-xs text-gray-500">
            <span>CocoScout fee (<%= has_promo ? "waived" : "5%" %>)</span>
            <span class="<%= has_promo ? 'text-green-600 font-medium' : '' %>">-$<%= "%.2f" % cocoscout_fee %></span>
          </div>
          <div class="flex justify-between text-sm font-semibold">
            <span class="text-gray-700">Net revenue per registration</span>
            <span class="text-pink-600">$<%= "%.2f" % producer_net %></span>
          </div>
          <% if has_promo %>
            <div class="mt-1">
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Promo code: <%= @wizard_state[:promo_code] %>
              </span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Details -->
    <div class="border border-gray-200 rounded-lg p-4">
      <div class="flex items-center justify-between mb-2">
        <h3 class="text-sm font-semibold text-gray-900">Details</h3>
        <%= link_to manage_course_wizard_details_path, class: "text-xs text-pink-600 hover:text-pink-700 font-medium" do %>
          Edit
        <% end %>
      </div>
      <dl class="space-y-2 text-sm">
        <div>
          <dt class="text-gray-500">Capacity</dt>
          <dd class="font-medium text-gray-900"><%= @wizard_state[:capacity].present? ? "#{@wizard_state[:capacity]} spots" : "Unlimited" %></dd>
        </div>
        <% if @wizard_state[:opens_at].present? || @wizard_state[:closes_at].present? %>
          <div>
            <dt class="text-gray-500">Registration Window</dt>
            <dd class="text-gray-700">
              <% if @wizard_state[:opens_at].present? %>
                Opens <%= DateTime.parse(@wizard_state[:opens_at]).strftime("%B %-d, %Y at %-I:%M %p") rescue @wizard_state[:opens_at] %>
              <% end %>
              <% if @wizard_state[:opens_at].present? && @wizard_state[:closes_at].present? %><br><% end %>
              <% if @wizard_state[:closes_at].present? %>
                Closes <%= DateTime.parse(@wizard_state[:closes_at]).strftime("%B %-d, %Y at %-I:%M %p") rescue @wizard_state[:closes_at] %>
              <% end %>
            </dd>
          </div>
        <% end %>

      </dl>
    </div>
  </div>

  <!-- What happens next -->
  <div class="mt-6 bg-gray-50 rounded-lg p-4">
    <p class="text-sm text-gray-700">
      <strong>What happens next?</strong> We'll create your course with the scheduled sessions and take you to its management page. You can open registration when you're ready.
    </p>
  </div>

  <div class="mt-8 flex items-center justify-between">
    <%= link_to manage_course_wizard_details_path, class: "text-sm text-gray-500 hover:text-gray-700 flex items-center gap-1" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      Back
    <% end %>
    <%= form_with url: manage_course_wizard_create_path, method: :post, local: true, class: "inline" do %>
      <%= render "shared/button", text: "Create Course", variant: "primary", size: "medium", type: :submit %>
    <% end %>
  </div>
<% end %>
