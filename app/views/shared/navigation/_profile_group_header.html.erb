<!-- Profile Header Navigation -->
<header class="hidden lg:flex fixed top-0 left-56 right-0 h-16 bg-white border-b border-gray-200 items-stretch justify-between z-50">
  <div class="flex items-stretch">
    <!-- Group Navigation Links -->
    <div class="flex items-center h-full border-r border-slate-200">
      <% is_profile = controller_name == 'groups' && action_name == 'edit' %>
      <% is_settings = controller_name == 'groups' && action_name == 'settings' %>
      <%= link_to "Group Profile", edit_group_path(@group), class: "px-4 py-2 text-sm font-medium transition #{is_profile ? 'text-pink-600' : 'text-slate-600 hover:text-slate-900'}" %>
      <%= link_to "Group Settings", settings_group_path(@group), class: "px-4 py-2 text-sm font-medium transition #{is_settings ? 'text-pink-600' : 'text-slate-600 hover:text-slate-900'}" %>
    </div>
  </div>

  <%= render "shared/navigation/user_dropdown" %>
</header>
