<%# Top menu with tab navigation
  Parameters:
    tabs: Array of { name:, path:, active: } hashes
    links: Array of { text:, path:, ... } hashes (optional, same format as top_menu)
%>
<% links = local_assigns.fetch(:links, []) %>

<% if turbo_native_app? %>
  <%# Native: keep the tab strip — it's useful sub-navigation within a screen %>
  <div class="flex gap-1 mb-4 overflow-x-auto">
    <% tabs.each do |tab| %>
      <%= link_to tab[:path], class: "whitespace-nowrap px-3 py-1.5 text-sm font-medium rounded-full transition-colors #{tab[:active] ? 'bg-pink-100 text-pink-700' : 'text-gray-500 hover:text-gray-700'}" do %>
        <%= tab[:name] %>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-2 sm:gap-4 mb-4 border-b border-gray-200">

    <div class="flex items-end gap-0 coustard-regular min-w-0 -mb-px">
      <% tabs.each do |tab| %>
        <%= link_to tab[:path], class: "px-4 py-2 text-md sm:text-xl font-medium border-b-2 transition-colors #{tab[:active] ? 'border-pink-500 text-pink-600' : 'border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300'}" do %>
          <%= tab[:name] %>
        <% end %>
      <% end %>
    </div>

    <% if links.any? %>
      <div class="flex gap-2 flex-wrap flex-shrink-0 pb-2">
        <% links.each do |link| %>
          <%= link_to link[:path] do %>
            <%= render "shared/button", text: link[:text], variant: link[:variant] || "primary", size: link[:size] || "small" %>
          <% end %>
        <% end %>
      </div>
    <% end %>

  </div>
<% end %>
