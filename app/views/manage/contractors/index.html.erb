<% content_for :title, "Contractors" %>

<div class="w-full mb-10">
  <%= render partial: "shared/notice", locals: { notice: notice, alert: alert } %>

  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      ["Money", manage_money_index_path],
      ["Contracts", manage_contracts_path]
    ],
    text: "Contractors",
    links: [
      { icon: "plus", text: "New Contractor", path: new_manage_contractor_path }
    ]
  } %>

  <% no_contractors_at_all = @total_count.zero? && @query.blank? && @filter == "all" %>

  <% unless no_contractors_at_all %>
    <%# Search + status filters (GET form so the search input submits) %>
    <%= form_with url: manage_contractors_path, method: :get, data: { turbo_action: "replace" } do %>
      <input type="hidden" name="filter" value="<%= @filter %>">
      <%= render "shared/filters/filter_bar",
        toggle_label: "Filter contractors",
        filter_groups: [
          { partial: "shared/filters/search_input",
            locals: { placeholder: "Search contractors…", value: @query, name: "q" } },
          { separator: true },
          { label: "Show", filters: [
            { text: "All (#{@total_count})", path: manage_contractors_path(q: @query.presence), active: @filter == "all" },
            { text: "With active contracts (#{@active_count})", path: manage_contractors_path(q: @query.presence, filter: "active"), active: @filter == "active" },
            { text: "Other (#{@inactive_count})", path: manage_contractors_path(q: @query.presence, filter: "inactive"), active: @filter == "inactive" }
          ] }
        ]
      %>
    <% end %>
  <% end %>

  <% if @contractors.any? %>
    <%# Contractors with active contracts %>
    <% if @contractors_with_active.any? %>
      <% if @filter == "all" %>
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">With active contracts</h2>
      <% end %>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-2 mb-6">
        <% @contractors_with_active.each do |contractor| %>
          <%= render "contractor_row", contractor: contractor %>
        <% end %>
      </div>
    <% end %>

    <%# Other contractors %>
    <% if @contractors_without_active.any? %>
      <% if @filter == "all" %>
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Other contractors</h2>
      <% end %>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-2 mb-6">
        <% @contractors_without_active.each do |contractor| %>
          <%= render "contractor_row", contractor: contractor %>
        <% end %>
      </div>
    <% end %>
  <% elsif no_contractors_at_all %>
    <div class="bg-gray-50 rounded-lg border border-dashed border-gray-300 p-12 text-center">
      <%= icon("users", class: "w-12 h-12 text-gray-400 mx-auto mb-4") %>
      <h3 class="text-lg font-medium text-gray-900 mb-2">No contractors yet</h3>
      <p class="text-gray-600 mb-4">
        Contractors are created automatically when you create a contract, or you can add them manually.
      </p>
      <%= link_to new_manage_contractor_path do %>
        <%= render "shared/button", text: "New Contractor", variant: "primary", icon: "plus" %>
      <% end %>
    </div>
  <% else %>
    <div class="bg-gray-50 rounded-lg border border-dashed border-gray-300 p-10 text-center">
      <p class="text-gray-600">No contractors match your search.</p>
      <%= link_to "Clear filters", manage_contractors_path, class: "text-pink-600 hover:text-pink-700 text-sm font-medium mt-2 inline-block" %>
    </div>
  <% end %>
</div>
