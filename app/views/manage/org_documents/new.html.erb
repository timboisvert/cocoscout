<% content_for :title, "New document" %>

<div class="w-full">
  <%= render partial: "shared/notice", locals: { notice: notice, alert: alert } %>
  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      [ "Documents", manage_org_documents_path ]
    ],
    text: "New document",
    links: []
  } %>

  <div class="max-w-xl bg-white border border-gray-200 rounded-lg shadow-sm p-6">
    <% if @document.errors.any? %>
      <div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        <%= @document.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <% selected = (@selected_production_ids || []).map(&:to_i) %>
    <%= form_with url: manage_org_documents_path, method: :post do %>
      <div class="space-y-5">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Which productions does this apply to?</label>
          <p class="text-xs text-gray-500 mb-2">Pick one or more. A handbook or policy can be shared by several productions — edit it once, everyone sees the update.</p>
          <% if @managed_productions.any? %>
            <div class="space-y-1 max-h-60 overflow-y-auto rounded-lg border border-gray-200 p-2">
              <% @managed_productions.each do |production| %>
                <label class="flex items-center gap-2 text-sm text-gray-800 px-2 py-1.5 rounded hover:bg-gray-50 cursor-pointer">
                  <input type="checkbox" name="production_ids[]" value="<%= production.id %>"
                         <%= "checked" if selected.include?(production.id) %>
                         class="h-4 w-4 text-pink-600 border-gray-300 rounded focus:ring-pink-500 accent-pink-500">
                  <span class="truncate"><%= production.name %></span>
                </label>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-gray-500">You don't manage any productions yet.</p>
          <% end %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
          <%= text_field_tag "production_document[title]", @document.title, required: true,
                placeholder: "e.g. Performer Handbook",
                class: "block w-full text-sm rounded-lg border border-gray-300 px-3 py-2.5 focus:ring-pink-500 focus:border-pink-500" %>
        </div>

        <p class="text-xs text-gray-500">
          New documents are shared with the production team (can edit) by default — you can change who can see it from the Sharing button once it's created.
        </p>
      </div>

      <div class="flex items-center justify-end gap-3 mt-6">
        <%= link_to "Cancel", manage_org_documents_path, class: "px-4 py-2 text-sm text-gray-600 hover:text-gray-900" %>
        <%= render "shared/button", text: "Create & write", variant: "primary", size: "medium", type: :submit %>
      </div>
    <% end %>
  </div>
</div>
