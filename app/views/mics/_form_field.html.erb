<%#
  A consistent label + input wrapper. Locals: name (string), label (string),
  type ("text"|"email"|"url"|"time"|"date"|"textarea"|"select"), required (bool),
  value (any), placeholder (string), help (string), options (array of [label, value]).

  Inputs are pink-focused, square corners, generous size.
%>
<%
  type = local_assigns[:type] || "text"
  required = local_assigns[:required] || false
  value = local_assigns[:value]
  placeholder = local_assigns[:placeholder]
  options = local_assigns[:options]
  field_id = "field_#{name.to_s.parameterize}_#{rand(99999)}"
  field_classes = "w-full px-3 py-2.5 border border-gray-300 bg-white text-gray-900 placeholder:text-gray-400 focus:border-pink-500 focus:ring-2 focus:ring-pink-200 outline-none text-sm"
%>
<div class="mb-4">
  <label for="<%= field_id %>" class="block text-xs uppercase tracking-wider text-gray-600 font-bold mb-1">
    <%= label %><% if required %> <span class="text-pink-500">*</span><% end %>
  </label>
  <% case type %>
  <% when "textarea" %>
    <textarea id="<%= field_id %>" name="<%= name %>"
              rows="<%= local_assigns[:rows] || 4 %>"
              <%= "required" if required %>
              placeholder="<%= local_assigns[:placeholder] %>"
              class="<%= field_classes %>"><%= value %></textarea>
  <% when "select" %>
    <select id="<%= field_id %>" name="<%= name %>" class="<%= field_classes %>">
      <% (options || []).each do |opt_label, opt_value| %>
        <option value="<%= opt_value %>" <%= "selected" if value.to_s == opt_value.to_s %>>
          <%= opt_label %>
        </option>
      <% end %>
    </select>
  <% else %>
    <input id="<%= field_id %>" type="<%= type %>" name="<%= name %>"
           value="<%= value %>"
           placeholder="<%= local_assigns[:placeholder] %>"
           maxlength="<%= local_assigns[:maxlength] %>"
           <%= "required" if required %>
           class="<%= field_classes %>">
  <% end %>
  <% if local_assigns[:help].present? %>
    <p class="mt-1 text-xs text-gray-500"><%= help %></p>
  <% end %>
</div>
