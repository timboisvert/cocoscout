<% content_for :title, "Home" %>

<div class="w-full mb-10">
  <%= render partial: "shared/notice", locals: { notice: notice } %>

  <% if @production_dashboards.any? %>
    <%
      # Aggregate data from all productions
      all_open_calls = []
      all_sign_up_forms = []
      all_open_vacancies = []

      @productions.each do |production|
        dashboard = @production_dashboards[production.id]
        next unless dashboard

        dashboard[:open_calls][:with_auditionees].each do |call_data|
          all_open_calls << call_data.merge(production: production)
        end

        dashboard[:sign_up_forms].each do |form_data|
          all_sign_up_forms << form_data.merge(production: production)
        end

        dashboard[:open_vacancies].each do |vacancy_data|
          all_open_vacancies << vacancy_data.merge(production: production)
        end
      end

      total_audition_signups = all_open_calls.sum { |c| c[:auditionee_count] }

      # Sort sign-up forms by next event date (soonest first)
      all_sign_up_forms.sort_by! { |f| f[:instance]&.show&.date_and_time || 100.years.from_now }
      soonest_form = all_sign_up_forms.first
    %>

    <!-- Row 1: Summary Boxes -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
      <%# Audition Sign-ups — accordion %>
      <div class="border border-gray-200 rounded-lg bg-white overflow-hidden">
        <details class="group">
          <summary class="list-none cursor-pointer p-4 hover:bg-gray-50 transition-colors [&::-webkit-details-marker]:hidden">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-pink-100 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <div class="text-xs text-gray-500 uppercase tracking-wide">Audition Sign-ups</div>
                <% if total_audition_signups > 0 %>
                  <div class="text-2xl font-bold text-gray-900 tabular-nums"><%= total_audition_signups %> <span class="text-sm font-normal text-gray-500">to review</span></div>
                <% else %>
                  <div class="text-sm text-gray-500">No open auditions</div>
                <% end %>
              </div>
              <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
          </summary>
          <div class="border-t border-gray-200 divide-y divide-gray-100">
            <% if all_open_calls.any? %>
              <% all_open_calls.each do |call_data| %>
                <% cycle = call_data[:call] %>
                <% production = call_data[:production] %>
                <%= link_to manage_signups_auditions_path(production), class: "flex items-center gap-3 px-4 py-3 hover:bg-gray-50 transition-colors no-underline" do %>
                  <% logo_variant = production.safe_logo_variant(:small) %>
                  <% if logo_variant %>
                    <div class="flex-shrink-0 w-8 h-5 rounded flex items-center justify-center overflow-hidden">
                      <%= image_tag logo_variant, alt: production.name, class: "w-full h-full object-cover rounded" %>
                    </div>
                  <% else %>
                    <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-pink-100 flex items-center justify-center">
                      <span class="text-xs font-bold text-pink-600"><%= production.initials %></span>
                    </div>
                  <% end %>
                  <div class="flex-1 min-w-0">
                    <div class="font-medium text-gray-900 text-sm truncate"><%= production.name %></div>
                    <div class="text-xs text-gray-500">
                      <% if cycle.closes_at.present? %>
                        Closes <%= cycle.closes_at.strftime("%b %-d") %>
                      <% else %>
                        Open-ended
                      <% end %>
                    </div>
                  </div>
                  <div class="text-right flex-shrink-0">
                    <span class="text-lg font-bold text-gray-900 tabular-nums"><%= call_data[:auditionee_count] %></span>
                    <div class="text-xs text-gray-500"><%= 'sign-up'.pluralize(call_data[:auditionee_count]) %></div>
                  </div>
                <% end %>
              <% end %>
            <% else %>
              <div class="px-4 py-3 text-sm text-gray-500">No open audition cycles.</div>
            <% end %>
          </div>
        </details>
      </div>

      <%# Event Registrations — accordion %>
      <div class="border border-gray-200 rounded-lg bg-white overflow-hidden">
        <details class="group">
          <summary class="list-none cursor-pointer p-4 hover:bg-gray-50 transition-colors [&::-webkit-details-marker]:hidden">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-pink-100 flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15a2.25 2.25 0 0 1 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" />
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <div class="text-xs text-gray-500 uppercase tracking-wide">Event Registrations</div>
                <% if soonest_form %>
                  <% soonest_show = soonest_form[:instance]&.show %>
                  <% soonest_regs = soonest_form[:instance]&.registration_count || 0 %>
                  <div class="text-sm font-medium text-gray-900 truncate"><%= soonest_form[:form].name %></div>
                  <div class="flex items-baseline gap-1.5">
                    <span class="text-lg font-bold text-gray-900 tabular-nums"><%= soonest_regs %></span>
                    <span class="text-xs text-gray-500">registered for next event</span>
                    <% if soonest_show %>
                      <span class="text-xs text-gray-400">· <%= soonest_show.date_and_time.strftime("%b %-d") %></span>
                    <% end %>
                  </div>
                <% else %>
                  <div class="text-sm text-gray-500">No active sign-up forms</div>
                <% end %>
              </div>
              <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
          </summary>
          <div class="border-t border-gray-200 divide-y divide-gray-100">
            <% if all_sign_up_forms.any? %>
              <% all_sign_up_forms.each do |form_data| %>
                <% form = form_data[:form] %>
                <% instance = form_data[:instance] %>
                <% form_status = form_data[:form_status] %>
                <% production = form_data[:production] %>
                <% next_show = instance&.show %>
                <%= link_to manage_signups_form_path(production, form), class: "flex items-center gap-3 px-4 py-3 hover:bg-gray-50 transition-colors no-underline" do %>
                  <% logo_variant = production.safe_logo_variant(:small) %>
                  <% if logo_variant %>
                    <div class="flex-shrink-0 w-8 h-5 rounded flex items-center justify-center overflow-hidden">
                      <%= image_tag logo_variant, alt: production.name, class: "w-full h-full object-cover rounded" %>
                    </div>
                  <% else %>
                    <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-pink-100 flex items-center justify-center">
                      <span class="text-xs font-bold text-pink-600"><%= production.initials %></span>
                    </div>
                  <% end %>
                  <div class="flex-1 min-w-0">
                    <div class="font-medium text-gray-900 text-sm truncate"><%= form.name %></div>
                    <div class="text-xs text-gray-500">
                      <%= production.name %>
                      <% if next_show %>
                        · Next: <%= next_show.date_and_time.strftime("%b %-d, %-I:%M%p") %>
                      <% end %>
                    </div>
                  </div>
                  <div class="text-right flex-shrink-0">
                    <span class="text-lg font-bold text-gray-900 tabular-nums"><%= instance&.registration_count || 0 %></span>
                    <div class="text-xs text-gray-500">registered</div>
                  </div>
                <% end %>
              <% end %>
            <% else %>
              <div class="px-4 py-3 text-sm text-gray-500">No active sign-up forms.</div>
            <% end %>
          </div>
        </details>
      </div>
    </div>

    <!-- Row 2: Vacancy Alerts -->
    <% if all_open_vacancies.any? %>
      <div class="border border-pink-200 rounded-lg overflow-hidden mb-6 bg-pink-50">
        <%= render "shared/card_header",
          title: "Open Vacancies (#{all_open_vacancies.size})",
          bg_class: "bg-pink-100",
          border_class: "border-pink-200",
          title_class: "text-pink-900",
          icon: '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" /></svg>' %>
        <div class="p-4 space-y-1">
          <% all_open_vacancies.each do |vacancy_data| %>
            <% vacancy = vacancy_data[:vacancy] %>
            <% show = vacancy_data[:show] %>
            <% production = vacancy_data[:production] %>
            <% vacated_by = vacancy.vacated_by %>
            <% is_linked = vacancy_data[:is_linked] %>
            <% affected_shows = is_linked ? vacancy_data[:affected_shows] : [show] %>
            <div class="group flex flex-col sm:flex-row sm:items-stretch bg-white border border-pink-200 rounded-lg hover:border-pink-400 transition-colors overflow-hidden">
              <div class="sm:w-1/3 px-3 py-2">
                <div class="flex items-center gap-3 mb-2">
                  <% logo_variant = production.safe_logo_variant(:small) %>
                  <% if logo_variant %>
                    <div class="flex-shrink-0 w-8 h-5 rounded flex items-center justify-center overflow-hidden">
                      <%= image_tag logo_variant, alt: production.name, class: "w-full h-full object-cover rounded" %>
                    </div>
                  <% else %>
                    <div class="flex-shrink-0 w-8 h-8 rounded bg-pink-100 flex items-center justify-center">
                      <span class="text-xs font-bold text-pink-600"><%= production.initials %></span>
                    </div>
                  <% end %>
                  <span class="font-medium text-gray-900 text-sm truncate"><%= production.name %></span>
                </div>
                <div class="text-sm text-gray-600">
                  <%= show.date_and_time.strftime("%b %-d, %l:%M %p").strip %>
                  <% if affected_shows.size > 1 %>
                    <span class="text-gray-400">+ <%= affected_shows.size - 1 %> more</span>
                  <% end %>
                </div>
              </div>
              <div class="sm:w-1/3 border-t sm:border-t-0 sm:border-l border-pink-200 px-3 py-2 flex flex-col justify-center">
                <div class="font-medium text-gray-900"><%= show.display_name %></div>
                <% if show.is_online %>
                  <div class="text-sm text-gray-600">Online</div>
                <% elsif show.location.present? %>
                  <div class="text-sm text-gray-600"><%= show.location.name %></div>
                <% end %>
              </div>
              <div class="sm:w-1/3 border-t sm:border-t-0 sm:border-l border-pink-200 px-3 py-2 flex items-center gap-3">
                <% if vacated_by %>
                  <% headshot_variant = vacated_by.safe_headshot_variant(:thumb) %>
                  <% if headshot_variant %>
                    <%= image_tag headshot_variant, class: "w-10 h-10 rounded-lg object-cover flex-shrink-0" %>
                  <% else %>
                    <div class="w-10 h-10 rounded-lg bg-gray-200 flex items-center justify-center text-gray-700 font-bold text-sm flex-shrink-0">
                      <%= vacated_by.initials %>
                    </div>
                  <% end %>
                <% end %>
                <div class="flex-1 min-w-0">
                  <div class="text-[10px] text-gray-400 uppercase tracking-wide">Can't make it</div>
                  <div class="text-sm flex items-center gap-1">
                    <span class="font-medium text-gray-900"><%= vacated_by&.name %></span>
                    <span class="text-gray-400">as</span>
                    <strong class="text-pink-500"><%= vacancy_data[:role].name %></strong>
                  </div>
                </div>
                <div class="flex-shrink-0 hidden group-hover:block">
                  <%= render "shared/button", text: "Review", path: manage_casting_vacancy_path(production, vacancy), variant: "primary", size: "small" %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Row 3: Calendar -->
    <%
      month_start_date = @current_month.to_date
      month_end_date = @current_month.end_of_month.to_date
    %>
    <div class="border border-gray-200 rounded-lg overflow-hidden mb-6">
      <%# Calendar Header with Navigation %>
      <div class="flex items-center justify-between px-4 py-3 bg-gray-50 border-b border-gray-200">
        <div>
          <% if @can_go_prev %>
            <%= link_to manage_path(month: @prev_month.strftime("%Y-%m-01")), class: "inline-flex items-center gap-1 text-sm text-gray-600 hover:text-gray-900" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
              </svg>
              <%= @prev_month.strftime("%b") %>
            <% end %>
          <% end %>
        </div>

        <div class="flex items-center gap-3">
          <h2 class="text-lg font-bold text-gray-900"><%= @current_month.strftime("%B %Y") %></h2>
          <% if @current_month != Time.current.beginning_of_month %>
            <%= link_to "Today", manage_path, class: "text-xs font-medium text-pink-600 hover:text-pink-700 border border-pink-200 rounded-full px-2 py-0.5" %>
          <% end %>
        </div>

        <div>
          <% if @can_go_next %>
            <%= link_to manage_path(month: @next_month.strftime("%Y-%m-01")), class: "inline-flex items-center gap-1 text-sm text-gray-600 hover:text-gray-900" do %>
              <%= @next_month.strftime("%b") %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            <% end %>
          <% end %>
        </div>
      </div>

      <%# Desktop Calendar Grid %>
      <div class="hidden md:block p-4">
        <%# Day headers %>
        <div class="grid grid-cols-7 gap-1 mb-1">
          <% %w[Sun Mon Tue Wed Thu Fri Sat].each do |day_name| %>
            <div class="text-center text-xs font-semibold text-gray-500 py-1"><%= day_name %></div>
          <% end %>
        </div>

        <div class="grid grid-cols-7 gap-1">
          <%# Empty cells before month starts %>
          <% month_start_date.wday.times do %>
            <div class="border border-gray-100 bg-gray-50 min-h-[80px] p-1"></div>
          <% end %>

          <%# Calendar days %>
          <% current_date = month_start_date %>
          <% while current_date <= month_end_date %>
            <% day_events = (@events_by_date[current_date] || []).sort_by { |e| e[:time] } %>
            <% is_past = current_date < Date.current %>
            <% is_today = current_date == Date.current %>
            <div class="border border-gray-200 min-h-[80px] p-1 <%= 'bg-blue-50' if is_today %> <%= 'opacity-50 bg-gray-50' if is_past %>">
              <div class="text-xs font-semibold mb-1 <%= is_past ? 'text-gray-400' : 'text-gray-700' %>">
                <%= current_date.day %>
              </div>

              <% day_events.first(4).each do |event| %>
                <%
                  color_classes = case event[:color]
                    when "pink" then "bg-pink-100 text-pink-800 border-pink-300 hover:bg-pink-200"
                    when "blue" then "bg-blue-100 text-blue-800 border-blue-300 hover:bg-blue-200"
                    when "green" then "bg-green-100 text-green-800 border-green-300 hover:bg-green-200"
                    when "amber" then "bg-amber-100 text-amber-800 border-amber-300 hover:bg-amber-200"
                    when "purple" then "bg-purple-100 text-purple-800 border-purple-300 hover:bg-purple-200"
                    else "bg-gray-100 text-gray-800 border-gray-300 hover:bg-gray-200"
                  end
                  color_classes = "bg-gray-100 text-gray-600 border-gray-300 hover:bg-gray-200" if is_past
                %>
                <%= link_to event[:path], class: "block mb-1" do %>
                  <div class="text-xs p-1.5 rounded border <%= color_classes %> transition-colors truncate">
                    <div class="font-semibold truncate"><%= event[:time].strftime("%-I:%M%p").downcase %></div>
                    <div class="truncate text-[10px]"><%= event[:title] %></div>
                  </div>
                <% end %>
              <% end %>
              <% if day_events.size > 4 %>
                <div class="text-[10px] text-gray-500 text-center mt-0.5">+<%= day_events.size - 4 %> more</div>
              <% end %>
            </div>
            <% current_date = current_date + 1.day %>
          <% end %>

          <%# Empty cells after month ends %>
          <% remaining_cells = (7 - (month_end_date + 1.day).wday) % 7 %>
          <% remaining_cells.times do %>
            <div class="border border-gray-100 bg-gray-50 min-h-[80px] p-1"></div>
          <% end %>
        </div>
      </div>

      <%# Mobile List View %>
      <div class="md:hidden p-4 space-y-1">
        <% current_date = month_start_date %>
        <% has_events = false %>
        <% while current_date <= month_end_date %>
          <% day_events = (@events_by_date[current_date] || []).sort_by { |e| e[:time] } %>
          <% if day_events.any? %>
            <% has_events = true %>
            <% is_past = current_date < Date.current %>
            <% is_today = current_date == Date.current %>
            <div class="<%= 'opacity-50' if is_past %>">
              <div class="text-xs font-semibold px-1 py-1 <%= is_today ? 'text-pink-600' : (is_past ? 'text-gray-400' : 'text-gray-500') %>">
                <%= current_date.strftime("%a, %b %-d") %>
              </div>
              <% day_events.each do |event| %>
                <%
                  dot_color = case event[:color]
                    when "pink" then "bg-pink-400"
                    when "blue" then "bg-blue-400"
                    when "green" then "bg-green-400"
                    when "amber" then "bg-amber-400"
                    when "purple" then "bg-purple-400"
                    else "bg-gray-400"
                  end
                  row_bg = case event[:color]
                    when "pink" then "bg-pink-50 border border-pink-200"
                    when "blue" then "bg-blue-50 border border-blue-200"
                    when "green" then "bg-green-50 border border-green-200"
                    when "amber" then "bg-amber-50 border border-amber-200"
                    when "purple" then "bg-purple-50 border border-purple-200"
                    else ""
                  end
                  if is_past
                    dot_color = "bg-gray-300"
                    row_bg = ""
                  end
                %>
                <%= link_to event[:path], class: "flex items-center gap-2 px-2 py-1.5 rounded hover:bg-gray-50 transition-colors #{row_bg}" do %>
                  <div class="w-1.5 h-1.5 rounded-full flex-shrink-0 <%= dot_color %>"></div>
                  <span class="text-xs text-gray-500 w-14 flex-shrink-0"><%= event[:time].strftime("%-I:%M%p").downcase %></span>
                  <span class="text-sm truncate flex-1 <%= is_past ? 'text-gray-400' : 'text-gray-900' %>"><%= event[:title] %></span>
                <% end %>
              <% end %>
            </div>
          <% end %>
          <% current_date = current_date + 1.day %>
        <% end %>
        <% unless has_events %>
          <div class="text-center text-sm text-gray-500 py-8">No events this month.</div>
        <% end %>
      </div>

      <%# Legend %>
      <div class="px-4 pb-3 flex flex-wrap gap-3 text-xs text-gray-500">
        <div class="flex items-center gap-1.5">
          <div class="w-2.5 h-2.5 rounded-sm bg-pink-300"></div>
          Shows
        </div>
        <div class="flex items-center gap-1.5">
          <div class="w-2.5 h-2.5 rounded-sm bg-blue-300"></div>
          Rehearsals
        </div>
        <div class="flex items-center gap-1.5">
          <div class="w-2.5 h-2.5 rounded-sm bg-green-300"></div>
          Meetings
        </div>
        <div class="flex items-center gap-1.5">
          <div class="w-2.5 h-2.5 rounded-sm bg-purple-300"></div>
          Course Sessions
        </div>
        <div class="flex items-center gap-1.5">
          <div class="w-2.5 h-2.5 rounded-sm bg-amber-300"></div>
          Third-party
        </div>
      </div>
    </div>

  <% else %>
    <!-- Empty state: new org, no productions yet -->
    <div class="max-w-2xl mx-auto mt-10">
      <div class="text-center mb-8">
        <h1 class="text-2xl font-bold text-gray-900 coustard-regular mb-2">Welcome to <%= Current.organization.name %></h1>
        <p class="text-sm text-gray-600">
          This is your production dashboard — where you manage the shows, courses, and events that <strong>you're</strong> producing.
          Get started by creating your first production or course.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
        <%# Create a Production card %>
        <%= link_to manage_productions_wizard_path, class: "block bg-white border border-gray-200 rounded-lg p-6 hover:border-pink-300 hover:shadow-sm transition group" do %>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-pink-100 flex items-center justify-center flex-shrink-0 group-hover:bg-pink-200 transition">
              <svg class="w-5 h-5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4V2m0 2a2 2 0 012-2h6a2 2 0 012 2m-8 0v2m8-2v2m-8 4h8m-8 4h4m4-4a4 4 0 110 8 4 4 0 010-8z" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-1">Create a Production</h3>
              <p class="text-xs text-gray-500 leading-relaxed">
                For shows, theater runs, festivals, or any event with a cast and crew.
                Manage auditions, casting, scheduling, and availability.
              </p>
            </div>
          </div>
        <% end %>

        <%# Create a Course card %>
        <%= link_to manage_course_wizard_basics_path, class: "block bg-white border border-gray-200 rounded-lg p-6 hover:border-pink-300 hover:shadow-sm transition group" do %>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-full bg-pink-100 flex items-center justify-center flex-shrink-0 group-hover:bg-pink-200 transition">
              <svg class="w-5 h-5 text-pink-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 mb-1">Create a Course</h3>
              <p class="text-xs text-gray-500 leading-relaxed">
                For workshops, classes, and training programs.
                Set up scheduling, registration, payments, and a listing in the course directory.
              </p>
            </div>
          </div>
        <% end %>
      </div>

      <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 text-center">
        <p class="text-xs text-gray-500">
          <strong>Already performing in someone else's production?</strong>
          That's managed from your <%= link_to "Talent Dashboard", my_dashboard_path, class: "text-pink-600 underline hover:text-pink-700" %>.
          This section is just for the things you're producing yourself.
        </p>
      </div>
    </div>
  <% end %>
</div>
