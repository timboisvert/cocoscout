{
  "settings": {
    "tabs": [
      { "title": "Dashboard", "path": "/my", "icon": "house" },
      { "title": "Shows", "path": "/my/shows", "icon": "calendar" },
      { "title": "Messages", "path": "/my/messages", "icon": "envelope" },
      { "title": "Requests", "path": "/my/requests", "icon": "bell" }
    ]
  },
  "rules": [
    {
      "patterns": [".*"],
      "properties": {
        "context": "default",
        "pull_to_refresh_enabled": true
      }
    },
    {
      "patterns": ["/new$", "/edit$", "/edit/"],
      "properties": {
        "context": "modal",
        "pull_to_refresh_enabled": false
      }
    },
    {
      "patterns": [
        "/my/messages/[0-9]+/reply",
        "/my/direct_messages/new",
        "/my/groups/new",
        "/my/profiles/new"
      ],
      "properties": {
        "context": "modal",
        "pull_to_refresh_enabled": false
      }
    },
    {
      "patterns": [
        "/my/sign_ups/.*/form$",
        "/my/questionnaires/.*/form$",
        "/my/submit_audition_request/.*/form$",
        "/my/course_registrations/.*/entry$",
        "/my/course_registrations/.*/register$"
      ],
      "properties": {
        "context": "modal",
        "pull_to_refresh_enabled": false
      }
    },
    {
      "patterns": ["/signin$", "/signup$", "/password$", "/reset/"],
      "properties": {
        "context": "default",
        "pull_to_refresh_enabled": false,
        "presentation": "replace_root"
      }
    }
  ]
}
