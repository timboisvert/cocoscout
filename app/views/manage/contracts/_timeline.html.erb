<%#
  Contract Timeline (Gantt Chart)

  Displays contracts as horizontal bars on a timeline.
  Fixed range: 3 months ago to 12 months from now (15 months total).

  Required:
    - contracts: Array of Contract objects
%>
<%
  # Get contracts with dates for the timeline (exclude cancelled)
  visible_contracts = contracts.select { |c| c.contract_start_date.present? && c.status != "cancelled" }

  # Fixed date range: 3 months ago to 12 months from now
  min_date = 3.months.ago.to_date.beginning_of_month
  max_date = 12.months.from_now.to_date.end_of_month

  total_days = (max_date - min_date).to_i

  # Generate 15 month segments
  months = []
  current = min_date
  while current <= max_date
    months << current
    current = current.next_month
  end

  # Today position
  today_offset = ((Date.current - min_date).to_f / total_days * 100).round(2)
%>

<% if visible_contracts.any? %>
  <div data-controller="contract-timeline" class="relative">
    <%# Month header with grid lines %>
    <div class="relative h-8 mb-2 border-b border-gray-200 flex">
      <% months.each_with_index do |month, idx| %>
        <div class="flex-1 text-center border-l border-gray-100 first:border-l-0">
          <span class="text-xs font-medium text-gray-500"><%= month.strftime("%b") %></span>
          <% if month.month == 1 || idx == 0 %>
            <span class="text-xs text-gray-400 ml-0.5"><%= month.strftime("'%y") %></span>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Timeline container with today marker %>
    <div class="relative">
      <%# Today marker %>
      <div class="absolute top-0 bottom-0 border-l-2 border-pink-400 z-20 pointer-events-none" style="left: <%= today_offset %>%;"></div>

      <%# Contract bars %>
      <div class="space-y-2">
        <% visible_contracts.each do |contract| %>
          <%
            start_date = contract.contract_start_date
            end_date = contract.contract_end_date || (start_date + 30.days)

            # Clamp dates to visible range
            visible_start = [start_date, min_date].max
            visible_end = [end_date, max_date].min

            # Skip if entirely outside visible range
            next if visible_start > max_date || visible_end < min_date

            # Calculate position and width as percentages
            left_offset = ((visible_start - min_date).to_f / total_days * 100).round(2)
            bar_width = ((visible_end - visible_start).to_f / total_days * 100).round(2)
            bar_width = [bar_width, 2].max # Minimum 2% width

            # Determine if bar starts before visible range or ends after
            starts_early = start_date < min_date
            ends_late = end_date > max_date

            # Status-based colors
            bar_color = case contract.status
              when "active" then "bg-green-500"
              when "completed" then "bg-blue-400"
              else "bg-pink-400"
            end

            display_name = contract.production_name.presence || contract.contractor_name
          %>
          <div class="relative h-10">
            <%= link_to manage_contract_path(contract),
                class: "absolute flex items-center h-8 rounded-sm #{bar_color} hover:opacity-80 transition-opacity cursor-pointer shadow-sm #{starts_early ? 'rounded-l-none' : ''} #{ends_late ? 'rounded-r-none' : ''}",
                style: "left: #{left_offset}%; width: #{bar_width}%; min-width: 60px;",
                title: "#{display_name}: #{start_date.strftime('%b %-d, %Y')} - #{end_date.strftime('%b %-d, %Y')}" do %>
              <span class="text-white text-xs font-medium truncate px-2 w-full">
                <%= display_name %>
              </span>
            <% end %>
          </div>
        <% end %>
      </div>

      <%# Month grid lines (behind bars) %>
      <div class="absolute inset-0 flex pointer-events-none" style="z-index: -1;">
        <% months.each do |month| %>
          <div class="flex-1 border-l border-gray-100 first:border-l-0"></div>
        <% end %>
      </div>
    </div>

    <%# Legend %>
    <div class="flex items-center gap-4 mt-6 pt-4 border-t border-gray-200">
      <div class="flex items-center gap-1.5">
        <div class="w-3 h-3 rounded bg-green-500"></div>
        <span class="text-xs text-gray-600">Active</span>
      </div>
      <div class="flex items-center gap-1.5">
        <div class="w-3 h-3 rounded bg-pink-400"></div>
        <span class="text-xs text-gray-600">Draft</span>
      </div>
      <div class="flex items-center gap-1.5">
        <div class="w-3 h-3 rounded bg-blue-400"></div>
        <span class="text-xs text-gray-600">Completed</span>
      </div>
      <div class="flex items-center gap-1.5 ml-auto">
        <div class="w-0.5 h-4 bg-pink-400"></div>
        <span class="text-xs text-gray-600">Today</span>
      </div>
    </div>
  </div>
<% else %>
  <div class="bg-gray-50 rounded-lg border border-dashed border-gray-300 p-8 text-center">
    <%= icon("calendar", class: "w-12 h-12 text-gray-400 mx-auto mb-4") %>
    <h3 class="text-lg font-medium text-gray-900 mb-2">No timeline data</h3>
    <p class="text-gray-600">
      Contracts need start dates to appear on the timeline.
    </p>
  </div>
<% end %>
