<%= render layout: "manage/course_offering_wizard/wizard_layout", locals: { step_name: "Instructor" } do %>
  <h2 class="text-lg font-bold text-gray-900 mb-1">Instructor</h2>
  <p class="text-sm text-gray-600 mb-6">Who's teaching this course? This info is shown on the registration page.</p>

  <%= form_with url: manage_course_wizard_instructor_path, method: :post, local: true do |form| %>
    <div class="space-y-5">
      <div>
        <label for="instructor_name" class="block text-sm font-medium text-gray-900 mb-1.5">
          Instructor Name
        </label>
        <input type="text" name="instructor_name" id="instructor_name"
               value="<%= @wizard_state[:instructor_name] %>"
               placeholder="e.g., Jane Smith"
               class="block w-full px-3 py-2.5 bg-white border border-gray-300 rounded-lg shadow-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 transition">
      </div>

      <div>
        <label for="instructor_bio" class="block text-sm font-medium text-gray-900 mb-1.5">
          Bio
        </label>
        <p class="text-xs text-gray-500 mb-2">A brief bio shown on the registration page.</p>
        <%= rich_text_area_tag :instructor_bio, @wizard_state[:instructor_bio], class: "w-full min-h-[120px]" %>
      </div>
    </div>

    <div class="mt-8 flex items-center justify-between">
      <%= link_to manage_course_wizard_schedule_path, class: "text-sm text-gray-500 hover:text-gray-700 flex items-center gap-1" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Back
      <% end %>
      <%= render "shared/button", text: "Next: Pricing", variant: "primary", size: "medium", type: :submit %>
    </div>
  <% end %>
<% end %>
