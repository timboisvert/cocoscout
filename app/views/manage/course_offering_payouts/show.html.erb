<% content_for :title, "Payout: #{@course_offering.title}" %>

<%
  registrations_count = @registrations.where(status: :confirmed).count
  refunded_count = @registrations.where(status: :refunded).count

  if @payout.paid?
    status_label = "Paid"
    status_class = "bg-green-100 text-green-700"
  elsif @payout.calculated?
    status_label = "Awaiting Payment"
    status_class = "bg-pink-100 text-pink-700"
  else
    status_label = "Pending"
    status_class = "bg-gray-100 text-gray-700"
  end
%>

<div class="w-full mb-10">
  <%= render partial: "shared/notice", locals: { notice: notice, alert: alert } %>
  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      ["Courses", manage_course_offerings_path],
      [@course_offering.title, manage_course_offering_path(@course_offering)]
    ],
    text: "Payout",
    links: []
  } %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Main Content -->
    <div class="lg:col-span-2 space-y-6">

      <!-- Revenue Summary Card -->
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
          <h2 class="text-lg font-semibold text-gray-900">Revenue Summary</h2>
          <span class="px-3 py-1 text-sm font-medium rounded-full <%= status_class %>"><%= status_label %></span>
        </div>
        <div class="px-6 py-4">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <div class="text-sm text-gray-500">Confirmed Registrations</div>
              <div class="text-2xl font-bold text-gray-900"><%= registrations_count %></div>
            </div>
            <div>
              <div class="text-sm text-gray-500">Refunded</div>
              <div class="text-2xl font-bold text-gray-900"><%= refunded_count %></div>
            </div>
          </div>

          <div class="mt-4 border-t border-gray-100 pt-4 space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600">Gross Revenue</span>
              <span class="text-sm font-semibold text-gray-900"><%= @payout.formatted_total_revenue %></span>
            </div>
            <% if @payout.total_revenue_override_cents.present? %>
              <div class="flex justify-between items-center">
                <span class="text-sm text-gray-600">Revenue Override</span>
                <span class="text-sm font-semibold text-amber-600">
                  <%= number_to_currency(@payout.total_revenue_override_cents / 100.0) %>
                </span>
              </div>
            <% end %>
            <div class="flex justify-between items-center">
              <span class="text-sm text-gray-600">
                Platform Fee
                <% if @coverage_type == "full" %>
                  <span class="text-green-600 font-medium">(waived)</span>
                <% elsif @coverage_type == "platform_only" %>
                  <span class="text-green-600 font-medium">(Stripe only)</span>
                <% else %>
                  (5%)
                <% end %>
              </span>
              <span class="text-sm text-gray-900">−<%= @payout.formatted_platform_fee %></span>
            </div>
            <div class="flex justify-between items-center border-t border-gray-100 pt-3">
              <span class="text-sm font-semibold text-gray-900">Net to Organization</span>
              <span class="text-lg font-bold text-gray-900"><%= @payout.formatted_net_revenue %></span>
            </div>
          </div>

          <% if @has_contract %>
            <div class="mt-4 bg-gray-50 rounded-lg p-3">
              <div class="flex items-center gap-2 text-sm text-gray-600">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/>
                </svg>
                <span>Contract: <strong><%= @contract.contractor_name %></strong> ·
                  <% if @contract.revenue_share? %>
                    Revenue Share (<%= @contract.contractor_share_percentage.to_i %>% contractor / <%= @contract.revenue_share_percentage.to_i %>% org)
                  <% elsif @contract.ticket_revenue_minus_fee? %>
                    Revenue minus <%= number_to_currency(@contract.flat_fee_amount) %> fee
                  <% end %>
                </span>
              </div>
              <% if @contractor&.any_payment_method_configured? %>
                <div class="mt-2 flex items-center gap-3 text-xs text-gray-500">
                  <% if @contractor.venmo_configured? %>
                    <span class="inline-flex items-center gap-1">
                      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.5 3c.9 1.5 1.3 3 1.3 5 0 5.5-4.7 12.7-8.5 17H5.2L2.8 3.5l6.3-.6 1.3 10.5c1.2-2 2.7-5.2 2.7-7.4 0-1.8-.3-3-0.8-4L19.5 3z"/></svg>
                      Venmo: <strong><%= @contractor.formatted_venmo_identifier %></strong>
                    </span>
                  <% end %>
                  <% if @contractor.zelle_configured? %>
                    <span class="inline-flex items-center gap-1">
                      💲 Zelle: <strong><%= @contractor.formatted_zelle_identifier %></strong>
                    </span>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="mt-4 bg-blue-50 rounded-lg p-3">
              <p class="text-sm text-blue-700">
                The organization receives <strong><%= @payout.formatted_net_revenue %></strong> from Stripe automatically. Use this page to track any payments you make to others (e.g., instructors).
              </p>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Payments -->
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
          <h2 class="text-lg font-semibold text-gray-900">Payments</h2>
          <% if @line_items.any? %>
            <span class="text-sm text-gray-500">
              <%= @payout.formatted_total_payout %> total
            </span>
          <% end %>
        </div>

        <% if @line_items.any? %>
          <div class="divide-y divide-gray-100">
            <% @line_items.each do |line_item| %>
              <div class="px-6 py-4 flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <% if line_item.payee.respond_to?(:safe_headshot_variant) %>
                    <% headshot_variant = line_item.payee.safe_headshot_variant(:thumb) %>
                    <% if headshot_variant %>
                      <%= image_tag headshot_variant, alt: line_item.payee_name, class: "w-10 h-10 rounded-lg object-cover" %>
                    <% else %>
                      <div class="w-10 h-10 rounded-lg bg-gray-200 flex items-center justify-center text-gray-600 font-bold text-sm">
                        <%= line_item.payee.respond_to?(:initials) ? line_item.payee.initials : line_item.payee_name[0..1].upcase %>
                      </div>
                    <% end %>
                  <% else %>
                    <div class="w-10 h-10 rounded-lg bg-gray-200 flex items-center justify-center text-gray-600 font-bold text-sm">
                      <%= line_item.payee_name[0..1].upcase %>
                    </div>
                  <% end %>
                  <div>
                    <div class="font-medium text-gray-900"><%= line_item.payee_name %></div>
                    <div class="text-sm text-gray-500">
                      <% if line_item.calculation_details["type"] == "contract_revenue_share" %>
                        Contract · <%= line_item.calculation_details["share_percentage"].to_i %>% share
                      <% elsif line_item.calculation_details["type"] == "contract_flat_fee" %>
                        Contract · Revenue minus <%= number_to_currency(line_item.calculation_details["flat_fee_cents"].to_i / 100.0) %>
                      <% else %>
                        Manual payment
                      <% end %>
                    </div>
                  </div>
                </div>
                <div class="flex items-center gap-3">
                  <span class="text-lg font-semibold text-gray-900"><%= line_item.formatted_amount %></span>
                  <% if line_item.paid? %>
                    <span class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-medium bg-green-100 text-green-700 rounded-full">
                      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                      </svg>
                      Paid
                      <% if line_item.payment_method %>
                        (<%= line_item.payment_method.titleize %>)
                      <% end %>
                    </span>
                  <% elsif !@payout.paid? %>
                    <div class="flex items-center gap-2">
                      <%# Show Venmo pay button if contractor has Venmo configured %>
                      <% if line_item.payee.is_a?(Contractor) && line_item.payee.venmo_configured? %>
                        <% pay_amount = line_item.amount_cents / 100.0 %>
                        <% pay_note = "#{@course_offering.title} — course payout" %>
                        <a href="<%= line_item.payee.venmo_payment_link(pay_amount, pay_note) %>"
                           class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white bg-blue-500 hover:bg-blue-600 rounded-lg transition-colors"
                           title="Open Venmo to pay <%= line_item.payee_name %>">
                          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M19.5 3c.9 1.5 1.3 3 1.3 5 0 5.5-4.7 12.7-8.5 17H5.2L2.8 3.5l6.3-.6 1.3 10.5c1.2-2 2.7-5.2 2.7-7.4 0-1.8-.3-3-0.8-4L19.5 3z"/>
                          </svg>
                          Pay <%= number_to_currency(pay_amount) %>
                        </a>
                      <% end %>
                      <%= form_with url: manage_course_offering_payout_mark_line_item_paid_path(@course_offering, line_item_id: line_item.id), method: :post, class: "inline-flex items-center gap-2" do |f| %>
                        <% default_method = line_item.payee.is_a?(Contractor) && line_item.payee.venmo_configured? ? "venmo" : nil %>
                        <%= f.select :payment_method,
                          CourseOfferingPayout::PAYMENT_METHODS.map { |m| [m.titleize, m] },
                          { selected: default_method },
                          class: "text-sm border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500" %>
                        <%= render "shared/button", text: "Mark Paid", variant: "secondary", size: "small", type: :submit %>
                      <% end %>
                      <% unless line_item.calculation_details["type"]&.start_with?("contract_") %>
                        <%= form_with url: manage_course_offering_payout_remove_line_item_path(@course_offering, line_item_id: line_item.id), method: :delete, class: "inline" do %>
                          <button type="submit" class="text-gray-400 hover:text-red-500 p-1" title="Remove">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
                            </svg>
                          </button>
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="px-6 py-8 text-center text-gray-500">
            No payments added yet.
          </div>
        <% end %>

        <%# Add manual payment form %>
        <% unless @payout.paid? %>
          <div class="px-6 py-4 border-t border-gray-200 bg-gray-50">
            <%= form_with url: manage_course_offering_payout_add_line_item_path(@course_offering), method: :post, class: "flex items-end gap-3" do |f| %>
              <div class="flex-1">
                <label class="block text-xs font-medium text-gray-600 mb-1">Payee Name</label>
                <%= f.text_field :label, placeholder: "e.g., Instructor name", class: "w-full text-sm border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500" %>
              </div>
              <div class="w-32">
                <label class="block text-xs font-medium text-gray-600 mb-1">Amount</label>
                <div class="relative">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm">$</span>
                  <%= f.text_field :amount, placeholder: "0.00", class: "w-full pl-7 text-sm border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500" %>
                </div>
              </div>
              <%= render "shared/button", text: "Add Payment", variant: "secondary", size: "small", type: :submit %>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="space-y-4">
      <!-- Actions Card -->
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="px-4 py-3 border-b border-gray-200">
          <h3 class="text-sm font-semibold text-gray-900">Actions</h3>
        </div>
        <div class="p-4 space-y-3">
          <% if @has_contract && @payout.can_recalculate? %>
            <%= form_with url: manage_course_offering_payout_recalculate_path(@course_offering), method: :post do %>
              <%= render "shared/button", text: "Recalculate from Contract", variant: "secondary", size: "medium", type: :submit %>
            <% end %>
          <% end %>

          <% if !@payout.paid? %>
            <% if @payout.calculated? && @line_items.any? %>
              <%= form_with url: manage_course_offering_payout_mark_all_paid_path(@course_offering), method: :post, class: "space-y-2" do |f| %>
                <%= f.select :payment_method,
                  CourseOfferingPayout::PAYMENT_METHODS.map { |m| [m.titleize, m] },
                  {},
                  class: "w-full text-sm border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500" %>
                <%= render "shared/button", text: "Mark All Paid", variant: "primary", size: "medium", type: :submit %>
              <% end %>
            <% end %>
          <% else %>
            <div class="text-center py-2">
              <span class="inline-flex items-center gap-1.5 text-green-600 font-medium">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                All Paid
              </span>
              <% if @payout.paid_at %>
                <p class="text-xs text-gray-500 mt-1">Paid on <%= @payout.paid_at.strftime("%b %-d, %Y") %></p>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Revenue Override Card -->
      <% unless @payout.paid? %>
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-3 border-b border-gray-200">
            <h3 class="text-sm font-semibold text-gray-900">Revenue Override</h3>
          </div>
          <div class="p-4">
            <p class="text-xs text-gray-500 mb-3">Override the calculated revenue amount if needed (e.g. for off-platform payments).</p>
            <%= form_with url: manage_course_offering_payout_revenue_override_path(@course_offering), method: :patch, class: "space-y-2" do |f| %>
              <div class="relative">
                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm">$</span>
                <%= f.text_field :total_revenue_override_cents,
                  value: @payout.total_revenue_override_cents ? ("%.2f" % (@payout.total_revenue_override_cents / 100.0)) : "",
                  placeholder: "Leave blank to use calculated",
                  class: "w-full pl-7 text-sm border-gray-300 rounded-lg focus:ring-pink-500 focus:border-pink-500" %>
              </div>
              <%= render "shared/button", text: "Update Override", variant: "secondary", size: "small", type: :submit %>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Details Card -->
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="px-4 py-3 border-b border-gray-200">
          <h3 class="text-sm font-semibold text-gray-900">Details</h3>
        </div>
        <div class="p-4 space-y-2 text-sm text-gray-600">
          <div class="flex justify-between">
            <span>Payout Type</span>
            <span class="font-medium text-gray-900"><%= @has_contract ? "Contract-based" : "Manual" %></span>
          </div>
          <div class="flex justify-between">
            <span>Last Calculated</span>
            <span class="font-medium text-gray-900">
              <%= @payout.calculated_at ? @payout.calculated_at.strftime("%b %-d, %Y %l:%M %p") : "Never" %>
            </span>
          </div>
          <div class="flex justify-between">
            <span>Registrations</span>
            <span class="font-medium text-gray-900"><%= registrations_count %></span>
          </div>
          <% if @course_offering.price_cents > 0 %>
            <div class="flex justify-between">
              <span>Price per Student</span>
              <span class="font-medium text-gray-900"><%= number_to_currency(@course_offering.price_cents / 100.0) %></span>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
