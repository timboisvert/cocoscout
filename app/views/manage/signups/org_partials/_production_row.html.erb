<%#
  Sign-ups Production Row — delegates chrome to shared/_production_row.
  Required: summary (Hash with production sign-up/audition data)

  Panels: Active Sign-up Forms, Auditions status
%>
<%
  production = summary[:production]
  active_forms_count = summary[:active_sign_up_forms_count] || 0
  audition_cycle = summary[:active_audition_cycle]
  audition_timeline_status = audition_cycle&.timeline_status
  audition_requests_count = summary[:audition_requests_count] || 0

  panels = []
  panels << {
    label: "Active Sign-up Forms",
    value: active_forms_count,
    value_class: active_forms_count > 0 ? "text-sm font-medium text-green-600" : "text-sm text-gray-400"
  }

  auditions_panel = { label: "Auditions" }
  if audition_cycle.present?
    case audition_timeline_status
    when :open
      auditions_panel[:value] = "Open"
      auditions_panel[:value_class] = "text-sm font-medium text-green-600"
      if audition_requests_count > 0
        auditions_panel[:sub] = "#{audition_requests_count} pending"
        auditions_panel[:sub_class] = "text-xs text-pink-600"
      end
    when :upcoming
      auditions_panel[:value] = "Upcoming"
      auditions_panel[:value_class] = "text-sm font-medium text-amber-600"
      auditions_panel[:sub] = "Opens #{audition_cycle.opens_at.strftime('%b %-d')}"
    when :closed
      auditions_panel[:value] = "Closed"
      auditions_panel[:value_class] = "text-sm font-medium text-gray-500"
      auditions_panel[:sub] = "Closed #{audition_cycle.closes_at.strftime('%b %-d')}"
      auditions_panel[:sub_class] = "text-xs text-gray-400"
    end
  else
    auditions_panel[:value] = "None"
    auditions_panel[:value_class] = "text-sm text-gray-400"
  end
  panels << auditions_panel
%>

<%= render "shared/production_row",
  production: production,
  link_path: manage_signups_production_path(production),
  info_width: "lg:w-1/2",
  panels: panels %>
