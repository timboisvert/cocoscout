<main class="w-full max-w-7xl mx-auto px-4 sm:px-6 py-8">
  <div class="flex items-baseline justify-between gap-3 flex-wrap mb-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Mics — search &amp; admin</h1>
      <p class="text-sm text-gray-600 mt-1">
        Every mic in the system. Pending work surfaced at the top; full table searchable below.
      </p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "Hubs →", mics_hubs_path, class: "text-sm text-pink-600 font-bold hover:underline" %>
      <%= link_to "Queue →", mics_queue_path, class: "text-sm text-pink-600 font-bold hover:underline" %>
    </div>
  </div>

  <% if flash[:notice] %>
    <div class="mb-4 px-3 py-2 border border-emerald-200 bg-emerald-50 text-emerald-700 text-sm"><%= flash[:notice] %></div>
  <% end %>
  <% if flash[:alert] %>
    <div class="mb-4 px-3 py-2 border border-red-200 bg-red-50 text-red-700 text-sm"><%= flash[:alert] %></div>
  <% end %>

  <%# Pending workload strip — counts per queue type, each clicks
      through to the existing queue page anchored at that section. %>
  <section class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
    <% [
      [ "Pending submissions", @pending_mic_count,        "#submissions" ],
      [ "Pending claims",      @pending_claim_count,      "#claims" ],
      [ "Pending challenges",  @pending_challenge_count,  "#challenges" ],
      [ "Pending suggestions", @pending_suggestion_count, "#suggestions" ]
    ].each do |label, count, anchor| %>
      <%= link_to "#{mics_queue_path}#{anchor}", class: "block bg-white border border-gray-200 hover:border-pink-400 px-4 py-3 transition-colors" do %>
        <div class="text-[10px] uppercase tracking-wider text-gray-500 font-bold"><%= label %></div>
        <div class="text-2xl font-bold <%= count.positive? ? "text-pink-600" : "text-gray-400" %> tabular-nums mt-1">
          <%= count %>
        </div>
      <% end %>
    <% end %>
  </section>

  <%# Search + filter row %>
  <section class="bg-white border border-gray-200 mb-4">
    <%= form_with url: mics_index_path, method: :get, local: true, class: "px-4 sm:px-5 py-4" do %>
      <div class="grid grid-cols-1 sm:grid-cols-12 gap-3 items-end">
        <label class="block text-sm sm:col-span-5">
          <span class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-1">Search</span>
          <input type="search" name="q" value="<%= params[:q] %>"
                 placeholder="Mic name, venue, city, or slug"
                 class="w-full px-3 py-2 text-sm border border-gray-300 focus:border-pink-500 outline-none">
        </label>

        <label class="block text-sm sm:col-span-3">
          <span class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-1">Hub</span>
          <select name="hub_id" class="w-full px-3 py-2 text-sm border border-gray-300 focus:border-pink-500 outline-none bg-white">
            <option value="">All hubs</option>
            <% @hubs.each do |hub| %>
              <option value="<%= hub.id %>" <%= "selected" if params[:hub_id].to_s == hub.id.to_s %>>
                <%= hub.name %>, <%= hub.state %>
              </option>
            <% end %>
          </select>
        </label>

        <label class="block text-sm sm:col-span-2">
          <span class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-1">Status</span>
          <select name="status" class="w-full px-3 py-2 text-sm border border-gray-300 focus:border-pink-500 outline-none bg-white">
            <% [ [ nil, "Any" ], [ "active", "Active" ], [ "pending", "Pending" ], [ "ended", "Ended" ] ].each do |val, label| %>
              <option value="<%= val %>" <%= "selected" if params[:status].to_s == val.to_s %>><%= label %></option>
            <% end %>
          </select>
        </label>

        <label class="block text-sm sm:col-span-2">
          <span class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-1">Claimed?</span>
          <select name="claimed" class="w-full px-3 py-2 text-sm border border-gray-300 focus:border-pink-500 outline-none bg-white">
            <% [ [ nil, "Any" ], [ "yes", "Claimed" ], [ "no", "Unclaimed" ] ].each do |val, label| %>
              <option value="<%= val %>" <%= "selected" if params[:claimed].to_s == val.to_s %>><%= label %></option>
            <% end %>
          </select>
        </label>
      </div>
      <div class="mt-3 flex items-center gap-2">
        <button type="submit" class="cursor-pointer px-4 py-2 bg-pink-500 hover:bg-pink-600 text-white text-sm font-bold">
          Search
        </button>
        <%= link_to "Clear", mics_index_path, class: "text-xs text-gray-500 hover:text-pink-600 underline" %>
        <span class="ml-auto text-xs text-gray-500"><%= pluralize(@total, "mic") %> matched · showing top <%= @mics.size %></span>
      </div>
    <% end %>
  </section>

  <%# Results table %>
  <section class="bg-white border border-gray-200">
    <% if @mics.any? %>
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200 text-left">
          <tr>
            <th class="px-4 py-2 text-xs uppercase tracking-wider text-gray-600 font-bold">Mic</th>
            <th class="px-4 py-2 text-xs uppercase tracking-wider text-gray-600 font-bold">Venue · City</th>
            <th class="px-4 py-2 text-xs uppercase tracking-wider text-gray-600 font-bold">When</th>
            <th class="px-4 py-2 text-xs uppercase tracking-wider text-gray-600 font-bold">Status</th>
            <th class="px-4 py-2 text-xs uppercase tracking-wider text-gray-600 font-bold text-right">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @mics.each do |mic| %>
            <% claimed   = mic.mic_producers.any? %>
            <% pending   = mic.pending %>
            <% status_chip = if pending then [ "Pending", "bg-amber-100 text-amber-700" ]
                              elsif mic.status_ended? then [ "Ended", "bg-gray-100 text-gray-500" ]
                              elsif claimed then [ "Claimed", "bg-emerald-100 text-emerald-700" ]
                              else [ "Unclaimed", "bg-pink-100 text-pink-700" ]
                              end %>
            <tr class="hover:bg-pink-50">
              <td class="px-4 py-2 align-top">
                <%= link_to mic.name, mics_detail_path(mic.slug), class: "font-bold text-gray-900 hover:underline", target: "_blank" %>
                <div class="text-[10px] text-gray-400 font-mono"><%= mic.slug %></div>
              </td>
              <td class="px-4 py-2 align-top text-gray-700">
                <%= mic.venue&.name %>
                <div class="text-xs text-gray-500"><%= mic.venue&.city %>, <%= mic.venue&.state %></div>
              </td>
              <td class="px-4 py-2 align-top text-gray-700 whitespace-nowrap">
                <%= mics_schedule_label(mic) || "—" %>
              </td>
              <td class="px-4 py-2 align-top">
                <span class="inline-flex items-center text-[10px] uppercase tracking-wider px-2 py-0.5 font-bold <%= status_chip[1] %>">
                  <%= status_chip[0] %>
                </span>
              </td>
              <td class="px-4 py-2 align-top text-right whitespace-nowrap">
                <%= link_to "Edit →", mics_producer_mic_path(mic.slug),
                      class: "inline-block px-2 py-1 text-xs bg-gray-900 hover:bg-black text-white font-bold" %>
                <%= button_to "Delete", mics_producer_destroy_mic_path(mic.slug), method: :delete,
                      data: { turbo_confirm: "Permanently delete \"#{mic.name}\"?" },
                      class: "cursor-pointer ml-1 inline-block px-2 py-1 text-xs bg-red-600 hover:bg-red-700 text-white font-bold align-top",
                      form_class: "inline-block" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="px-4 py-10 text-center text-sm text-gray-500">
        <% if params[:q].present? || params[:hub_id].present? || params[:status].present? || params[:claimed].present? %>
          No mics match those filters.
          <%= link_to "Clear search", mics_index_path, class: "text-pink-600 underline" %>.
        <% else %>
          No mics in the system yet.
        <% end %>
      </p>
    <% end %>
  </section>
</main>
