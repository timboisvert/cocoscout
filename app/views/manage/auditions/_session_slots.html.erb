<%#
  Assigned auditionees for one session + a trailing "Add" slot.
  Locals: session, production, audition_cycle
  Re-rendered server-side by add_to_session / remove_from_session and swapped in
  by the audition-assign Stimulus controller.
%>
<div class="flex flex-wrap gap-2 p-3">
  <% session.auditions.each do |audition| %>
    <% ent = audition.auditionable %>
    <% next unless ent %>
    <%
      headshot = safe_headshot_url(ent, variant: :thumb)
      status_ring = case audition.response_status
                    when :accepted then "bg-green-500"
                    when :declined then "bg-red-500"
                    else "bg-yellow-400"
                    end
      profile_path = audition.audition_request_id ? manage_signups_auditions_cycle_request_path(production, audition_cycle, audition.audition_request_id) : nil
    %>
    <div class="relative group w-24 flex flex-col items-center text-center p-2 rounded-lg border border-gray-200 hover:border-gray-300 bg-white">
      <%# Remove on hover %>
      <button type="button"
              data-audition-id="<%= audition.id %>"
              data-session-id="<%= session.id %>"
              data-request-id="<%= audition.audition_request_id %>"
              title="Remove from this session"
              class="absolute -top-1.5 -right-1.5 z-10 w-5 h-5 rounded-full bg-white border border-gray-300 text-gray-400 hover:text-red-600 hover:border-red-300 shadow-sm flex items-center justify-center opacity-0 group-hover:opacity-100 transition cursor-pointer">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3 h-3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
      </button>

      <div class="relative">
        <% if headshot %>
          <%= image_tag headshot, alt: ent.name, class: "w-12 h-12 rounded-lg object-cover" %>
        <% else %>
          <div class="w-12 h-12 rounded-lg bg-gray-100 flex items-center justify-center text-gray-700 font-bold text-sm">
            <%= ent.respond_to?(:initials) ? ent.initials : ent.name.to_s[0, 2].upcase %>
          </div>
        <% end %>
        <span class="absolute -top-0.5 -right-0.5 w-2.5 h-2.5 rounded-full ring-2 ring-white <%= status_ring %>"></span>
      </div>

      <% if profile_path %>
        <%= link_to ent.name.to_s.truncate(18), profile_path,
              class: "mt-1 text-[11px] font-medium text-gray-900 leading-tight hover:text-pink-600 truncate w-full" %>
      <% else %>
        <span class="mt-1 text-[11px] font-medium text-gray-900 leading-tight truncate w-full"><%= ent.name.to_s.truncate(18) %></span>
      <% end %>
    </div>
  <% end %>

  <%# Add slot — always present, opens the assign modal for this session. %>
  <button type="button"
          data-add-slot="true"
          data-session-id="<%= session.id %>"
          data-session-label="<%= session.start_at.strftime("%A, %b %-d at %-l:%M %p") %>"
          class="w-24 h-[88px] flex flex-col items-center justify-center gap-1 rounded-lg border border-dashed border-gray-300 text-gray-400 hover:border-pink-400 hover:text-pink-600 hover:bg-pink-50 transition cursor-pointer">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
    <span class="text-[11px] font-medium">Add</span>
  </button>
</div>
