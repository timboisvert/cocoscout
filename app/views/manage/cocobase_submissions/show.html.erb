<% content_for :title, "Submission - #{@submission.submittable.name}" %>

<%
  entity = @submission.submittable
  headshot_variant = entity.safe_headshot_variant(:thumb)
%>

<div class="w-full mb-10">
  <%= render partial: "shared/notice", locals: { notice: notice } %>
  <%= render partial: "shared/top_menu", locals: {
    breadcrumbs: [
      ["Shows & Events", manage_shows_path],
      [@production.name, manage_production_shows_path(@production)],
      [@show.event_type.titleize, manage_production_show_path(@production, @show)],
      ["Cocobase", manage_show_cocobase_path(@production, @show)],
      ["Submissions", manage_show_cocobase_submissions_path(@production, @show)]
    ],
    text: entity.name,
    links: []
  } %>

  <div class="max-w-3xl mx-auto space-y-6">
    <!-- Person Header -->
    <div class="bg-white border border-gray-200 rounded-lg shadow-sm p-6">
      <div class="flex items-center gap-4">
        <% if headshot_variant %>
          <%= image_tag headshot_variant, alt: entity.name, class: "w-14 h-14 rounded-lg object-cover" %>
        <% else %>
          <div class="w-14 h-14 rounded-lg bg-gray-200 flex items-center justify-center text-gray-600 font-bold text-lg">
            <%= entity.initials %>
          </div>
        <% end %>
        <div class="flex-1">
          <h2 class="text-lg font-semibold text-gray-900"><%= entity.name %></h2>
          <div class="flex items-center gap-2 mt-1">
            <% case @submission.status %>
            <% when "submitted" %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Submitted</span>
              <% if @submission.submitted_at.present? %>
                <span class="text-xs text-gray-500"><%= @submission.submitted_at.strftime("%b %-d, %Y at %l:%M %p") %></span>
              <% end %>
            <% when "in_progress" %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">In Progress</span>
            <% else %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">Pending</span>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <!-- Answers -->
    <div class="bg-white border border-gray-200 rounded-lg shadow-sm">
      <% if @fields.any? %>
        <div class="divide-y divide-gray-200">
          <% @fields.each do |field| %>
            <% answer = @answers_by_field[field.id] %>
            <div class="p-4">
              <div class="flex items-center gap-2 mb-1">
                <p class="text-sm font-medium text-gray-700"><%= field.label %></p>
                <% if field.required? %>
                  <span class="text-pink-500 text-xs">Required</span>
                <% end %>
              </div>
              <% if field.description.present? %>
                <p class="text-xs text-gray-400 mb-2"><%= field.description %></p>
              <% end %>

              <% if answer.present? %>
                <% case field.field_type %>
                <% when "text", "textarea" %>
                  <p class="text-sm text-gray-900 whitespace-pre-wrap"><%= answer.value %></p>

                <% when "url" %>
                  <% if answer.value.present? %>
                    <a href="<%= answer.value %>" target="_blank" rel="noopener noreferrer"
                       class="text-sm text-pink-600 hover:text-pink-700 underline break-all">
                      <%= answer.value %>
                    </a>
                    <% if answer.youtube_url? %>
                      <div class="mt-2 rounded-lg overflow-hidden border border-gray-200">
                        <iframe width="100%" height="200" src="https://www.youtube.com/embed/<%= answer.youtube_embed_id %>"
                          frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                          allowfullscreen class="rounded-lg"></iframe>
                      </div>
                    <% elsif answer.spotify_url? %>
                      <div class="mt-2 rounded-lg overflow-hidden border border-gray-200">
                        <iframe src="https://open.spotify.com/embed/<%= answer.spotify_embed_uri %>" width="100%" height="152"
                          frameborder="0" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                          loading="lazy" class="rounded-lg"></iframe>
                      </div>
                    <% end %>
                  <% end %>

                <% when "file_upload" %>
                  <% if answer.file.attached? %>
                    <div class="flex items-center gap-2">
                      <% if answer.file.content_type&.start_with?("image/") %>
                        <%= image_tag answer.file, class: "w-32 h-32 object-cover rounded-lg" %>
                      <% else %>
                        <a href="<%= url_for(answer.file) %>" target="_blank" rel="noopener noreferrer"
                           class="inline-flex items-center gap-1 text-sm text-pink-600 hover:text-pink-700">
                          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                          </svg>
                          <%= answer.file.filename %>
                        </a>
                      <% end %>
                    </div>
                  <% else %>
                    <p class="text-sm text-gray-400 italic">No file uploaded</p>
                  <% end %>

                <% when "yesno" %>
                  <% if answer.value == "yes" %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-700">Yes</span>
                  <% elsif answer.value == "no" %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-700">No</span>
                  <% else %>
                    <p class="text-sm text-gray-400 italic">Not answered</p>
                  <% end %>
                <% end %>
              <% else %>
                <p class="text-sm text-gray-400 italic">Not answered</p>
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-8 text-gray-500">
          <p class="text-sm">No fields defined for this Cocobase.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
