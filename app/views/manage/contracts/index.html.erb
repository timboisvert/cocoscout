<% content_for :title, "Contracts" %>

<%
  contracts_description = <<~HTML
    <p>
      Manage contracts for third-party productions, venue rentals, and external bookings.
      Track payments, services, and space reservations all in one place.
    </p>
  HTML

  contracts_actions = [
    { icon: "plus", text: "New Contract", description: "Create a new contract", path: manage_new_contract_wizard_path },
    { icon: "users", text: "Contractors", description: "Manage contractor relationships", path: manage_contractors_path },
    { icon: "archive", text: "Past Contracts", description: "View completed contracts", path: completed_manage_contracts_path }
  ]
%>

<div class="w-full mb-10">
  <%= render partial: "shared/notice", locals: { notice: notice, alert: alert } %>

  <%= render "shared/module_header",
    title: "Contracts",
    description: contracts_description,
    actions: contracts_actions
  %>

  <div class="border-t border-gray-200 pt-4 mt-2">
  <%# Contract Stats %>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
    <div class="bg-white rounded-lg border border-gray-200 p-5">
      <div class="text-sm text-gray-500 mb-1">Received This Year</div>
      <div class="text-2xl font-semibold text-green-600"><%= number_to_currency(@money_received) %></div>
      <div class="text-xs text-gray-500">paid incoming payments</div>
    </div>

    <div class="bg-white rounded-lg border border-gray-200 p-5">
      <div class="text-sm text-gray-500 mb-1">Remaining to Receive</div>
      <div class="text-2xl font-semibold text-pink-600"><%= number_to_currency(@money_remaining) %></div>
      <div class="text-xs text-gray-500">pending incoming payments</div>
    </div>

    <div class="bg-white rounded-lg border border-gray-200 p-5">
      <div class="text-sm text-gray-500 mb-1"><%= Date.current.year %> Contract Value</div>
      <div class="text-2xl font-semibold text-gray-900"><%= number_to_currency(@total_contract_value) %></div>
      <% if @has_projections %>
        <div class="text-xs text-pink-600 mt-1">
          + <%= number_to_currency(@projected_revenue_low, precision: 0) %> - <%= number_to_currency(@projected_revenue_high, precision: 0) %> projected
        </div>
      <% else %>
        <div class="text-xs text-gray-500">contracts starting this year</div>
      <% end %>
    </div>
  </div>

  <%# Persistent warning for any overdue payments (they may sit in a past month) %>
  <% if @late_payments_count > 0 %>
    <div class="flex items-center gap-2 px-4 py-3 mb-4 rounded-lg bg-red-50 border border-red-200 text-sm text-red-800">
      <%= icon("alert-circle", class: "w-4 h-4 flex-shrink-0") %>
      <span>
        <strong><%= pluralize(@late_payments_count, "payment") %></strong> overdue. Late payments are marked in red on the calendar — use the month arrows to find them.
      </span>
    </div>
  <% end %>

  <%# Unified calendar: payments + shows + rentals, month by month %>
  <% calendar_legend = capture do %>
    <span class="inline-flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-green-300"></span> Payment in</span>
    <span class="inline-flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-red-300"></span> Payment out</span>
    <span class="inline-flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-pink-300"></span> Show</span>
    <span class="inline-flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-blue-300"></span> Rental</span>
    <span class="inline-flex items-center gap-1"><span class="w-2.5 h-2.5 rounded-sm bg-red-500"></span> Late</span>
  <% end %>
  <%= render "shared/month_calendar",
    current_month: @current_month,
    prev_month: @prev_month,
    next_month: @next_month,
    items_by_date: @calendar_items_by_date,
    item_partial: "manage/contracts/calendar_item",
    month_link: ->(m) { manage_contracts_path(month: m.strftime("%Y-%m-01")) },
    today_link: manage_contracts_path,
    legend: calendar_legend %>

  <%# Active contracts list, below the upcoming-stuff calendar %>
  <% if @sorted_contracts.any? %>
    <div data-controller="tabs">
      <nav class="flex space-x-2 border-b border-gray-200 mb-4">
        <button type="button" data-tabs-target="tab" data-index="0" data-action="tabs#select" class="px-4 py-2 text-sm font-medium bg-white border-b-2 text-pink-600 cursor-pointer whitespace-nowrap">
          <%= icon("list", class: "w-4 h-4 inline mr-1") %>
          Active Contracts
        </button>
        <button type="button" data-tabs-target="tab" data-index="1" data-action="tabs#select" class="px-4 py-2 text-sm font-medium bg-gray-50 border-b-2 text-gray-500 cursor-pointer whitespace-nowrap">
          <%= icon("calendar", class: "w-4 h-4 inline mr-1") %>
          Timeline
        </button>
      </nav>

      <%# Active Contracts Tab %>
      <div data-tabs-target="panel">
        <div class="space-y-2">
          <% @sorted_contracts.each do |contract| %>
            <%= render "contract_list_row", contract: contract %>
          <% end %>
        </div>
      </div>

      <%# Timeline Tab %>
      <div data-tabs-target="panel" class="hidden">
        <%= render "timeline", contracts: @sorted_contracts %>
      </div>
    </div>
  <% end %>

  <%# Empty state %>
  <% if @contracts.empty? %>
    <div class="bg-gray-50 rounded-lg border border-dashed border-gray-300 p-12 text-center">
      <%= icon("file-text", class: "w-12 h-12 text-gray-400 mx-auto mb-4") %>
      <h3 class="text-lg font-medium text-gray-900 mb-2">No contracts yet</h3>
      <p class="text-gray-600 mb-4">
        Create a contract when an external group wants to rent your space or perform at your venue.
      </p>
      <%= render "shared/button", text: "New Contract", variant: "primary", icon: "plus", path: manage_new_contract_wizard_path %>
    </div>
  <% end %>
  </div>
</div>
