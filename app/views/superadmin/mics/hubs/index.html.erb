<main class="w-full max-w-6xl mx-auto px-4 sm:px-6 py-8">
  <h1 class="text-2xl font-bold text-gray-900 mb-2">City hubs</h1>
  <p class="text-sm text-gray-600 mb-6">
    Promote cities, archive them, and appoint captains who can manage every mic in their city.
  </p>

  <% if flash[:notice] %>
    <div class="mb-4 px-3 py-2 border border-emerald-200 bg-emerald-50 text-emerald-700 text-sm"><%= flash[:notice] %></div>
  <% end %>
  <% if flash[:alert] %>
    <div class="mb-4 px-3 py-2 border border-red-200 bg-red-50 text-red-700 text-sm"><%= flash[:alert] %></div>
  <% end %>

  <section class="bg-white border border-gray-200 mb-6">
    <header class="px-4 sm:px-5 py-3 border-b border-gray-100 bg-gray-50">
      <h2 class="text-xs uppercase tracking-wider text-gray-600 font-bold">Add a new hub</h2>
    </header>
    <div class="px-4 sm:px-5 py-4">
      <%= form_with url: create_mics_hub_path, method: :post,
            data: { controller: "slug-generator" },
            class: "grid grid-cols-1 sm:grid-cols-5 gap-3 items-end" do %>
        <label class="block text-sm sm:col-span-2">
          <span class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-1">Name</span>
          <input type="text" name="city_hub[name]" required placeholder="Indianapolis"
                 data-slug-generator-target="source"
                 data-action="input->slug-generator#regenerate"
                 class="w-full px-3 py-2 text-sm border border-gray-300 focus:border-pink-500 outline-none">
        </label>
        <%= render "shared/us_state_select",
              name: "city_hub[state]", required: true, value: nil,
              data: { "slug-generator-target": "source",
                      action: "change->slug-generator#regenerate" } %>
        <label class="block text-sm">
          <span class="block text-xs uppercase tracking-wider text-gray-500 font-bold mb-1">Slug</span>
          <input type="text" name="city_hub[slug]" required placeholder="indianapolis-in"
                 data-slug-generator-target="slug"
                 data-action="input->slug-generator#markEdited"
                 class="w-full px-3 py-2 text-sm border border-gray-300 focus:border-pink-500 outline-none">
        </label>
        <button type="submit"
                class="cursor-pointer px-4 py-2 bg-pink-500 hover:bg-pink-600 text-white text-sm font-bold">
          Create hub
        </button>
      <% end %>
    </div>
  </section>

  <section class="bg-white border border-gray-200">
    <header class="px-4 sm:px-5 py-3 border-b border-gray-100 bg-gray-50">
      <h2 class="text-xs uppercase tracking-wider text-gray-600 font-bold">All hubs</h2>
    </header>
    <% if @hubs.any? %>
      <ul class="divide-y divide-gray-100">
        <% @hubs.each do |hub| %>
          <% mic_count = hub.mics.count %>
          <% editor_count = hub.memberships.where(role: CityHubMembership.roles[:editor]).count %>
          <li class="px-4 sm:px-5 py-3 flex items-baseline gap-3 hover:bg-pink-50">
            <div class="flex-1 min-w-0">
              <%= link_to mics_hub_path(hub.slug), class: "font-bold text-gray-900 hover:underline" do %>
                <%= hub.name %>, <%= hub.state %>
              <% end %>
              <div class="text-xs text-gray-500">
                <%= pluralize(mic_count, "mic") %> · <%= pluralize(editor_count, "captain") %> · slug <code class="bg-gray-100 px-1"><%= hub.slug %></code>
              </div>
            </div>
            <span class="inline-flex items-center text-[10px] uppercase tracking-wider px-2 py-0.5 font-bold
                <%= { "active" => "bg-emerald-100 text-emerald-700", "draft" => "bg-amber-100 text-amber-700", "archived" => "bg-gray-200 text-gray-600" }[hub.status] %>">
              <%= hub.status %>
            </span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="px-4 sm:px-5 py-6 text-sm text-gray-500">No hubs yet.</p>
    <% end %>
  </section>
</main>
