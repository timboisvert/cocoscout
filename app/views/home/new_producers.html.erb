                    </div>
                    <div class="carousel-slide absolute inset-0 hidden" data-slide="1">
                      <%= image_tag "screenshots/auditions/2-submissions-list.png", alt: "Audition Submissions List", class: "w-full" %>
                    </div>
                    <div class="carousel-slide absolute inset-0 hidden" data-slide="2">
                      <%= image_tag "screenshots/auditions/3-submission-detail.png", alt: "Submission Detail View", class: "w-full" %>
                    </div>
                  </div>
                  <!-- Navigation Arrows -->
                  <button type="button" class="carousel-prev absolute left-3 top-1/2 -translate-y-1/2 w-10 h-10 rounded-full bg-pink-500 text-white shadow-lg flex items-center justify-center hover:bg-pink-600 transition-colors focus:outline-none focus:ring-2 focus:ring-pink-500 focus:ring-offset-2">
