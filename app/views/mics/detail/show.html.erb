<%
  venue    = @mic.venue
  city     = venue.city
  state    = venue.state
  slug     = "#{city.parameterize}-#{state.downcase}"
  day      = mics_recurrence_day_label(@mic)
  title    = [ @mic.name, day && "#{day} Open Mic", venue.name && "at #{venue.name}", venue.neighborhood_city ].compact.join(" — ")
  description = [
    "#{@mic.name} is a #{mics_format_label(@mic.format).downcase} open mic at #{venue.name} in #{venue.neighborhood_city}.",
    @mic.blurb.presence
  ].compact.join(" ")
  mics_seo title: title, description: description

  breadcrumbs = [
    [ "Find a Mic", mics_home_url ],
    [ "#{city}, #{state}", mics_city_url(slug) ],
    [ @mic.name, mics_detail_url(@mic.slug) ]
  ]

  status_badge =
    case @mic.status
    when "dormant" then [ "Dormant",  "bg-amber-50 text-amber-700 border-amber-200" ]
    when "ended"   then [ "Ended",    "bg-gray-100 text-gray-600  border-gray-200" ]
    else nil
    end

  verified_text =
    if @mic.last_verified_at.present?
      days = ((Time.current - @mic.last_verified_at) / 1.day).floor
      days.zero? ? "Verified today" : "Verified #{pluralize(days, "day")} ago"
    end
%>
<%= render "mics/header" %>

<%# Big pink masthead. %>
<%
  claim_visible = !@mic.claimed?
  edit_visible  = @mic.manageable_by?(Current.user)
  has_actions   = claim_visible || edit_visible
  masthead_pad  = has_actions ? "pt-6 pb-6 sm:pt-10 sm:pb-10" : "pt-6 pb-3 sm:pt-10 sm:pb-5"
%>
<section class="w-full bg-pink-500 text-white">
  <div class="w-full px-4 sm:px-8 <%= masthead_pad %>">
    <nav class="text-xs text-pink-100 mb-3">
      <%= link_to "Find a Mic", mics_home_path, class: "hover:text-white underline-offset-4 hover:underline" %>
      <span class="px-1">›</span>
      <%= link_to "#{city}, #{state}", mics_city_path(slug), class: "hover:text-white underline-offset-4 hover:underline" %>
    </nav>

    <%# Title row: name on the left, Favorite card on the right (stacks below on mobile). %>
    <div class="flex flex-col md:flex-row md:items-start md:justify-between md:gap-6">
      <div class="flex-1 min-w-0">
        <h1 class="coustard-regular text-4xl sm:text-6xl leading-[1.05]"><%= @mic.name %></h1>
        <p class="mt-3 text-pink-100 text-sm sm:text-base">
          <%= day %> · <%= @mic.starts_local_time&.strftime("%-l:%M %p") %> · <%= venue.name %> · <%= venue.neighborhood_city %>
        </p>
      </div>

      <% if Current.user %>
        <% favorited = MicFavorite.where(user_id: Current.user.id, mic_id: @mic.id).exists? %>
        <div class="mt-4 md:mt-0 md:shrink-0">
          <%= button_to mics_favorite_path(@mic.slug), method: :post,
                class: "cursor-pointer w-full md:w-auto flex items-center justify-center gap-2 px-5 py-3 text-base font-bold transition-colors duration-100 rounded #{favorited ? "bg-gray-900 text-white hover:bg-black active:bg-gray-700" : "bg-white text-pink-700 hover:bg-pink-100 active:bg-pink-200"}" do %>
            <span class="text-2xl leading-none"><%= favorited ? "★" : "☆" %></span>
            <span><%= favorited ? "Favorited" : "Favorite this mic" %></span>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="mt-4 flex items-center gap-2 flex-wrap">
      <% if @mic.paused? %>
        <span class="inline-flex items-center text-[11px] uppercase tracking-wider px-2 py-1 bg-amber-500 text-white font-bold rounded">
          ⏸ Paused<% if @mic.canceled_until.present? && @mic.canceled_until >= Date.current %> · back <%= @mic.canceled_until.strftime("%b %-d") %><% end %>
        </span>
      <% end %>
      <% if @mic.powered_by_cocoscout? %>
        <span class="inline-flex items-center text-[11px] uppercase tracking-wider px-2 py-1 bg-gray-900 text-white font-bold rounded">
          Powered by CocoScout
        </span>
      <% end %>
      <% if status_badge %>
        <span class="inline-flex items-center text-[11px] uppercase tracking-wider px-2 py-1 border bg-white rounded <%= status_badge[1] %>">
          <%= status_badge[0] %>
        </span>
      <% end %>
      <% if verified_text %>
        <span class="text-xs text-pink-100"><%= verified_text %></span>
        <%# Visual separator so the verified line doesn't bump into the suggest-edit link. %>
        <span class="text-pink-200" aria-hidden="true">·</span>
      <% end %>
      <%# Small inline text link — opens the suggest/report modal. Sized
          to be unobtrusive (it's lower-priority than Claim/Edit) but
          present everywhere on the page so anyone can speak up. %>
      <button type="button"
              onclick="document.getElementById('modal-suggest-edit').showModal()"
              class="cursor-pointer text-xs text-pink-100 hover:text-white underline-offset-4 hover:underline">
        Suggest an edit / report an inaccuracy
      </button>
    </div>

    <%# Primary actions — only the things people who run the mic or run
        the site need from up here. Suggest-an-edit + dispute-owner live
        in the footer where the "community" copy already explains them.
        Skip the whole row (and its `mt-5` spacer) when there's nothing
        to show; the masthead's bottom padding also shrinks (see top). %>
    <% if has_actions %>
      <div class="mt-5 flex flex-wrap gap-2 text-sm">
        <% if claim_visible %>
          <%= link_to "Claim this mic →", mics_claim_path(@mic.slug),
                class: "px-3 py-1.5 bg-gray-900 text-white font-bold hover:bg-black rounded" %>
        <% end %>
        <% if edit_visible %>
          <%= link_to "Edit", mics_owner_mic_path(@mic.slug),
                class: "px-3 py-1.5 bg-gray-900 text-white font-bold hover:bg-black rounded" %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>

<%# Next-occurrence status banner — surfaces a posted status for the
    upcoming date right under the masthead. Banner appears whenever
    either (a) the status is non-default (cancelled / extra_spots), OR
    (b) the producer left a note (even if the status itself is the
    default "running_as_planned" — they wrote a heads-up for visitors).
    Falls back to canned copy when no note was supplied. %>
<%
  next_occ_with_status = @next_occurrences.find do |o|
    s = o[:mic_status]
    note_present = o[:mic_status_note].to_s.strip.present?
    # Non-default status always shows; default-status shows only when
    # accompanied by a note.
    (s.present? && s != "running_as_planned") || note_present
  end
%>
<% if next_occ_with_status %>
  <%
    status_kind = next_occ_with_status[:mic_status].to_s
    note        = next_occ_with_status[:mic_status_note].to_s.strip
    starts_at   = next_occ_with_status[:starts_at]
    is_today    = starts_at.to_date == Date.current
    date_label  = is_today ? "Tonight" : starts_at.strftime("%A %b %-d")
    banner = case status_kind
    when "cancelled" then {
      bg:    "bg-red-50 border-red-300",
      head:  "text-red-800",
      body:  "text-red-900",
      label: "Cancelled",
      desc:  "#{date_label} is off."
    }
    when "extra_spots" then {
      bg:    "bg-emerald-50 border-emerald-300",
      head:  "text-emerald-800",
      body:  "text-emerald-900",
      label: "Extra spots",
      desc:  "#{date_label}: extra spots are open."
    }
    else {
      bg:    "bg-pink-50 border-pink-300",
      head:  "text-pink-800",
      body:  "text-pink-900",
      label: "From the host",
      desc:  date_label
    }
    end
  %>
  <section class="w-full px-4 sm:px-8 py-3 border-b border-gray-100">
    <div class="<%= banner[:bg] %> border rounded p-4 sm:p-5">
      <div class="flex items-baseline justify-between gap-3 flex-wrap mb-1">
        <span class="text-xs uppercase tracking-wider <%= banner[:head] %> font-bold"><%= banner[:label] %></span>
        <span class="text-xs <%= banner[:head] %> tabular-nums">
          <%= starts_at.strftime("%a %b %-d · %-l:%M %p") %>
        </span>
      </div>
      <p class="<%= banner[:body] %> text-sm sm:text-base whitespace-pre-line">
        <%= note.presence || banner[:desc] %>
      </p>
    </div>
  </section>
<% end %>

<main class="w-full bg-white">
  <%# Two stacked rows on a pink-50 background:
      Row 1: Format · Start time · (Spot length) · (Cap) · (Age)
      Row 2: everything sign-up related (type · opens · cost when paid) %>
  <%
    basic_cells = []
    basic_cells << [ "Format", mics_format_label(@mic.format) ]
    basic_cells << [ "Start time", @mic.starts_local_time.strftime("%-l:%M %p") ] if @mic.starts_local_time.present?
    basic_cells << [ "Spot length", mics_spot_length_label(@mic.spot_length_minutes) ] if @mic.spot_length_minutes.present?
    basic_cells << [ "Max performers", @mic.signup_cap.to_s ]                    if @mic.signup_cap.present?
    basic_cells << [ "Age", "#{@mic.min_age}+" ]                                  if @mic.min_age.present?

    signup_cells = []
    if @mic.signup_method.present?
      value = mics_signup_method_label(@mic.signup_method)
      value += " · Bucket draw" if @mic.bucket_draw
      signup_cells << [ "Sign-up type", value ]
    elsif @mic.bucket_draw
      signup_cells << [ "Sign-up type", "Bucket draw" ]
    end

    # How-to-sign-up and Sign-up notes share the structured grid with
    # Sign-up type / opens / cost. Order: type → how to sign up →
    # opens → notes → cost. Each cell renders only when present;
    # nothing forces empty slots.
    if @signup_info && @signup_info[:channel_text].present?
      signup_cells << [ "How to sign up", @signup_info[:channel_text] ]
    end
    signup_cells << [ "Sign-up opens", mics_signup_opens_label(@mic.signup_opens_at_text) ] if @mic.signup_opens_at_text.present?
    signup_cells << [ "Sign-up notes", @mic.signup_notes ] if @mic.signup_notes.present?
    # Cost shown only when there's an actual price; "free" is assumed default.
    signup_cells << [ "Cost", mics_cost_label(@mic) ]                            if mics_cost_label(@mic).present? && @mic.cost != "free"
  %>
  <section class="border-b border-pink-100 bg-pink-50">
    <div class="w-full px-4 sm:px-8 py-5 space-y-4">
      <%# Row 1: basic info — always 4 cells, empties hold their space. %>
      <dl class="grid grid-cols-2 lg:grid-cols-4 gap-4 text-sm">
        <% 4.times do |i|
             cell = basic_cells[i] %>
          <div>
            <% if cell %>
              <dt class="text-[10px] uppercase tracking-wider text-pink-700 font-bold"><%= cell[0] %></dt>
              <dd class="mt-0.5 coustard-regular text-lg text-gray-900"><%= cell[1] %></dd>
            <% end %>
          </div>
        <% end %>
      </dl>

      <% if signup_cells.any? %>
        <%# Row 2: sign-up info — same 4-cell grid; renders every cell
            present so How to sign up / Notes appear alongside the
            structured fields. Wraps to a second row above 4 cells. %>
        <dl class="grid grid-cols-2 lg:grid-cols-4 gap-4 text-sm pt-3 border-t border-pink-200">
          <% signup_cells.each do |cell| %>
            <div>
              <dt class="text-[10px] uppercase tracking-wider text-pink-700 font-bold"><%= cell[0] %></dt>
              <dd class="mt-0.5 coustard-regular text-lg text-gray-900 whitespace-pre-line"><%= cell[1] %></dd>
            </div>
          <% end %>
        </dl>
      <% end %>

      <%# Sign-up CTA — only the actual button case lives below the grid;
          the free-text "How to sign up" channel is now one of the cells
          above, so we no longer render it twice. %>
      <% if @signup_info && @signup_info[:url].present? %>
        <div class="pt-1">
          <%= link_to @signup_info[:url], target: "_blank", rel: "noopener",
                class: "cursor-pointer inline-flex items-center gap-2 px-5 py-3 bg-pink-500 hover:bg-pink-600 active:bg-pink-700 text-white font-bold transition-colors duration-100 rounded" do %>
            Sign up
            <span aria-hidden="true">→</span>
            <% if @signup_info[:powered_by_cocoscout] %>
              <span class="text-[10px] uppercase tracking-wider opacity-80 ml-1">on CocoScout</span>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>

  <% if @mic.blurb.present? %>
    <section class="border-b border-gray-100">
      <div class="w-full px-4 sm:px-8 py-6 max-w-3xl">
        <div class="text-base text-gray-700 whitespace-pre-line"><%= @mic.blurb %></div>
      </div>
    </section>
  <% end %>

  <% announcements = @mic.mic_announcements.recent(5).to_a %>
  <% if announcements.any? %>
    <section class="border-b border-gray-100">
      <div class="w-full px-4 sm:px-8 py-6">
        <h2 class="text-[10px] uppercase tracking-wider text-gray-500 font-bold mb-3">Latest News</h2>
        <ul class="space-y-3 max-w-3xl">
          <% announcements.each do |a| %>
            <li class="border-l-4 border-pink-500 pl-4 py-1">
              <div class="text-xs uppercase tracking-wider text-gray-500 font-bold"><%= a.posted_at.strftime("%a %b %-d, %-l:%M%p") %></div>
              <% if a.title.present? %>
                <div class="coustard-regular text-lg text-gray-900 mt-0.5"><%= a.title %></div>
              <% end %>
              <div class="text-sm text-gray-700 mt-1 whitespace-pre-line"><%= a.body %></div>
            </li>
          <% end %>
        </ul>
      </div>
    </section>
  <% end %>

  <%# Socials — Instagram, X, TikTok, Website. %>
  <% socials = @mic.mic_links.where(link_type: MicLink.link_types.values).ordered.to_a %>
  <% if socials.any? %>
    <section class="border-b border-gray-100">
      <div class="w-full px-4 sm:px-8 py-5">
        <h2 class="text-[10px] uppercase tracking-wider text-gray-500 font-bold mb-3">Socials</h2>
        <div class="flex flex-wrap gap-2">
          <% socials.each do |link| %>
            <% icon = case link.link_type
              when "instagram" then "📷"
              when "tiktok"    then "♪"
              when "x_twitter" then "𝕏"
              when "website"   then "🌐"
              else "↗"
              end %>
            <% display = link.label.presence || case link.link_type
              when "x_twitter" then "X / Twitter"
              else link.link_type.humanize
              end %>
            <a href="<%= link.url %>" target="_blank" rel="noopener"
               class="cursor-pointer inline-flex items-center gap-1.5 px-3 py-1.5 bg-white border border-pink-200 hover:bg-pink-50 hover:border-pink-300 text-sm text-gray-800 transition-colors duration-100 rounded">
              <span class="text-base leading-none"><%= icon %></span>
              <span class="font-bold"><%= display %></span>
            </a>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>

<%# Sign-up channel + bucket draw + opens-at are already surfaced in the fact strip above.
    The CTA button now lives in the masthead button row when there's a URL. %>

  <%# When a mic is paused, render the hiatus card front-and-center
      instead of the normal upcoming calendar. The schedule is still
      shown above (so people understand the cadence), but the calendar
      is replaced with a clear "this is paused — here's why" message. %>
  <% if @mic.paused? %>
    <section class="border-b border-gray-100">
      <div class="w-full px-4 sm:px-8 py-6">
        <% will_resume = @mic.canceled_until.present? && @mic.canceled_until >= Date.current %>
        <div class="rounded border border-amber-300 bg-amber-50 p-5 sm:p-6">
          <div class="flex items-baseline justify-between gap-3 flex-wrap mb-2">
            <div class="text-xs uppercase tracking-wider text-amber-800 font-bold">
              ⏸ This mic is paused
            </div>
            <% if will_resume %>
              <div class="text-xs uppercase tracking-wider text-emerald-700 font-bold">
                Back on <%= @mic.canceled_until.strftime("%a %b %-d") %>
              </div>
            <% else %>
              <div class="text-xs uppercase tracking-wider text-amber-700 font-bold">On hiatus</div>
            <% end %>
          </div>
          <% if @mic.pause_note.present? %>
            <p class="text-base sm:text-lg text-gray-900 whitespace-pre-line"><%= @mic.pause_note %></p>
          <% else %>
            <p class="text-base sm:text-lg text-gray-900">
              <% if will_resume %>
                The regular schedule picks back up on <%= @mic.canceled_until.strftime("%A, %B %-d") %>.
              <% else %>
                The owner hasn't set a return date. Check back, or favorite the mic so we can let you know when it comes back.
              <% end %>
            </p>
          <% end %>
          <% if Current.user %>
            <% favorited = MicFavorite.where(user_id: Current.user.id, mic_id: @mic.id).exists? %>
            <% unless favorited %>
              <p class="mt-3 text-xs text-amber-800">Hit the ★ above to favorite this mic — it'll stay in your "My Mics" while it's paused.</p>
            <% end %>
          <% end %>
        </div>
        <% if will_resume && @next_occurrences.any? %>
          <%# Still show upcoming dates AFTER the resume date so favoriters
              know the cadence going forward. Use the existing partial. %>
          <div class="mt-6">
            <%= render "mics/detail/upcoming", mic: @mic,
                  next_occurrences: @next_occurrences, upcoming_view: @upcoming_view %>
          </div>
        <% end %>
      </div>
    </section>
  <% else %>
    <%= render "mics/detail/upcoming", mic: @mic,
          next_occurrences: @next_occurrences, upcoming_view: @upcoming_view %>
  <% end %>

  <section class="border-b border-gray-100">
    <div class="w-full px-4 sm:px-8 py-6">
      <h2 class="text-[10px] uppercase tracking-wider text-gray-500 font-bold mb-3">Venue</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <%# Left: name + address + accessibility %>
        <div class="text-sm text-gray-700">
          <div class="coustard-regular text-2xl text-gray-900"><%= venue.name %></div>
          <% if venue.full_address.present? %>
            <div class="text-gray-600 mt-1"><%= venue.full_address %></div>
          <% end %>
          <% if venue.neighborhood.present? %>
            <div class="text-xs text-gray-500 mt-1"><%= venue.neighborhood %></div>
          <% end %>
          <% access = (venue.accessibility || {}).merge(@mic.accessibility || {}) %>
          <% if access.values.any? %>
            <ul class="mt-3 flex flex-wrap gap-x-3 gap-y-1 text-xs text-gray-600">
              <% case access["wheelchair_level"]
                  when "fully"   %><li>♿ Fully wheelchair accessible</li>
                  <% when "partial" %><li>♿ Partially wheelchair accessible (building only)</li>
              <% end %>
              <% if access["all_ages"] %><li>All ages</li><% end %>
              <% if access["bar_free"] %><li>No bar / dry</li><% end %>
              <% if access["smoke_free"] %><li>Smoke-free</li><% end %>
              <% if access["asl"] %><li>ASL on request</li><% end %>
            </ul>
          <% end %>
          <% if venue.geocoded? %>
            <p class="mt-3 text-xs text-gray-500">
              Open in
              <a href="https://maps.apple.com/?ll=<%= venue.lat %>,<%= venue.lng %>&q=<%= ERB::Util.url_encode(venue.name) %>"
                 target="_blank" rel="noopener" class="text-pink-600 font-bold hover:underline">Apple Maps</a> ·
              <a href="https://www.google.com/maps/search/?api=1&query=<%= ERB::Util.url_encode("#{venue.name} #{venue.full_address}") %>"
                 target="_blank" rel="noopener" class="text-pink-600 font-bold hover:underline">Google Maps</a>
            </p>
          <% end %>
        </div>

        <%# Right: map %>
        <% if venue.geocoded? %>
          <div>
            <div
              data-controller="mics-map"
              data-mics-map-mics-value="<%= [ {
                slug:  @mic.slug,
                name:  @mic.name,
                url:   mics_detail_path(@mic.slug),
                venue: "#{venue.name} · #{venue.neighborhood_city}",
                lat:   venue.lat,
                lng:   venue.lng,
                day:   mics_day_name(@mic.day_of_week),
                time:  @mic.starts_local_time&.strftime("%-l:%M %p")
              } ].to_json %>"
              data-mics-map-center-value="<%= venue.lat %>,<%= venue.lng %>"
              data-mics-map-zoom-value="15"
              class="w-full h-64 md:h-full min-h-[240px] bg-gray-100 border border-gray-200">
            </div>
            <p class="mt-1 text-[10px] text-gray-400">
              Map data © <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener" class="underline">OpenStreetMap</a> contributors.
            </p>
          </div>
        <% else %>
          <div class="text-xs text-gray-400 italic">Map will appear here once the address is geocoded.</div>
        <% end %>
      </div>
    </div>
  </section>

  <% if @mic.host_summary.present? %>
    <section class="border-b border-gray-100">
      <div class="w-full px-4 sm:px-8 py-6">
        <h2 class="text-[10px] uppercase tracking-wider text-gray-500 font-bold mb-2">Hosts</h2>
        <p class="text-sm text-gray-700"><%= @mic.host_summary %></p>
      </div>
    </section>
  <% end %>

  <% @next_occurrences.each do |occ| %>
    <%= mics_jsonld(mic_event_jsonld(@mic, occ)) %>
  <% end %>
  <%= mics_breadcrumbs_jsonld(breadcrumbs) %>

  <footer class="w-full px-4 sm:px-8 py-6 border-t border-gray-100 space-y-3">
    <%# Community actions — the rarely-used ones live here, framed by
        the line that explains why they exist. %>
    <div class="flex flex-wrap items-baseline gap-x-4 gap-y-2 text-xs text-gray-500">
      <span>Owners update directly. Community can suggest edits using the link at the top.</span>
      <% if Current.user && @mic.claimed? %>
        <%= link_to "Claim this mic →", mics_claim_path(@mic.slug),
              class: "text-pink-600 font-bold hover:underline",
              title: "Already claimed by someone else? File a claim — the current lead has 72 hours to respond." %>
      <% end %>
    </div>
    <div class="text-xs">
      <%= link_to "← Back to #{city}, #{state}", mics_city_path(slug), class: "text-pink-600 font-bold hover:underline" %>
    </div>
  </footer>
</main>

<%# Suggest-an-edit modal — opened from the small text link in the
    masthead. POSTs to the existing #create suggestion endpoint, so
    notifications fire and the captain/superadmins still hear about it
    via Mics::NotificationService.notify_suggestion. %>
<dialog id="modal-suggest-edit"
        class="fixed inset-0 m-auto w-[min(36rem,92vw)] max-h-[85vh] p-0 rounded shadow-2xl backdrop:bg-gray-900/50 overflow-hidden">
  <div class="flex flex-col max-h-[85vh]">
    <div class="flex items-center justify-between gap-3 px-5 sm:px-6 py-3 border-b border-gray-100 bg-pink-500 text-white shrink-0">
      <h3 class="text-lg sm:text-xl font-bold">Suggest an edit / report an inaccuracy</h3>
      <button type="button"
              onclick="this.closest('dialog').close()"
              class="cursor-pointer px-2 py-1 text-white hover:bg-pink-600 active:bg-pink-700 text-sm leading-none">
        ✕
      </button>
    </div>
    <div class="px-5 sm:px-6 py-5 overflow-y-auto">
      <p class="text-sm text-gray-600 mb-4">
        Anyone can submit. <strong>Goes straight to the <%= @mic.venue&.city_hub ? "#{@mic.venue.city_hub.name} city captain" : "site admins" %></strong>. We use these to fix outdated info, flag a closed venue, or correct a wrong day/time.
      </p>
      <%= form_with url: mics_create_suggestion_path(@mic.slug), method: :post,
            class: "space-y-4" do %>
        <% unless Current.user %>
          <%= render "mics/form_field", name: "mic_suggestion[submitter_email]", label: "Your email (so we can follow up)", type: "email", required: true %>
        <% end %>
        <%= render "mics/form_field", name: "mic_suggestion[note]", label: "What needs to change?", type: "textarea", rows: 5, required: true,
              placeholder: "e.g. The mic moved to Wednesdays at 8 PM as of last month. Or: this venue is closed." %>
        <div class="flex justify-end gap-2 pt-3 border-t border-gray-100">
          <button type="button"
                  onclick="this.closest('dialog').close()"
                  class="cursor-pointer px-4 py-2 text-sm text-gray-600 hover:text-gray-900">Cancel</button>
          <%= render "shared/button", text: "Send report", variant: "primary", size: "medium", type: :submit %>
        </div>
      <% end %>
    </div>
  </div>
</dialog>

<%= render "mics/site_footer" %>
